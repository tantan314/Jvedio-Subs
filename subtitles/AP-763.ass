Dialogue: 0,0:00:04.00,0:00:10.07,Default2,,0,0,0,,應該沒有問題吧 目前這方案\N如果賞施的話
Dialogue: 0,0:00:10.67,0:00:12.14,Default2,,0,0,0,,絕對非常棒
Dialogue: 0,0:00:18.15,0:00:20.22,Default2,,0,0,0,,好期待吧\N好期待
Dialogue: 0,0:00:21.35,0:00:22.68,Default2,,0,0,0,,各位老師久等了
Dialogue: 0,0:00:23.49,0:00:28.09,Default2,,0,0,0,,那麼我們開始今天的選人
Dialogue: 0,0:00:31.96,0:00:33.23,Default2,,0,0,0,,本次的商品
Dialogue: 0,0:00:54.12,0:00:57.65,Default2,,0,0,0,,就如大家看的這樣
Dialogue: 0,0:00:58.65,0:01:03.86,Default2,,0,0,0,,她的下半身 可以全部購入
Dialogue: 0,0:01:06.93,0:01:11.07,Default2,,0,0,0,,那麼請大家出價吧
Dialogue: 0,0:02:24.14,0:02:25.21,Default2,,0,0,0,,不喜歡嗎?
Dialogue: 0,0:02:28.68,0:02:31.48,Default2,,0,0,0,,請吧 靠近一點看看
Dialogue: 0,0:02:49.50,0:02:51.23,Default2,,0,0,0,,年輕女孩子的身體
Dialogue: 0,0:02:52.57,0:02:53.37,Default2,,0,0,0,,不錯啊
Dialogue: 0,0:02:55.64,0:02:56.84,Default2,,0,0,0,,皮膚也很嫩啊
Dialogue: 0,0:02:58.84,0:03:02.04,Default2,,0,0,0,,滑溜溜的\N太棒了
Dialogue: 0,0:03:04.78,0:03:06.58,Default2,,0,0,0,,感覺怎麼樣呢
Dialogue: 0,0:03:08.52,0:03:09.58,Default2,,0,0,0,,非常核
Dialogue: 0,0:04:03.84,0:04:05.44,Default2,,0,0,0,,真是太棒了
Dialogue: 0,0:04:14.72,0:04:16.38,Default2,,0,0,0,,好厲害
Dialogue: 0,0:04:19.85,0:04:22.66,Default2,,0,0,0,,夾住了 夾住了
Dialogue: 0,0:06:36.46,0:06:38.06,Default2,,0,0,0,,胸部很棒
Dialogue: 0,0:07:30.04,0:07:31.51,Default2,,0,0,0,,乳頭很棒啊
Dialogue: 0,0:09:10.21,0:09:14.35,Default2,,0,0,0,,沒有毛的\N滑溜溜的靠近一點哦
Dialogue: 0,0:09:15.22,0:09:16.55,Default2,,0,0,0,,看到了哦
Dialogue: 0,0:09:40.17,0:09:41.71,Default2,,0,0,0,,那麼 不好意思了
Dialogue: 0,0:09:51.05,0:09:52.85,Default2,,0,0,0,,幫忙拿著腿
Dialogue: 0,0:10:23.02,0:10:27.29,Default2,,0,0,0,,各位裡面的聲音
Dialogue: 0,0:10:56.92,0:10:58.65,Default2,,0,0,0,,好厲害 滑溜溜的\N滑溜溜的
Dialogue: 0,0:11:18.47,0:11:20.54,Default2,,0,0,0,,想要怎麼樣呢
Dialogue: 0,0:11:22.54,0:11:26.28,Default2,,0,0,0,,各位請吧 過來這裡
Dialogue: 0,0:11:30.75,0:11:32.02,Default2,,0,0,0,,出來了
Dialogue: 0,0:11:38.03,0:11:40.96,Default2,,0,0,0,,非常不錯啊\N滑溜溜的
Dialogue: 0,0:11:50.44,0:11:51.31,Default2,,0,0,0,,大棒了
Dialogue: 0,0:12:30.54,0:12:31.88,Default2,,0,0,0,,不錯吧
Dialogue: 0,0:12:44.23,0:12:45.49,Default2,,0,0,0,,腿張開一點
Dialogue: 0,0:12:49.23,0:12:50.97,Default2,,0,0,0,,太棒了
Dialogue: 0,0:12:52.37,0:12:54.24,Default2,,0,0,0,,感覺到了吧
Dialogue: 0,0:13:07.65,0:13:09.58,Default2,,0,0,0,,轉過來後面可以吧
Dialogue: 0,0:13:26.53,0:13:28.07,Default2,,0,0,0,,身材非常棒啊
Dialogue: 0,0:13:44.29,0:13:45.55,Default2,,0,0,0,,太棒了
Dialogue: 0,0:14:04.71,0:14:08.98,Default2,,0,0,0,,皮膚非常不錯\N全部看到了太棒了
Dialogue: 0,0:14:14.52,0:14:20.05,Default2,,0,0,0,,非常不錯 很緊致啊\N繼續翹起來一點
Dialogue: 0,0:14:22.46,0:14:25.99,Default2,,0,0,0,,太棒了 太棒了 手感太棒了
Dialogue: 0,0:14:29.00,0:14:33.40,Default2,,0,0,0,,看看這裡 真是太棒了
Dialogue: 0,0:14:39.27,0:14:41.28,Default2,,0,0,0,,張開腿
Dialogue: 0,0:14:49.82,0:14:53.62,Default2,,0,0,0,,濕漉漉了哦 大家看
Dialogue: 0,0:15:10.17,0:15:13.24,Default2,,0,0,0,,怎麼樣 這個聲音\N非常棒
Dialogue: 0,0:15:19.78,0:15:21.98,Default2,,0,0,0,,很容易濕了 是不是
Dialogue: 0,0:15:23.98,0:15:25.25,Default2,,0,0,0,,濕漉漉的
Dialogue: 0,0:15:33.26,0:15:34.86,Default2,,0,0,0,,繼續啊\N繼續
Dialogue: 0,0:15:35.73,0:15:36.60,Default2,,0,0,0,,太厲害了
Dialogue: 0,0:15:46.87,0:15:47.74,Default2,,0,0,0,,非常不錯
Dialogue: 0,0:15:48.81,0:15:49.61,Default2,,0,0,0,,那麼
Dialogue: 0,0:15:51.01,0:15:52.55,Default2,,0,0,0,,接下來是這裡啊
Dialogue: 0,0:16:01.09,0:16:02.36,Default2,,0,0,0,,那麼不好意思了
Dialogue: 0,0:16:03.02,0:16:05.63,Default2,,0,0,0,,這個是非常重要的
Dialogue: 0,0:16:05.89,0:16:10.90,Default2,,0,0,0,,首先大家要好好\N準備一下
Dialogue: 0,0:16:41.26,0:16:42.26,Default2,,0,0,0,,各位
Dialogue: 0,0:16:43.66,0:16:47.40,Default2,,0,0,0,,看著感覺怎麼樣啊
Dialogue: 0,0:16:49.20,0:16:50.27,Default2,,0,0,0,,非常棒啊
Dialogue: 0,0:16:58.15,0:16:59.35,Default2,,0,0,0,,好可愛啊
Dialogue: 0,0:17:00.41,0:17:01.55,Default2,,0,0,0,,這麼淫蕩
Dialogue: 0,0:17:29.51,0:17:31.45,Default2,,0,0,0,,各位 不錯吧
Dialogue: 0,0:17:32.45,0:17:33.11,Default2,,0,0,0,,太棒了
Dialogue: 0,0:17:36.18,0:17:37.05,Default2,,0,0,0,,厲害
Dialogue: 0,0:17:41.92,0:17:43.39,Default2,,0,0,0,,肉棒
Dialogue: 0,0:17:45.06,0:17:47.59,Default2,,0,0,0,,怎麼樣 口交非常擅長吧
Dialogue: 0,0:17:50.00,0:17:51.33,Default2,,0,0,0,,這個確實是的
Dialogue: 0,0:18:12.95,0:18:14.35,Default2,,0,0,0,,這樣好舒服吧
Dialogue: 0,0:18:15.29,0:18:18.03,Default2,,0,0,0,,那麼站起來
Dialogue: 0,0:19:09.08,0:19:11.01,Default2,,0,0,0,,好舒服吧
Dialogue: 0,0:19:15.68,0:19:17.75,Default2,,0,0,0,,感覺非常棒吧
Dialogue: 0,0:20:26.02,0:20:30.49,Default2,,0,0,0,,好的 各位接下來開始投標
Dialogue: 0,0:20:31.23,0:20:32.09,Default2,,0,0,0,,不錯啊
Dialogue: 0,0:20:33.03,0:20:35.96,Default2,,0,0,0,,那麼 最低金額是二十萬
Dialogue: 0,0:20:39.10,0:20:40.10,Default2,,0,0,0,,二十一
Dialogue: 0,0:20:41.10,0:20:41.97,Default2,,0,0,0,,三十
Dialogue: 0,0:20:43.77,0:20:44.44,Default2,,0,0,0,,三十二
Dialogue: 0,0:20:45.24,0:20:46.97,Default2,,0,0,0,,三十二了\N三十三
Dialogue: 0,0:20:50.98,0:20:51.85,Default2,,0,0,0,,四十
Dialogue: 0,0:20:52.98,0:20:54.38,Default2,,0,0,0,,四十了
Dialogue: 0,0:20:56.78,0:20:58.72,Default2,,0,0,0,,四十五
Dialogue: 0,0:21:01.05,0:21:01.92,Default2,,0,0,0,,四十五了啊
Dialogue: 0,0:21:03.46,0:21:05.73,Default2,,0,0,0,,還有其他人嗎?\N五十
Dialogue: 0,0:21:08.53,0:21:09.20,Default2,,0,0,0,,五十五
Dialogue: 0,0:21:14.80,0:21:15.87,Default2,,0,0,0,,這是最高嗎?
Dialogue: 0,0:21:16.60,0:21:17.54,Default2,,0,0,0,,五十七
Dialogue: 0,0:21:19.67,0:21:22.41,Default2,,0,0,0,,五十七了\N七十
Dialogue: 0,0:21:23.28,0:21:24.75,Default2,,0,0,0,,七十 不錯啊
Dialogue: 0,0:21:27.41,0:21:28.28,Default2,,0,0,0,,七十三
Dialogue: 0,0:21:29.35,0:21:30.15,Default2,,0,0,0,,七十三了
Dialogue: 0,0:21:33.02,0:21:37.49,Default2,,0,0,0,,一百萬\N一百萬了
Dialogue: 0,0:21:37.96,0:21:41.90,Default2,,0,0,0,,一百萬了\N一百一
Dialogue: 0,0:21:43.03,0:21:44.36,Default2,,0,0,0,,一百一啊
Dialogue: 0,0:21:46.77,0:21:47.77,Default2,,0,0,0,,一百二
Dialogue: 0,0:21:48.50,0:21:50.44,Default2,,0,0,0,,一百二十五
Dialogue: 0,0:21:52.04,0:21:53.97,Default2,,0,0,0,,一百二十五了
Dialogue: 0,0:21:55.11,0:22:00.85,Default2,,0,0,0,,我們的商品逐漸漲價了\N還有其他的嗎?
Dialogue: 0,0:22:02.38,0:22:04.05,Default2,,0,0,0,,一百多了\N一百三十
Dialogue: 0,0:22:07.05,0:22:08.92,Default2,,0,0,0,,一百三十
Dialogue: 0,0:22:12.59,0:22:13.46,Default2,,0,0,0,,一百三十二
Dialogue: 0,0:22:14.26,0:22:19.27,Default2,,0,0,0,,一百三十二萬\N兩百
Dialogue: 0,0:22:22.47,0:22:24.27,Default2,,0,0,0,,厲害啊\N厲害
Dialogue: 0,0:22:25.61,0:22:29.08,Default2,,0,0,0,,兩百萬了\N兩百一十
Dialogue: 0,0:22:29.61,0:22:32.15,Default2,,0,0,0,,兩百一十啊
Dialogue: 0,0:22:34.15,0:22:35.95,Default2,,0,0,0,,兩百二十
Dialogue: 0,0:22:36.15,0:22:37.88,Default2,,0,0,0,,兩百二十啊
Dialogue: 0,0:22:43.96,0:22:47.09,Default2,,0,0,0,,兩百二十五\N兩百二十五
Dialogue: 0,0:22:54.03,0:22:56.64,Default2,,0,0,0,,覺得怎麼樣啊\N雨百二十五
Dialogue: 0,0:22:57.90,0:23:00.51,Default2,,0,0,0,,兩百三十\N兩百三十
Dialogue: 0,0:23:07.18,0:23:08.38,Default2,,0,0,0,,兩百五十
Dialogue: 0,0:23:09.45,0:23:12.52,Default2,,0,0,0,,已經兩百五十了
Dialogue: 0,0:23:18.86,0:23:21.26,Default2,,0,0,0,,最後了嗎?兩百五十
Dialogue: 0,0:23:22.40,0:23:26.20,Default2,,0,0,0,,沒有再高的嗎?\N兩百五十五
Dialogue: 0,0:23:26.40,0:23:27.87,Default2,,0,0,0,,兩百五十五
Dialogue: 0,0:23:31.81,0:23:33.54,Default2,,0,0,0,,兩百五十五
Dialogue: 0,0:23:35.14,0:23:37.08,Default2,,0,0,0,,兩百八十
Dialogue: 0,0:23:37.88,0:23:39.88,Default2,,0,0,0,,兩百八十啊
Dialogue: 0,0:23:42.68,0:23:44.75,Default2,,0,0,0,,兩百九十\N兩百九十
Dialogue: 0,0:23:46.29,0:23:48.29,Default2,,0,0,0,,現在是兩百九十
Dialogue: 0,0:23:49.16,0:23:51.89,Default2,,0,0,0,,還有沒有\N剛剛三百
Dialogue: 0,0:23:53.23,0:23:56.23,Default2,,0,0,0,,三百啊\N三百二十
Dialogue: 0,0:23:56.70,0:23:58.03,Default2,,0,0,0,,三百二十
Dialogue: 0,0:24:01.17,0:24:03.44,Default2,,0,0,0,,三百二十 怎麼樣呢
Dialogue: 0,0:24:04.84,0:24:07.37,Default2,,0,0,0,,三百三十三
Dialogue: 0,0:24:08.51,0:24:11.58,Default2,,0,0,0,,三百三十三了
Dialogue: 0,0:24:14.98,0:24:16.32,Default2,,0,0,0,,怎麼樣了
Dialogue: 0,0:24:33.33,0:24:41.27,Default2,,0,0,0,,那麼 這邊的客人\N花費三百三十三萬
Dialogue: 0,0:24:42.14,0:24:44.48,Default2,,0,0,0,,拍得我們的商品\N謝謝啊
Dialogue: 0,0:24:55.69,0:24:57.76,Default2,,0,0,0,,原來是這樣啊\N真是讓人期待
Dialogue: 0,0:25:03.50,0:25:04.50,Default2,,0,0,0,,真的非常厲害
Dialogue: 0,0:25:07.83,0:25:10.70,Default2,,0,0,0,,各位 大家久等了
Dialogue: 0,0:25:11.37,0:25:16.64,Default2,,0,0,0,,那麼 接下來我們看看\N今天的另外一個商品
Dialogue: 0,0:25:19.38,0:25:22.58,Default2,,0,0,0,,商品就是這個
Dialogue: 0,0:25:41.27,0:25:43.07,Default2,,0,0,0,,大家應該都知道
Dialogue: 0,0:25:44.07,0:25:49.61,Default2,,0,0,0,,她目前還沒有參與過\N我們的現場拍賣
Dialogue: 0,0:25:51.68,0:25:58.29,Default2,,0,0,0,,那麼我們開始了
Dialogue: 0,0:27:15.03,0:27:19.10,Default2,,0,0,0,,各位 靠近一 點看看
Dialogue: 0,0:27:45.19,0:27:47.46,Default2,,0,0,0,,非常不錯
Dialogue: 0,0:27:52.67,0:27:54.20,Default2,,0,0,0,,
Dialogue: 0,0:28:05.35,0:28:06.55,Default2,,0,0,0,,靠近一點
Dialogue: 0,0:31:34.09,0:31:35.22,Default2,,0,0,0,,很好
Dialogue: 0,0:32:13.19,0:32:18.46,Default2,,0,0,0,,濕了吧 大家還想看看吧
Dialogue: 0,0:32:19.87,0:32:21.27,Default2,,0,0,0,,不錯啊
Dialogue: 0,0:32:35.82,0:32:37.02,Default2,,0,0,0,,不要啊
Dialogue: 0,0:32:42.82,0:32:46.69,Default2,,0,0,0,,來 抱著那邊的腿
Dialogue: 0,0:33:18.26,0:33:19.33,Default2,,0,0,0,,不行啊
Dialogue: 0,0:33:24.33,0:33:25.40,Default2,,0,0,0,,不要啊
Dialogue: 0,0:34:13.31,0:34:15.72,Default2,,0,0,0,,不行啊\N太厲害了
Dialogue: 0,0:34:18.72,0:34:20.05,Default2,,0,0,0,,不要啊
Dialogue: 0,0:34:22.06,0:34:27.33,Default2,,0,0,0,,太厲害了\N濕漉漉的 沒有關係吧
Dialogue: 0,0:34:36.00,0:34:39.54,Default2,,0,0,0,,接下來各位客人
Dialogue: 0,0:34:40.27,0:34:44.41,Default2,,0,0,0,,好好嘗試我們的產品
Dialogue: 0,0:34:57.62,0:35:02.10,Default2,,0,0,0,,求你了\N看著我這裡
Dialogue: 0,0:35:03.10,0:35:06.97,Default2,,0,0,0,,非常棒\N感覺一下
Dialogue: 0,0:35:07.70,0:35:10.70,Default2,,0,0,0,,不行啊\N濕漉漉的了
Dialogue: 0,0:35:55.08,0:35:57.28,Default2,,0,0,0,,摸一下\N哪裡啊
Dialogue: 0,0:35:57.48,0:35:58.48,Default2,,0,0,0,,好好感覺一下
Dialogue: 0,0:36:04.02,0:36:09.16,Default2,,0,0,0,,乳頭這裡 對了 好敏感吧
Dialogue: 0,0:37:25.24,0:37:26.84,Default2,,0,0,0,,這裡也要
Dialogue: 0,0:37:30.44,0:37:31.78,Default2,,0,0,0,,屁股這裡哦
Dialogue: 0,0:37:57.27,0:37:59.07,Default2,,0,0,0,,好舒服吧
Dialogue: 0,0:38:52.66,0:38:54.33,Default2,,0,0,0,,好害羞嗎?
Dialogue: 0,0:39:02.47,0:39:04.00,Default2,,0,0,0,,不行啊
Dialogue: 0,0:39:10.88,0:39:11.88,Default2,,0,0,0,,不行啊
Dialogue: 0,0:40:28.89,0:40:30.89,Default2,,0,0,0,,乳頭勃起了
Dialogue: 0,0:40:54.45,0:40:56.38,Default2,,0,0,0,,感覺怎麼樣啊
Dialogue: 0,0:41:55.77,0:42:00.71,Default2,,0,0,0,,讓大家好好看看小穴
Dialogue: 0,0:42:23.07,0:42:24.07,Default2,,0,0,0,,屁股也是
Dialogue: 0,0:42:30.41,0:42:32.55,Default2,,0,0,0,,好好看著哦
Dialogue: 0,0:43:02.31,0:43:06.91,Default2,,0,0,0,,看看這裡太厲害了
Dialogue: 0,0:43:10.58,0:43:15.52,Default2,,0,0,0,,感覺怎麼樣啊\N是
Dialogue: 0,0:43:15.72,0:43:17.46,Default2,,0,0,0,,慢慢的 可以吧
Dialogue: 0,0:43:19.33,0:43:20.86,Default2,,0,0,0,,這樣啊
Dialogue: 0,0:43:28.07,0:43:32.20,Default2,,0,0,0,,來 確認一下 確認一下\N不行啊
Dialogue: 0,0:43:46.29,0:43:47.55,Default2,,0,0,0,,好興奮吧
Dialogue: 0,0:43:55.43,0:43:59.23,Default2,,0,0,0,,來 各位 盡情享受
Dialogue: 0,0:44:05.37,0:44:08.31,Default2,,0,0,0,,接下來這是最後的嘗試
Dialogue: 0,0:44:26.53,0:44:27.59,Default2,,0,0,0,,不行啊
Dialogue: 0,0:47:09.42,0:47:10.49,Default2,,0,0,0,,不行啊
Dialogue: 0,0:47:51.86,0:47:54.13,Default2,,0,0,0,,高潮了 高潮了
Dialogue: 0,0:48:13.35,0:48:19.09,Default2,,0,0,0,,好的 接下來開始投標
Dialogue: 0,0:48:19.96,0:48:21.56,Default2,,0,0,0,,二十萬開始
Dialogue: 0,0:48:23.83,0:48:26.37,Default2,,0,0,0,,二十五\N二十五
