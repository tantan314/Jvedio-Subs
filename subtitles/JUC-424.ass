Dialogue: 0,0:58:14.45,0:58:15.52,Default,,0,0,0,,小玲
Dialogue: 0,0:58:16.46,0:58:18.06,Default,,0,0,0,,好痛 不要
Dialogue: 0,0:58:18.46,0:58:20.59,Default,,0,0,0,,好痛
Dialogue: 0,0:58:26.20,0:58:28.34,Default,,0,0,0,,姊夫，不要
Dialogue: 0,0:58:36.88,0:58:38.61,Default,,0,0,0,,姊夫\N小玲
Dialogue: 0,0:58:38.88,0:58:39.95,Default,,0,0,0,,小玲
Dialogue: 0,0:58:55.83,0:58:56.90,Default,,0,0,0,,不要
Dialogue: 0,0:58:57.16,0:58:59.17,Default,,0,0,0,,小玲，小玲\N不要
Dialogue: 0,0:59:03.70,0:59:05.04,Default,,0,0,0,,小玲
Dialogue: 0,0:59:05.17,0:59:06.91,Default,,0,0,0,,不能对不起姐姐
Dialogue: 0,0:59:13.31,0:59:14.65,Default,,0,0,0,,姊夫
Dialogue: 0,0:59:18.52,0:59:20.12,Default,,0,0,0,,干什么啊
Dialogue: 0,0:59:38.27,0:59:40.27,Default,,0,0,0,,干什么啊
Dialogue: 0,0:59:51.89,0:59:54.55,Default,,0,0,0,,姊夫，不要\N我不要
Dialogue: 0,0:59:57.22,1:00:00.16,Default,,0,0,0,,姊夫，不要啊
Dialogue: 0,1:00:02.83,1:00:05.63,Default,,0,0,0,,小玲\N住手啊
Dialogue: 0,1:00:06.83,1:00:09.24,Default,,0,0,0,,小玲\N还有姐姐
Dialogue: 0,1:00:09.37,1:00:11.10,Default,,0,0,0,,不要啊
Dialogue: 0,1:00:21.11,1:00:22.32,Default,,0,0,0,,姊夫
Dialogue: 0,1:00:22.72,1:00:23.78,Default,,0,0,0,,小玲
Dialogue: 0,1:00:24.85,1:00:26.85,Default,,0,0,0,,不 不要
Dialogue: 0,1:00:31.26,1:00:33.79,Default,,0,0,0,,不要 姊夫
Dialogue: 0,1:01:04.22,1:01:05.83,Default,,0,0,0,,不要啊
Dialogue: 0,1:01:24.38,1:01:25.98,Default,,0,0,0,,住手啊
Dialogue: 0,1:01:28.11,1:01:29.72,Default,,0,0,0,,姊夫
Dialogue: 0,1:01:30.65,1:01:31.99,Default,,0,0,0,,不行
Dialogue: 0,1:01:45.47,1:01:46.67,Default,,0,0,0,,姊夫
