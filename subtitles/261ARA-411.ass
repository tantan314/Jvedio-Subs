Dialogue: 0,0:00:01.06,0:00:04.07,Default,,0,0,0,,(本片開始)
Dialogue: 0,0:00:50.05,0:00:53.05,Default,,0,0,0,,讓你久等了 是美緒嗎 是的
Dialogue: 0,0:00:53.05,0:00:56.05,Default,,0,0,0,,請多指教
Dialogue: 0,0:00:57.05,0:01:00.06,Default,,0,0,0,,真可愛啊 謝謝誇獎
Dialogue: 0,0:01:01.06,0:01:04.06,Default,,0,0,0,,我們邊走邊聊吧
Dialogue: 0,0:01:04.06,0:01:07.06,Default,,0,0,0,,真是太可愛了
Dialogue: 0,0:01:11.07,0:01:14.07,Default,,0,0,0,,真好看
Dialogue: 0,0:01:14.07,0:01:17.07,Default,,0,0,0,,你現在是學生嗎 是的
Dialogue: 0,0:01:20.01,0:01:23.01,Default,,0,0,0,,是什麼學生 是設計的專門學校
Dialogue: 0,0:01:28.02,0:01:31.02,Default,,0,0,0,,服裝設計嗎 是的
Dialogue: 0,0:01:32.02,0:01:35.02,Default,,0,0,0,,真好看
Dialogue: 0,0:01:35.02,0:01:38.03,Default,,0,0,0,,喜歡衣服嗎 是的
Dialogue: 0,0:01:38.03,0:01:41.03,Default,,0,0,0,,今天你特地過來
Dialogue: 0,0:01:44.03,0:01:47.04,Default,,0,0,0,,知道等一下要做什麼吧 知道
Dialogue: 0,0:01:50.04,0:01:53.04,Default,,0,0,0,,要做什麼
Dialogue: 0,0:01:57.05,0:02:00.05,Default,,0,0,0,,這邊人挺多的 好害羞
Dialogue: 0,0:02:01.05,0:02:04.05,Default,,0,0,0,,人還挺多的
Dialogue: 0,0:02:09.06,0:02:12.06,Default,,0,0,0,,今天要做什麼呢
Dialogue: 0,0:02:14.06,0:02:17.07,Default,,0,0,0,,就是做那種事對吧
Dialogue: 0,0:02:19.07,0:02:22.07,Default,,0,0,0,,是什麼事呢
Dialogue: 0,0:02:28.01,0:02:30.01,Default,,0,0,0,,做愛
Dialogue: 0,0:02:30.01,0:02:33.01,Default,,0,0,0,,這麼可愛的女生
Dialogue: 0,0:02:34.02,0:02:37.02,Default,,0,0,0,,也會做那種事呢
Dialogue: 0,0:02:38.02,0:02:41.02,Default,,0,0,0,,那種事是指什麼呢
Dialogue: 0,0:02:48.03,0:02:51.03,Default,,0,0,0,,做愛 好害羞
Dialogue: 0,0:02:53.03,0:02:56.04,Default,,0,0,0,,做什麼 做愛
Dialogue: 0,0:02:57.04,0:03:00.04,Default,,0,0,0,,那麼可愛的女生竟然說這種話
Dialogue: 0,0:03:02.04,0:03:05.05,Default,,0,0,0,,你是來做愛的對吧
Dialogue: 0,0:03:07.05,0:03:10.05,Default,,0,0,0,,來應徵的理由是什麼
Dialogue: 0,0:03:13.05,0:03:16.06,Default,,0,0,0,,我本來就有興趣
Dialogue: 0,0:03:18.06,0:03:21.06,Default,,0,0,0,,想拍拍看
Dialogue: 0,0:03:21.06,0:03:24.07,Default,,0,0,0,,有什麼想做的事呢
Dialogue: 0,0:03:33.01,0:03:36.01,Default,,0,0,0,,好害羞
Dialogue: 0,0:03:36.01,0:03:39.01,Default,,0,0,0,,想被肉棒用力抽插
Dialogue: 0,0:03:39.01,0:03:42.02,Default,,0,0,0,,真大膽啊
Dialogue: 0,0:03:42.02,0:03:45.02,Default,,0,0,0,,再說一次 你剛才講什麼
Dialogue: 0,0:03:47.02,0:03:50.02,Default,,0,0,0,,想被肉棒用力抽插
Dialogue: 0,0:03:52.03,0:03:55.03,Default,,0,0,0,,插那裡嗎
Dialogue: 0,0:03:55.03,0:03:58.03,Default,,0,0,0,,過來吧
Dialogue: 0,0:03:58.03,0:04:01.04,Default,,0,0,0,,喜歡這樣嗎 喜歡
Dialogue: 0,0:04:05.04,0:04:08.04,Default,,0,0,0,,這麼可愛的女生
Dialogue: 0,0:04:08.04,0:04:11.05,Default,,0,0,0,,你幾歲了 20歲
Dialogue: 0,0:04:13.05,0:04:16.05,Default,,0,0,0,,真年輕
Dialogue: 0,0:04:16.05,0:04:19.05,Default,,0,0,0,,讓我從背後拍一下
Dialogue: 0,0:04:20.05,0:04:23.06,Default,,0,0,0,,真好看
Dialogue: 0,0:04:25.06,0:04:28.06,Default,,0,0,0,,稱想被做什麼
Dialogue: 0,0:04:31.07,0:04:34.07,Default,,0,0,0,,想被肉棒用力抽插
Dialogue: 0,0:04:36.07,0:04:39.01,Default,,0,0,0,,你說什麼啊 快來吧
Dialogue: 0,0:04:41.01,0:04:44.01,Default,,0,0,0,,喜歡做得激烈點嗎
Dialogue: 0,0:04:48.02,0:04:51.02,Default,,0,0,0,,挺有興趣的
Dialogue: 0,0:04:58.03,0:05:01.03,Default,,0,0,0,,真看不出來
Dialogue: 0,0:05:01.03,0:05:04.03,Default,,0,0,0,,有交往對象嗎 沒有
Dialogue: 0,0:05:10.04,0:05:13.04,Default,,0,0,0,,你應該很有男人緣吧
Dialogue: 0,0:05:15.04,0:05:18.05,Default,,0,0,0,,沒人約你去吃飯嗎
Dialogue: 0,0:05:19.05,0:05:22.05,Default,,0,0,0,,跟朋發去吃飯也不會做那種事
Dialogue: 0,0:05:25.05,0:05:28.06,Default,,0,0,0,,那現在是單身吧 是的
Dialogue: 0,0:05:30.06,0:05:33.06,Default,,0,0,0,,徵男友中嗎 是的
Dialogue: 0,0:05:33.06,0:05:36.06,Default,,0,0,0,,這是個好機會呢
Dialogue: 0,0:05:39.07,0:05:42.07,Default,,0,0,0,,喜歡怎樣的男生
Dialogue: 0,0:05:45.01,0:05:48.01,Default,,0,0,0,,溫柔的人
Dialogue: 0,0:05:48.01,0:05:51.01,Default,,0,0,0,,有人會對稱不溫柔嗎
Dialogue: 0,0:05:51.01,0:05:54.02,Default,,0,0,0,,偶爾會有
Dialogue: 0,0:05:54.02,0:05:57.02,Default,,0,0,0,,大家都會對你很溫柔吧
Dialogue: 0,0:06:01.02,0:06:04.03,Default,,0,0,0,,想做怎樣的衣服
Dialogue: 0,0:06:06.03,0:06:09.03,Default,,0,0,0,,我喜歡這種風格的衣服
Dialogue: 0,0:06:10.03,0:06:13.03,Default,,0,0,0,,之後想當時裝設計師
Dialogue: 0,0:06:16.04,0:06:19.04,Default,,0,0,0,,是畫圖的那種嗎
Dialogue: 0,0:06:22.04,0:06:25.05,Default,,0,0,0,,我想自己做衣服
Dialogue: 0,0:06:27.05,0:06:30.05,Default,,0,0,0,,想要有自己的品牌嗎 是的
Dialogue: 0,0:06:33.05,0:06:36.06,Default,,0,0,0,,這樣的女生等一下要做設呢麼
Dialogue: 0,0:06:39.06,0:06:42.06,Default,,0,0,0,,做愛
Dialogue: 0,0:06:45.07,0:06:48.07,Default,,0,0,0,,我都拍下來了
Dialogue: 0,0:06:54.01,0:06:57.01,Default,,0,0,0,,請進
Dialogue: 0,0:07:03.02,0:07:06.02,Default,,0,0,0,,要關門了
Dialogue: 0,0:07:07.02,0:07:10.02,Default,,0,0,0,,緊張嗎
Dialogue: 0,0:07:10.02,0:07:13.03,Default,,0,0,0,,有一點
Dialogue: 0,0:07:15.03,0:07:18.03,Default,,0,0,0,,還有點時間才會到
Dialogue: 0,0:07:20.03,0:07:23.04,Default,,0,0,0,,喜歡做愛嗎 喜歡
Dialogue: 0,0:07:25.04,0:07:28.04,Default,,0,0,0,,這樣啊
Dialogue: 0,0:07:28.04,0:07:31.05,Default,,0,0,0,,第一次做是幾歲
Dialogue: 0,0:07:33.05,0:07:36.05,Default,,0,0,0,,我算比較晚
Dialogue: 0,0:07:36.05,0:07:39.05,Default,,0,0,0,,高一的時候 這樣算晚嗎
Dialogue: 0,0:07:41.06,0:07:44.06,Default,,0,0,0,,在我的學校算晚
Dialogue: 0,0:07:45.06,0:07:48.06,Default,,0,0,0,,周圍的人都很早嗎
Dialogue: 0,0:07:49.06,0:07:52.07,Default,,0,0,0,,國中畢業就做過了
Dialogue: 0,0:07:54.07,0:07:57.07,Default,,0,0,0,,對像是誰
Dialogue: 0,0:07:57.07,0:08:00.01,Default,,0,0,0,,同校的學長
Dialogue: 0,0:08:00.01,0:08:03.01,Default,,0,0,0,,有留下回憶嗎
Dialogue: 0,0:08:04.01,0:08:07.01,Default,,0,0,0,,當時太緊張 不記得了
Dialogue: 0,0:08:13.02,0:08:16.02,Default,,0,0,0,,不知不覺就結束嗎
Dialogue: 0,0:08:17.02,0:08:20.03,Default,,0,0,0,,當時根本搞不清楚發生什麼事
Dialogue: 0,0:08:20.03,0:08:23.03,Default,,0,0,0,,男性經驗有多少人
Dialogue: 0,0:08:24.03,0:08:27.03,Default,,0,0,0,,沒很多耶
Dialogue: 0,0:08:29.04,0:08:32.04,Default,,0,0,0,,三個人 真的嗎
Dialogue: 0,0:08:33.04,0:08:36.04,Default,,0,0,0,,不是是三十人嗎不是
Dialogue: 0,0:08:39.05,0:08:42.05,Default,,0,0,0,,都是男朋友嗎 都是
Dialogue: 0,0:08:44.05,0:08:47.05,Default,,0,0,0,,沒跟男朋友以外的人做過嗎
Dialogue: 0,0:08:47.05,0:08:50.06,Default,,0,0,0,,雖然有些順序不太對
Dialogue: 0,0:08:52.06,0:08:55.06,Default,,0,0,0,,交往前做過嗎
Dialogue: 0,0:08:57.06,0:09:00.07,Default,,0,0,0,,但後來都有交往
Dialogue: 0,0:09:00.07,0:09:03.07,Default,,0,0,0,,你這麼可愛 應該會有人追吧
Dialogue: 0,0:09:08.01,0:09:11.01,Default,,0,0,0,,專門學校都是女生
Dialogue: 0,0:09:13.01,0:09:16.02,Default,,0,0,0,,沒機會認識男生
Dialogue: 0,0:09:16.02,0:09:19.02,Default,,0,0,0,,你喜歡溫柔的人
Dialogue: 0,0:09:22.02,0:09:25.03,Default,,0,0,0,,還有什麼要求嗎 做愛技術要好
Dialogue: 0,0:09:29.03,0:09:32.03,Default,,0,0,0,,這麼直接
Dialogue: 0,0:09:36.04,0:09:39.04,Default,,0,0,0,,分得出技術好壞嗎
Dialogue: 0,0:09:40.04,0:09:43.04,Default,,0,0,0,,可能跟契合度有關
Dialogue: 0,0:09:47.05,0:09:50.05,Default,,0,0,0,,跟某些人做了也不覺得舒服
Dialogue: 0,0:09:54.06,0:09:57.06,Default,,0,0,0,,跟合的人做比較好
Dialogue: 0,0:09:57.06,0:10:00.06,Default,,0,0,0,,有什麼特殊的做愛經驗嗎
Dialogue: 0,0:10:04.07,0:10:07.07,Default,,0,0,0,,特殊的做愛
Dialogue: 0,0:10:12.01,0:10:15.01,Default,,0,0,0,,用手機拍之類的
Dialogue: 0,0:10:20.01,0:10:23.02,Default,,0,0,0,,在浴室
Dialogue: 0,0:10:23.02,0:10:26.02,Default,,0,0,0,,出去旅行時在浴室做了
Dialogue: 0,0:10:29.02,0:10:32.03,Default,,0,0,0,,溫泉旅館嗎 是的
Dialogue: 0,0:10:35.03,0:10:38.03,Default,,0,0,0,,我懂
Dialogue: 0,0:10:39.03,0:10:42.04,Default,,0,0,0,,男生都是這樣吧 是啊
Dialogue: 0,0:10:47.04,0:10:50.04,Default,,0,0,0,,當然會做啊
Dialogue: 0,0:10:53.05,0:10:56.05,Default,,0,0,0,,有什麼想嘗試的做法
Dialogue: 0,0:10:57.05,0:11:00.05,Default,,0,0,0,,想被玩弄
Dialogue: 0,0:11:02.06,0:11:05.06,Default,,0,0,0,,這種話平常很難說出口吧
Dialogue: 0,0:11:09.06,0:11:12.07,Default,,0,0,0,,之前的對象都很普通
Dialogue: 0,0:11:20.01,0:11:23.01,Default,,0,0,0,,會希望用點玩具之類的玩弄我
Dialogue: 0,0:11:28.02,0:11:31.02,Default,,0,0,0,,會自慰嗎 偶爾會
Dialogue: 0,0:11:35.02,0:11:38.03,Default,,0,0,0,,都怎麼做 用手指
Dialogue: 0,0:11:40.03,0:11:43.03,Default,,0,0,0,,或是用按摩器 你有嗎
Dialogue: 0,0:11:46.03,0:11:49.04,Default,,0,0,0,,自己買的嗎 是的
Dialogue: 0,0:11:51.04,0:11:54.04,Default,,0,0,0,,網購嗎 跟朋友去量販店買的
Dialogue: 0,0:11:58.05,0:12:01.05,Default,,0,0,0,,你剛才說想被玩弄
Dialogue: 0,0:12:04.05,0:12:07.05,Default,,0,0,0,,今天可以這樣做嗎 好的
Dialogue: 0,0:12:11.06,0:12:14.06,Default,,0,0,0,,當然得看你的意願
Dialogue: 0,0:12:18.07,0:12:21.07,Default,,0,0,0,,如果你會興奮的話我就盡量幫忙
Dialogue: 0,0:12:25.01,0:12:28.01,Default,,0,0,0,,這個正在拍喔 這在拍喔
Dialogue: 0,0:12:30.01,0:12:33.01,Default,,0,0,0,,是啊
Dialogue: 0,0:12:34.01,0:12:37.02,Default,,0,0,0,,能看著鏡頭
Dialogue: 0,0:12:40.02,0:12:43.02,Default,,0,0,0,,對著鏡頭說想被肉棒用力插嗎
Dialogue: 0,0:12:49.03,0:12:52.03,Default,,0,0,0,,這樣嗎 就是這樣
Dialogue: 0,0:12:57.04,0:13:00.04,Default,,0,0,0,,我想被肉棒用力插
Dialogue: 0,0:13:05.05,0:13:08.05,Default,,0,0,0,,真可愛啊
Dialogue: 0,0:13:09.05,0:13:12.05,Default,,0,0,0,,到了喔 先把安全帶解開
Dialogue: 0,0:13:21.06,0:13:24.06,Default,,0,0,0,,要在這拍嗎 外面看不到的
Dialogue: 0,0:13:35.01,0:13:38.01,Default,,0,0,0,,白色的
Dialogue: 0,0:13:45.02,0:13:48.02,Default,,0,0,0,,馬上就到了 我們走吧
Dialogue: 0,0:13:51.03,0:13:54.03,Default,,0,0,0,,想被用力插嗎 想
Dialogue: 0,0:13:57.03,0:14:00.03,Default,,0,0,0,,好厲害
Dialogue: 0,0:14:00.03,0:14:03.04,Default,,0,0,0,,我們到了呢
Dialogue: 0,0:14:04.04,0:14:07.04,Default,,0,0,0,,緊張嗎 緊張
Dialogue: 0,0:14:07.04,0:14:10.04,Default,,0,0,0,,到這邊表情變有點僵硬呢
Dialogue: 0,0:14:12.05,0:14:15.05,Default,,0,0,0,,外面的風景如何 好漂亮
Dialogue: 0,0:14:20.05,0:14:23.06,Default,,0,0,0,,這裡能看到整個都市
Dialogue: 0,0:14:32.07,0:14:35.07,Default,,0,0,0,,真不錯的風景
Dialogue: 0,0:14:37.07,0:14:40.01,Default,,0,0,0,,你叫什麼名字
Dialogue: 0,0:14:41.01,0:14:44.01,Default,,0,0,0,,美緒
Dialogue: 0,0:14:45.01,0:14:48.02,Default,,0,0,0,,幾歲20歲
Dialogue: 0,0:14:48.02,0:14:51.02,Default,,0,0,0,,真年輕啊
Dialogue: 0,0:14:52.02,0:14:55.02,Default,,0,0,0,,是做什麼的 專校學生
Dialogue: 0,0:14:58.03,0:15:01.03,Default,,0,0,0,,什麼科系 服裝設計
Dialogue: 0,0:15:02.03,0:15:05.03,Default,,0,0,0,,衣服真好看呢
Dialogue: 0,0:15:06.03,0:15:08.04,Default,,0,0,0,,太棒了
Dialogue: 0,0:15:08.04,0:15:11.04,Default,,0,0,0,,能站起來嗎
Dialogue: 0,0:15:12.04,0:15:15.04,Default,,0,0,0,,身高多少 153
Dialogue: 0,0:15:21.05,0:15:24.05,Default,,0,0,0,,能轉一圈嗎
Dialogue: 0,0:15:32.06,0:15:35.06,Default,,0,0,0,,等等喔
Dialogue: 0,0:15:35.06,0:15:38.07,Default,,0,0,0,,屁股有一半被看到了喔
Dialogue: 0,0:15:44.07,0:15:47.01,Default,,0,0,0,,是丁字褲嗎 是的
Dialogue: 0,0:15:48.01,0:15:51.01,Default,,0,0,0,,平常都穿丁字褲嗎
Dialogue: 0,0:15:51.01,0:15:54.01,Default,,0,0,0,,比較常穿
Dialogue: 0,0:15:55.02,0:15:58.02,Default,,0,0,0,,布的面積真小啊
Dialogue: 0,0:16:06.03,0:16:09.03,Default,,0,0,0,,能轉過來嗎
Dialogue: 0,0:16:16.04,0:16:19.04,Default,,0,0,0,,現在跟我獨處對吧
Dialogue: 0,0:16:23.04,0:16:26.05,Default,,0,0,0,,哪裡會舒服呢
Dialogue: 0,0:16:29.05,0:16:32.05,Default,,0,0,0,,胸部跟陰蒂
Dialogue: 0,0:16:38.06,0:16:41.06,Default,,0,0,0,,我喜歡摸胸部跟陰蒂
Dialogue: 0,0:16:41.06,0:16:44.06,Default,,0,0,0,,這是叫我摸的意思嗎
Dialogue: 0,0:16:59.01,0:17:02.02,Default,,0,0,0,,是什麼罩杯 F罩杯
Dialogue: 0,0:17:03.02,0:17:06.02,Default,,0,0,0,,穿著衣服看不出來
Dialogue: 0,0:17:10.02,0:17:13.03,Default,,0,0,0,,真大
Dialogue: 0,0:17:25.04,0:17:28.04,Default,,0,0,0,,真漂亮
Dialogue: 0,0:17:33.05,0:17:36.05,Default,,0,0,0,,胸部跟哪裡舒服 陰蒂
Dialogue: 0,0:17:40.05,0:17:43.06,Default,,0,0,0,,看起來真色
Dialogue: 0,0:18:40.05,0:18:43.05,Default,,0,0,0,,舒服嗎 好舒服
Dialogue: 0,0:18:58.07,0:19:01.07,Default,,0,0,0,,變硬了
Dialogue: 0,0:19:05.01,0:19:08.01,Default,,0,0,0,,屁股對著這邊
Dialogue: 0,0:19:13.01,0:19:16.02,Default,,0,0,0,,真色啊
Dialogue: 0,0:19:22.02,0:19:25.03,Default,,0,0,0,,摸屁股有感覺嗎
Dialogue: 0,0:19:41.04,0:19:44.04,Default,,0,0,0,,好舒服
