Dialogue: 0,0:00:01.10,0:00:04.03,Default1,,0,0,0,,影片开始
Dialogue: 0,0:00:10.04,0:00:13.11,Default1,,0,0,0,,这样有感觉吗
Dialogue: 0,0:00:15.11,0:00:18.05,Default1,,0,0,0,,怎么说
Dialogue: 0,0:00:20.05,0:00:23.12,Default1,,0,0,0,,突然害羞了
Dialogue: 0,0:00:25.12,0:00:28.06,Default1,,0,0,0,,啊来了
Dialogue: 0,0:00:35.13,0:00:38.07,Default1,,0,0,0,,你好
Dialogue: 0,0:00:40.07,0:00:43.14,Default1,,0,0,0,,不用客气
Dialogue: 0,0:00:45.14,0:00:48.08,Default1,,0,0,0,,今天一起共演呢
Dialogue: 0,0:00:50.08,0:00:53.15,Default1,,0,0,0,,请多指教
Dialogue: 0,0:00:55.15,0:00:58.09,Default1,,0,0,0,,请多指教
Dialogue: 0,0:01:00.09,0:01:03.16,Default1,,0,0,0,,我也是
Dialogue: 0,0:01:05.16,0:01:08.10,Default1,,0,0,0,,都好假喔
Dialogue: 0,0:01:15.04,0:01:18.11,Default1,,0,0,0,,现在怎么办呢
Dialogue: 0,0:01:30.12,0:01:33.05,Default1,,0,0,0,,问题吗
Dialogue: 0,0:01:35.06,0:01:38.13,Default1,,0,0,0,,这么多
Dialogue: 0,0:01:45.07,0:01:48.14,Default1,,0,0,0,,自我推销吗
Dialogue: 0,0:01:55.08,0:01:58.15,Default1,,0,0,0,,主题喔
Dialogue: 0,0:02:05.09,0:02:08.16,Default1,,0,0,0,,那开始吧
Dialogue: 0,0:02:15.10,0:02:18.03,Default1,,0,0,0,,那么
Dialogue: 0,0:02:20.04,0:02:23.10,Default1,,0,0,0,,就是
Dialogue: 0,0:02:25.11,0:02:28.04,Default1,,0,0,0,,身材算不错吧
Dialogue: 0,0:02:30.05,0:02:33.11,Default1,,0,0,0,,还有就是
Dialogue: 0,0:02:35.12,0:02:38.05,Default1,,0,0,0,,动作
Dialogue: 0,0:02:40.06,0:02:43.12,Default1,,0,0,0,,我的话
Dialogue: 0,0:02:45.13,0:02:48.06,Default1,,0,0,0,,应该是
Dialogue: 0,0:02:50.07,0:02:53.13,Default1,,0,0,0,,和风向吗
Dialogue: 0,0:03:00.08,0:03:03.14,Default1,,0,0,0,,共演作品
Dialogue: 0,0:03:05.15,0:03:08.08,Default1,,0,0,0,,怎么说
Dialogue: 0,0:03:10.09,0:03:13.15,Default1,,0,0,0,,我很喜欢呢
Dialogue: 0,0:03:15.16,0:03:18.09,Default1,,0,0,0,,我也是呢
Dialogue: 0,0:03:20.10,0:03:23.03,Default1,,0,0,0,,因为啊
Dialogue: 0,0:03:25.03,0:03:28.10,Default1,,0,0,0,,可以有很多
Dialogue: 0,0:03:30.11,0:03:33.04,Default1,,0,0,0,,不同的感觉
Dialogue: 0,0:03:35.04,0:03:38.11,Default1,,0,0,0,,对啊
Dialogue: 0,0:03:40.12,0:03:43.05,Default1,,0,0,0,,再来
Dialogue: 0,0:03:45.05,0:03:48.12,Default1,,0,0,0,,最有印象的
Dialogue: 0,0:03:50.13,0:03:53.06,Default1,,0,0,0,,我吗
Dialogue: 0,0:03:55.06,0:03:58.13,Default1,,0,0,0,,就是那个
Dialogue: 0,0:04:00.14,0:04:03.07,Default1,,0,0,0,,其实啊
Dialogue: 0,0:04:05.07,0:04:08.14,Default1,,0,0,0,,我也搞不清楚
Dialogue: 0,0:04:10.15,0:04:13.08,Default1,,0,0,0,,但就是一起痴女
Dialogue: 0,0:04:20.16,0:04:23.09,Default1,,0,0,0,,我也是
Dialogue: 0,0:04:25.09,0:04:28.03,Default1,,0,0,0,,么么说
Dialogue: 0,0:04:30.03,0:04:33.10,Default1,,0,0,0,,很有去呢
Dialogue: 0,0:04:35.10,0:04:38.04,Default1,,0,0,0,,第一挑战那种
Dialogue: 0,0:04:40.04,0:04:43.11,Default1,,0,0,0,,激烈高潮的
Dialogue: 0,0:04:50.05,0:04:53.12,Default1,,0,0,0,,对啊
Dialogue: 0,0:04:55.12,0:04:58.06,Default1,,0,0,0,,很有趣
Dialogue: 0,0:05:00.06,0:05:03.13,Default1,,0,0,0,,对对对
Dialogue: 0,0:05:05.13,0:05:08.07,Default1,,0,0,0,,第一次都很有趣
Dialogue: 0,0:05:15.14,0:05:18.08,Default1,,0,0,0,,摄影的小话
Dialogue: 0,0:05:20.08,0:05:23.15,Default1,,0,0,0,,我的话一
Dialogue: 0,0:05:25.15,0:05:28.09,Default1,,0,0,0,,就是出糗吧
Dialogue: 0,0:05:30.09,0:05:33.16,Default1,,0,0,0,,有时候
Dialogue: 0,0:05:35.03,0:05:38.10,Default1,,0,0,0,,不能控制啊
Dialogue: 0,0:05:40.10,0:05:43.04,Default1,,0,0,0,,我懂我懂
Dialogue: 0,0:05:45.04,0:05:48.11,Default1,,0,0,0,,会很尴尬呢
Dialogue: 0,0:05:50.11,0:05:53.05,Default1,,0,0,0,,对方也是
Dialogue: 0,0:05:55.05,0:05:58.12,Default1,,0,0,0,,不知道怎么做
Dialogue: 0,0:06:00.12,0:06:03.06,Default1,,0,0,0,,一瞬间大家
Dialogue: 0,0:06:05.06,0:06:08.13,Default1,,0,0,0,,都会卡住对不对
Dialogue: 0,0:06:10.13,0:06:13.07,Default1,,0,0,0,,对啊
Dialogue: 0,0:06:15.07,0:06:18.14,Default1,,0,0,0,,我懂我懂
Dialogue: 0,0:06:20.14,0:06:23.08,Default1,,0,0,0,,很好玩
Dialogue: 0,0:06:25.08,0:06:28.15,Default1,,0,0,0,,私生活
Dialogue: 0,0:06:30.15,0:06:33.09,Default1,,0,0,0,,私生活吗
Dialogue: 0,0:06:35.09,0:06:38.16,Default1,,0,0,0,,我的话
Dialogue: 0,0:06:40.16,0:06:43.10,Default1,,0,0,0,,其实呢
Dialogue: 0,0:06:45.10,0:06:48.04,Default1,,0,0,0,,我很懒喔
Dialogue: 0,0:06:50.04,0:06:53.11,Default1,,0,0,0,,真的
Dialogue: 0,0:06:55.11,0:06:58.05,Default1,,0,0,0,,你们不会知道的
Dialogue: 0,0:07:00.05,0:07:03.12,Default1,,0,0,0,,我也不能说太多
Dialogue: 0,0:07:05.12,0:07:08.06,Default1,,0,0,0,,免得呢
Dialogue: 0,0:07:10.06,0:07:13.13,Default1,,0,0,0,,吓到人
Dialogue: 0,0:07:15.13,0:07:18.07,Default1,,0,0,0,,放心吧
Dialogue: 0,0:07:20.07,0:07:23.14,Default1,,0,0,0,,但是基本上
Dialogue: 0,0:07:25.14,0:07:28.08,Default1,,0,0,0,,我可以养活自己的
Dialogue: 0,0:07:30.08,0:07:33.15,Default1,,0,0,0,,我的话
Dialogue: 0,0:07:35.15,0:07:38.09,Default1,,0,0,0,,应该是
Dialogue: 0,0:07:40.09,0:07:43.16,Default1,,0,0,0,,严谨的吧
Dialogue: 0,0:07:45.16,0:07:48.10,Default1,,0,0,0,,我懂
Dialogue: 0,0:07:50.10,0:07:53.03,Default1,,0,0,0,,看起来就像对吧
Dialogue: 0,0:08:05.05,0:08:08.12,Default1,,0,0,0,,好像很有趣呢
Dialogue: 0,0:08:10.12,0:08:13.05,Default1,,0,0,0,,这样聊聊
Dialogue: 0,0:08:15.06,0:08:18.13,Default1,,0,0,0,,开始有点
Dialogue: 0,0:08:20.13,0:08:23.06,Default1,,0,0,0,,期待今天共演了
Dialogue: 0,0:08:30.14,0:08:33.07,Default1,,0,0,0,,理想的爱爱
Dialogue: 0,0:08:35.08,0:08:38.15,Default1,,0,0,0,,理想吗
Dialogue: 0,0:08:40.15,0:08:43.08,Default1,,0,0,0,,那当然是
Dialogue: 0,0:08:45.09,0:08:48.16,Default1,,0,0,0,,互相的给予
Dialogue: 0,0:08:50.16,0:08:53.09,Default1,,0,0,0,,不是单方面
Dialogue: 0,0:08:55.10,0:08:58.03,Default1,,0,0,0,,接受
Dialogue: 0,0:09:00.04,0:09:03.10,Default1,,0,0,0,,也不是说
Dialogue: 0,0:09:05.11,0:09:08.04,Default1,,0,0,0,,单方面
Dialogue: 0,0:09:10.05,0:09:13.11,Default1,,0,0,0,,给予
Dialogue: 0,0:09:15.12,0:09:18.05,Default1,,0,0,0,,这样子
Dialogue: 0,0:09:20.06,0:09:23.12,Default1,,0,0,0,,最棒吧
Dialogue: 0,0:09:25.13,0:09:28.06,Default1,,0,0,0,,还有就是
Dialogue: 0,0:09:30.07,0:09:33.13,Default1,,0,0,0,,不要提到我的工作
Dialogue: 0,0:09:35.14,0:09:38.07,Default1,,0,0,0,,对啊
Dialogue: 0,0:09:40.08,0:09:43.14,Default1,,0,0,0,,提到的话超讨厌
Dialogue: 0,0:09:45.15,0:09:48.08,Default1,,0,0,0,,喜欢的体位和棒棒
Dialogue: 0,0:10:20.12,0:10:23.05,Default1,,0,0,0,,后背吧
Dialogue: 0,0:10:25.05,0:10:33.06,Default1,,0,0,0,,对啊
Dialogue: 0,0:10:45.07,0:10:53.08,Default1,,0,0,0,,正常体位
Dialogue: 0,0:10:55.08,0:10:58.15,Default1,,0,0,0,,但是呢
Dialogue: 0,0:11:00.16,0:11:03.09,Default1,,0,0,0,,从后面
Dialogue: 0,0:11:05.09,0:11:08.30,Default1,,0,0,0,,有一种
Dialogue: 0,0:11:10.03,0:11:13.10,Default1,,0,0,0,,奇妙的快感
Dialogue: 0,0:11:15.10,0:11:18.04,Default1,,0,0,0,,我懂
Dialogue: 0,0:11:20.04,0:11:23.11,Default1,,0,0,0,,就是好像
Dialogue: 0,0:11:30.05,0:11:33.12,Default1,,0,0,0,,不能见人
Dialogue: 0,0:11:35.12,0:11:38.06,Default1,,0,0,0,,那种被侵犯
Dialogue: 0,0:11:40.06,0:11:43.13,Default1,,0,0,0,,还是被偷窥
Dialogue: 0,0:11:45.13,0:11:48.07,Default1,,0,0,0,,不一样
Dialogue: 0,0:11:50.07,0:11:53.14,Default1,,0,0,0,,大概这样吧
Dialogue: 0,0:11:55.14,0:11:58.08,Default1,,0,0,0,,胜负内衣裤
Dialogue: 0,0:12:00.08,0:12:03.15,Default1,,0,0,0,,有吗
Dialogue: 0,0:12:05.15,0:12:08.09,Default1,,0,0,0,,有喔
Dialogue: 0,0:12:10.09,0:12:13.16,Default1,,0,0,0,,多少有
Dialogue: 0,0:12:15.03,0:12:18.10,Default1,,0,0,0,,但是呢
Dialogue: 0,0:12:20.10,0:12:23.04,Default1,,0,0,0,,多半还是
Dialogue: 0,0:12:25.04,0:12:28.11,Default1,,0,0,0,,看心情
Dialogue: 0,0:12:30.11,0:12:33.05,Default1,,0,0,0,,这样吧
Dialogue: 0,0:12:35.05,0:12:38.12,Default1,,0,0,0,,特定的呢
Dialogue: 0,0:12:40.12,0:12:43.06,Default1,,0,0,0,,有吗
Dialogue: 0,0:12:45.06,0:12:48.13,Default1,,0,0,0,,应该还好
Dialogue: 0,0:12:50.13,0:12:53.07,Default1,,0,0,0,,不算固定呢
Dialogue: 0,0:12:55.07,0:12:58.14,Default1,,0,0,0,,主要是
Dialogue: 0,0:13:00.14,0:13:03.08,Default1,,0,0,0,,看心情喔
Dialogue: 0,0:13:05.08,0:13:08.15,Default1,,0,0,0,,这样子
Dialogue: 0,0:13:10.15,0:13:13.09,Default1,,0,0,0,,那现在呢
Dialogue: 0,0:13:15.09,0:13:18.16,Default1,,0,0,0,,有穿吗
Dialogue: 0,0:13:20.16,0:13:23.10,Default1,,0,0,0,,算吗
Dialogue: 0,0:13:25.10,0:13:28.04,Default1,,0,0,0,,好像不一样
Dialogue: 0,0:13:30.04,0:13:33.11,Default1,,0,0,0,,真的吗
Dialogue: 0,0:13:35.11,0:13:38.05,Default1,,0,0,0,,看看
Dialogue: 0,0:13:40.05,0:13:43.12,Default1,,0,0,0,,好棒喔
Dialogue: 0,0:13:45.12,0:13:48.06,Default1,,0,0,0,,真性感
Dialogue: 0,0:13:50.06,0:13:53.13,Default1,,0,0,0,,对啊
Dialogue: 0,0:13:55.13,0:13:58.07,Default1,,0,0,0,,我就喜欢
Dialogue: 0,0:14:00.07,0:14:03.14,Default1,,0,0,0,,这样子
Dialogue: 0,0:14:05.14,0:14:08.08,Default1,,0,0,0,,绑的感觉
Dialogue: 0,0:14:15.15,0:14:18.09,Default1,,0,0,0,,好棒喔
Dialogue: 0,0:14:20.09,0:14:23.16,Default1,,0,0,0,,对吧
Dialogue: 0,0:14:25.16,0:14:28.10,Default1,,0,0,0,,我也喜欢
Dialogue: 0,0:14:30.10,0:14:33.03,Default1,,0,0,0,,内裤是这样
Dialogue: 0,0:14:45.05,0:14:48.12,Default1,,0,0,0,,换你
Dialogue: 0,0:15:10.14,0:15:13.07,Default1,,0,0,0,,害羞起来了
Dialogue: 0,0:15:15.08,0:15:18.15,Default1,,0,0,0,,不会啦
