Dialogue: 0,0:41:21.30,0:41:24.10,Default,,0,0,0,, -不行了 -可以的吧
Dialogue: 0,0:41:25.87,0:41:28.86,Default,,0,0,0,,再來一次吧
Dialogue: 0,0:41:30.27,0:41:33.61,Default,,0,0,0,,不行了剛射啊
Dialogue: 0,0:41:34.95,0:41:37.14,Default,,0,0,0,,進去了呢
Dialogue: 0,0:41:39.18,0:41:43.35,Default,,0,0,0,, -馬上勃起了 -不行了
Dialogue: 0,0:41:45.02,0:41:47.55,Default,,0,0,0,,還有精液的吧
Dialogue: 0,0:41:56.10,0:42:00.43,Default,,0,0,0,,肉棒很硬呢 男優好厲害
Dialogue: 0,0:42:27.20,0:42:29.00,Default,,0,0,0,,舒服啊
Dialogue: 0,0:42:35.34,0:42:37.03,Default,,0,0,0,,高潮了
Dialogue: 0,0:42:45.95,0:42:48.04,Default,,0,0,0,,肉棒真舒服
Dialogue: 0,0:42:50.32,0:42:52.59,Default,,0,0,0,,好厲害舒服
Dialogue: 0,0:43:21.02,0:43:24.68,Default,,0,0,0,,好厲害 高潮了
Dialogue: 0,0:43:38.97,0:43:40.53,Default,,0,0,0,,舒服
Dialogue: 0,0:43:46.38,0:43:48.57,Default,,0,0,0,,插我
Dialogue: 0,0:44:09.90,0:44:12.10,Default,,0,0,0,,給我吧
Dialogue: 0,0:44:28.02,0:44:29.32,Default,,0,0,0,,舒服
Dialogue: 0,0:44:48.81,0:44:51.93,Default,,0,0,0,, -喜歡正常位嗎 -喜歡
Dialogue: 0,0:44:53.08,0:44:56.24,Default,,0,0,0,, -這樣可以嗎 -再深一點
Dialogue: 0,0:44:59.05,0:45:01.18,Default,,0,0,0,,給我吧
Dialogue: 0,0:45:19.00,0:45:20.60,Default,,0,0,0,,高潮了
Dialogue: 0,0:45:26.98,0:45:29.78,Default,,0,0,0,,不行了
Dialogue: 0,0:45:38.96,0:45:41.05,Default,,0,0,0,,高潮了
Dialogue: 0,0:45:52.77,0:45:55.80,Default,,0,0,0,,繼續給我
Dialogue: 0,0:46:19.00,0:46:20.86,Default,,0,0,0,,再深一點
Dialogue: 0,0:46:25.10,0:46:29.01,Default,,0,0,0,, -舒服的話可以發出聲音\N -舒服
Dialogue: 0,0:46:31.64,0:46:33.08,Default,,0,0,0,,不行了
Dialogue: 0,0:46:42.65,0:46:43.75,Default,,0,0,0,,高潮了
Dialogue: 0,0:47:28.50,0:47:33.44,Default,,0,0,0,,真舒服 高潮了
Dialogue: 0,0:47:51.32,0:47:53.19,Default,,0,0,0,,好厲害
Dialogue: 0,0:48:55.35,0:48:57.62,Default,,0,0,0,,舒服
Dialogue: 0,0:49:22.05,0:49:26.04,Default,,0,0,0,,高潮了啊
Dialogue: 0,0:49:38.20,0:49:41.65,Default,,0,0,0,, -要射了 -內射吧
Dialogue: 0,0:49:44.30,0:49:46.57,Default,,0,0,0,, -真的射了 -射我
Dialogue: 0,0:49:52.34,0:49:54.04,Default,,0,0,0,,射了
Dialogue: 0,0:50:06.79,0:50:08.59,Default,,0,0,0,,好厲害
Dialogue: 0,0:50:37.32,0:50:39.62,Default,,0,0,0,,好厲害啊
Dialogue: 0,0:50:48.73,0:50:52.50,Default,,0,0,0,, -怎麼樣 -這個肉棒非常棒
Dialogue: 0,0:50:57.11,0:50:59.01,Default,,0,0,0,,還是勃起的
Dialogue: 0,0:51:01.28,0:51:04.77,Default,,0,0,0,, -不行了 -真的嗎
Dialogue: 0,0:51:05.18,0:51:07.74,Default,,0,0,0,,不行了
Dialogue: 0,0:51:10.82,0:51:13.99,Default,,0,0,0,, -可以嗎 -等一下
Dialogue: 0,0:51:15.16,0:51:17.15,Default,,0,0,0,,真的不行了
Dialogue: 0,0:51:17.70,0:51:21.06,Default,,0,0,0,, -好癢啊 -好厲害
Dialogue: 0,0:51:21.50,0:51:23.83,Default,,0,0,0,,等一下啊
Dialogue: 0,0:51:27.77,0:51:29.60,Default,,0,0,0,,怎麼了
Dialogue: 0,0:51:34.08,0:51:36.84,Default,,0,0,0,, -要射了 -不能射
Dialogue: 0,0:51:42.65,0:51:45.12,Default,,0,0,0,,不可以的
Dialogue: 0,0:51:48.16,0:51:50.32,Default,,0,0,0,,不行了
Dialogue: 0,0:51:52.10,0:51:54.59,Default,,0,0,0,,穿上吧
Dialogue: 0,0:52:01.61,0:52:05.80,Default,,0,0,0,, -可以拍嗎 -這是什麼
Dialogue: 0,0:52:06.68,0:52:09.15,Default,,0,0,0,, -沒事吧 -沒事的
Dialogue: 0,0:52:13.35,0:52:16.45,Default,,0,0,0,, -幾次都可以嗎 -可以的
Dialogue: 0,0:52:24.43,0:52:28.09,Default,,0,0,0,,現在覺得很激動
Dialogue: 0,0:52:28.40,0:52:33.27,Default,,0,0,0,,（對男優的印象是）\N男優肉棒都很大
Dialogue: 0,0:52:34.67,0:52:40.58,Default,,0,0,0,,讓我很舒服 很棒
Dialogue: 0,0:52:41.58,0:52:45.31,Default,,0,0,0,,做幾次都可以的感覺
Dialogue: 0,0:52:57.03,0:53:00.93,Default,,0,0,0,, -怎麼樣 第一次拍av\N -舒服
Dialogue: 0,0:53:02.00,0:53:04.06,Default,,0,0,0,, -舒服嗎 -非常舒服
Dialogue: 0,0:53:06.94,0:53:10.70,Default,,0,0,0,, -你不常做愛吧\N -這樣很奇怪嗎
Dialogue: 0,0:53:11.04,0:53:12.44,Default,,0,0,0,,不是的
Dialogue: 0,0:53:16.55,0:53:18.34,Default,,0,0,0,,這是什麼表情
Dialogue: 0,0:53:20.35,0:53:23.25,Default,,0,0,0,,-下一場戲呢 -下一場啊
Dialogue: 0,0:53:24.46,0:53:28.55,Default,,0,0,0,,要等一下才行
Dialogue: 0,0:53:29.09,0:53:33.46,Default,,0,0,0,, -是嗎 -你可以休息下
Dialogue: 0,0:53:42.74,0:53:44.67,Default,,0,0,0,,你滿足了吧
Dialogue: 0,0:53:47.08,0:53:48.84,Default,,0,0,0,,還可以做
Dialogue: 0,0:53:51.78,0:53:54.65,Default,,0,0,0,,-下一場戲是六點 -六點
Dialogue: 0,0:53:56.42,0:54:01.38,Default,,0,0,0,, -很晚呢 -3小時半後
Dialogue: 0,0:54:09.53,0:54:13.96,Default,,0,0,0,, -做什麼好 -休息
Dialogue: 0,0:54:16.87,0:54:20.47,Default,,0,0,0,, -去下面吧 -去嗎
Dialogue: 0,0:54:20.48,0:54:23.04,Default,,0,0,0,,-下面有人嗎 -有
Dialogue: 0,0:54:23.48,0:54:26.51,Default,,0,0,0,,－一直拍嗎 -嗯
Dialogue: 0,0:54:33.79,0:54:41.03,Default,,0,0,0,, -這樣我都勃起了\N -騙人吧 真的嗎 發現了
Dialogue: 0,0:54:43.20,0:54:45.86,Default,,0,0,0,, -硬嗎 -是的
Dialogue: 0,0:54:47.44,0:54:53.40,Default,,0,0,0,,那麼想嗎 這一點時間都做嗎
Dialogue: 0,0:54:56.45,0:54:59.88,Default,,0,0,0,, -可以嗎 -還沒問
Dialogue: 0,0:55:03.96,0:55:05.55,Default,,0,0,0,,過去問嗎
Dialogue: 0,0:55:05.86,0:55:11.45,Default,,0,0,0,,（剛才的男優還沒回來）
Dialogue: 0,0:55:11.46,0:55:14.80,Default,,0,0,0,,平常也這麼想要嗎
Dialogue: 0,0:55:16.13,0:55:17.26,Default,,0,0,0,,是啊
Dialogue: 0,0:55:17.40,0:55:19.46,Default,,0,0,0,,一天要幾次
Dialogue: 0,0:55:20.14,0:55:22.94,Default,,0,0,0,,最少的話
Dialogue: 0,0:55:24.28,0:55:27.14,Default,,0,0,0,,四次左右吧
Dialogue: 0,0:55:28.91,0:55:32.41,Default,,0,0,0,, -在這邊 -好厲害
Dialogue: 0,0:55:33.75,0:55:36.88,Default,,0,0,0,,好厲害 這樣逼真
Dialogue: 0,0:55:38.09,0:55:41.86,Default,,0,0,0,, -是的 -好厲害呢
Dialogue: 0,0:55:47.07,0:55:51.06,Default,,0,0,0,, -在裡面吧 -可以過去嗎
Dialogue: 0,0:55:51.60,0:55:56.23,Default,,0,0,0,, -你去說吧 -我試試看
Dialogue: 0,0:56:01.55,0:56:06.57,Default,,0,0,0,,對不起打擾了
Dialogue: 0,0:56:06.58,0:56:10.21,Default,,0,0,0,,辛苦了 有時間嗎
Dialogue: 0,0:56:11.89,0:56:16.99,Default,,0,0,0,,過來下好嗎 打擾了
Dialogue: 0,0:56:21.23,0:56:23.60,Default,,0,0,0,,沒事的 過來
Dialogue: 0,0:56:25.64,0:56:28.16,Default,,0,0,0,,關門
Dialogue: 0,0:56:42.49,0:56:46.01,Default,,0,0,0,,怎麼了嗎
Dialogue: 0,0:56:46.16,0:56:48.68,Default,,0,0,0,,不是摸過了嗎
Dialogue: 0,0:56:50.46,0:56:53.09,Default,,0,0,0,,剛射過啊
Dialogue: 0,0:56:55.60,0:57:01.80,Default,,0,0,0,, -等一下 不行的 -為什麼
Dialogue: 0,0:57:04.64,0:57:08.81,Default,,0,0,0,, -我沒聽說 -發現了
Dialogue: 0,0:57:10.95,0:57:14.94,Default,,0,0,0,, -這是什麼 -發現了
Dialogue: 0,0:57:16.05,0:57:18.72,Default,,0,0,0,,為什麼拍
Dialogue: 0,0:57:19.49,0:57:22.39,Default,,0,0,0,,找到你了
Dialogue: 0,0:57:22.39,0:57:26.66,Default,,0,0,0,,這樣會暴露的
Dialogue: 0,0:57:32.80,0:57:34.53,Default,,0,0,0,,在等嗎
Dialogue: 0,0:57:35.61,0:57:38.17,Default,,0,0,0,, -是的 -勃起了嗎
Dialogue: 0,0:57:39.11,0:57:43.10,Default,,0,0,0,,還不夠吧
Dialogue: 0,0:57:43.95,0:57:46.44,Default,,0,0,0,,不是的
Dialogue: 0,0:57:47.65,0:57:50.92,Default,,0,0,0,,看看就知道了
Dialogue: 0,0:57:50.99,0:57:57.43,Default,,0,0,0,, -是嗎 -工作結束了吧
Dialogue: 0,0:57:58.50,0:58:02.02,Default,,0,0,0,,這樣好奇怪啊
Dialogue: 0,0:58:03.17,0:58:07.57,Default,,0,0,0,, -想要了嗎 -小聲點
Dialogue: 0,0:58:14.85,0:58:18.15,Default,,0,0,0,,忍不住了呢
Dialogue: 0,0:58:19.72,0:58:24.12,Default,,0,0,0,,不可以 住手
Dialogue: 0,0:58:24.39,0:58:26.82,Default,,0,0,0,,別動了
Dialogue: 0,0:58:29.13,0:58:30.69,Default,,0,0,0,,別動啊
Dialogue: 0,0:58:37.70,0:58:42.77,Default,,0,0,0,,沒事的吧 可以
Dialogue: 0,0:58:51.75,0:58:54.12,Default,,0,0,0,,直接弄更好嗎
Dialogue: 0,0:59:01.03,0:59:02.58,Default,,0,0,0,,怎麼了
Dialogue: 0,0:59:08.70,0:59:10.40,Default,,0,0,0,,等一下
Dialogue: 0,0:59:16.47,0:59:18.91,Default,,0,0,0,,過來這邊
Dialogue: 0,0:59:35.46,0:59:39.83,Default,,0,0,0,, -還有吧 -剛才射完了
Dialogue: 0,0:59:40.77,0:59:44.79,Default,,0,0,0,, -我來讓你射 -等一下
Dialogue: 0,0:59:45.37,0:59:49.67,Default,,0,0,0,, -為什麼害羞 -不是的
Dialogue: 0,0:59:51.64,0:59:55.58,Default,,0,0,0,, -換內褲了嗎 -是啊
Dialogue: 0,0:59:56.75,1:00:00.51,Default,,0,0,0,, -剛才攝影了啊\N -不換就好了
Dialogue: 0,1:00:08.29,1:00:10.39,Default,,0,0,0,,摸到肉棒了
Dialogue: 0,1:00:16.97,1:00:18.99,Default,,0,0,0,,這是什麼啊
Dialogue: 0,1:00:23.91,1:00:29.54,Default,,0,0,0,, -讓我看看 -住手吧
Dialogue: 0,1:00:30.28,1:00:32.41,Default,,0,0,0,,真的要做嗎
Dialogue: 0,1:00:50.74,1:00:52.10,Default,,0,0,0,,好厲害
Dialogue: 0,1:00:54.74,1:00:58.20,Default,,0,0,0,, -舒服嗎 -是的
Dialogue: 0,1:00:59.01,1:01:01.88,Default,,0,0,0,, -舒服嗎 -但是
Dialogue: 0,1:01:03.65,1:01:06.91,Default,,0,0,0,, -勃起了哦 -可是
Dialogue: 0,1:01:07.39,1:01:09.18,Default,,0,0,0,,但是
Dialogue: 0,1:01:20.37,1:01:24.10,Default,,0,0,0,,坐下了吧
Dialogue: 0,1:02:09.15,1:02:11.05,Default,,0,0,0,,舒服嗎
Dialogue: 0,1:02:46.18,1:02:49.85,Default,,0,0,0,,好騷 主動開始□交了
Dialogue: 0,1:02:51.76,1:02:55.89,Default,,0,0,0,, -平常也這樣嗎 -差不多
Dialogue: 0,1:03:03.97,1:03:05.63,Default,,0,0,0,,喜歡哪裡
Dialogue: 0,1:03:09.77,1:03:12.54,Default,,0,0,0,,軀頭敏感嗎
Dialogue: 0,1:03:13.54,1:03:17.67,Default,,0,0,0,, -舒服吧 -受不了了
Dialogue: 0,1:03:18.12,1:03:21.28,Default,,0,0,0,, -明B裡敏感 -是嗎
Dialogue: 0,1:03:26.29,1:03:27.66,Default,,0,0,0,,這裡吧
Dialogue: 0,1:03:37.60,1:03:40.40,Default,,0,0,0,,肉棒很硬了
Dialogue: 0,1:03:43.67,1:03:46.01,Default,,0,0,0,,還可以做的呢
Dialogue: 0,1:04:27.55,1:04:29.45,Default,,0,0,0,,沒事的
Dialogue: 0,1:05:16.47,1:05:18.26,Default,,0,0,0,,那邊能看到吧
Dialogue: 0,1:05:20.04,1:05:22.27,Default,,0,0,0,,小心點
Dialogue: 0,1:05:29.51,1:05:31.45,Default,,0,0,0,,遮起來了嗎
Dialogue: 0,1:05:32.98,1:05:34.75,Default,,0,0,0,,可以了
Dialogue: 0,1:06:24.90,1:06:27.60,Default,,0,0,0,,摸我啊
Dialogue: 0,1:06:36.55,1:06:38.54,Default,,0,0,0,,怎麼辦好呢
Dialogue: 0,1:06:55.03,1:06:56.83,Default,,0,0,0,,摸我
Dialogue: 0,1:08:09.04,1:08:10.97,Default,,0,0,0,,看這裡
Dialogue: 0,1:08:33.70,1:08:39.16,Default,,0,0,0,,等一下 我還沒吃飯
Dialogue: 0,1:09:08.17,1:09:09.50,Default,,0,0,0,,高潮了
Dialogue: 0,1:09:16.07,1:09:18.80,Default,,0,0,0,,繼續弄我
Dialogue: 0,1:09:22.28,1:09:24.18,Default,,0,0,0,,不行吧
Dialogue: 0,1:09:25.82,1:09:27.65,Default,,0,0,0,,過來這邊
Dialogue: 0,1:09:47.24,1:09:53.04,Default,,0,0,0,, -實際 試過這樣嗎\N -辦公室的話 試過
Dialogue: 0,1:10:45.33,1:10:50.13,Default,,0,0,0,,好厲害 要高潮了
Dialogue: 0,1:10:53.67,1:10:55.17,Default,,0,0,0,,要暴露了呢
Dialogue: 0,1:11:08.49,1:11:10.75,Default,,0,0,0,,可以打電話嗎
Dialogue: 0,1:11:13.99,1:11:16.08,Default,,0,0,0,,讓我看看
Dialogue: 0,1:11:19.46,1:11:24.49,Default,,0,0,0,,這邊是接待處 有客人嗎
Dialogue: 0,1:11:26.87,1:11:33.74,Default,,0,0,0,,3點嗎 我知道了 好的
Dialogue: 0,1:11:34.88,1:11:36.54,Default,,0,0,0,,失禮了
Dialogue: 0,1:11:46.62,1:11:49.02,Default,,0,0,0,, -怎麼樣 -興奮了
Dialogue: 0,1:11:51.80,1:11:56.70,Default,,0,0,0,,繼續吧 用手指
Dialogue: 0,1:11:59.57,1:12:04.44,Default,,0,0,0,,用手指吧
Dialogue: 0,1:12:48.05,1:12:50.25,Default,,0,0,0,,濕透了呢
Dialogue: 0,1:12:50.99,1:12:55.29,Default,,0,0,0,,好厲害 好多水
Dialogue: 0,1:12:58.40,1:13:03.60,Default,,0,0,0,, -肉棒怎麼樣了 -勃起了
Dialogue: 0,1:13:04.14,1:13:09.20,Default,,0,0,0,, -是嗎 -要看到了
Dialogue: 0,1:13:10.34,1:13:12.43,Default,,0,0,0,,我藏起來吧
Dialogue: 0,1:13:14.65,1:13:16.44,Default,,0,0,0,,怎麼辦
Dialogue: 0,1:13:26.12,1:13:32.12,Default,,0,0,0,, -半勃起了 -剛才才做過
Dialogue: 0,1:14:02.79,1:14:04.82,Default,,0,0,0,,奶頭也要
Dialogue: 0,1:14:43.40,1:14:45.39,Default,,0,0,0,,好厲害
Dialogue: 0,1:15:02.05,1:15:04.04,Default,,0,0,0,,光是□交就濕了嗎
Dialogue: 0,1:15:18.07,1:15:23.91,Default,,0,0,0,, -還想來一次嗎 -想要
Dialogue: 0,1:15:24.44,1:15:28.11,Default,,0,0,0,, -我知道了 -應該可以的
Dialogue: 0,1:16:08.15,1:16:09.45,Default,,0,0,0,,怎麼了
Dialogue: 0,1:16:27.87,1:16:31.17,Default,,0,0,0,,拜託了 再硬一點
Dialogue: 0,1:16:33.61,1:16:35.64,Default,,0,0,0,,變硬吧
Dialogue: 0,1:16:43.29,1:16:45.52,Default,,0,0,0,,舒服嗎
Dialogue: 0,1:17:06.58,1:17:08.98,Default,,0,0,0,,黏糊糊的呢
Dialogue: 0,1:17:17.16,1:17:20.72,Default,,0,0,0,,龜頭最舒服了吧
Dialogue: 0,1:17:25.36,1:17:29.86,Default,,0,0,0,, -不行了嗎 -受不了了
Dialogue: 0,1:17:31.00,1:17:33.13,Default,,0,0,0,,忍不住了啊
Dialogue: 0,1:18:03.84,1:18:08.00,Default,,0,0,0,, -那麼喜歡肉棒嗎 -喜歡
Dialogue: 0,1:18:24.02,1:18:26.15,Default,,0,0,0,,好硬啊
Dialogue: 0,1:18:41.44,1:18:43.93,Default,,0,0,0,,再硬一點
Dialogue: 0,1:18:59.36,1:19:02.26,Default,,0,0,0,,為什麼這樣的表情
Dialogue: 0,1:19:04.83,1:19:07.26,Default,,0,0,0,, -不行了 -喜歡快速抽插嗎
Dialogue: 0,1:19:08.80,1:19:11.89,Default,,0,0,0,, -太舒服了 -沒事的
Dialogue: 0,1:19:19.31,1:19:21.61,Default,,0,0,0,,不行了
Dialogue: 0,1:19:26.82,1:19:30.55,Default,,0,0,0,,不行 要射了啊
Dialogue: 0,1:19:33.49,1:19:34.89,Default,,0,0,0,,射了
Dialogue: 0,1:19:51.08,1:19:55.41,Default,,0,0,0,,好厲害 射了好多
Dialogue: 0,1:19:58.65,1:20:02.81,Default,,0,0,0,,太敏感了
Dialogue: 0,1:20:03.65,1:20:07.02,Default,,0,0,0,, -怎麼樣 -好癢
Dialogue: 0,1:20:08.89,1:20:11.38,Default,,0,0,0,,不行了
Dialogue: 0,1:20:13.13,1:20:18.59,Default,,0,0,0,, -為什麼射了 -不行了
Dialogue: 0,1:20:20.41,1:20:23.60,Default,,0,0,0,, -等一下 真的 -不行
Dialogue: 0,1:20:24.21,1:20:28.34,Default,,0,0,0,,別拍了 不行了
Dialogue: 0,1:20:29.38,1:20:32.87,Default,,0,0,0,,幹嘛 別跑
Dialogue: 0,1:20:33.62,1:20:37.08,Default,,0,0,0,,跑掉了呢
Dialogue: 0,1:20:44.63,1:20:47.33,Default,,0,0,0,, -好厲害 -還想要的呢
Dialogue: 0,1:20:48.43,1:20:55.33,Default,,0,0,0,,（關於自慰）\N第一次自慰是初中
Dialogue: 0,1:20:56.67,1:21:03.64,Default,,0,0,0,,在家也自慰\N公司也加班有時候很晚
Dialogue: 0,1:21:04.48,1:21:06.78,Default,,0,0,0,,那時候忍不住 就去廁所自慰
Dialogue: 0,1:21:08.72,1:21:11.71,Default,,0,0,0,,（會幻想什麼事情唧\N來前台的人
Dialogue: 0,1:21:11.92,1:21:15.36,Default,,0,0,0,,跟我做愛的劇情
Dialogue: 0,1:21:15.86,1:21:18.39,Default,,0,0,0,,（如何自慰的）\N用手指也有
Dialogue: 0,1:21:19.36,1:21:21.96,Default,,0,0,0,,也用玩具
Dialogue: 0,1:21:22.27,1:21:25.79,Default,,0,0,0,,（什麼樣的玩家）\N肉棒形狀的
Dialogue: 0,1:21:27.00,1:21:28.67,Default,,0,0,0,,道具
Dialogue: 0,1:21:30.71,1:21:32.23,Default,,0,0,0,,想自慰嗎
Dialogue: 0,1:21:34.68,1:21:37.08,Default,,0,0,0,, -什麼 -想讓你自慰
Dialogue: 0,1:21:37.15,1:21:40.38,Default,,0,0,0,, -自慰嗎 -男優走了
Dialogue: 0,1:21:41.35,1:21:46.12,Default,,0,0,0,, -剛才想插進去的 -是啊
Dialogue: 0,1:21:47.09,1:21:49.29,Default,,0,0,0,,沒事吧
Dialogue: 0,1:21:49.29,1:21:51.92,Default,,0,0,0,,是啊
Dialogue: 0,1:21:53.10,1:21:57.86,Default,,0,0,0,, -想插進去的呢\N -你喜歡被插到最深處吧
Dialogue: 0,1:21:57.90,1:21:59.43,Default,,0,0,0,,喜歡
Dialogue: 0,1:22:00.27,1:22:03.73,Default,,0,0,0,,所以自慰也舒服吧
Dialogue: 0,1:22:04.14,1:22:07.84,Default,,0,0,0,,想看你舒服的自慰
Dialogue: 0,1:22:09.55,1:22:11.41,Default,,0,0,0,,在左邊
Dialogue: 0,1:22:15.95,1:22:18.95,Default,,0,0,0,, -社長室嗎 -是的
Dialogue: 0,1:22:23.63,1:22:26.12,Default,,0,0,0,,這是什麼
Dialogue: 0,1:22:27.80,1:22:31.29,Default,,0,0,0,,等一下 有好多
Dialogue: 0,1:22:32.74,1:22:34.30,Default,,0,0,0,,這是什麼
Dialogue: 0,1:22:36.47,1:22:38.41,Default,,0,0,0,,固定了嗎
Dialogue: 0,1:22:42.45,1:22:44.24,Default,,0,0,0,,好厲害
Dialogue: 0,1:22:47.99,1:22:49.95,Default,,0,0,0,, -是這樣的嗎 -是的
Dialogue: 0,1:22:50.62,1:22:54.25,Default,,0,0,0,, -給你準備的 -是什麼
Dialogue: 0,1:22:54.59,1:22:56.29,Default,,0,0,0,,陽具
Dialogue: 0,1:23:08.27,1:23:09.90,Default,,0,0,0,,好厲害啊
Dialogue: 0,1:23:12.14,1:23:13.54,Default,,0,0,0,,好厲害
Dialogue: 0,1:23:15.18,1:23:19.95,Default,,0,0,0,, -會舔肉棒嗎 -舔的
Dialogue: 0,1:23:19.95,1:23:23.91,Default,,0,0,0,, -讓我看看 -看嗎
Dialogue: 0,1:23:46.94,1:23:48.45,Default,,0,0,0,,這樣的
Dialogue: 0,1:23:52.95,1:23:54.85,Default,,0,0,0,,這邊呢
Dialogue: 0,1:24:00.43,1:24:01.89,Default,,0,0,0,,這裡
Dialogue: 0,1:24:03.70,1:24:06.22,Default,,0,0,0,, -感覺不錯 -是嗎
Dialogue: 0,1:24:06.90,1:24:08.80,Default,,0,0,0,,是我喜歡的形狀
Dialogue: 0,1:24:36.59,1:24:40.66,Default,,0,0,0,, -怎麼弄肉棒的 -怎麼弄
Dialogue: 0,1:24:44.84,1:24:46.50,Default,,0,0,0,,肉棒嗎
Dialogue: 0,1:24:50.14,1:24:55.81,Default,,0,0,0,,怎麼說呢 這樣弄的
Dialogue: 0,1:26:42.79,1:26:44.38,Default,,0,0,0,,碰到了奶頭嗎
Dialogue: 0,1:27:10.08,1:27:14.61,Default,,0,0,0,,拿著 讓我看看
Dialogue: 0,1:27:17.06,1:27:19.32,Default,,0,0,0,,碰到了
Dialogue: 0,1:27:47.69,1:27:52.42,Default,,0,0,0,,還沒變硬呢 要先□交才行
Dialogue: 0,1:27:53.62,1:27:55.68,Default,,0,0,0,,□交嗎
Dialogue: 0,1:28:37.10,1:28:39.70,Default,,0,0,0,,在想什麼呢
Dialogue: 0,1:28:41.94,1:28:43.93,Default,,0,0,0,,剛才男優的肉棒
Dialogue: 0,1:28:49.55,1:28:52.52,Default,,0,0,0,, -變硬了嗎 -是的
Dialogue: 0,1:29:46.50,1:29:48.70,Default,,0,0,0,,插進去可以嗎
Dialogue: 0,1:29:51.41,1:29:52.88,Default,,0,0,0,,這樣子
Dialogue: 0,1:30:14.40,1:30:15.80,Default,,0,0,0,,從前面
Dialogue: 0,1:32:33.24,1:32:34.50,Default,,0,0,0,,高潮了
Dialogue: 0,1:32:47.72,1:32:49.55,Default,,0,0,0,,好厲害
Dialogue: 0,1:32:55.93,1:32:58.26,Default,,0,0,0,,後入可以嗎
Dialogue: 0,1:34:25.35,1:34:27.98,Default,,0,0,0,,還是這邊的好
Dialogue: 0,1:34:46.00,1:34:48.30,Default,,0,0,0,, -流水了嗎 -是的
Dialogue: 0,1:34:52.18,1:34:55.34,Default,,0,0,0,,舒服 好厲害
Dialogue: 0,1:34:56.78,1:35:01.88,Default,,0,0,0,,想要高潮了呢 舒服
Dialogue: 0,1:35:49.60,1:35:51.00,Default,,0,0,0,,高潮了
Dialogue: 0,1:36:11.56,1:36:15.75,Default,,0,0,0,,好厲害啊 舒服
Dialogue: 0,1:36:34.21,1:36:35.91,Default,,0,0,0,,好多水
Dialogue: 0,1:36:46.66,1:36:50.99,Default,,0,0,0,,（你的性慾很強嗎）\N是的 很強
Dialogue: 0,1:36:51.73,1:36:56.22,Default,,0,0,0,,工作的時候 也會興奮
Dialogue: 0,1:36:57.20,1:37:03.66,Default,,0,0,0,,（覺得男人怎樣最騷）\N是什麼呢 我喜歡主動
Dialogue: 0,1:37:04.28,1:37:08.91,Default,,0,0,0,,對方的話 我也喜歡對方叫
Dialogue: 0,1:37:11.45,1:37:16.58,Default,,0,0,0,,感覺很可愛 想疼愛對方
Dialogue: 0,1:37:21.23,1:37:24.79,Default,,0,0,0,,（當初預定還有1個男優）
Dialogue: 0,1:37:24.83,1:37:28.39,Default,,0,0,0,,（因為臨時不能來了\N（就請他先等了一下）
Dialogue: 0,1:37:38.81,1:37:38.97,Default,,0,0,0,,進去吧
Dialogue: 0,1:37:39.34,1:37:43.14,Default,,0,0,0,, -可以嗎 -可以
Dialogue: 0,1:39:09.90,1:39:11.99,Default,,0,0,0,,早上好
Dialogue: 0,1:39:21.85,1:39:24.14,Default,,0,0,0,,你幹麻
Dialogue: 0,1:39:30.42,1:39:31.39,Default,,0,0,0,,等一下
Dialogue: 0,1:39:36.69,1:39:39.99,Default,,0,0,0,, -再一次好嗎\N -不是結束了嗎
Dialogue: 0,1:39:42.13,1:39:44.16,Default,,0,0,0,, -結束了 -沒有的
Dialogue: 0,1:39:46.00,1:39:49.47,Default,,0,0,0,,這樣能回去嗎
Dialogue: 0,1:39:50.78,1:39:53.01,Default,,0,0,0,,有髒東西
Dialogue: 0,1:39:53.85,1:39:58.15,Default,,0,0,0,,這樣回不去的吧
Dialogue: 0,1:40:00.25,1:40:02.48,Default,,0,0,0,,但是沒時問了
Dialogue: 0,1:40:05.86,1:40:10.39,Default,,0,0,0,, -我們再來一次好嗎\N -欽 等一下 導演救我
Dialogue: 0,1:40:31.45,1:40:35.55,Default,,0,0,0,, -還可以嗎\N -或許可以 好厲害
Dialogue: 0,1:40:37.76,1:40:40.49,Default,,0,0,0,, -男優好厲害 -還好
Dialogue: 0,1:40:42.19,1:40:44.06,Default,,0,0,0,, -還可以吧 -忍不住了
Dialogue: 0,1:40:52.54,1:40:55.23,Default,,0,0,0,,還要嗎
Dialogue: 0,1:40:58.34,1:41:01.71,Default,,0,0,0,, -我沒聽說這個 -沒說
Dialogue: 0,1:41:07.42,1:41:12.75,Default,,0,0,0,, -習慣了被侵犯嗎\N -你說什麼呢
Dialogue: 0,1:41:18.50,1:41:24.20,Default,,0,0,0,, -接受了呢 -等一下 這個
Dialogue: 0,1:41:29.87,1:41:34.14,Default,,0,0,0,, -知道會來了吧 -知道的嗎
Dialogue: 0,1:41:34.85,1:41:36.80,Default,,0,0,0,,不知道啊
Dialogue: 0,1:41:37.82,1:41:40.68,Default,,0,0,0,,我準備回家了
Dialogue: 0,1:41:41.15,1:41:44.88,Default,,0,0,0,,為什麼這樣呢
Dialogue: 0,1:41:46.09,1:41:49.92,Default,,0,0,0,,整理東西
Dialogue: 0,1:41:53.00,1:41:57.43,Default,,0,0,0,, -為什麼是這樣的\N -很敏感的
Dialogue: 0,1:41:58.57,1:42:01.40,Default,,0,0,0,,這裡
Dialogue: 0,1:42:02.71,1:42:03.94,Default,,0,0,0,,你看這裡
Dialogue: 0,1:42:08.05,1:42:11.47,Default,,0,0,0,,這是什麼 好厲害
Dialogue: 0,1:42:17.26,1:42:20.35,Default,,0,0,0,, -你幹嘛 -幹嘛
Dialogue: 0,1:42:24.00,1:42:27.12,Default,,0,0,0,,脫掉吧
Dialogue: 0,1:42:29.20,1:42:33.14,Default,,0,0,0,,脫掉了呢 好厲害
Dialogue: 0,1:42:42.38,1:42:46.54,Default,,0,0,0,, -還可以射呢 -肯定不行了
Dialogue: 0,1:42:47.75,1:42:49.74,Default,,0,0,0,,不行了的
Dialogue: 0,1:42:52.29,1:42:53.81,Default,,0,0,0,,是可以勃起的
Dialogue: 0,1:43:09.77,1:43:11.61,Default,,0,0,0,,很硬了哦
Dialogue: 0,1:43:23.55,1:43:26.15,Default,,0,0,0,,動起來吧
Dialogue: 0,1:44:00.73,1:44:02.06,Default,,0,0,0,,怎麼了
Dialogue: 0,1:44:14.47,1:44:17.17,Default,,0,0,0,,用這個肉棒嗎
Dialogue: 0,1:44:19.21,1:44:21.04,Default,,0,0,0,,這裡
Dialogue: 0,1:44:26.05,1:44:29.92,Default,,0,0,0,,變大了呢
Dialogue: 0,1:44:31.12,1:44:33.11,Default,,0,0,0,,不要跑啦
Dialogue: 0,1:45:33.79,1:45:36.31,Default,,0,0,0,, -可以插進去嗎 -可以
Dialogue: 0,1:45:37.46,1:45:39.82,Default,,0,0,0,,想插進去了 準備可以了
Dialogue: 0,1:45:45.86,1:45:48.42,Default,,0,0,0,,脫掉哦
Dialogue: 0,1:46:01.71,1:46:03.04,Default,,0,0,0,,好厲害
Dialogue: 0,1:46:12.02,1:46:13.65,Default,,0,0,0,,很深 很舒服
Dialogue: 0,1:46:48.16,1:46:51.46,Default,,0,0,0,,這樣子站起來吧
Dialogue: 0,1:46:53.70,1:46:55.96,Default,,0,0,0,,從後面插我
Dialogue: 0,1:47:20.63,1:47:22.82,Default,,0,0,0,,還可以走嗎
Dialogue: 0,1:47:54.49,1:47:56.12,Default,,0,0,0,,用力插我
Dialogue: 0,1:48:03.90,1:48:06.10,Default,,0,0,0,,高潮了
Dialogue: 0,1:48:18.72,1:48:22.74,Default,,0,0,0,, -怎麼辦 -從前面插我吧
Dialogue: 0,1:49:02.63,1:49:05.06,Default,,0,0,0,,更大了
Dialogue: 0,1:49:08.20,1:49:10.39,Default,,0,0,0,,真舒服啊
Dialogue: 0,1:49:33.06,1:49:36.12,Default,,0,0,0,,高潮了啊
Dialogue: 0,1:49:47.71,1:49:49.94,Default,,0,0,0,,親我
Dialogue: 0,1:50:44.26,1:50:49.80,Default,,0,0,0,, -要射了 -可以的 射我吧
Dialogue: 0,1:50:49.80,1:50:51.79,Default,,0,0,0,,可以射嗎
Dialogue: 0,1:50:57.44,1:50:59.00,Default,,0,0,0,,射了啊
Dialogue: 0,1:51:35.61,1:51:39.55,Default,,0,0,0,, -還可以插進去嗎\N -不行了 好癢
Dialogue: 0,1:51:42.85,1:51:47.62,Default,,0,0,0,, -剛才也這樣說的 -不行
Dialogue: 0,1:51:47.99,1:51:49.79,Default,,0,0,0,,好癢
Dialogue: 0,1:51:50.23,1:51:54.60,Default,,0,0,0,,現在是最硬的
Dialogue: 0,1:52:04.08,1:52:07.67,Default,,0,0,0,, -站好啊 -不行了
Dialogue: 0,1:52:09.75,1:52:12.51,Default,,0,0,0,,下面你弄我吧
Dialogue: 0,1:52:15.15,1:52:16.85,Default,,0,0,0,,脫掉
Dialogue: 0,1:52:36.31,1:52:40.51,Default,,0,0,0,, -第幾次了 -第四次
Dialogue: 0,1:53:10.48,1:53:11.97,Default,,0,0,0,,舒服
Dialogue: 0,1:53:28.06,1:53:35.09,Default,,0,0,0,, -還可以射精吧 可以吧\N -不行了
Dialogue: 0,1:53:36.20,1:53:38.13,Default,,0,0,0,,舔我
Dialogue: 0,1:53:47.75,1:53:54.05,Default,,0,0,0,, -肉棒想插進去吧 -不行的
Dialogue: 0,1:54:11.07,1:54:13.09,Default,,0,0,0,,想內射呢
Dialogue: 0,1:54:16.51,1:54:19.48,Default,,0,0,0,,自己精液的味道怎麼樣
Dialogue: 0,1:54:23.25,1:54:26.68,Default,,0,0,0,, -我是男優 -是嗎 專業的
Dialogue: 0,1:54:44.40,1:54:46.10,Default,,0,0,0,,非常舒服
Dialogue: 0,1:54:58.78,1:55:02.75,Default,,0,0,0,,男優的話 精液都吸乾淨
Dialogue: 0,1:55:04.39,1:55:06.98,Default,,0,0,0,,和剛才一样
Dialogue: 0,1:55:14.67,1:55:18.69,Default,,0,0,0,,內射進去的精液 都吸乾淨
Dialogue: 0,1:55:50.60,1:55:54.09,Default,,0,0,0,,真舒服 那裡
Dialogue: 0,1:56:07.65,1:56:11.32,Default,,0,0,0,,真舒服啊 舒服
Dialogue: 0,1:56:15.83,1:56:17.19,Default,,0,0,0,,高潮了
Dialogue: 0,1:56:23.63,1:56:27.16,Default,,0,0,0,,繼續 舒服
Dialogue: 0,1:56:52.50,1:56:54.09,Default,,0,0,0,,高潮了
Dialogue: 0,1:57:13.35,1:57:15.75,Default,,0,0,0,,肉棒動起來了
Dialogue: 0,1:57:33.07,1:57:35.20,Default,,0,0,0,,好厲害啊
Dialogue: 0,1:57:41.48,1:57:45.25,Default,,0,0,0,,男優好厲害 又勃起了
Dialogue: 0,1:57:48.52,1:57:50.21,Default,,0,0,0,,好厲害
Dialogue: 0,1:58:01.30,1:58:03.10,Default,,0,0,0,,高潮了
Dialogue: 0,1:58:09.27,1:58:15.14,Default,,0,0,0,,好厲害 好多精液呢
Dialogue: 0,1:58:25.29,1:58:27.19,Default,,0,0,0,,為什麼突然主動了
Dialogue: 0,1:58:30.46,1:58:32.73,Default,,0,0,0,,我不知道
Dialogue: 0,1:58:33.63,1:58:36.36,Default,,0,0,0,, -想要了吧 -不是的
Dialogue: 0,1:58:42.04,1:58:45.84,Default,,0,0,0,,難道現在想逃跑嗎
Dialogue: 0,1:58:47.45,1:58:50.44,Default,,0,0,0,, -那個 -不行的
Dialogue: 0,1:58:51.15,1:58:53.11,Default,,0,0,0,,我要多弄你
Dialogue: 0,1:59:00.89,1:59:02.83,Default,,0,0,0,,懲罰你
Dialogue: 0,1:59:51.38,1:59:53.04,Default,,0,0,0,,舒服嗎
Dialogue: 0,1:59:57.55,2:00:00.54,Default,,0,0,0,,好厲害 很硬了
Dialogue: 0,2:00:03.72,2:00:05.45,Default,,0,0,0,,插進去吧
Dialogue: 0,2:00:06.62,2:00:11.43,Default,,0,0,0,,怎麼辦好呢 坐下
Dialogue: 0,2:00:16.60,2:00:18.54,Default,,0,0,0,,好厲害
Dialogue: 0,2:00:24.68,2:00:26.20,Default,,0,0,0,,真舒服
Dialogue: 0,2:00:38.86,2:00:40.41,Default,,0,0,0,,很硬呢
Dialogue: 0,2:01:22.87,2:01:24.60,Default,,0,0,0,,真舒服
Dialogue: 0,2:01:43.86,2:01:45.45,Default,,0,0,0,,高潮了啊
Dialogue: 0,2:02:22.23,2:02:26.70,Default,,0,0,0,,高潮了呢 插我吧
Dialogue: 0,2:03:13.95,2:03:15.94,Default,,0,0,0,,舒服啊
Dialogue: 0,2:03:25.36,2:03:27.19,Default,,0,0,0,,舒服啊
Dialogue: 0,2:03:31.90,2:03:33.96,Default,,0,0,0,,舒服
Dialogue: 0,2:03:42.24,2:03:43.87,Default,,0,0,0,,高潮了啊
Dialogue: 0,2:03:55.35,2:03:59.85,Default,,0,0,0,,再深一點 舒服啊
Dialogue: 0,2:04:34.76,2:04:36.45,Default,,0,0,0,,高潮了啊
Dialogue: 0,2:05:25.81,2:05:27.44,Default,,0,0,0,,高潮了
Dialogue: 0,2:05:42.29,2:05:44.23,Default,,0,0,0,, -側面嗎 -是的
Dialogue: 0,2:05:55.81,2:05:59.71,Default,,0,0,0,, -看到了吧 -看到了
Dialogue: 0,2:06:30.58,2:06:32.87,Default,,0,0,0,,繼續給我啊
Dialogue: 0,2:06:38.35,2:06:39.85,Default,,0,0,0,,高潮了
Dialogue: 0,2:06:51.50,2:06:53.19,Default,,0,0,0,,舒服
Dialogue: 0,2:07:06.28,2:07:10.74,Default,,0,0,0,,還可以射精吧
Dialogue: 0,2:07:13.08,2:07:15.58,Default,,0,0,0,,可能可以吧
Dialogue: 0,2:07:20.63,2:07:22.12,Default,,0,0,0,,後入我吧
