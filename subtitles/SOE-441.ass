Dialogue: 0,0:00:01.75,0:00:09.49,Default,,0,0,0,,﻿初音美野里的沉默性交
Dialogue: 0,0:00:23.75,0:00:25.91,Default,,0,0,0,,﻿早安\N早安
Dialogue: 0,0:00:26.66,0:00:30.33,Default,,0,0,0,,﻿早安 多指教\N指教
Dialogue: 0,0:00:35.45,0:00:38.20,Default,,0,0,0,,﻿早安
Dialogue: 0,0:00:44.29,0:00:46.83,Default,,0,0,0,,早安\N早安
Dialogue: 0,0:00:48.41,0:00:51.58,Default,,0,0,0,,﻿先去泡茶\N谢谢
Dialogue: 0,0:01:00.58,0:01:01.74,Default,,0,0,0,,﻿正在拍啊
Dialogue: 0,0:01:03.50,0:01:11.87,Default,,0,0,0,,（一﻿开始就觉得摄影机很可疑)
Dialogue: 0,0:01:18.50,0:01:22.33,Default,,0,0,0,,﻿打搅了
Dialogue: 0,0:01:24.16,0:01:26.87,Default,,0,0,0,,﻿喝点茶吧\N谢谢
Dialogue: 0,0:01:31.54,0:01:33.79,Default,,0,0,0,,﻿请多指教
Dialogue: 0,0:01:35.12,0:01:38.70,Default,,0,0,0,,﻿身材不错耶\N是吗
Dialogue: 0,0:01:41.62,0:01:45.99,Default,,0,0,0,,﻿今天想要拍摄
Dialogue: 0,0:01:47.95,0:01:52.29,Default,,0,0,0,,﻿内容是你的一天
Dialogue: 0,0:01:53.00,0:01:59.04,Default,,0,0,0,,﻿就是妳的一整天生活
Dialogue: 0,0:02:03.41,0:02:04.74,Default,,0,0,0,,﻿早安
Dialogue: 0,0:02:06.37,0:02:08.45,Default,,0,0,0,,﻿就是这感觉
Dialogue: 0,0:02:09.33,0:02:11.12,Default,,0,0,0,,﻿好棒的笑容耶
Dialogue: 0,0:02:16.12,0:02:21.20,Default,,0,0,0,,﻿身体状况怎样啊\N超棒的啊
Dialogue: 0,0:02:23.29,0:02:26.87,Default,,0,0,0,,﻿请多多配合了
Dialogue: 0,0:02:28.00,0:02:31.87,Default,,0,0,0,,﻿应该没问题的
Dialogue: 0,0:02:32.41,0:02:35.20,Default,,0,0,0,,﻿我不太会吃螺丝的
Dialogue: 0,0:02:37.58,0:02:39.08,Default,,0,0,0,,﻿一起坐下吧
Dialogue: 0,0:02:40.41,0:02:42.58,Default,,0,0,0,,﻿我们家的制作\N请多指教
Dialogue: 0,0:02:43.04,0:02:48.04,Default,,0,0,0,,﻿他会帮忙妳的\N知道
Dialogue: 0,0:02:49.87,0:02:53.16,Default,,0,0,0,,﻿不管什么都可以\N那请多指教了
Dialogue: 0,0:02:55.00,0:03:01.20,Default,,0,0,0,,﻿那就立刻\N请经纪人稍坐一下
Dialogue: 0,0:03:02.04,0:03:06.20,Default,,0,0,0,,﻿请到那边等一下
Dialogue: 0,0:03:09.95,0:03:13.45,Default,,0,0,0,,﻿那边有饮料\N请到\N到那边休息吧
Dialogue: 0,0:03:19.29,0:03:21.08,Default,,0,0,0,,﻿请站着一下吧
Dialogue: 0,0:03:28.91,0:03:30.66,Default,,0,0,0,,﻿拍一下全身吧
Dialogue: 0,0:03:36.66,0:03:38.16,Default,,0,0,0,,﻿身材很棒耶
Dialogue: 0,0:03:38.87,0:03:42.04,Default,,0,0,0,,﻿谢谢\N这样可以吧
Dialogue: 0,0:03:43.75,0:03:45.41,Default,,0,0,0,,看﻿一下旁边
Dialogue: 0,0:03:48.45,0:03:49.54,Default,,0,0,0,,﻿胸部很大
Dialogue: 0,0:03:52.25,0:03:53.45,Default,,0,0,0,,﻿谢谢
Dialogue: 0,0:03:58.08,0:03:59.49,Default,,0,0,0,,﻿请教一下
Dialogue: 0,0:04:00.20,0:04:02.62,Default,,0,0,0,,﻿性感带是哪边
Dialogue: 0,0:04:03.12,0:04:06.87,Default,,0,0,0,,﻿性感带啊
Dialogue: 0,0:04:08.87,0:04:10.62,Default,,0,0,0,,﻿背部
Dialogue: 0,0:04:14.75,0:04:16.62,Default,,0,0,0,,﻿背部啊
Dialogue: 0,0:04:22.29,0:04:24.12,Default,,0,0,0,,﻿这是检查
Dialogue: 0,0:04:29.50,0:04:32.87,Default,,0,0,0,,﻿舒服吗\N痒痒的很舒服
Dialogue: 0,0:04:35.16,0:04:39.66,Default,,0,0,0,,其他的性感带呢
Dialogue: 0,0:04:43.20,0:04:45.37,Default,,0,0,0,,﻿脖子
Dialogue: 0,0:05:01.25,0:05:02.45,Default,,0,0,0,,﻿变热了耶
Dialogue: 0,0:05:10.04,0:05:11.29,Default,,0,0,0,,﻿放松一下
Dialogue: 0,0:05:14.20,0:05:15.99,Default,,0,0,0,,﻿其他那边是性感带？
Dialogue: 0,0:05:16.54,0:05:20.95,Default,,0,0,0,,﻿其他都很敏感\N胸部
Dialogue: 0,0:05:22.12,0:05:23.58,Default,,0,0,0,,﻿全身啊
Dialogue: 0,0:06:10.00,0:06:11.20,Default,,0,0,0,,﻿要做什么
Dialogue: 0,0:07:04.08,0:07:06.58,Default,,0,0,0,,﻿要做到怎样程度啊
Dialogue: 0,0:15:19.33,0:15:20.49,Default,,0,0,0,,﻿不可以出声喔
Dialogue: 0,0:15:21.54,0:15:22.79,Default,,0,0,0,,﻿会被发现的
Dialogue: 0,0:17:49.45,0:17:50.91,Default,,0,0,0,,﻿还在采访中
Dialogue: 0,0:17:54.37,0:17:55.83,Default,,0,0,0,,﻿一下就完了
Dialogue: 0,0:22:11.87,0:22:12.95,Default,,0,0,0,,﻿不可以出声音
Dialogue: 0,0:22:13.91,0:22:15.04,Default,,0,0,0,,﻿会被发现的喔
Dialogue: 0,0:23:59.66,0:24:00.99,Default,,0,0,0,,﻿刚刚觉得怎样
Dialogue: 0,0:24:02.83,0:24:05.74,Default,,0,0,0,,﻿很紧张耶
Dialogue: 0,0:24:08.25,0:24:12.04,Default,,0,0,0,,﻿又不能发出声音
Dialogue: 0,0:24:13.91,0:24:16.70,Default,,0,0,0,,﻿有点兴奋
Dialogue: 0,0:24:19.33,0:24:23.79,Default,,0,0,0,,﻿很爽吧
Dialogue: 0,0:24:27.62,0:24:29.16,Default,,0,0,0,,﻿这是柳橙汁\N谢谢
Dialogue: 0,0:24:30.45,0:24:39.54,Default,,0,0,0,,﻿(导演说了这一次的企划内容)
Dialogue: 0,0:24:42.45,0:24:43.49,Default,,0,0,0,,﻿这样啊
Dialogue: 0,0:24:45.41,0:24:47.41,Default,,0,0,0,,﻿没问题吧
Dialogue: 0,0:24:49.54,0:24:55.12,Default,,0,0,0,,﻿又不能发出声音
Dialogue: 0,0:24:56.08,0:24:59.16,Default,,0,0,0,,﻿有点难受又有点兴奋
Dialogue: 0,0:24:59.79,0:25:01.70,Default,,0,0,0,,﻿有点矛盾的感觉
Dialogue: 0,0:25:02.54,0:25:05.37,Default,,0,0,0,,﻿虽然有点唐突
Dialogue: 0,0:25:06.45,0:25:10.54,Default,,0,0,0,,﻿就在这边
Dialogue: 0,0:25:11.20,0:25:15.33,Default,,0,0,0,,﻿可以拍摄在厕所自慰吗
Dialogue: 0,0:25:16.75,0:25:17.70,Default,,0,0,0,,﻿自慰
Dialogue: 0,0:25:22.20,0:25:23.41,Default,,0,0,0,,﻿不好吧
Dialogue: 0,0:25:29.04,0:25:32.29,Default,,0,0,0,,﻿(交给她小玩具)
Dialogue: 0,0:25:34.16,0:25:35.58,Default,,0,0,0,,﻿好多喔
Dialogue: 0,0:25:36.29,0:25:38.16,Default,,0,0,0,,﻿会被听见
Dialogue: 0,0:25:41.95,0:25:46.33,Default,,0,0,0,,﻿不要发出声音
Dialogue: 0,0:25:46.91,0:25:49.54,Default,,0,0,0,,﻿然后去执行命令
Dialogue: 0,0:25:57.04,0:25:58.24,Default,,0,0,0,,﻿是这边吧
Dialogue: 0,0:26:00.83,0:26:04.79,Default,,0,0,0,,﻿今天很唐突的事情很多
Dialogue: 0,0:26:05.33,0:26:09.95,Default,,0,0,0,,﻿很紧张的状态
Dialogue: 0,0:26:10.70,0:26:13.16,Default,,0,0,0,,﻿这是第一次
Dialogue: 0,0:26:14.37,0:26:15.29,Default,,0,0,0,,﻿我走了
Dialogue: 0,0:26:25.08,0:26:31.58,Default,,0,0,0,,﻿我想开始自慰了
Dialogue: 0,0:26:50.20,0:26:51.99,Default,,0,0,0,,﻿好紧张
Dialogue: 0,0:27:48.50,0:27:50.29,Default,,0,0,0,,﻿真是害羞
Dialogue: 0,0:28:33.58,0:28:35.87,Default,,0,0,0,,有这东西
Dialogue: 0,0:28:40.37,0:28:41.54,Default,,0,0,0,,﻿没事的吧
Dialogue: 0,0:29:57.62,0:29:58.91,Default,,0,0,0,,﻿有人
Dialogue: 0,0:30:08.08,0:30:09.16,Default,,0,0,0,,﻿没事的吧
Dialogue: 0,0:30:26.54,0:30:28.49,Default,,0,0,0,,﻿用一下这个吧
Dialogue: 0,0:30:36.75,0:30:37.95,Default,,0,0,0,,﻿不会太吵吧
Dialogue: 0,0:30:42.70,0:30:43.83,Default,,0,0,0,,﻿没事吧
Dialogue: 0,0:32:07.33,0:32:08.29,Default,,0,0,0,,﻿正在插啊
Dialogue: 0,0:33:53.62,0:33:54.49,Default,,0,0,0,,﻿看见了
Dialogue: 0,0:34:20.41,0:34:21.54,Default,,0,0,0,,﻿这个很糟吧
Dialogue: 0,0:35:12.20,0:35:13.16,Default,,0,0,0,,﻿好爽喔！
Dialogue: 0,0:35:50.66,0:35:51.62,Default,,0,0,0,,﻿进去了
Dialogue: 0,0:36:02.91,0:36:04.29,Default,,0,0,0,,﻿去了啊!
Dialogue: 0,0:36:58.25,0:37:00.54,Default,,0,0,0,,﻿好像肉棒喔
Dialogue: 0,0:37:12.66,0:37:13.74,Default,,0,0,0,,﻿没事吧
Dialogue: 0,0:37:25.04,0:37:28.49,Default,,0,0,0,,﻿在厕所自慰了
Dialogue: 0,0:37:31.58,0:37:33.54,Default,,0,0,0,,﻿没事的吧
Dialogue: 0,0:37:40.50,0:37:44.08,Default,,0,0,0,,﻿很兴奋喔
Dialogue: 0,0:37:47.33,0:37:48.54,Default,,0,0,0,,﻿真是的
Dialogue: 0,0:37:56.83,0:37:58.49,Default,,0,0,0,,﻿放进去吧
Dialogue: 0,0:39:43.83,0:39:46.24,Default,,0,0,0,,﻿可以出声吧\N不可以吧
Dialogue: 0,0:39:47.08,0:39:49.37,Default,,0,0,0,,﻿没事的\N听不见的
Dialogue: 0,0:40:18.79,0:40:19.83,Default,,0,0,0,,﻿很爽吧
Dialogue: 0,0:41:11.50,0:41:12.74,Default,,0,0,0,,﻿不可以啊
Dialogue: 0,0:41:35.45,0:41:36.58,Default,,0,0,0,,﻿去了
Dialogue: 0,0:42:30.79,0:42:32.04,Default,,0,0,0,,﻿想要高潮吧
Dialogue: 0,0:42:33.87,0:42:35.33,Default,,0,0,0,,﻿不要太激烈
Dialogue: 0,0:42:52.87,0:42:54.04,Default,,0,0,0,,﻿旁边有人吧
Dialogue: 0,0:43:03.00,0:43:04.29,Default,,0,0,0,,﻿有人吧\N有
Dialogue: 0,0:43:08.70,0:43:10.16,Default,,0,0,0,,﻿会被发现的
Dialogue: 0,0:43:12.91,0:43:14.04,Default,,0,0,0,,﻿看一下啊
Dialogue: 0,0:43:20.08,0:43:22.33,Default,,0,0,0,,﻿怎样了啊
Dialogue: 0,0:43:25.66,0:43:27.12,Default,,0,0,0,,﻿喜欢这样吧
Dialogue: 0,0:43:41.29,0:43:42.70,Default,,0,0,0,,﻿不要太大声
Dialogue: 0,0:44:22.37,0:44:23.41,Default,,0,0,0,,﻿站好啊
Dialogue: 0,0:44:37.08,0:44:38.16,Default,,0,0,0,,﻿会被听见的啊
Dialogue: 0,0:44:58.16,0:44:59.62,Default,,0,0,0,,﻿不要太激烈
Dialogue: 0,0:46:34.50,0:46:35.58,Default,,0,0,0,,﻿好爽
Dialogue: 0,0:46:47.79,0:46:48.87,Default,,0,0,0,,﻿这样好爽
Dialogue: 0,0:48:03.70,0:48:05.54,Default,,0,0,0,,有人吧
Dialogue: 0,0:48:45.87,0:48:47.08,Default,,0,0,0,,﻿想做爱吧
Dialogue: 0,0:48:48.04,0:48:49.12,Default,,0,0,0,,﻿是吧
Dialogue: 0,0:48:51.25,0:48:52.83,Default,,0,0,0,,﻿不可以太激烈
Dialogue: 0,0:48:54.70,0:48:57.08,Default,,0,0,0,,﻿站着喔
Dialogue: 0,0:49:03.00,0:49:04.04,Default,,0,0,0,,﻿想要肉棒吧
Dialogue: 0,0:49:30.12,0:49:31.45,Default,,0,0,0,,﻿进去了
Dialogue: 0,0:50:06.16,0:50:08.08,Default,,0,0,0,,﻿脱掉吧
Dialogue: 0,0:50:40.70,0:50:42.95,Default,,0,0,0,,﻿会发出声音的
Dialogue: 0,0:51:46.08,0:51:49.58,Default,,0,0,0,,﻿不要太激烈啊
Dialogue: 0,0:56:28.70,0:56:30.12,Default,,0,0,0,,﻿好爽喔！
Dialogue: 0,0:56:31.79,0:56:33.29,Default,,0,0,0,,﻿超爽的
Dialogue: 0,0:56:38.20,0:56:39.37,Default,,0,0,0,,﻿好爽
Dialogue: 0,0:57:44.62,0:57:45.66,Default,,0,0,0,,﻿去了啊
Dialogue: 0,0:58:38.87,0:58:40.45,Default,,0,0,0,,﻿要射了
Dialogue: 0,0:59:20.12,0:59:22.49,Default,,0,0,0,,﻿好爽喔\N妳做什么
Dialogue: 0,0:59:30.79,0:59:32.54,Default,,0,0,0,,﻿结束了啊
Dialogue: 0,0:59:51.16,0:59:53.74,Default,,0,0,0,,﻿还想做爱啊
Dialogue: 0,1:00:07.04,1:00:10.74,Default,,0,0,0,,﻿怎样啊刚刚那边
Dialogue: 0,1:00:11.12,1:00:17.20,Default,,0,0,0,,﻿那边很紧张耶\N不过很好玩
Dialogue: 0,1:00:18.54,1:00:20.08,Default,,0,0,0,,﻿觉得好好玩
Dialogue: 0,1:00:21.00,1:00:23.20,Default,,0,0,0,,﻿平常没有体验过的
Dialogue: 0,1:00:23.70,1:00:29.66,Default,,0,0,0,,﻿平常和朋友常去吧
Dialogue: 0,1:00:30.58,1:00:32.91,Default,,0,0,0,,﻿跟你一起去的朋友都很可爱吧
Dialogue: 0,1:00:36.45,1:00:40.70,Default,,0,0,0,,﻿可爱吧\N我不太清楚
Dialogue: 0,1:00:41.37,1:00:50.58,Default,,0,0,0,,﻿个性上或是服装上都很可爱
Dialogue: 0,1:00:51.37,1:00:57.45,Default,,0,0,0,,因为常常一起去\N﻿所以兴趣个性都很和
Dialogue: 0,1:00:59.29,1:01:01.62,Default,,0,0,0,,﻿真想见见她啊
Dialogue: 0,1:01:02.41,1:01:03.45,Default,,0,0,0,,﻿跟我朋友？
Dialogue: 0,1:01:04.87,1:01:07.79,Default,,0,0,0,,﻿帮我介绍啊
Dialogue: 0,1:01:09.25,1:01:10.87,Default,,0,0,0,,﻿普通的介绍吗\N是啊
Dialogue: 0,1:01:12.20,1:01:14.95,Default,,0,0,0,,﻿这样不好吗\N不知道啊
Dialogue: 0,1:01:15.41,1:01:19.79,Default,,0,0,0,,﻿因为跟你朋友没什么直接关系
Dialogue: 0,1:01:21.12,1:01:22.33,Default,,0,0,0,,﻿帮我介绍吧
Dialogue: 0,1:01:22.66,1:01:30.70,Default,,0,0,0,,﻿我朋友常常说\N有好的男人就介绍给她
Dialogue: 0,1:01:31.83,1:01:35.91,Default,,0,0,0,,﻿不过我已经35了
Dialogue: 0,1:01:36.58,1:01:38.58,Default,,0,0,0,,﻿她说她喜欢年纪大的
Dialogue: 0,1:01:39.62,1:01:42.45,Default,,0,0,0,,﻿应该没问题吧
Dialogue: 0,1:01:43.04,1:01:45.16,Default,,0,0,0,,﻿应该没问题的
Dialogue: 0,1:01:46.12,1:01:47.54,Default,,0,0,0,,﻿现在去吧
Dialogue: 0,1:01:47.54,1:01:48.37,Default,,0,0,0,,﻿
Dialogue: 0,1:01:49.29,1:01:50.83,Default,,0,0,0,,﻿现在去\N现在?
Dialogue: 0,1:01:53.95,1:01:57.41,Default,,0,0,0,,﻿现在去跟她说
Dialogue: 0,1:02:00.00,1:02:01.74,Default,,0,0,0,,﻿不知道耶
Dialogue: 0,1:02:04.58,1:02:07.49,Default,,0,0,0,,﻿不知道会拖多久啊
Dialogue: 0,1:02:08.00,1:02:10.91,Default,,0,0,0,,﻿先去看看
Dialogue: 0,1:02:12.16,1:02:13.79,Default,,0,0,0,,﻿如果不在的话就算了
Dialogue: 0,1:02:15.50,1:02:21.62,Default,,0,0,0,,﻿就说我朋友刚好到这边附近
Dialogue: 0,1:02:21.95,1:02:27.12,Default,,0,0,0,,﻿如果她在家的话\N也不会拍到她脸
Dialogue: 0,1:02:29.08,1:02:33.37,Default,,0,0,0,,﻿住址知道吗\N知道啊
Dialogue: 0,1:02:34.70,1:02:36.12,Default,,0,0,0,,﻿那就没问题了啊
Dialogue: 0,1:02:37.54,1:02:39.04,Default,,0,0,0,,﻿不会乱来啊
Dialogue: 0,1:02:43.95,1:02:45.20,Default,,0,0,0,,﻿不会乱来吧
Dialogue: 0,1:02:46.20,1:02:48.49,Default,,0,0,0,,﻿不知道在不在家喔
Dialogue: 0,1:02:50.95,1:02:53.12,Default,,0,0,0,,走吧\N﻿要去吗
Dialogue: 0,1:02:53.58,1:02:56.62,Default,,0,0,0,,﻿跟我说着住址吧
Dialogue: 0,1:03:00.33,1:03:04.49,Default,,0,0,0,,这边吗\N是的
Dialogue: 0,1:03:00.33,1:03:04.49,Default,,0,0,0,,{\fs12\pos(369.651,261.661)}几乎推着初音去朋友住的公寓
Dialogue: 0,1:03:04.50,1:03:06.87,Default,,0,0,0,,﻿真的要去吗
Dialogue: 0,1:03:12.37,1:03:15.66,Default,,0,0,0,,要去吗\N﻿真是好玩啊
Dialogue: 0,1:03:18.25,1:03:22.24,Default,,0,0,0,,﻿没有联络一下\N不知道在不在家
Dialogue: 0,1:03:33.95,1:03:35.99,Default,,0,0,0,,﻿来了\N在家耶
Dialogue: 0,1:03:42.20,1:03:44.54,Default,,0,0,0,,﻿怎样了\N今天休假啊
Dialogue: 0,1:03:50.41,1:03:54.49,Default,,0,0,0,,﻿妳的姓名是
Dialogue: 0,1:03:58.25,1:04:01.12,Default,,0,0,0,,﻿她是我朋友穗
Dialogue: 0,1:04:01.58,1:04:04.16,Default,,0,0,0,,﻿初次见面\N什么啊
Dialogue: 0,1:04:06.50,1:04:07.83,Default,,0,0,0,,﻿让我关上一下
Dialogue: 0,1:04:11.20,1:04:13.79,Default,,0,0,0,,﻿我正在拍她的一天
Dialogue: 0,1:04:14.45,1:04:18.41,Default,,0,0,0,,﻿因为到这附近
Dialogue: 0,1:04:26.58,1:04:28.49,Default,,0,0,0,,﻿会打扰到邻居
Dialogue: 0,1:04:30.29,1:04:32.20,Default,,0,0,0,,﻿没事吧\N谢谢了
Dialogue: 0,1:04:33.91,1:04:35.16,Default,,0,0,0,,﻿打搅了
Dialogue: 0,1:04:39.20,1:04:43.58,Default,,0,0,0,,﻿(和男优很平常的在聊天)
Dialogue: 0,1:04:51.37,1:04:55.95,Default,,0,0,0,,现在的拍摄可以拍到脸吗
Dialogue: 0,1:04:56.79,1:04:59.12,Default,,0,0,0,,﻿可以弄马赛克吗
Dialogue: 0,1:05:03.12,1:05:05.66,Default,,0,0,0,,﻿让我介绍一下啊
Dialogue: 0,1:05:08.00,1:05:11.04,Default,,0,0,0,,﻿妳不是没男友吗\N是啊
Dialogue: 0,1:05:12.79,1:05:16.20,Default,,0,0,0,,﻿不是叫我介绍\N那件事情啊
Dialogue: 0,1:05:17.37,1:05:21.70,Default,,0,0,0,,﻿喜欢年长的吗\N喜欢啊
Dialogue: 0,1:05:21.91,1:05:23.70,Default,,0,0,0,,﻿我已经35了
Dialogue: 0,1:05:24.50,1:05:26.24,Default,,0,0,0,,﻿刚刚好吧
Dialogue: 0,1:05:26.83,1:05:33.24,Default,,0,0,0,,﻿等等喔
Dialogue: 0,1:05:43.79,1:05:44.99,Default,,0,0,0,,﻿等等喔
Dialogue: 0,1:05:50.58,1:05:51.58,Default,,0,0,0,,﻿抱歉
Dialogue: 0,1:06:17.12,1:06:19.04,Default,,0,0,0,,﻿什么啊
Dialogue: 0,1:06:30.95,1:06:33.08,Default,,0,0,0,,﻿在旁边耶
Dialogue: 0,1:06:54.37,1:06:55.99,Default,,0,0,0,,﻿很兴奋了啊
Dialogue: 0,1:06:57.16,1:06:59.08,Default,,0,0,0,,﻿这边不好吧
Dialogue: 0,1:06:59.95,1:07:01.24,Default,,0,0,0,,﻿不好吧
Dialogue: 0,1:07:19.12,1:07:20.29,Default,,0,0,0,,﻿不要啊
Dialogue: 0,1:07:37.41,1:07:39.49,Default,,0,0,0,,﻿这样的话用一下乳头
Dialogue: 0,1:08:17.12,1:08:18.54,Default,,0,0,0,,﻿这边也来吧
Dialogue: 0,1:08:21.62,1:08:22.79,Default,,0,0,0,,﻿没事的
Dialogue: 0,1:09:14.62,1:09:16.20,Default,,0,0,0,,﻿放进去吧
Dialogue: 0,1:09:31.75,1:09:32.74,Default,,0,0,0,,﻿妳没事吧
Dialogue: 0,1:09:33.95,1:09:35.16,Default,,0,0,0,,﻿没事的
Dialogue: 0,1:10:16.41,1:10:17.99,Default,,0,0,0,,﻿不要啊
Dialogue: 0,1:10:23.87,1:10:26.41,Default,,0,0,0,,﻿的
Dialogue: 0,1:11:25.75,1:11:28.16,Default,,0,0,0,,﻿不要出声
Dialogue: 0,1:14:39.16,1:14:40.33,Default,,0,0,0,,﻿用棉被遮一下
Dialogue: 0,1:15:04.45,1:15:05.95,Default,,0,0,0,,﻿美野里没事吧
Dialogue: 0,1:15:07.95,1:15:09.49,Default,,0,0,0,,﻿好像感冒了喔
Dialogue: 0,1:15:11.00,1:15:13.87,Default,,0,0,0,,﻿我们聊完了喔\N很开心
Dialogue: 0,1:15:15.50,1:15:17.62,Default,,0,0,0,,﻿想说约会看看
Dialogue: 0,1:15:19.91,1:15:22.54,Default,,0,0,0,,﻿要约会吗
Dialogue: 0,1:15:27.41,1:15:31.04,Default,,0,0,0,,﻿脸没事吧\N有点红
Dialogue: 0,1:15:33.25,1:15:37.45,Default,,0,0,0,,﻿这边房间比较温暖啊
Dialogue: 0,1:15:38.29,1:15:39.33,Default,,0,0,0,,﻿好热
Dialogue: 0,1:15:39.79,1:15:41.79,Default,,0,0,0,,﻿谢谢给我们时间
Dialogue: 0,1:15:42.45,1:15:44.12,Default,,0,0,0,,﻿走吧
Dialogue: 0,1:15:47.83,1:15:48.70,Default,,0,0,0,,以庆功宴为名，去了一家店
Dialogue: 0,1:15:48.70,1:15:50.49,Default,,0,0,0,,﻿辛苦了
Dialogue: 0,1:15:54.04,1:15:55.20,Default,,0,0,0,,﻿知道了
Dialogue: 0,1:15:55.70,1:15:57.58,Default,,0,0,0,,﻿今天辛苦了
Dialogue: 0,1:16:00.29,1:16:04.58,Default,,0,0,0,,﻿今天很紧张
Dialogue: 0,1:16:05.58,1:16:08.66,Default,,0,0,0,,﻿真的很开心
Dialogue: 0,1:16:10.00,1:16:12.74,Default,,0,0,0,,﻿新的感受
Dialogue: 0,1:16:13.04,1:16:21.12,Default,,0,0,0,,﻿朋友那边不太好吧
Dialogue: 0,1:16:21.87,1:16:24.49,Default,,0,0,0,,﻿还好吧\N应该被发现了
Dialogue: 0,1:16:26.45,1:16:27.87,Default,,0,0,0,,﻿我很会说话的
Dialogue: 0,1:16:29.20,1:16:31.45,Default,,0,0,0,,﻿之后见面会有点怕怕的
Dialogue: 0,1:16:33.50,1:16:34.54,Default,,0,0,0,,﻿抱歉了
Dialogue: 0,1:16:35.25,1:16:38.45,Default,,0,0,0,,﻿之后会去约会
Dialogue: 0,1:16:38.58,1:16:43.83,Default,,0,0,0,,﻿之后我问问她
Dialogue: 0,1:16:50.16,1:16:51.49,Default,,0,0,0,,﻿今天的妳很棒耶
Dialogue: 0,1:16:54.04,1:16:56.99,Default,,0,0,0,,﻿之前漫画店那边玩的很厉害
Dialogue: 0,1:17:07.33,1:17:08.45,Default,,0,0,0,,﻿有点危险耶
Dialogue: 0,1:17:26.66,1:17:29.83,Default,,0,0,0,,﻿什么
Dialogue: 0,1:18:05.33,1:18:06.37,Default,,0,0,0,,﻿没在看吧
Dialogue: 0,1:18:18.25,1:18:20.16,Default,,0,0,0,,﻿没事吧
Dialogue: 0,1:18:46.04,1:18:47.20,Default,,0,0,0,,﻿不行啦
Dialogue: 0,1:19:44.83,1:19:46.20,Default,,0,0,0,,﻿没被看见吧
Dialogue: 0,1:21:03.20,1:21:04.12,Default,,0,0,0,,﻿没被看见吧
Dialogue: 0,1:21:19.29,1:21:20.66,Default,,0,0,0,,﻿没事的
Dialogue: 0,1:21:24.87,1:21:25.87,Default,,0,0,0,,﻿真的吗
Dialogue: 0,1:21:52.66,1:21:55.45,Default,,0,0,0,,﻿回来了啦
Dialogue: 0,1:22:18.16,1:22:19.20,Default,,0,0,0,,﻿不可以啦
Dialogue: 0,1:26:19.54,1:26:21.70,Default,,0,0,0,,﻿快擦一下
Dialogue: 0,1:26:28.45,1:26:29.87,Default,,0,0,0,,﻿抱歉沾到眼镜了
Dialogue: 0,1:26:40.91,1:26:42.91,Default,,0,0,0,,﻿沾好多喔
Dialogue: 0,1:26:49.04,1:26:50.58,Default,,0,0,0,,﻿被发现了吧
Dialogue: 0,1:26:51.66,1:26:53.24,Default,,0,0,0,,﻿没事的
Dialogue: 0,1:27:01.37,1:27:03.29,Default,,0,0,0,,﻿真是吓了一跳
Dialogue: 0,1:27:04.79,1:27:05.99,Default,,0,0,0,,﻿辛苦了
Dialogue: 0,1:27:06.83,1:27:09.62,Default,,0,0,0,,﻿辛苦了\N滴下来了啦
Dialogue: 0,1:27:19.16,1:27:21.87,Default,,0,0,0,,﻿现在的时间
Dialogue: 0,1:27:25.87,1:27:29.79,Default,,0,0,0,,﻿经纪人给的卡片
Dialogue: 0,1:27:32.54,1:27:34.08,Default,,0,0,0,,﻿她在里面睡觉
Dialogue: 0,1:27:55.62,1:27:58.20,Default,,0,0,0,,﻿有两个人
Dialogue: 0,1:28:01.87,1:28:02.99,Default,,0,0,0,,﻿里面那一个
Dialogue: 0,1:28:54.33,1:28:55.87,Default,,0,0,0,,﻿用过的
Dialogue: 0,1:30:16.50,1:30:18.04,Default,,0,0,0,,﻿不会醒耶
Dialogue: 0,1:33:37.08,1:33:38.20,Default,,0,0,0,,﻿有穿内裤啊
Dialogue: 0,1:57:47.66,1:57:49.24,Default,,0,0,0,,﻿超爽的啊

