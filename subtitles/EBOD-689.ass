Dialogue: 0,0:00:06.00,0:00:07.98,Default,,0000,0000,0000,,看起来不错
Dialogue: 0,0:00:08.00,0:00:08.98,Default,,0000,0000,0000,,看看
Dialogue: 0,0:00:09.00,0:00:09.98,Default,,0000,0000,0000,,还在拍吗
Dialogue: 0,0:00:12.00,0:00:12.98,Default,,0000,0000,0000,,他喜欢这个吗
Dialogue: 0,0:00:13.00,0:00:13.99,Default,,0000,0000,0000,,对啊
Dialogue: 0,0:00:14.01,0:00:14.99,Default,,0000,0000,0000,,换了新手机
Dialogue: 0,0:00:16.01,0:00:17.99,Default,,0000,0000,0000,,很喜欢拍
Dialogue: 0,0:00:18.01,0:00:18.99,Default,,0000,0000,0000,,喜欢啊
Dialogue: 0,0:00:21.01,0:00:21.99,Default,,0000,0000,0000,,吃火锅
Dialogue: 0,0:00:22.01,0:00:22.99,Default,,0000,0000,0000,,火锅万岁
Dialogue: 0,0:00:24.02,0:00:25.00,Default,,0000,0000,0000,,不错
Dialogue: 0,0:00:25.02,0:00:30.00,Default,,0000,0000,0000,,一直拍也挺烦人的吧
Dialogue: 0,0:00:31.02,0:00:33.00,Default,,0000,0000,0000,,不会有什么打算吧
Dialogue: 0,0:00:33.02,0:00:34.01,Default,,0000,0000,0000,,不是吧
Dialogue: 0,0:00:34.03,0:00:36.01,Default,,0000,0000,0000,,不可能
Dialogue: 0,0:00:36.03,0:00:37.01,Default,,0000,0000,0000,,不要想太多
Dialogue: 0,0:00:38.03,0:00:39.01,Default,,0000,0000,0000,,不会
Dialogue: 0,0:00:40.03,0:00:41.01,Default,,0000,0000,0000,,三个人一起拍吧
Dialogue: 0,0:00:42.03,0:00:43.01,Default,,0000,0000,0000,,过来
Dialogue: 0,0:00:44.04,0:00:45.02,Default,,0000,0000,0000,,一起
Dialogue: 0,0:00:47.04,0:00:48.02,Default,,0000,0000,0000,,火锅
Dialogue: 0,0:00:49.04,0:00:50.02,Default,,0000,0000,0000,,好吃
Dialogue: 0,0:00:51.04,0:00:54.03,Default,,0000,0000,0000,,你们交往多久了
Dialogue: 0,0:00:54.05,0:00:55.03,Default,,0000,0000,0000,,2年
Dialogue: 0,0:00:55.05,0:00:56.03,Default,,0000,0000,0000,,大概2年了
Dialogue: 0,0:00:56.05,0:00:57.03,Default,,0000,0000,0000,,这麽久了
Dialogue: 0,0:00:59.05,0:01:01.03,Default,,0000,0000,0000,,亲一个给我看看
Dialogue: 0,0:01:04.06,0:01:06.04,Default,,0000,0000,0000,,很自然地感觉
Dialogue: 0,0:01:06.06,0:01:08.04,Default,,0000,0000,0000,,真好
Dialogue: 0,0:01:09.06,0:01:10.04,Default,,0000,0000,0000,,羡慕
Dialogue: 0,0:01:10.06,0:01:11.04,Default,,0000,0000,0000,,你和阿武交往多久了
Dialogue: 0,0:01:12.06,0:01:14.05,Default,,0000,0000,0000,,一年左右
Dialogue: 0,0:01:15.07,0:01:16.05,Default,,0000,0000,0000,,也挺久了
Dialogue: 0,0:01:17.07,0:01:21.05,Default,,0000,0000,0000,,但是都忙於工作
Dialogue: 0,0:01:22.07,0:01:23.05,Default,,0000,0000,0000,,不见面吗
Dialogue: 0,0:01:24.08,0:01:26.06,Default,,0000,0000,0000,,自从换工作後
Dialogue: 0,0:01:27.08,0:01:28.06,Default,,0000,0000,0000,,不会吧
Dialogue: 0,0:01:28.08,0:01:29.06,Default,,0000,0000,0000,,真的吗
Dialogue: 0,0:01:29.08,0:01:30.06,Default,,0000,0000,0000,,太忙了
Dialogue: 0,0:01:30.08,0:01:31.06,Default,,0000,0000,0000,,不好吧
Dialogue: 0,0:01:32.08,0:01:33.06,Default,,0000,0000,0000,,见不到
Dialogue: 0,0:01:33.08,0:01:35.07,Default,,0000,0000,0000,,今天也很晚下班吗
Dialogue: 0,0:01:36.09,0:01:38.07,Default,,0000,0000,0000,,他说一会要过来的
Dialogue: 0,0:01:39.09,0:01:40.07,Default,,0000,0000,0000,,嗯嗯
Dialogue: 0,0:01:40.09,0:01:41.07,Default,,0000,0000,0000,,我们先吃吧
Dialogue: 0,0:01:42.09,0:01:43.07,Default,,0000,0000,0000,,来吧
Dialogue: 0,0:01:44.10,0:01:45.08,Default,,0000,0000,0000,,好吃
Dialogue: 0,0:01:45.10,0:01:46.08,Default,,0000,0000,0000,,美味
Dialogue: 0,0:01:46.10,0:01:47.08,Default,,0000,0000,0000,,真的
Dialogue: 0,0:01:48.10,0:01:49.08,Default,,0000,0000,0000,,真的吗
Dialogue: 0,0:01:50.10,0:01:53.08,Default,,0000,0000,0000,,我们四个都是同一所大学的
Dialogue: 0,0:01:54.11,0:01:57.09,Default,,0000,0000,0000,,又是两对情侣真是奇蹟
Dialogue: 0,0:01:58.11,0:01:59.09,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:01:59.11,0:02:01.09,Default,,0000,0000,0000,,阿武是不是有点慢
Dialogue: 0,0:02:02.11,0:02:03.09,Default,,0000,0000,0000,,说的也是
Dialogue: 0,0:02:04.12,0:02:08.10,Default,,0000,0000,0000,,对了我最近买了一台新相机
Dialogue: 0,0:02:09.12,0:02:10.10,Default,,0000,0000,0000,,又买了相机
Dialogue: 0,0:02:12.12,0:02:13.10,Default,,0000,0000,0000,,真是喜欢拍
Dialogue: 0,0:02:14.13,0:02:16.11,Default,,0000,0000,0000,,你去拿来
Dialogue: 0,0:02:18.13,0:02:20.11,Default,,0000,0000,0000,,来记录下这个时刻
Dialogue: 0,0:02:21.13,0:02:22.11,Default,,0000,0000,0000,,那我去拿
Dialogue: 0,0:02:23.13,0:02:24.12,Default,,0000,0000,0000,,这个
Dialogue: 0,0:02:24.14,0:02:26.12,Default,,0000,0000,0000,,看起来不错
Dialogue: 0,0:02:26.14,0:02:27.12,Default,,0000,0000,0000,,是吧
Dialogue: 0,0:02:27.14,0:02:30.12,Default,,0000,0000,0000,,他又偷偷买了一台
Dialogue: 0,0:02:31.14,0:02:32.12,Default,,0000,0000,0000,,为什么录影
Dialogue: 0,0:02:32.14,0:02:33.12,Default,,0000,0000,0000,,走开
Dialogue: 0,0:02:33.14,0:02:34.13,Default,,0000,0000,0000,,太近了
Dialogue: 0,0:02:37.15,0:02:39.13,Default,,0000,0000,0000,,拍得好看吗
Dialogue: 0,0:02:39.15,0:02:40.13,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:02:40.15,0:02:42.13,Default,,0000,0000,0000,,超级漂亮的
Dialogue: 0,0:02:42.15,0:02:43.13,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:02:44.16,0:02:45.14,Default,,0000,0000,0000,,好朋友
Dialogue: 0,0:02:47.16,0:02:49.14,Default,,0000,0000,0000,,你离他太近了吧
Dialogue: 0,0:02:52.16,0:02:53.14,Default,,0000,0000,0000,,没有吧
Dialogue: 0,0:02:55.17,0:02:56.15,Default,,0000,0000,0000,,普通的距离
Dialogue: 0,0:02:56.17,0:02:58.15,Default,,0000,0000,0000,,不要在意
Dialogue: 0,0:02:59.17,0:03:01.15,Default,,0000,0000,0000,,用乌龙面作结束可以吗
Dialogue: 0,0:03:03.17,0:03:04.16,Default,,0000,0000,0000,,我去拿乌龙面
Dialogue: 0,0:03:04.18,0:03:05.16,Default,,0000,0000,0000,,谢谢
Dialogue: 0,0:03:06.18,0:03:07.16,Default,,0000,0000,0000,,刚才很近吗
Dialogue: 0,0:03:10.18,0:03:11.16,Default,,0000,0000,0000,,有一点
Dialogue: 0,0:03:12.18,0:03:13.16,Default,,0000,0000,0000,,差点露馅了
Dialogue: 0,0:03:13.18,0:03:14.17,Default,,0000,0000,0000,,没事的
Dialogue: 0,0:03:18.19,0:03:19.17,Default,,0000,0000,0000,,不要
Dialogue: 0,0:03:20.19,0:03:21.17,Default,,0000,0000,0000,,不行
Dialogue: 0,0:03:23.19,0:03:26.18,Default,,0000,0000,0000,,我对女朋友藏了一个秘密
Dialogue: 0,0:03:29.20,0:03:30.18,Default,,0000,0000,0000,,阿武你太慢了
Dialogue: 0,0:03:30.20,0:03:31.18,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:03:32.20,0:03:33.18,Default,,0000,0000,0000,,抱歉
Dialogue: 0,0:03:34.21,0:03:36.19,Default,,0000,0000,0000,,人手不够
Dialogue: 0,0:03:36.21,0:03:37.19,Default,,0000,0000,0000,,辛苦了
Dialogue: 0,0:03:37.21,0:03:38.19,Default,,0000,0000,0000,,忙死了
Dialogue: 0,0:03:38.21,0:03:40.19,Default,,0000,0000,0000,,（四人是大学同学）
Dialogue: 0,0:03:40.21,0:03:42.19,Default,,0000,0000,0000,,（又分别是两对情侣）
Dialogue: 0,0:03:44.22,0:03:45.20,Default,,0000,0000,0000,,太好吃了
Dialogue: 0,0:03:46.22,0:03:47.20,Default,,0000,0000,0000,,沾到脸上
Dialogue: 0,0:03:48.22,0:03:49.20,Default,,0000,0000,0000,,有
Dialogue: 0,0:03:50.22,0:03:51.20,Default,,0000,0000,0000,,谢谢
Dialogue: 0,0:03:52.22,0:03:53.20,Default,,0000,0000,0000,,关系真好
Dialogue: 0,0:03:55.23,0:03:56.21,Default,,0000,0000,0000,,下次四人一起去玩吧
Dialogue: 0,0:03:57.23,0:03:58.21,Default,,0000,0000,0000,,好啊
Dialogue: 0,0:03:59.23,0:04:00.21,Default,,0000,0000,0000,,哪里
Dialogue: 0,0:04:00.23,0:04:01.21,Default,,0000,0000,0000,,游乐场
Dialogue: 0,0:04:01.23,0:04:02.21,Default,,0000,0000,0000,,水族馆
Dialogue: 0,0:04:02.23,0:04:03.21,Default,,0000,0000,0000,,水族馆吗
Dialogue: 0,0:04:04.24,0:04:05.22,Default,,0000,0000,0000,,露营更好吧
Dialogue: 0,0:04:06.24,0:04:07.22,Default,,0000,0000,0000,,露营不错啊
Dialogue: 0,0:04:08.24,0:04:12.22,Default,,0000,0000,0000,,（四人决定结伴出游）
Dialogue: 0,0:04:12.24,0:04:14.23,Default,,0000,0000,0000,,(小玲是阿武的女友）
Dialogue: 0,0:04:17.25,0:04:18.23,Default,,0000,0000,0000,,赢了
Dialogue: 0,0:04:19.25,0:04:20.23,Default,,0000,0000,0000,,好快
Dialogue: 0,0:04:20.25,0:04:21.23,Default,,0000,0000,0000,,真的是
Dialogue: 0,0:04:22.25,0:04:23.23,Default,,0000,0000,0000,,受不了
Dialogue: 0,0:04:23.25,0:04:24.24,Default,,0000,0000,0000,,我看看
Dialogue: 0,0:04:24.26,0:04:25.24,Default,,0000,0000,0000,,这牌不错
Dialogue: 0,0:04:27.26,0:04:28.24,Default,,0000,0000,0000,,真的
Dialogue: 0,0:04:30.26,0:04:31.24,Default,,0000,0000,0000,,怎麽
Dialogue: 0,0:04:32.26,0:04:34.25,Default,,0000,0000,0000,,我要发大招了
Dialogue: 0,0:04:36.27,0:04:37.25,Default,,0000,0000,0000,,我抽了喔
Dialogue: 0,0:04:38.27,0:04:41.25,Default,,0000,0000,0000,,（小铃的爽朗笑容\N总是充满色慾）
Dialogue: 0,0:04:45.28,0:04:46.26,Default,,0000,0000,0000,,这里
Dialogue: 0,0:04:54.29,0:04:55.27,Default,,0000,0000,0000,,运气太好了
Dialogue: 0,0:04:58.29,0:04:59.27,Default,,0000,0000,0000,,太好了
Dialogue: 0,0:05:00.29,0:05:02.27,Default,,0000,0000,0000,,（四人一起的日子增多了）
Dialogue: 0,0:05:02.29,0:05:05.28,Default,,0000,0000,0000,,（我发现自己迷恋上小铃了）
Dialogue: 0,0:05:13.30,0:05:15.29,Default,,0000,0000,0000,,麻烦你去买个东西吧
Dialogue: 0,0:05:17.31,0:05:18.29,Default,,0000,0000,0000,,没事的
Dialogue: 0,0:05:24.32,0:05:25.30,Default,,0000,0000,0000,,谢谢
Dialogue: 0,0:05:31.32,0:05:32.30,Default,,0000,0000,0000,,亲一下
Dialogue: 0,0:05:32.32,0:05:34.31,Default,,0000,0000,0000,,被看到就完了
Dialogue: 0,0:05:34.33,0:05:36.31,Default,,0000,0000,0000,,看不到的
Dialogue: 0,0:05:36.33,0:05:37.31,Default,,0000,0000,0000,,没事
Dialogue: 0,0:05:38.33,0:05:39.31,Default,,0000,0000,0000,,不要
Dialogue: 0,0:05:43.33,0:05:44.32,Default,,0000,0000,0000,,真的不可以
Dialogue: 0,0:05:45.34,0:05:46.32,Default,,0000,0000,0000,,没事
Dialogue: 0,0:05:48.34,0:05:52.32,Default,,0000,0000,0000,,（纯真的眼神，柔软的嘴唇）
Dialogue: 0,0:05:54.35,0:05:56.33,Default,,0000,0000,0000,,夏天果然要吃冰棒
Dialogue: 0,0:05:56.35,0:05:57.33,Default,,0000,0000,0000,,没错
Dialogue: 0,0:05:59.35,0:06:00.33,Default,,0000,0000,0000,,你吃下我的
Dialogue: 0,0:06:00.35,0:06:01.33,Default,,0000,0000,0000,,好啊
Dialogue: 0,0:06:02.35,0:06:03.33,Default,,0000,0000,0000,,来
Dialogue: 0,0:06:07.36,0:06:09.34,Default,,0000,0000,0000,,还是我的好吃
Dialogue: 0,0:06:10.36,0:06:11.34,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:06:14.37,0:06:16.35,Default,,0000,0000,0000,,你的融化了
Dialogue: 0,0:06:17.37,0:06:18.35,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:06:22.37,0:06:23.35,Default,,0000,0000,0000,,真的是
Dialogue: 0,0:06:23.37,0:06:24.36,Default,,0000,0000,0000,,走开
Dialogue: 0,0:06:26.38,0:06:29.36,Default,,0000,0000,0000,,桃子我尝尝你的
Dialogue: 0,0:06:29.38,0:06:30.36,Default,,0000,0000,0000,,好
Dialogue: 0,0:06:31.38,0:06:32.36,Default,,0000,0000,0000,,好大一口
Dialogue: 0,0:06:33.38,0:06:34.37,Default,,0000,0000,0000,,香草
Dialogue: 0,0:06:34.39,0:06:35.37,Default,,0000,0000,0000,,好吃吧
Dialogue: 0,0:06:38.39,0:06:39.37,Default,,0000,0000,0000,,沾到了
Dialogue: 0,0:06:41.39,0:06:42.37,Default,,0000,0000,0000,,乾净了吗
Dialogue: 0,0:06:42.39,0:06:46.38,Default,,0000,0000,0000,,（我知道不可以伤害\N女友和好朋友）
Dialogue: 0,0:06:51.40,0:06:52.38,Default,,0000,0000,0000,,你看看
Dialogue: 0,0:06:52.40,0:06:54.39,Default,,0000,0000,0000,,还有香草口味
Dialogue: 0,0:06:54.41,0:06:56.39,Default,,0000,0000,0000,,真是谢谢
Dialogue: 0,0:06:56.41,0:06:58.39,Default,,0000,0000,0000,,好吃吧
Dialogue: 0,0:06:58.41,0:06:59.39,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:07:04.42,0:07:05.40,Default,,0000,0000,0000,,来
Dialogue: 0,0:07:09.42,0:07:13.40,Default,,0000,0000,0000,,（但我忽略了好友\N跟女友的关系）
Dialogue: 0,0:07:16.43,0:07:19.41,Default,,0000,0000,0000,,（因此）
Dialogue: 0,0:07:25.44,0:07:26.42,Default,,0000,0000,0000,,今天要在这过夜
Dialogue: 0,0:07:26.44,0:07:28.42,Default,,0000,0000,0000,,所以我打算卸妆
Dialogue: 0,0:07:29.44,0:07:30.42,Default,,0000,0000,0000,,过来
Dialogue: 0,0:07:36.45,0:07:37.43,Default,,0000,0000,0000,,不行
Dialogue: 0,0:07:37.45,0:07:38.43,Default,,0000,0000,0000,,没事
Dialogue: 0,0:07:39.45,0:07:40.43,Default,,0000,0000,0000,,被听到怎麽办
Dialogue: 0,0:07:40.45,0:07:41.43,Default,,0000,0000,0000,,放心
Dialogue: 0,0:07:44.46,0:07:46.44,Default,,0000,0000,0000,,阿武也在
Dialogue: 0,0:07:47.46,0:07:48.44,Default,,0000,0000,0000,,放心
Dialogue: 0,0:07:48.46,0:07:49.44,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:08:04.48,0:08:05.46,Default,,0000,0000,0000,,你们在干嘛
Dialogue: 0,0:08:06.48,0:08:11.46,Default,,0000,0000,0000,,我打算卸个妆
Dialogue: 0,0:08:12.48,0:08:15.47,Default,,0000,0000,0000,,你们的动作也太迅速了
Dialogue: 0,0:08:18.49,0:08:20.47,Default,,0000,0000,0000,,好好洗吧
Dialogue: 0,0:08:26.50,0:08:27.48,Default,,0000,0000,0000,,虚惊一场
Dialogue: 0,0:08:28.50,0:08:29.48,Default,,0000,0000,0000,,吓死
Dialogue: 0,0:08:38.51,0:08:41.49,Default,,0000,0000,0000,,（禁断恋爱理不清的关系）
Dialogue: 0,0:08:47.52,0:08:48.50,Default,,0000,0000,0000,,不行
Dialogue: 0,0:08:53.53,0:08:54.51,Default,,0000,0000,0000,,真的不行
Dialogue: 0,0:08:55.53,0:08:56.51,Default,,0000,0000,0000,,没事
Dialogue: 0,0:09:00.53,0:09:04.52,Default,,0000,0000,0000,,（我对女友的秘密越来越多）
Dialogue: 0,0:09:08.54,0:09:09.52,Default,,0000,0000,0000,,那个
Dialogue: 0,0:09:11.54,0:09:12.52,Default,,0000,0000,0000,,觉得
Dialogue: 0,0:09:14.55,0:09:16.53,Default,,0000,0000,0000,,这样不好
Dialogue: 0,0:09:16.55,0:09:17.53,Default,,0000,0000,0000,,没事
Dialogue: 0,0:09:35.57,0:09:37.55,Default,,0000,0000,0000,,（让我把持不住的身材）
Dialogue: 0,0:09:37.57,0:09:41.55,Default,,0000,0000,0000,,（好友女友3日连拍影像）
Dialogue: 0,0:09:47.58,0:09:48.56,Default,,0000,0000,0000,,冲绳吗
Dialogue: 0,0:09:50.58,0:09:54.57,Default,,0000,0000,0000,,和家人约好要去三天两夜
Dialogue: 0,0:09:59.59,0:10:00.57,Default,,0000,0000,0000,,真的吗
Dialogue: 0,0:10:00.59,0:10:01.57,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:10:02.59,0:10:06.58,Default,,0000,0000,0000,,三天两夜很快的
Dialogue: 0,0:10:08.60,0:10:09.58,Default,,0000,0000,0000,,这样啊
Dialogue: 0,0:10:11.60,0:10:12.58,Default,,0000,0000,0000,,想要什么礼物
Dialogue: 0,0:10:14.61,0:10:15.59,Default,,0000,0000,0000,,珊瑚礁
Dialogue: 0,0:10:16.61,0:10:19.59,Default,,0000,0000,0000,,我要拿世上最漂亮的那个给你
Dialogue: 0,0:10:21.61,0:10:22.59,Default,,0000,0000,0000,,什么时候去
Dialogue: 0,0:10:22.61,0:10:24.60,Default,,0000,0000,0000,,下礼拜吧
Dialogue: 0,0:10:26.62,0:10:27.60,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:10:29.62,0:10:31.60,Default,,0000,0000,0000,,离上课还有一段时间
Dialogue: 0,0:10:41.63,0:10:42.61,Default,,0000,0000,0000,,喜欢吗
Dialogue: 0,0:10:44.64,0:10:45.62,Default,,0000,0000,0000,,寂寞吗
Dialogue: 0,0:10:46.64,0:10:47.62,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:10:48.64,0:10:49.62,Default,,0000,0000,0000,,说清楚
Dialogue: 0,0:10:51.64,0:10:52.62,Default,,0000,0000,0000,,寂寞
Dialogue: 0,0:10:55.65,0:10:57.63,Default,,0000,0000,0000,,喜欢吗
Dialogue: 0,0:10:57.65,0:10:58.63,Default,,0000,0000,0000,,喜欢
Dialogue: 0,0:10:59.65,0:11:00.63,Default,,0000,0000,0000,,我也喜欢
Dialogue: 0,0:11:05.66,0:11:06.64,Default,,0000,0000,0000,,差不多了
Dialogue: 0,0:11:08.66,0:11:09.64,Default,,0000,0000,0000,,该走了
Dialogue: 0,0:11:09.66,0:11:11.64,Default,,0000,0000,0000,,我送你去车站
Dialogue: 0,0:11:11.66,0:11:12.64,Default,,0000,0000,0000,,不用
Dialogue: 0,0:11:12.66,0:11:13.65,Default,,0000,0000,0000,,真的吗
Dialogue: 0,0:11:13.67,0:11:15.65,Default,,0000,0000,0000,,我可以自己去
Dialogue: 0,0:11:20.67,0:11:21.65,Default,,0000,0000,0000,,喜欢吗
Dialogue: 0,0:11:23.68,0:11:24.66,Default,,0000,0000,0000,,会寂寞吗
Dialogue: 0,0:11:24.68,0:11:25.66,Default,,0000,0000,0000,,寂寞
Dialogue: 0,0:11:25.68,0:11:26.66,Default,,0000,0000,0000,,我也是
Dialogue: 0,0:11:27.68,0:11:29.66,Default,,0000,0000,0000,,真的吗
Dialogue: 0,0:11:29.68,0:11:30.66,Default,,0000,0000,0000,,我不在你会出轨吗
Dialogue: 0,0:11:31.68,0:11:32.66,Default,,0000,0000,0000,,不会
Dialogue: 0,0:11:32.68,0:11:33.67,Default,,0000,0000,0000,,真的吗
Dialogue: 0,0:11:35.69,0:11:37.67,Default,,0000,0000,0000,,我会送你冲绳最好的礼物
Dialogue: 0,0:11:38.69,0:11:39.67,Default,,0000,0000,0000,,等我回来
Dialogue: 0,0:11:42.69,0:11:44.68,Default,,0000,0000,0000,,我该走了
Dialogue: 0,0:11:44.70,0:11:45.68,Default,,0000,0000,0000,,快来不及了
Dialogue: 0,0:11:47.70,0:11:48.68,Default,,0000,0000,0000,,那我走了
Dialogue: 0,0:11:49.70,0:11:50.68,Default,,0000,0000,0000,,我亲爱的佑太
Dialogue: 0,0:11:52.70,0:11:53.69,Default,,0000,0000,0000,,我走了
Dialogue: 0,0:12:09.72,0:12:10.70,Default,,0000,0000,0000,,小铃啊
Dialogue: 0,0:12:16.73,0:12:17.71,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:12:18.73,0:12:20.71,Default,,0000,0000,0000,,阿武今天要打工吗
Dialogue: 0,0:12:24.74,0:12:25.72,Default,,0000,0000,0000,,要啊
Dialogue: 0,0:12:26.74,0:12:27.72,Default,,0000,0000,0000,,这样
Dialogue: 0,0:12:28.74,0:12:29.72,Default,,0000,0000,0000,,那个
Dialogue: 0,0:12:34.75,0:12:36.73,Default,,0000,0000,0000,,不要拍了啊
Dialogue: 0,0:12:38.75,0:12:40.73,Default,,0000,0000,0000,,你真的很喜欢拍
Dialogue: 0,0:12:41.75,0:12:42.73,Default,,0000,0000,0000,,纪念
Dialogue: 0,0:12:42.75,0:12:44.74,Default,,0000,0000,0000,,好不容易只有我们
Dialogue: 0,0:12:44.76,0:12:45.74,Default,,0000,0000,0000,,所以呢
Dialogue: 0,0:12:46.76,0:12:47.74,Default,,0000,0000,0000,,纪念一下
Dialogue: 0,0:12:48.76,0:12:50.74,Default,,0000,0000,0000,,他不会回来吗
Dialogue: 0,0:12:51.76,0:12:54.75,Default,,0000,0000,0000,,他已经去旅行了啊
Dialogue: 0,0:12:55.77,0:12:56.75,Default,,0000,0000,0000,,没事
Dialogue: 0,0:12:57.77,0:12:58.75,Default,,0000,0000,0000,,手好冰
Dialogue: 0,0:12:59.77,0:13:00.75,Default,,0000,0000,0000,,有点冷
Dialogue: 0,0:13:00.77,0:13:02.75,Default,,0000,0000,0000,,一会就好
Dialogue: 0,0:13:02.77,0:13:05.76,Default,,0000,0000,0000,,我给我温暖
Dialogue: 0,0:13:06.78,0:13:07.76,Default,,0000,0000,0000,,好啊
Dialogue: 0,0:13:10.78,0:13:11.76,Default,,0000,0000,0000,,约会
Dialogue: 0,0:13:13.79,0:13:14.77,Default,,0000,0000,0000,,怎麽
Dialogue: 0,0:13:15.79,0:13:17.77,Default,,0000,0000,0000,,这样也可以吗
Dialogue: 0,0:13:18.79,0:13:19.77,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:13:20.79,0:13:21.77,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:13:22.79,0:13:23.78,Default,,0000,0000,0000,,机会难得
Dialogue: 0,0:13:24.80,0:13:27.78,Default,,0000,0000,0000,,像恋人一样的
Dialogue: 0,0:13:30.80,0:13:31.78,Default,,0000,0000,0000,,真的
Dialogue: 0,0:13:35.81,0:13:36.79,Default,,0000,0000,0000,,摆姿势
Dialogue: 0,0:13:36.81,0:13:38.79,Default,,0000,0000,0000,,好可爱啊
Dialogue: 0,0:13:38.81,0:13:39.79,Default,,0000,0000,0000,,好
Dialogue: 0,0:13:39.81,0:13:40.79,Default,,0000,0000,0000,,结束
Dialogue: 0,0:13:40.81,0:13:41.79,Default,,0000,0000,0000,,多拍一会
Dialogue: 0,0:13:44.82,0:13:45.80,Default,,0000,0000,0000,,可爱
Dialogue: 0,0:13:45.82,0:13:46.80,Default,,0000,0000,0000,,不错
Dialogue: 0,0:13:47.82,0:13:48.80,Default,,0000,0000,0000,,做鬼脸
Dialogue: 0,0:13:48.82,0:13:50.80,Default,,0000,0000,0000,,鬼脸
Dialogue: 0,0:13:50.82,0:13:51.80,Default,,0000,0000,0000,,什么鬼脸
Dialogue: 0,0:13:51.82,0:13:52.80,Default,,0000,0000,0000,,鬼脸
Dialogue: 0,0:13:56.83,0:13:59.81,Default,,0000,0000,0000,,今天服装的重点在哪里
Dialogue: 0,0:14:00.83,0:14:01.81,Default,,0000,0000,0000,,今天
Dialogue: 0,0:14:02.83,0:14:03.82,Default,,0000,0000,0000,,今天啊
Dialogue: 0,0:14:04.84,0:14:05.82,Default,,0000,0000,0000,,少女感
Dialogue: 0,0:14:06.84,0:14:07.82,Default,,0000,0000,0000,,像吗
Dialogue: 0,0:14:08.84,0:14:09.82,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:14:09.84,0:14:10.82,Default,,0000,0000,0000,,是吧
Dialogue: 0,0:14:11.84,0:14:13.83,Default,,0000,0000,0000,,那个语调是怎样
Dialogue: 0,0:14:16.85,0:14:17.83,Default,,0000,0000,0000,,害羞啦
Dialogue: 0,0:14:22.85,0:14:23.84,Default,,0000,0000,0000,,怎麽
Dialogue: 0,0:14:24.86,0:14:25.84,Default,,0000,0000,0000,,什么
Dialogue: 0,0:14:26.86,0:14:27.84,Default,,0000,0000,0000,,好害羞
Dialogue: 0,0:14:27.86,0:14:28.84,Default,,0000,0000,0000,,害羞吗
Dialogue: 0,0:14:29.86,0:14:31.84,Default,,0000,0000,0000,,这个好像是兔子
Dialogue: 0,0:14:34.87,0:14:36.85,Default,,0000,0000,0000,,你坐在兔子上面
Dialogue: 0,0:14:37.87,0:14:38.85,Default,,0000,0000,0000,,可爱吗
Dialogue: 0,0:14:39.87,0:14:40.85,Default,,0000,0000,0000,,你更可爱
Dialogue: 0,0:14:41.87,0:14:42.85,Default,,0000,0000,0000,,没有
Dialogue: 0,0:14:43.88,0:14:44.86,Default,,0000,0000,0000,,比兔子可爱
Dialogue: 0,0:14:44.88,0:14:45.86,Default,,0000,0000,0000,,别说了
Dialogue: 0,0:14:45.88,0:14:47.86,Default,,0000,0000,0000,,你模仿一下兔子
Dialogue: 0,0:14:47.88,0:14:49.86,Default,,0000,0000,0000,,你在拍吗
Dialogue: 0,0:14:58.89,0:14:59.87,Default,,0000,0000,0000,,害羞
Dialogue: 0,0:15:01.89,0:15:02.87,Default,,0000,0000,0000,,你在拍哪里
Dialogue: 0,0:15:03.90,0:15:04.88,Default,,0000,0000,0000,,拍兔子
Dialogue: 0,0:15:06.90,0:15:07.88,Default,,0000,0000,0000,,秋千真令人怀念
Dialogue: 0,0:15:09.90,0:15:10.88,Default,,0000,0000,0000,,喜欢
Dialogue: 0,0:15:10.90,0:15:12.88,Default,,0000,0000,0000,,秋千真好
Dialogue: 0,0:15:14.91,0:15:15.89,Default,,0000,0000,0000,,怎麽
Dialogue: 0,0:15:17.91,0:15:18.89,Default,,0000,0000,0000,,我们这样真的没关系吧
Dialogue: 0,0:15:19.91,0:15:22.89,Default,,0000,0000,0000,,你太敏感了没事的
Dialogue: 0,0:15:24.92,0:15:25.90,Default,,0000,0000,0000,,毕竟都是朋友
Dialogue: 0,0:15:26.92,0:15:27.90,Default,,0000,0000,0000,,会保密的
Dialogue: 0,0:15:30.92,0:15:31.90,Default,,0000,0000,0000,,好
Dialogue: 0,0:15:32.92,0:15:33.91,Default,,0000,0000,0000,,没事的
Dialogue: 0,0:15:35.93,0:15:40.91,Default,,0000,0000,0000,,我感觉阿武和桃子之间\N关系也很好
Dialogue: 0,0:15:41.93,0:15:42.91,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:15:42.93,0:15:43.92,Default,,0000,0000,0000,,你不反感吗
Dialogue: 0,0:15:46.94,0:15:49.92,Default,,0000,0000,0000,,我们要报复吗
Dialogue: 0,0:15:50.94,0:15:52.92,Default,,0000,0000,0000,,不是这个意思
Dialogue: 0,0:15:53.95,0:15:58.93,Default,,0000,0000,0000,,我是单纯地喜欢你
Dialogue: 0,0:16:01.95,0:16:02.93,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:16:03.96,0:16:05.94,Default,,0000,0000,0000,,明白了
Dialogue: 0,0:16:05.96,0:16:07.94,Default,,0000,0000,0000,,我会保密
Dialogue: 0,0:16:08.96,0:16:09.94,Default,,0000,0000,0000,,不会
Dialogue: 0,0:16:09.96,0:16:11.94,Default,,0000,0000,0000,,你要不要来我家
Dialogue: 0,0:16:15.97,0:16:16.95,Default,,0000,0000,0000,,去佑太家吗
Dialogue: 0,0:16:16.97,0:16:17.95,Default,,0000,0000,0000,,对啊
Dialogue: 0,0:16:19.97,0:16:21.95,Default,,0000,0000,0000,,这样不好吧
Dialogue: 0,0:16:21.97,0:16:22.95,Default,,0000,0000,0000,,为什么
Dialogue: 0,0:16:24.98,0:16:27.96,Default,,0000,0000,0000,,被发现了不好吧
Dialogue: 0,0:16:27.98,0:16:28.96,Default,,0000,0000,0000,,什么
Dialogue: 0,0:16:28.98,0:16:30.96,Default,,0000,0000,0000,,突然回来怎麽办
Dialogue: 0,0:16:30.98,0:16:31.96,Default,,0000,0000,0000,,桃子吗
Dialogue: 0,0:16:32.98,0:16:35.97,Default,,0000,0000,0000,,他都去旅游了
Dialogue: 0,0:16:35.99,0:16:36.97,Default,,0000,0000,0000,,阿武突然出现的话呢
Dialogue: 0,0:16:38.99,0:16:40.97,Default,,0000,0000,0000,,他不会突然过来的
Dialogue: 0,0:16:47.00,0:16:47.98,Default,,0000,0000,0000,,好吗
Dialogue: 0,0:16:50.00,0:16:50.98,Default,,0000,0000,0000,,走吧
Dialogue: 0,0:16:53.00,0:16:53.99,Default,,0000,0000,0000,,好
Dialogue: 0,0:16:55.01,0:16:55.99,Default,,0000,0000,0000,,那就这样麽决定罗
Dialogue: 0,0:17:00.01,0:17:00.99,Default,,0000,0000,0000,,走吧
Dialogue: 0,0:17:16.03,0:17:17.01,Default,,0000,0000,0000,,谢谢
Dialogue: 0,0:17:20.03,0:17:21.01,Default,,0000,0000,0000,,我说
Dialogue: 0,0:17:22.03,0:17:27.02,Default,,0000,0000,0000,,我们之间都互相有
Dialogue: 0,0:17:28.04,0:17:29.02,Default,,0000,0000,0000,,有另一半
Dialogue: 0,0:17:31.04,0:17:34.03,Default,,0000,0000,0000,,还这样做你觉得好吗
Dialogue: 0,0:17:39.05,0:17:41.03,Default,,0000,0000,0000,,虽然觉得对不起桃子
Dialogue: 0,0:17:43.05,0:17:46.04,Default,,0000,0000,0000,,但是我喜欢你
Dialogue: 0,0:18:12.08,0:18:13.06,Default,,0000,0000,0000,,怎麽办
Dialogue: 0,0:18:24.10,0:18:25.08,Default,,0000,0000,0000,,那个
Dialogue: 0,0:18:26.10,0:18:27.08,Default,,0000,0000,0000,,在这
Dialogue: 0,0:18:30.10,0:18:32.08,Default,,0000,0000,0000,,桃子不在的时候
Dialogue: 0,0:18:35.11,0:18:37.09,Default,,0000,0000,0000,,我就是你的女朋友吗
Dialogue: 0,0:18:45.12,0:18:46.10,Default,,0000,0000,0000,,桃子不在的时候
Dialogue: 0,0:18:48.12,0:18:49.10,Default,,0000,0000,0000,,做我的女友吧
Dialogue: 0,0:18:59.13,0:19:02.11,Default,,0000,0000,0000,,爱情故事好像都会有这句台词
Dialogue: 0,0:19:05.14,0:19:06.12,Default,,0000,0000,0000,,桃子不会回来
Dialogue: 0,0:19:06.14,0:19:09.12,Default,,0000,0000,0000,,也不会让武知道
Dialogue: 0,0:19:13.14,0:19:14.13,Default,,0000,0000,0000,,把这当作我们两个的秘密吧
Dialogue: 0,0:20:44.24,0:20:45.22,Default,,0000,0000,0000,,要去哪
Dialogue: 0,0:21:20.27,0:21:21.25,Default,,0000,0000,0000,,你果然是巨乳
Dialogue: 0,0:21:22.27,0:21:23.25,Default,,0000,0000,0000,,我没给你看过好吗
Dialogue: 0,0:21:25.28,0:21:26.26,Default,,0000,0000,0000,,透过衣服也看得出来
Dialogue: 0,0:21:29.28,0:21:30.26,Default,,0000,0000,0000,,你平常都在看啊
Dialogue: 0,0:21:32.28,0:21:33.26,Default,,0000,0000,0000,,真变态
Dialogue: 0,0:21:50.30,0:21:51.28,Default,,0000,0000,0000,,好大
Dialogue: 0,0:21:56.31,0:21:57.29,Default,,0000,0000,0000,,阿武真是赚到了
Dialogue: 0,0:22:02.31,0:22:03.29,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:22:06.32,0:22:07.30,Default,,0000,0000,0000,,好棒
Dialogue: 0,0:22:14.33,0:22:16.31,Default,,0000,0000,0000,,桃子也是这样的吧
Dialogue: 0,0:22:18.33,0:22:21.31,Default,,0000,0000,0000,,跟桃子的完全不一样
Dialogue: 0,0:22:23.33,0:22:24.32,Default,,0000,0000,0000,,你的胸部很棒
Dialogue: 0,0:22:31.34,0:22:32.32,Default,,0000,0000,0000,,你真是个坏男友
Dialogue: 0,0:22:37.35,0:22:38.33,Default,,0000,0000,0000,,喜欢
Dialogue: 0,0:22:40.35,0:22:41.33,Default,,0000,0000,0000,,乳房
Dialogue: 0,0:22:42.35,0:22:43.33,Default,,0000,0000,0000,,好软
Dialogue: 0,0:22:52.36,0:22:53.34,Default,,0000,0000,0000,,再让我看看
Dialogue: 0,0:23:04.38,0:23:05.36,Default,,0000,0000,0000,,内衣太色情了吧
Dialogue: 0,0:23:06.38,0:23:07.36,Default,,0000,0000,0000,,什么
Dialogue: 0,0:23:10.38,0:23:13.36,Default,,0000,0000,0000,,我一直都穿这种
Dialogue: 0,0:23:36.41,0:23:37.39,Default,,0000,0000,0000,,我忍不住了
Dialogue: 0,0:23:37.41,0:23:38.39,Default,,0000,0000,0000,,什么
Dialogue: 0,0:23:39.41,0:23:40.39,Default,,0000,0000,0000,,好色啊
Dialogue: 0,0:23:42.41,0:23:43.39,Default,,0000,0000,0000,,害羞
Dialogue: 0,0:23:43.41,0:23:45.40,Default,,0000,0000,0000,,我喜欢
Dialogue: 0,0:23:59.43,0:24:00.41,Default,,0000,0000,0000,,不要看
Dialogue: 0,0:24:02.43,0:24:04.42,Default,,0000,0000,0000,,真是一对好奶
Dialogue: 0,0:24:36.47,0:24:38.45,Default,,0000,0000,0000,,忍不住了
Dialogue: 0,0:24:54.49,0:24:55.47,Default,,0000,0000,0000,,我兴奋了
Dialogue: 0,0:24:59.49,0:25:01.47,Default,,0000,0000,0000,,你好坏
Dialogue: 0,0:25:04.50,0:25:05.48,Default,,0000,0000,0000,,真好吃
Dialogue: 0,0:25:33.53,0:25:34.51,Default,,0000,0000,0000,,舒服吗
Dialogue: 0,0:25:34.53,0:25:35.51,Default,,0000,0000,0000,,舒服
Dialogue: 0,0:26:09.56,0:26:10.54,Default,,0000,0000,0000,,真的
Dialogue: 0,0:26:26.58,0:26:28.56,Default,,0000,0000,0000,,好色啊
Dialogue: 0,0:26:31.58,0:26:33.57,Default,,0000,0000,0000,,这样的
Dialogue: 0,0:26:44.60,0:26:45.58,Default,,0000,0000,0000,,你真狡猾
Dialogue: 0,0:26:47.60,0:26:48.58,Default,,0000,0000,0000,,真坏
Dialogue: 0,0:26:50.60,0:26:51.58,Default,,0000,0000,0000,,什么
Dialogue: 0,0:26:55.61,0:26:56.59,Default,,0000,0000,0000,,干喃
Dialogue: 0,0:26:57.61,0:26:58.59,Default,,0000,0000,0000,,这麽急
Dialogue: 0,0:26:59.61,0:27:00.59,Default,,0000,0000,0000,,坏人
Dialogue: 0,0:27:04.62,0:27:05.60,Default,,0000,0000,0000,,我看
Dialogue: 0,0:27:05.62,0:27:07.60,Default,,0000,0000,0000,,美丽的
Dialogue: 0,0:27:08.62,0:27:09.60,Default,,0000,0000,0000,,我有在修的
Dialogue: 0,0:27:15.63,0:27:16.61,Default,,0000,0000,0000,,湿了
Dialogue: 0,0:27:18.63,0:27:19.61,Default,,0000,0000,0000,,湿吗
Dialogue: 0,0:27:25.64,0:27:26.62,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:27:28.64,0:27:30.62,Default,,0000,0000,0000,,湿洒洒的了
Dialogue: 0,0:28:02.67,0:28:04.66,Default,,0000,0000,0000,,身材真好
Dialogue: 0,0:28:05.68,0:28:06.66,Default,,0000,0000,0000,,可以拍照吗
Dialogue: 0,0:28:07.68,0:28:08.66,Default,,0000,0000,0000,,不要啊
Dialogue: 0,0:28:09.68,0:28:11.66,Default,,0000,0000,0000,,不用照片的
Dialogue: 0,0:28:12.68,0:28:13.67,Default,,0000,0000,0000,,太美了
Dialogue: 0,0:28:19.69,0:28:20.67,Default,,0000,0000,0000,,看
Dialogue: 0,0:28:22.69,0:28:23.68,Default,,0000,0000,0000,,是我的了
Dialogue: 0,0:28:30.70,0:28:33.69,Default,,0000,0000,0000,,那今天你也是我的
Dialogue: 0,0:28:38.71,0:28:39.69,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:28:43.72,0:28:45.70,Default,,0000,0000,0000,,把胸部夹紧好吗
Dialogue: 0,0:28:47.72,0:28:48.70,Default,,0000,0000,0000,,这样
Dialogue: 0,0:28:48.72,0:28:49.70,Default,,0000,0000,0000,,可以吗
Dialogue: 0,0:28:49.72,0:28:50.70,Default,,0000,0000,0000,,试看看
Dialogue: 0,0:28:54.73,0:28:55.71,Default,,0000,0000,0000,,好棒
Dialogue: 0,0:28:55.73,0:28:57.71,Default,,0000,0000,0000,,这样
Dialogue: 0,0:28:58.73,0:28:59.71,Default,,0000,0000,0000,,太好了
Dialogue: 0,0:29:09.74,0:29:12.72,Default,,0000,0000,0000,,阿武都不曾赞美过我的身体
Dialogue: 0,0:29:13.75,0:29:14.73,Default,,0000,0000,0000,,今天我很开心
Dialogue: 0,0:29:15.75,0:29:16.73,Default,,0000,0000,0000,,真的吗
Dialogue: 0,0:29:16.75,0:29:17.73,Default,,0000,0000,0000,,你这麽夸我
Dialogue: 0,0:29:17.75,0:29:18.73,Default,,0000,0000,0000,,你都是优点
Dialogue: 0,0:29:22.75,0:29:23.74,Default,,0000,0000,0000,,看看
Dialogue: 0,0:29:36.77,0:29:37.75,Default,,0000,0000,0000,,忍不住了
Dialogue: 0,0:29:57.79,0:29:58.77,Default,,0000,0000,0000,,舔下面
Dialogue: 0,0:30:03.80,0:30:05.78,Default,,0000,0000,0000,,我还没洗乾净呢
Dialogue: 0,0:30:07.80,0:30:08.78,Default,,0000,0000,0000,,不要
Dialogue: 0,0:30:09.80,0:30:10.78,Default,,0000,0000,0000,,没事
Dialogue: 0,0:30:17.81,0:30:18.79,Default,,0000,0000,0000,,好臭
Dialogue: 0,0:30:19.81,0:30:20.79,Default,,0000,0000,0000,,害羞
