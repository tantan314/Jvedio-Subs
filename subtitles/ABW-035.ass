Dialogue: 0,0:00:40.22,0:00:43.22,Default,,0,0,0,,小学二年级吧
Dialogue: 0,0:00:43.22,0:00:45.36,Default,,0,0,0,,我会自己摸一下
Dialogue: 0,0:00:45.36,0:00:48.23,Default,,0,0,0,,我觉得有感觉吧
Dialogue: 0,0:00:51.20,0:00:54.20,Default,,0,0,0,,在床里面
Dialogue: 0,0:00:55.20,0:00:58.20,Default,,0,0,0,,夹住摩擦我起得
Dialogue: 0,0:00:58.20,0:01:01.21,Default,,0,0,0,,真的蛮舒服的
Dialogue: 0,0:01:02.21,0:01:05.21,Default,,0,0,0,,很开心
Dialogue: 0,0:01:14.22,0:01:17.22,Default,,0,0,0,,没有极限
Dialogue: 0,0:01:19.23,0:01:22.19,Default,,0,0,0,,比谁都还要贪心
Dialogue: 0,0:01:22.20,0:01:25.20,Default,,0,0,0,,比谁都 美丽
Dialogue: 0,0:01:28.20,0:01:31.20,Default,,0,0,0,,当个好女人
Dialogue: 0,0:01:32.21,0:01:35.11,Default,,0,0,0,,我理想的女性
Dialogue: 0,0:01:35.21,0:01:38.21,Default,,0,0,0,,美丽非常完美
Dialogue: 0,0:01:40.21,0:01:43.15,Default,,0,0,0,,想更美
Dialogue: 0,0:01:43.22,0:01:46.22,Default,,0,0,0,,完美的女性
Dialogue: 0,0:01:47.22,0:01:50.22,Default,,0,0,0,,追求妹妹有极限
Dialogue: 0,0:01:51.22,0:01:54.20,Default,,0,0,0,,内外都要
Dialogue: 0,0:01:54.20,0:01:57.20,Default,,0,0,0,,为什么拍摄
Dialogue: 0,0:01:57.20,0:02:00.20,Default,,0,0,0,,我有认识的人在拍摄
Dialogue: 0,0:02:03.20,0:02:06.20,Default,,0,0,0,,开始会怕\N
Dialogue: 0,0:02:07.21,0:02:10.21,Default,,0,0,0,,还是有点在意
Dialogue: 0,0:02:10.21,0:02:13.21,Default,,0,0,0,,不过我真的很喜欢情色\N
Dialogue: 0,0:02:15.21,0:02:18.22,Default,,0,0,0,,19岁开始
Dialogue: 0,0:02:19.22,0:02:22.22,Default,,0,0,0,,进去AV的世界
Dialogue: 0,0:02:27.23,0:02:30.40,Default,,0,0,0,,该说是天职吗?
Dialogue: 0,0:02:34.20,0:02:37.20,Default,,0,0,0,,我看了很多
Dialogue: 0,0:02:37.20,0:02:40.21,Default,,0,0,0,,很在乎别人怎么看
Dialogue: 0,0:02:40.21,0:02:43.21,Default,,0,0,0,,因为我四周的人
Dialogue: 0,0:02:44.21,0:02:47.21,Default,,0,0,0,,怎么说我
Dialogue: 0,0:02:48.21,0:02:51.22,Default,,0,0,0,,我会非常在意
Dialogue: 0,0:02:55.22,0:02:58.22,Default,,0,0,0,,所以我会去寻找看看
Dialogue: 0,0:03:03.20,0:03:06.20,Default,,0,0,0,,但是对自己没自信
Dialogue: 0,0:03:10.20,0:03:13.21,Default,,0,0,0,,学生时候男生几个
Dialogue: 0,0:03:14.21,0:03:17.21,Default,,0,0,0,,我会在意
Dialogue: 0,0:03:18.21,0:03:21.21,Default,,0,0,0,,自已的表现
Dialogue: 0,0:03:22.22,0:03:24.22,Default,,0,0,0,,每天都很在意
Dialogue: 0,0:03:24.22,0:03:27.22,Default,,0,0,0,,过着比较着每一天
Dialogue: 0,0:03:28.22,0:03:31.09,Default,,0,0,0,,自己被无视
Dialogue: 0,0:03:31.22,0:03:34.23,Default,,0,0,0,,朋友被说可爱
Dialogue: 0,0:03:39.20,0:03:41.77,Default,,0,0,0,,好像没有初恋
Dialogue: 0,0:03:41.77,0:03:44.20,Default,,0,0,0,,没交往啊
Dialogue: 0,0:03:44.20,0:03:47.21,Default,,0,0,0,,我喜欢他可是
Dialogue: 0,0:03:47.21,0:03:50.21,Default,,0,0,0,,他有女友了
Dialogue: 0,0:03:50.21,0:03:53.21,Default,,0,0,0,,希望可以当他喜欢的女孩\N
Dialogue: 0,0:03:55.21,0:03:58.22,Default,,0,0,0,,不甘心
Dialogue: 0,0:03:58.22,0:04:01.22,Default,,0,0,0,,第二次
Dialogue: 0,0:04:03.22,0:04:06.09,Default,,0,0,0,,角色扮演
Dialogue: 0,0:04:08.23,0:04:11.10,Default,,0,0,0,,我觉得女生外表
Dialogue: 0,0:04:13.50,0:04:15.20,Default,,0,0,0,,真的很重要
Dialogue: 0,0:04:15.20,0:04:18.20,Default,,0,0,0,,可是我没有那么有自信
Dialogue: 0,0:04:20.21,0:04:23.21,Default,,0,0,0,,但是性爱的话
Dialogue: 0,0:04:23.54,0:04:26.21,Default,,0,0,0,,可以获胜
Dialogue: 0,0:04:28.21,0:04:31.22,Default,,0,0,0,,要是做爱
Dialogue: 0,0:04:33.22,0:04:35.22,Default,,0,0,0,,我一定可以获胜
Dialogue: 0,0:04:35.22,0:04:38.22,Default,,0,0,0,,结果男生都是看脸
Dialogue: 0,0:04:41.23,0:04:44.20,Default,,0,0,0,,我现在的话
Dialogue: 0,0:04:45.20,0:04:48.57,Default,,0,0,0,,可以知道方向
Dialogue: 0,0:04:48.57,0:04:51.20,Default,,0,0,0,,谢谢告诉我
Dialogue: 0,0:04:53.21,0:04:56.21,Default,,0,0,0,,也是因为当初的选择
Dialogue: 0,0:04:58.21,0:05:01.21,Default,,0,0,0,,其实我很感谢
Dialogue: 0,0:05:05.48,0:05:08.22,Default,,0,0,0,,所谓的性爱
Dialogue: 0,0:05:10.22,0:05:13.23,Default,,0,0,0,,很开心
Dialogue: 0,0:05:15.23,0:05:18.20,Default,,0,0,0,,觉得很舒服
Dialogue: 0,0:05:20.20,0:05:23.20,Default,,0,0,0,,拍摄很冲击
Dialogue: 0,0:05:23.20,0:05:26.20,Default,,0,0,0,,我不太知道的魅力
Dialogue: 0,0:05:27.21,0:05:30.21,Default,,0,0,0,,真的差很多
Dialogue: 0,0:05:33.21,0:05:35.85,Default,,0,0,0,,我是我
Dialogue: 0,0:05:35.85,0:05:38.22,Default,,0,0,0,,很开心
Dialogue: 0,0:05:38.52,0:05:41.22,Default,,0,0,0,,身体很满足\N
Dialogue: 0,0:05:45.22,0:05:48.59,Default,,0,0,0,,真的很感谢
Dialogue: 0,0:05:48.59,0:05:51.40,Default,,0,0,0,,理想的性爱
Dialogue: 0,0:05:52.20,0:05:55.20,Default,,0,0,0,,舒服是最重要的
Dialogue: 0,0:05:58.20,0:06:01.21,Default,,0,0,0,,我太开心了
Dialogue: 0,0:06:01.21,0:06:04.21,Default,,0,0,0,,没问题吧
Dialogue: 0,0:06:04.21,0:06:07.21,Default,,0,0,0,,可以一起开心更好
Dialogue: 0,0:06:07.21,0:06:10.22,Default,,0,0,0,,这次没有脚本没有演技
Dialogue: 0,0:06:11.28,0:06:14.22,Default,,0,0,0,,蜜美杏
Dialogue: 0,0:06:15.22,0:06:18.22,Default,,0,0,0,,只是为了性爱的快乐
Dialogue: 0,0:06:20.23,0:06:23.20,Default,,0,0,0,,为了快乐的做爱
Dialogue: 0,0:06:45.22,0:06:48.12,Default,,0,0,0,,为什么喝水
Dialogue: 0,0:06:50.22,0:06:53.23,Default,,0,0,0,,感觉很怪
Dialogue: 0,0:06:54.23,0:06:57.20,Default,,0,0,0,,因为你说一对一
Dialogue: 0,0:06:58.20,0:07:01.20,Default,,0,0,0,,不太习惯
Dialogue: 0,0:07:03.20,0:07:06.20,Default,,0,0,0,,合作最好的对象呢?
Dialogue: 0,0:07:12.21,0:07:15.21,Default,,0,0,0,,出道时候
Dialogue: 0,0:07:15.21,0:07:18.22,Default,,0,0,0,,第一次
Dialogue: 0,0:07:18.22,0:07:21.22,Default,,0,0,0,,一定会记得吧
Dialogue: 0,0:07:23.49,0:07:26.22,Default,,0,0,0,,一起
Dialogue: 0,0:07:27.29,0:07:30.20,Default,,0,0,0,,真的
Dialogue: 0,0:07:30.20,0:07:33.20,Default,,0,0,0,,新鲜吗?
Dialogue: 0,0:07:33.20,0:07:36.20,Default,,0,0,0,,不一样
Dialogue: 0,0:07:37.20,0:07:40.21,Default,,0,0,0,,里面最靠近
Dialogue: 0,0:07:44.21,0:07:47.21,Default,,0,0,0,,没有演技的
Dialogue: 0,0:07:49.22,0:07:52.22,Default,,0,0,0,,很像本能
Dialogue: 0,0:07:55.22,0:07:58.22,Default,,0,0,0,,是自己的感觉
Dialogue: 0,0:08:05.20,0:08:08.20,Default,,0,0,0,,到了 谢谢
Dialogue: 0,0:08:14.21,0:08:17.21,Default,,0,0,0,,可以吗? 好的
Dialogue: 0,0:08:37.20,0:08:40.20,Default,,0,0,0,,几楼 6
Dialogue: 0,0:08:40.20,0:08:43.20,Default,,0,0,0,,好的
Dialogue: 0,0:08:45.20,0:08:48.21,Default,,0,0,0,,会紧张吗? 还好
Dialogue: 0,0:08:50.21,0:08:53.21,Default,,0,0,0,,还可以 谢谢
Dialogue: 0,0:08:58.22,0:09:01.22,Default,,0,0,0,,抱歉 请吧
Dialogue: 0,0:09:03.22,0:09:06.22,Default,,0,0,0,,紧张
Dialogue: 0,0:09:15.20,0:09:18.20,Default,,0,0,0,,你好
Dialogue: 0,0:09:18.20,0:09:21.21,Default,,0,0,0,,请多指教
Dialogue: 0,0:09:21.21,0:09:24.21,Default,,0,0,0,,我进来了哦
Dialogue: 0,0:09:24.21,0:09:29.21,Default,,0,0,0,,初次见面
Dialogue: 0,0:09:30.22,0:09:33.22,Default,,0,0,0,,你好 我是蜜美杏
Dialogue: 0,0:09:33.22,0:09:36.22,Default,,0,0,0,,抱歉 打扰了
Dialogue: 0,0:09:40.23,0:09:42.19,Default,,0,0,0,,好开心
Dialogue: 0,0:09:42.20,0:09:45.20,Default,,0,0,0,,请坐 抱歉
Dialogue: 0,0:09:45.20,0:09:48.20,Default,,0,0,0,,好厉害
Dialogue: 0,0:09:55.21,0:09:58.21,Default,,0,0,0,,接下来请多指教
Dialogue: 0,0:09:58.21,0:10:01.21,Default,,0,0,0,,再见
Dialogue: 0,0:10:08.22,0:10:11.22,Default,,0,0,0,,你好
Dialogue: 0,0:10:11.22,0:10:14.23,Default,,0,0,0,,第一次看
Dialogue: 0,0:10:14.23,0:10:17.20,Default,,0,0,0,,有点不习惯
Dialogue: 0,0:10:17.20,0:10:20.20,Default,,0,0,0,,有听说了吧
Dialogue: 0,0:10:20.20,0:10:23.20,Default,,0,0,0,,拍摄的事
Dialogue: 0,0:10:23.20,0:10:25.20,Default,,0,0,0,,对啊
Dialogue: 0,0:10:25.20,0:10:28.21,Default,,0,0,0,,我喜欢被动一点
Dialogue: 0,0:10:35.21,0:10:38.22,Default,,0,0,0,,这样啊
Dialogue: 0,0:10:38.22,0:10:41.22,Default,,0,0,0,,喝醉的话
Dialogue: 0,0:10:42.22,0:10:45.22,Default,,0,0,0,,也可以
Dialogue: 0,0:10:45.22,0:10:48.19,Default,,0,0,0,,放松一点
Dialogue: 0,0:10:51.46,0:10:54.20,Default,,0,0,0,,实际拍摄
Dialogue: 0,0:10:55.47,0:10:58.20,Default,,0,0,0,,有过吗?
Dialogue: 0,0:10:59.21,0:11:02.21,Default,,0,0,0,,很少
Dialogue: 0,0:11:03.21,0:11:06.21,Default,,0,0,0,,不太多
Dialogue: 0,0:11:06.21,0:11:08.21,Default,,0,0,0,,私下没有
Dialogue: 0,0:11:08.21,0:11:11.22,Default,,0,0,0,,工作呢？
Dialogue: 0,0:11:12.22,0:11:15.22,Default,,0,0,0,,一次吧
Dialogue: 0,0:11:15.22,0:11:18.22,Default,,0,0,0,,很少 对
Dialogue: 0,0:11:21.23,0:11:24.20,Default,,0,0,0,,是 总之
Dialogue: 0,0:11:24.20,0:11:27.20,Default,,0,0,0,,还没
Dialogue: 0,0:11:28.20,0:11:31.20,Default,,0,0,0,,那继续唷
Dialogue: 0,0:11:35.21,0:11:38.21,Default,,0,0,0,,可以的
Dialogue: 0,0:11:40.21,0:11:43.22,Default,,0,0,0,,怎么做好
Dialogue: 0,0:11:45.22,0:11:48.22,Default,,0,0,0,,我也不知道
Dialogue: 0,0:11:53.23,0:11:56.19,Default,,0,0,0,,你怎么开始
Dialogue: 0,0:11:58.20,0:12:01.20,Default,,0,0,0,,问一下喜欢什么
Dialogue: 0,0:12:04.30,0:12:07.21,Default,,0,0,0,,放这吧
Dialogue: 0,0:12:07.21,0:12:10.21,Default,,0,0,0,,抱歉 谢谢
Dialogue: 0,0:12:13.21,0:12:16.21,Default,,0,0,0,,喜欢这样啊
Dialogue: 0,0:12:17.22,0:12:20.22,Default,,0,0,0,,脚
Dialogue: 0,0:12:20.22,0:12:23.22,Default,,0,0,0,,靠近点好
Dialogue: 0,0:12:28.23,0:12:31.20,Default,,0,0,0,,你呢?
Dialogue: 0,0:12:33.20,0:12:36.20,Default,,0,0,0,,喜欢
Dialogue: 0,0:12:39.21,0:12:42.21,Default,,0,0,0,,味道
Dialogue: 0,0:12:43.21,0:12:46.21,Default,,0,0,0,,我看
Dialogue: 0,0:12:52.22,0:12:55.22,Default,,0,0,0,,真棒 谢谢
Dialogue: 0,0:12:58.22,0:13:01.23,Default,,0,0,0,,可以吗? 请吧
Dialogue: 0,0:13:01.23,0:13:04.20,Default,,0,0,0,,你要的话
Dialogue: 0,0:13:04.20,0:13:07.20,Default,,0,0,0,,讨厌
Dialogue: 0,0:13:08.20,0:13:11.20,Default,,0,0,0,,请摸 抱歉
Dialogue: 0,0:13:12.21,0:13:15.21,Default,,0,0,0,,好暖 真棒
Dialogue: 0,0:13:26.22,0:13:29.22,Default,,0,0,0,,好像
Dialogue: 0,0:13:30.29,0:13:33.23,Default,,0,0,0,,很久没牵手
Dialogue: 0,0:13:33.23,0:13:36.19,Default,,0,0,0,,真的
Dialogue: 0,0:13:38.20,0:13:41.20,Default,,0,0,0,,很棒
Dialogue: 0,0:13:43.20,0:13:46.20,Default,,0,0,0,,谢谢
Dialogue: 0,0:13:47.21,0:13:50.21,Default,,0,0,0,,这样亲也很好
Dialogue: 0,0:13:51.21,0:13:54.21,Default,,0,0,0,,对吧
Dialogue: 0,0:13:55.21,0:13:58.22,Default,,0,0,0,,不
Dialogue: 0,0:14:03.22,0:14:06.22,Default,,0,0,0,,亲到了
Dialogue: 0,0:14:10.20,0:14:13.20,Default,,0,0,0,,喜欢怎样的
Dialogue: 0,0:14:15.20,0:14:18.20,Default,,0,0,0,,亲的
Dialogue: 0,0:14:21.21,0:14:24.21,Default,,0,0,0,,很有趣
Dialogue: 0,0:14:27.21,0:14:30.22,Default,,0,0,0,,可以吧
Dialogue: 0,0:14:33.22,0:14:36.22,Default,,0,0,0,,这样的话
Dialogue: 0,0:14:38.22,0:14:41.23,Default,,0,0,0,,男生都可以讲
Dialogue: 0,0:14:43.20,0:14:46.20,Default,,0,0,0,,可以吗?
Dialogue: 0,0:14:51.20,0:14:54.21,Default,,0,0,0,,我都可以
Dialogue: 0,0:14:55.21,0:14:58.21,Default,,0,0,0,,放这
Dialogue: 0,0:15:00.21,0:15:03.22,Default,,0,0,0,,可以吧
