Dialogue: 0,0:00:28.60,0:00:46.51,Default,,0000,0000,0000,,（新闻）
Dialogue: 0,0:00:48.81,0:00:50.55,Default,,0000,0000,0000,,不好 要迟到了
Dialogue: 0,0:00:51.09,0:00:52.91,Default,,0000,0000,0000,,妈妈 得快点吃早饭
Dialogue: 0,0:00:53.10,0:00:54.23,Default,,0000,0000,0000,,我要吃饭
Dialogue: 0,0:00:55.47,0:00:57.55,Default,,0000,0000,0000,,我快迟到了 快点
Dialogue: 0,0:00:57.76,0:00:58.93,Default,,0000,0000,0000,,抱歉哦
Dialogue: 0,0:00:59.63,0:01:02.02,Default,,0000,0000,0000,,怎么了啊 慌里慌张的
Dialogue: 0,0:01:02.37,0:01:05.26,Default,,0000,0000,0000,,从今天要开始复习 马上要考试了
Dialogue: 0,0:01:05.99,0:01:07.81,Default,,0000,0000,0000,,是吗 加油哦
Dialogue: 0,0:01:12.59,0:01:14.77,Default,,0000,0000,0000,,姐姐吃相真差呢
Dialogue: 0,0:01:15.76,0:01:16.44,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:01:18.62,0:01:20.65,Default,,0000,0000,0000,,你看 都沾脸上了
Dialogue: 0,0:01:22.32,0:01:24.22,Default,,0000,0000,0000,,会被男生讨厌哦
Dialogue: 0,0:01:25.83,0:01:27.66,Default,,0000,0000,0000,,早餐还是慢慢儿吃吧
Dialogue: 0,0:01:29.88,0:01:31.55,Default,,0000,0000,0000,,可没那时间了
Dialogue: 0,0:01:33.71,0:01:34.43,Default,,0000,0000,0000,,我走了
Dialogue: 0,0:01:34.43,0:01:35.44,Default,,0000,0000,0000,,姐姐 你的拍子
Dialogue: 0,0:01:37.18,0:01:38.14,Default,,0000,0000,0000,,那我走了
Dialogue: 0,0:01:38.59,0:01:41.26,Default,,0000,0000,0000,,路上小心哦
Dialogue: 0,0:01:48.03,0:01:49.12,Default,,0000,0000,0000,,没问题吧
Dialogue: 0,0:01:56.39,0:01:57.50,Default,,0000,0000,0000,,我出门了
Dialogue: 0,0:02:14.15,0:02:15.48,Default,,0000,0000,0000,,我们搬到这儿都一个月了吧
Dialogue: 0,0:02:16.80,0:02:18.06,Default,,0000,0000,0000,,都一个月了吧
Dialogue: 0,0:02:19.83,0:02:20.93,Default,,0000,0000,0000,,好像是呢
Dialogue: 0,0:02:24.34,0:02:25.30,Default,,0000,0000,0000,,已经没事了
Dialogue: 0,0:02:26.96,0:02:27.72,Default,,0000,0000,0000,,什么
Dialogue: 0,0:02:30.51,0:02:31.21,Default,,0000,0000,0000,,没什么
Dialogue: 0,0:02:39.86,0:02:40.80,Default,,0000,0000,0000,,亲爱的
Dialogue: 0,0:02:42.50,0:02:43.42,Default,,0000,0000,0000,,你变了呢
Dialogue: 0,0:02:46.80,0:02:47.45,Default,,0000,0000,0000,,因为
Dialogue: 0,0:02:48.32,0:02:49.76,Default,,0000,0000,0000,,自从搬来这儿
Dialogue: 0,0:02:52.05,0:02:54.22,Default,,0000,0000,0000,,嘴里就没总挂着工作了
Dialogue: 0,0:02:56.54,0:02:57.13,Default,,0000,0000,0000,,你以前
Dialogue: 0,0:02:58.09,0:03:00.68,Default,,0000,0000,0000,,都没时间和家人一起吃饭呢
Dialogue: 0,0:03:10.03,0:03:10.77,Default,,0000,0000,0000,,从今以后
Dialogue: 0,0:03:11.39,0:03:13.95,Default,,0000,0000,0000,,我会好好陪伴家人的
Dialogue: 0,0:03:21.56,0:03:23.47,Default,,0000,0000,0000,,以前真是对不住你们
Dialogue: 0,0:03:24.32,0:03:26.41,Default,,0000,0000,0000,,完全顾不上家里
Dialogue: 0,0:03:27.89,0:03:31.11,Default,,0000,0000,0000,,步美和小舞能健康成长
Dialogue: 0,0:03:35.02,0:03:35.90,Default,,0000,0000,0000,,都是多亏了你呢
Dialogue: 0,0:03:36.84,0:03:37.78,Default,,0000,0000,0000,,谢谢你 裕子
Dialogue: 0,0:03:39.54,0:03:40.40,Default,,0000,0000,0000,,亲爱的
Dialogue: 0,0:03:41.31,0:03:41.89,Default,,0000,0000,0000,,裕子
Dialogue: 0,0:03:49.61,0:03:50.80,Default,,0000,0000,0000,,哇 秀恩爱
Dialogue: 0,0:03:53.26,0:03:55.25,Default,,0000,0000,0000,,要迟到了哦 快去上学
Dialogue: 0,0:03:56.09,0:03:56.68,Default,,0000,0000,0000,,是
Dialogue: 0,0:04:12.60,0:04:13.13,Default,,0000,0000,0000,,亲爱的
Dialogue: 0,0:04:14.80,0:04:16.26,Default,,0000,0000,0000,,今晚来庆祝一下吧
Dialogue: 0,0:04:16.53,0:04:17.60,Default,,0000,0000,0000,,纪念搬家一个月
Dialogue: 0,0:04:21.41,0:04:23.63,Default,,0000,0000,0000,,我会做好吃的 要快点回家哦
Dialogue: 0,0:04:24.55,0:04:25.72,Default,,0000,0000,0000,,知道了 我先走了
Dialogue: 0,0:04:26.26,0:04:27.08,Default,,0000,0000,0000,,路上小心
Dialogue: 0,0:05:14.32,0:05:14.85,Default,,0000,0000,0000,,若头
Dialogue: 0,0:05:15.63,0:05:16.49,Default,,0000,0000,0000,,是小塚
Dialogue: 0,0:05:19.61,0:05:20.41,Default,,0000,0000,0000,,是我
Dialogue: 0,0:05:21.61,0:05:22.72,Default,,0000,0000,0000,,找到藤泽了
Dialogue: 0,0:05:24.44,0:05:25.48,Default,,0000,0000,0000,,你确定吗
Dialogue: 0,0:05:26.89,0:05:27.39,Default,,0000,0000,0000,,是的
Dialogue: 0,0:05:28.55,0:05:30.19,Default,,0000,0000,0000,,那家伙过的还挺滋润
Dialogue: 0,0:05:33.01,0:05:34.06,Default,,0000,0000,0000,,藤泽这货
Dialogue: 0,0:05:35.02,0:05:36.48,Default,,0000,0000,0000,,听说现在过得挺逍遥啊
Dialogue: 0,0:05:44.33,0:05:45.37,Default,,0000,0000,0000,,他家人也在一起
Dialogue: 0,0:05:46.51,0:05:48.94,Default,,0000,0000,0000,,老婆女儿 都是上等货呢
Dialogue: 0,0:05:49.75,0:05:51.21,Default,,0000,0000,0000,,不许擅自行动
Dialogue: 0,0:05:52.58,0:05:54.40,Default,,0000,0000,0000,,在我们感到之前你先等着
Dialogue: 0,0:05:55.42,0:05:55.90,Default,,0000,0000,0000,,是
Dialogue: 0,0:06:00.57,0:06:01.82,Default,,0000,0000,0000,,联络大哥
Dialogue: 0,0:06:13.86,0:06:14.38,Default,,0000,0000,0000,,大哥
Dialogue: 0,0:06:15.96,0:06:17.92,Default,,0000,0000,0000,,我们招到藤泽那家伙了
Dialogue: 0,0:06:20.25,0:06:20.62,Default,,0000,0000,0000,,是
Dialogue: 0,0:06:22.22,0:06:23.43,Default,,0000,0000,0000,,恭候大哥
Dialogue: 0,0:07:36.40,0:07:43.91,Default,,0000,0000,0000,,{\pos(358,42)}（母女之牢 地狱的开端）
Dialogue: 0,0:08:07.67,0:08:08.49,Default,,0000,0000,0000,,我回来了
Dialogue: 0,0:08:09.55,0:08:10.42,Default,,0000,0000,0000,,回来啦
Dialogue: 0,0:08:12.15,0:08:13.32,Default,,0000,0000,0000,,社团活动没去吗
Dialogue: 0,0:08:13.78,0:08:16.03,Default,,0000,0000,0000,,因为明天有考试 就延到下周了
Dialogue: 0,0:08:17.21,0:08:19.67,Default,,0000,0000,0000,,我先去学习了 饭做好了叫我哦
Dialogue: 0,0:08:21.58,0:08:22.64,Default,,0000,0000,0000,,今天会很丰盛呢
Dialogue: 0,0:08:23.46,0:08:24.18,Default,,0000,0000,0000,,请期待哦
Dialogue: 0,0:08:25.77,0:08:26.49,Default,,0000,0000,0000,,真的吗
Dialogue: 0,0:08:27.60,0:08:29.09,Default,,0000,0000,0000,,小舞想吃蛋包饭
Dialogue: 0,0:08:29.43,0:08:32.47,Default,,0000,0000,0000,,妈妈会做的 加油学习吧
Dialogue: 0,0:08:32.77,0:08:33.36,Default,,0000,0000,0000,,好的
Dialogue: 0,0:08:56.24,0:08:56.66,Default,,0000,0000,0000,,头儿
Dialogue: 0,0:08:57.59,0:08:58.27,Default,,0000,0000,0000,,就是这儿
Dialogue: 0,0:09:13.94,0:09:14.88,Default,,0000,0000,0000,,这是他女儿
Dialogue: 0,0:09:29.66,0:09:31.08,Default,,0000,0000,0000,,我回来了 妈妈
Dialogue: 0,0:09:31.76,0:09:33.21,Default,,0000,0000,0000,,步美你回来啦
Dialogue: 0,0:09:35.64,0:09:37.48,Default,,0000,0000,0000,,今天真是累坏了呢
Dialogue: 0,0:09:40.07,0:09:42.48,Default,,0000,0000,0000,,看起来好好吃 真丰盛呢
Dialogue: 0,0:09:43.75,0:09:46.09,Default,,0000,0000,0000,,因为搬过来刚好一个月了
Dialogue: 0,0:09:46.50,0:09:48.08,Default,,0000,0000,0000,,所以想庆祝一下呢
Dialogue: 0,0:09:49.31,0:09:50.50,Default,,0000,0000,0000,,是吗
Dialogue: 0,0:09:50.73,0:09:52.17,Default,,0000,0000,0000,,都过这么久了呢
Dialogue: 0,0:09:55.61,0:09:58.00,Default,,0000,0000,0000,,新学校怎么样 交到朋友了吗
Dialogue: 0,0:09:59.26,0:10:01.36,Default,,0000,0000,0000,,在社团里交到了好朋友
Dialogue: 0,0:10:45.13,0:10:47.96,Default,,0000,0000,0000,,我们家周围再热闹点就好了呢
Dialogue: 0,0:10:48.41,0:10:50.07,Default,,0000,0000,0000,,周围都还是些空房子
Dialogue: 0,0:10:51.37,0:10:52.15,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:10:53.79,0:10:56.35,Default,,0000,0000,0000,,这一带是刚落成的住宅街呢
Dialogue: 0,0:10:58.14,0:10:59.41,Default,,0000,0000,0000,,住户还会增加的
Dialogue: 0,0:11:05.67,0:11:06.25,Default,,0000,0000,0000,,你们
Dialogue: 0,0:11:06.46,0:11:06.96,Default,,0000,0000,0000,,快逃啊
Dialogue: 0,0:11:19.70,0:11:20.86,Default,,0000,0000,0000,,亲爱的
Dialogue: 0,0:11:23.22,0:11:24.07,Default,,0000,0000,0000,,爸爸
Dialogue: 0,0:11:25.71,0:11:26.82,Default,,0000,0000,0000,,爸爸
Dialogue: 0,0:11:27.71,0:11:28.39,Default,,0000,0000,0000,,亲爱的
Dialogue: 0,0:11:29.52,0:11:30.18,Default,,0000,0000,0000,,不
Dialogue: 0,0:11:32.50,0:11:33.34,Default,,0000,0000,0000,,亲爱的
Dialogue: 0,0:11:38.77,0:11:43.40,Default,,0000,0000,0000,,爸爸\N亲爱的
Dialogue: 0,0:11:51.30,0:11:52.66,Default,,0000,0000,0000,,请别杀我
Dialogue: 0,0:11:59.00,0:12:00.31,Default,,0000,0000,0000,,不会杀你的 女人
Dialogue: 0,0:12:10.66,0:12:11.59,Default,,0000,0000,0000,,3亿日元的
Dialogue: 0,0:12:12.25,0:12:13.15,Default,,0000,0000,0000,,借款
Dialogue: 0,0:12:15.29,0:12:16.05,Default,,0000,0000,0000,,怎么
Dialogue: 0,0:12:16.74,0:12:18.76,Default,,0000,0000,0000,,老公公司倒闭了都不知道吗
Dialogue: 0,0:12:20.19,0:12:21.04,Default,,0000,0000,0000,,这小子
Dialogue: 0,0:12:21.55,0:12:23.30,Default,,0000,0000,0000,,居然借钱不还
Dialogue: 0,0:12:28.31,0:12:30.52,Default,,0000,0000,0000,,还以为逃哪儿去了
Dialogue: 0,0:12:31.35,0:12:34.51,Default,,0000,0000,0000,,居然明目张胆地住在这么好的房子里啊
Dialogue: 0,0:12:35.86,0:12:37.86,Default,,0000,0000,0000,,而且都还过了一个月了
Dialogue: 0,0:12:41.24,0:12:42.26,Default,,0000,0000,0000,,亲爱的
Dialogue: 0,0:12:53.93,0:12:56.45,Default,,0000,0000,0000,,钱我们会慢慢回收
Dialogue: 0,0:12:57.62,0:12:59.56,Default,,0000,0000,0000,,首先让我们尝尝
Dialogue: 0,0:13:00.12,0:13:01.74,Default,,0000,0000,0000,,抵押品的滋味儿吧
Dialogue: 0,0:13:07.44,0:13:08.96,Default,,0000,0000,0000,,给我起来
Dialogue: 0,0:13:09.79,0:13:10.93,Default,,0000,0000,0000,,妈妈
Dialogue: 0,0:13:18.41,0:13:20.32,Default,,0000,0000,0000,,放开我妈妈
Dialogue: 0,0:13:22.16,0:13:23.22,Default,,0000,0000,0000,,妈妈
Dialogue: 0,0:13:33.22,0:13:34.51,Default,,0000,0000,0000,,妈妈
Dialogue: 0,0:13:37.03,0:13:38.40,Default,,0000,0000,0000,,吵死了 把她嘴堵上
Dialogue: 0,0:13:39.63,0:13:41.01,Default,,0000,0000,0000,,来吧来吧
Dialogue: 0,0:13:41.55,0:13:42.82,Default,,0000,0000,0000,,妈妈
Dialogue: 0,0:13:55.53,0:13:58.79,Default,,0000,0000,0000,,不要\N夫人 您就乖乖从了吧
Dialogue: 0,0:14:01.13,0:14:03.30,Default,,0000,0000,0000,,给我老实点儿
Dialogue: 0,0:14:11.12,0:14:11.90,Default,,0000,0000,0000,,脱了
Dialogue: 0,0:14:16.75,0:14:17.77,Default,,0000,0000,0000,,住手
Dialogue: 0,0:14:28.29,0:14:30.15,Default,,0000,0000,0000,,脱啊
Dialogue: 0,0:14:30.19,0:14:32.14,Default,,0000,0000,0000,,不准碍事
Dialogue: 0,0:14:34.36,0:14:35.69,Default,,0000,0000,0000,,老实脱了吧
Dialogue: 0,0:14:35.69,0:14:38.25,Default,,0000,0000,0000,,住手\N脱啊
Dialogue: 0,0:14:44.94,0:14:47.86,Default,,0000,0000,0000,,快脱了给我们看
Dialogue: 0,0:14:51.24,0:14:52.20,Default,,0000,0000,0000,,不要
Dialogue: 0,0:14:53.74,0:14:55.54,Default,,0000,0000,0000,,妈妈
Dialogue: 0,0:14:55.99,0:14:56.90,Default,,0000,0000,0000,,不要
Dialogue: 0,0:14:57.32,0:14:59.34,Default,,0000,0000,0000,,妈妈
Dialogue: 0,0:15:01.52,0:15:02.74,Default,,0000,0000,0000,,脱
Dialogue: 0,0:15:07.08,0:15:08.26,Default,,0000,0000,0000,,奶子好赞
Dialogue: 0,0:15:46.03,0:15:46.99,Default,,0000,0000,0000,,不要啊
Dialogue: 0,0:15:47.75,0:15:49.73,Default,,0000,0000,0000,,不错啊 骚屄好骚啊
Dialogue: 0,0:15:53.93,0:15:55.10,Default,,0000,0000,0000,,住手
Dialogue: 0,0:15:57.03,0:16:01.39,Default,,0000,0000,0000,,不准动
Dialogue: 0,0:16:09.27,0:16:10.39,Default,,0000,0000,0000,,舒服吧
Dialogue: 0,0:16:12.10,0:16:14.97,Default,,0000,0000,0000,,舒服吧 舒不舒服啊
Dialogue: 0,0:16:16.85,0:16:18.38,Default,,0000,0000,0000,,住手啊
Dialogue: 0,0:16:23.68,0:16:25.04,Default,,0000,0000,0000,,再叫好听点儿
Dialogue: 0,0:16:26.70,0:16:28.96,Default,,0000,0000,0000,,住手
Dialogue: 0,0:16:30.16,0:16:32.06,Default,,0000,0000,0000,,主动一点儿如何啊
Dialogue: 0,0:16:48.95,0:16:50.47,Default,,0000,0000,0000,,也给女儿看看吧
Dialogue: 0,0:16:52.08,0:16:53.08,Default,,0000,0000,0000,,给女儿看看
Dialogue: 0,0:16:54.13,0:16:54.96,Default,,0000,0000,0000,,不要
Dialogue: 0,0:17:08.45,0:17:09.50,Default,,0000,0000,0000,,牛逼
Dialogue: 0,0:17:13.72,0:17:14.65,Default,,0000,0000,0000,,湿了啊
Dialogue: 0,0:17:18.12,0:17:19.42,Default,,0000,0000,0000,,爽不爽啊
Dialogue: 0,0:17:20.42,0:17:22.44,Default,,0000,0000,0000,,怎么回事啊 夫人
Dialogue: 0,0:17:22.85,0:17:23.66,Default,,0000,0000,0000,,爽不爽啊
Dialogue: 0,0:17:33.64,0:17:34.64,Default,,0000,0000,0000,,这么湿啊
Dialogue: 0,0:17:37.88,0:17:41.78,Default,,0000,0000,0000,,这女的就算死了老公还能高潮啊
Dialogue: 0,0:17:44.68,0:17:46.07,Default,,0000,0000,0000,,真的啊
Dialogue: 0,0:17:47.77,0:17:48.74,Default,,0000,0000,0000,,四肢着地
Dialogue: 0,0:17:53.39,0:17:54.31,Default,,0000,0000,0000,,不要
Dialogue: 0,0:18:24.73,0:18:27.46,Default,,0000,0000,0000,,才刚开始哦\N张嘴啊
Dialogue: 0,0:18:30.23,0:18:33.54,Default,,0000,0000,0000,,快张嘴
Dialogue: 0,0:18:42.08,0:18:45.20,Default,,0000,0000,0000,,张嘴 吃鸡巴
Dialogue: 0,0:18:46.36,0:18:47.71,Default,,0000,0000,0000,,要再吃进去些
Dialogue: 0,0:18:54.44,0:18:55.24,Default,,0000,0000,0000,,好吃吧
Dialogue: 0,0:18:57.90,0:18:59.10,Default,,0000,0000,0000,,不准吐出来哦
Dialogue: 0,0:19:02.05,0:19:04.11,Default,,0000,0000,0000,,不听话就动你女儿哦
Dialogue: 0,0:19:04.75,0:19:05.82,Default,,0000,0000,0000,,好主意
Dialogue: 0,0:19:05.85,0:19:08.48,Default,,0000,0000,0000,,认真点儿吃
Dialogue: 0,0:19:10.54,0:19:12.16,Default,,0000,0000,0000,,吐你妹啊
Dialogue: 0,0:19:12.33,0:19:14.88,Default,,0000,0000,0000,,好了 我帮你 吃吧
Dialogue: 0,0:19:15.24,0:19:16.87,Default,,0000,0000,0000,,你不是很喜欢吗
Dialogue: 0,0:19:25.44,0:19:26.91,Default,,0000,0000,0000,,龟头有露出来了哦
Dialogue: 0,0:19:34.94,0:19:36.66,Default,,0000,0000,0000,,好淫乱的妈妈啊
Dialogue: 0,0:19:37.93,0:19:38.99,Default,,0000,0000,0000,,不准偷懒哦
Dialogue: 0,0:19:39.47,0:19:41.07,Default,,0000,0000,0000,,你看你吃得多香啊
Dialogue: 0,0:19:44.65,0:19:46.21,Default,,0000,0000,0000,,这女的好贪婪啊
Dialogue: 0,0:19:47.38,0:19:48.85,Default,,0000,0000,0000,,屁眼也这么淫荡
Dialogue: 0,0:19:52.14,0:19:53.65,Default,,0000,0000,0000,,爽歪歪哟
Dialogue: 0,0:19:56.85,0:19:59.41,Default,,0000,0000,0000,,蛋蛋也舔舔吧
Dialogue: 0,0:20:02.14,0:20:03.89,Default,,0000,0000,0000,,认真点儿
Dialogue: 0,0:20:06.21,0:20:09.41,Default,,0000,0000,0000,,把舌头伸出来
Dialogue: 0,0:20:12.77,0:20:14.60,Default,,0000,0000,0000,,舔啊
Dialogue: 0,0:20:17.54,0:20:19.42,Default,,0000,0000,0000,,没吃过吧 吃啊
Dialogue: 0,0:20:20.54,0:20:23.45,Default,,0000,0000,0000,,要不让女儿也试试吗
Dialogue: 0,0:20:23.50,0:20:24.49,Default,,0000,0000,0000,,继续
Dialogue: 0,0:20:28.52,0:20:30.02,Default,,0000,0000,0000,,让你女儿也尝尝吧
Dialogue: 0,0:20:34.95,0:20:36.27,Default,,0000,0000,0000,,别停啊
