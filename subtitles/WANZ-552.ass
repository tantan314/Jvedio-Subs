Dialogue: 0,0:02:16.65,0:02:19.31,Default,,0000,0000,0000,,什么呀
Dialogue: 0,0:02:19.31,0:02:22.35,Default,,0000,0000,0000,,不要打扰呀
Dialogue: 0,0:02:22.48,0:02:25.45,Default,,0000,0000,0000,,这样很无聊呢
Dialogue: 0,0:02:25.45,0:02:28.51,Default,,0000,0000,0000,,你会呀？教我吧
Dialogue: 0,0:02:40.45,0:02:43.41,Default,,0000,0000,0000,,这什么？
Dialogue: 0,0:02:43.58,0:02:46.41,Default,,0000,0000,0000,,不要弄啦
Dialogue: 0,0:02:50.51,0:02:53.38,Default,,0000,0000,0000,,我都不懂呢
Dialogue: 0,0:02:57.58,0:03:00.48,Default,,0000,0000,0000,,你会教我吧
Dialogue: 0,0:03:01.71,0:03:04.51,Default,,0000,0000,0000,,这样不能专心呀
Dialogue: 0,0:03:08.51,0:03:11.41,Default,,0000,0000,0000,,这样会被骂啦
Dialogue: 0,0:03:12.31,0:03:15.61,Default,,0000,0000,0000,,不要这样啦
Dialogue: 0,0:03:23.71,0:03:26.58,Default,,0000,0000,0000,,好无聊啊
Dialogue: 0,0:03:26.58,0:03:30.48,Default,,0000,0000,0000,,还是去玩吧
Dialogue: 0,0:03:36.45,0:03:39.48,Default,,0000,0000,0000,,啊！对了！
Dialogue: 0,0:03:39.48,0:03:42.55,Default,,0000,0000,0000,,有个好玩的东西
Dialogue: 0,0:03:48.38,0:03:51.38,Default,,0000,0000,0000,,什么？
Dialogue: 0,0:03:51.38,0:03:54.31,Default,,0000,0000,0000,,很可爱吧
Dialogue: 0,0:03:54.31,0:03:57.38,Default,,0000,0000,0000,,为什么带这个？
Dialogue: 0,0:03:58.45,0:04:01.35,Default,,0000,0000,0000,,很有趣哟
Dialogue: 0,0:04:01.35,0:04:04.41,Default,,0000,0000,0000,,搞什么呀？
Dialogue: 0,0:04:04.41,0:04:07.38,Default,,0000,0000,0000,,你看着吧
Dialogue: 0,0:04:20.35,0:04:23.48,Default,,0000,0000,0000,,再一次
Dialogue: 0,0:04:24.41,0:04:27.75,Default,,0000,0000,0000,,套不到呢
Dialogue: 0,0:04:46.58,0:04:49.71,Default,,0000,0000,0000,,真是的
Dialogue: 0,0:04:49.71,0:04:54.41,Default,,0000,0000,0000,,喂
Dialogue: 0,0:04:54.41,0:04:56.38,Default,,0000,0000,0000,,如何？
Dialogue: 0,0:04:56.38,0:05:00.78,Default,,0000,0000,0000,,什么？还问呀
Dialogue: 0,0:05:04.51,0:05:07.38,Default,,0000,0000,0000,,我很无聊
Dialogue: 0,0:05:07.38,0:05:10.41,Default,,0000,0000,0000,,这样不能专心呀
Dialogue: 0,0:05:10.41,0:05:13.45,Default,,0000,0000,0000,,为什么？
Dialogue: 0,0:05:17.45,0:05:21.11,Default,,0000,0000,0000,,我很无聊呀
Dialogue: 0,0:05:22.58,0:05:25.38,Default,,0000,0000,0000,,一起玩呀
Dialogue: 0,0:05:25.38,0:05:28.31,Default,,0000,0000,0000,,不是玩的时间
Dialogue: 0,0:05:33.31,0:05:36.31,Default,,0000,0000,0000,,比起读书
Dialogue: 0,0:05:36.38,0:05:39.58,Default,,0000,0000,0000,,来一起开心吧
Dialogue: 0,0:05:43.55,0:05:46.35,Default,,0000,0000,0000,,来玩呀
Dialogue: 0,0:05:54.35,0:05:57.65,Default,,0000,0000,0000,,一起玩呀
Dialogue: 0,0:05:57.65,0:06:17.45,Default,,0000,0000,0000,,你脸压到我胸部了
Dialogue: 0,0:06:17.45,0:06:20.25,Default,,0000,0000,0000,,是你压我呀
Dialogue: 0,0:06:20.25,0:06:23.38,Default,,0000,0000,0000,,我没有呀
Dialogue: 0,0:06:24.61,0:06:26.31,Default,,0000,0000,0000,,住手
Dialogue: 0,0:06:26.31,0:06:29.38,Default,,0000,0000,0000,,你摸了
Dialogue: 0,0:06:30.31,0:06:33.41,Default,,0000,0000,0000,,你很色
Dialogue: 0,0:06:33.41,0:06:36.45,Default,,0000,0000,0000,,不是我吧
Dialogue: 0,0:06:46.38,0:06:49.48,Default,,0000,0000,0000,,这什么？
Dialogue: 0,0:06:49.48,0:06:52.38,Default,,0000,0000,0000,,什么呀？
Dialogue: 0,0:06:57.48,0:07:00.35,Default,,0000,0000,0000,,都硬了
Dialogue: 0,0:07:00.35,0:07:02.35,Default,,0000,0000,0000,,没有
Dialogue: 0,0:07:02.35,0:07:05.51,Default,,0000,0000,0000,,都碰到了
Dialogue: 0,0:07:06.41,0:07:09.38,Default,,0000,0000,0000,,住手啦
Dialogue: 0,0:07:16.45,0:07:19.38,Default,,0000,0000,0000,,你做什么？
Dialogue: 0,0:07:19.38,0:07:23.35,Default,,0000,0000,0000,,想看吧
Dialogue: 0,0:07:24.41,0:07:27.38,Default,,0000,0000,0000,,会痛啦
Dialogue: 0,0:07:27.38,0:07:30.38,Default,,0000,0000,0000,,是痛吗？
Dialogue: 0,0:07:30.38,0:07:33.41,Default,,0000,0000,0000,,都硬起来了
Dialogue: 0,0:07:44.41,0:07:47.48,Default,,0000,0000,0000,,想跟我玩吗？
Dialogue: 0,0:07:48.45,0:07:51.55,Default,,0000,0000,0000,,这样子 都硬咯
Dialogue: 0,0:07:54.58,0:07:57.88,Default,,0000,0000,0000,,我还想要玩呢
Dialogue: 0,0:08:04.38,0:08:07.48,Default,,0000,0000,0000,,看内裤会兴奋呀？
Dialogue: 0,0:08:12.38,0:08:15.41,Default,,0000,0000,0000,,刚刚都看了
Dialogue: 0,0:08:15.41,0:08:18.38,Default,,0000,0000,0000,,才没有
Dialogue: 0,0:08:19.45,0:08:22.48,Default,,0000,0000,0000,,碰到了
Dialogue: 0,0:08:24.41,0:08:27.38,Default,,0000,0000,0000,,都硬成这样了
Dialogue: 0,0:08:28.41,0:08:31.38,Default,,0000,0000,0000,,来做舒服的事
Dialogue: 0,0:08:31.71,0:08:34.41,Default,,0000,0000,0000,,舒服的？
Dialogue: 0,0:08:34.41,0:08:37.45,Default,,0000,0000,0000,,然后再读书吧
Dialogue: 0,0:08:48.48,0:08:51.55,Default,,0000,0000,0000,,变很硬了唷
Dialogue: 0,0:08:53.41,0:08:56.38,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:08:58.45,0:09:01.38,Default,,0000,0000,0000,,很爽吗？
Dialogue: 0,0:09:02.38,0:09:05.45,Default,,0000,0000,0000,,这样子吗？
Dialogue: 0,0:09:06.45,0:09:09.35,Default,,0000,0000,0000,,再来
Dialogue: 0,0:09:13.45,0:09:16.81,Default,,0000,0000,0000,,来看看
Dialogue: 0,0:09:16.81,0:09:19.15,Default,,0000,0000,0000,,真棒呢
Dialogue: 0,0:09:21.65,0:09:23.35,Default,,0000,0000,0000,,这个是什么
Dialogue: 0,0:09:26.35,0:09:29.75,Default,,0000,0000,0000,,这个是什么？
Dialogue: 0,0:09:31.48,0:09:34.81,Default,,0000,0000,0000,,为什么那么涨呢？
Dialogue: 0,0:09:41.41,0:09:44.55,Default,,0000,0000,0000,,一直抽动呢
Dialogue: 0,0:09:48.48,0:09:51.45,Default,,0000,0000,0000,,要看咯
Dialogue: 0,0:09:56.45,0:09:59.35,Default,,0000,0000,0000,,住手
Dialogue: 0,0:09:59.35,0:10:02.98,Default,,0000,0000,0000,,果然变大了
Dialogue: 0,0:10:12.55,0:10:18.05,Default,,0000,0000,0000,,你肉棒是这样呀？
Dialogue: 0,0:10:19.35,0:10:23.48,Default,,0000,0000,0000,,很可爱的肉棒呢
Dialogue: 0,0:10:31.48,0:10:34.48,Default,,0000,0000,0000,,住手啦
Dialogue: 0,0:10:36.41,0:10:39.78,Default,,0000,0000,0000,,来做好玩的事情
Dialogue: 0,0:10:54.55,0:10:57.45,Default,,0000,0000,0000,,舒服吗？
Dialogue: 0,0:10:57.45,0:11:00.38,Default,,0000,0000,0000,,有碰到吧？
Dialogue: 0,0:11:05.35,0:11:08.65,Default,,0000,0000,0000,,舒服吗？
Dialogue: 0,0:11:09.41,0:11:12.35,Default,,0000,0000,0000,,这样子
Dialogue: 0,0:11:15.45,0:11:18.35,Default,,0000,0000,0000,,肉棒很硬呢
Dialogue: 0,0:11:18.35,0:11:21.35,Default,,0000,0000,0000,,喜欢这样呀？
Dialogue: 0,0:11:22.51,0:11:25.38,Default,,0000,0000,0000,,是喜欢
Dialogue: 0,0:11:25.38,0:11:28.35,Default,,0000,0000,0000,,果然呢
Dialogue: 0,0:11:28.35,0:11:31.35,Default,,0000,0000,0000,,那就继续吧
Dialogue: 0,0:11:32.45,0:11:35.78,Default,,0000,0000,0000,,很舒服吧？
Dialogue: 0,0:11:37.55,0:11:40.41,Default,,0000,0000,0000,,让你更舒服
Dialogue: 0,0:11:53.51,0:11:56.41,Default,,0000,0000,0000,,舒服吗？
Dialogue: 0,0:12:00.61,0:12:02.35,Default,,0000,0000,0000,,真棒
Dialogue: 0,0:12:02.35,0:12:05.35,Default,,0000,0000,0000,,好硬哟
Dialogue: 0,0:12:07.38,0:12:11.08,Default,,0000,0000,0000,,很爽吧
Dialogue: 0,0:12:24.41,0:12:27.55,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:12:31.51,0:12:34.35,Default,,0000,0000,0000,,真厉害
Dialogue: 0,0:12:38.45,0:12:41.35,Default,,0000,0000,0000,,真可爱
Dialogue: 0,0:12:42.51,0:12:45.65,Default,,0000,0000,0000,,再继续做吧
Dialogue: 0,0:12:49.48,0:12:52.55,Default,,0000,0000,0000,,这样很厉害吧？
Dialogue: 0,0:12:57.38,0:13:00.41,Default,,0000,0000,0000,,好像插入一样
Dialogue: 0,0:13:06.48,0:13:09.35,Default,,0000,0000,0000,,可以这样呢
Dialogue: 0,0:13:10.58,0:13:13.31,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:13:13.31,0:13:16.35,Default,,0000,0000,0000,,很棒的呀
Dialogue: 0,0:13:48.51,0:13:51.51,Default,,0000,0000,0000,,这样很舒服吧？
Dialogue: 0,0:14:00.41,0:14:03.38,Default,,0000,0000,0000,,弄到了
Dialogue: 0,0:14:10.38,0:14:13.31,Default,,0000,0000,0000,,乳头都硬了
Dialogue: 0,0:14:14.41,0:14:17.35,Default,,0000,0000,0000,,真下流
Dialogue: 0,0:14:17.35,0:14:20.31,Default,,0000,0000,0000,,住手
Dialogue: 0,0:14:21.55,0:14:24.48,Default,,0000,0000,0000,,怎么啦？
Dialogue: 0,0:14:26.41,0:14:29.41,Default,,0000,0000,0000,,什么呀？
Dialogue: 0,0:14:30.41,0:14:33.48,Default,,0000,0000,0000,,会射的
Dialogue: 0,0:14:35.38,0:14:38.58,Default,,0000,0000,0000,,才不要停下呢
Dialogue: 0,0:14:47.48,0:14:50.38,Default,,0000,0000,0000,,住手啦
Dialogue: 0,0:15:00.38,0:15:03.41,Default,,0000,0000,0000,,这样很棒吧？
Dialogue: 0,0:15:18.58,0:15:21.38,Default,,0000,0000,0000,,想插入吧？
Dialogue: 0,0:15:21.38,0:15:24.38,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:15:24.38,0:15:27.38,Default,,0000,0000,0000,,可是很舒服呀
Dialogue: 0,0:15:32.35,0:15:34.38,Default,,0000,0000,0000,,我忍不住了
Dialogue: 0,0:15:34.38,0:15:37.51,Default,,0000,0000,0000,,肉棒插入吧
Dialogue: 0,0:15:43.41,0:15:46.55,Default,,0000,0000,0000,,都那么硬了
Dialogue: 0,0:15:54.41,0:15:57.35,Default,,0000,0000,0000,,我的淫穴很舒服哟
Dialogue: 0,0:15:59.48,0:16:02.71,Default,,0000,0000,0000,,比这样还舒服哟
Dialogue: 0,0:16:20.38,0:16:23.35,Default,,0000,0000,0000,,可以吗？
Dialogue: 0,0:16:24.41,0:16:27.28,Default,,0000,0000,0000,,不行
Dialogue: 0,0:16:31.41,0:16:34.35,Default,,0000,0000,0000,,好硬呀
Dialogue: 0,0:16:36.51,0:16:39.41,Default,,0000,0000,0000,,再来吧
Dialogue: 0,0:16:43.51,0:16:46.41,Default,,0000,0000,0000,,肉棒好硬
Dialogue: 0,0:16:48.58,0:16:51.35,Default,,0000,0000,0000,,可以吧？
Dialogue: 0,0:16:52.35,0:16:55.55,Default,,0000,0000,0000,,都那么硬了哟
Dialogue: 0,0:16:59.35,0:17:02.35,Default,,0000,0000,0000,,肉棒很舒服吧？
Dialogue: 0,0:17:24.65,0:17:27.78,Default,,0000,0000,0000,,肉棒好厉害
Dialogue: 0,0:17:27.78,0:17:31.01,Default,,0000,0000,0000,,很硬呢
Dialogue: 0,0:17:36.51,0:17:39.38,Default,,0000,0000,0000,,这样很爽吧？
Dialogue: 0,0:17:45.41,0:17:48.35,Default,,0000,0000,0000,,好棒
Dialogue: 0,0:17:49.41,0:17:52.45,Default,,0000,0000,0000,,真棒呢
Dialogue: 0,0:18:00.48,0:18:03.31,Default,,0000,0000,0000,,肉棒很大
Dialogue: 0,0:18:07.38,0:18:09.35,Default,,0000,0000,0000,,不行
Dialogue: 0,0:18:09.35,0:18:12.38,Default,,0000,0000,0000,,要射了
Dialogue: 0,0:18:12.38,0:18:15.68,Default,,0000,0000,0000,,这样要射了吗？
Dialogue: 0,0:18:26.58,0:18:29.41,Default,,0000,0000,0000,,再来吧
Dialogue: 0,0:18:33.35,0:18:36.48,Default,,0000,0000,0000,,射了吗？
Dialogue: 0,0:18:36.48,0:18:39.41,Default,,0000,0000,0000,,屁股热热的
Dialogue: 0,0:19:01.38,0:19:04.35,Default,,0000,0000,0000,,真厉害呢
Dialogue: 0,0:19:06.41,0:19:09.31,Default,,0000,0000,0000,,你都射了呀
Dialogue: 0,0:19:10.38,0:19:13.28,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:19:14.51,0:19:17.31,Default,,0000,0000,0000,,我想插入呀
Dialogue: 0,0:19:31.41,0:19:34.41,Default,,0000,0000,0000,,你们还在呀？
Dialogue: 0,0:19:36.31,0:19:40.01,Default,,0000,0000,0000,,在做什么呀？
Dialogue: 0,0:19:40.01,0:19:43.51,Default,,0000,0000,0000,,这个。。。
Dialogue: 0,0:19:45.35,0:19:48.35,Default,,0000,0000,0000,,在教室里做什么？
Dialogue: 0,0:19:50.38,0:19:53.41,Default,,0000,0000,0000,,抱歉 -等等
Dialogue: 0,0:20:01.41,0:20:04.38,Default,,0000,0000,0000,,做这样的事
Dialogue: 0,0:20:04.38,0:20:07.28,Default,,0000,0000,0000,,很糟糕呀
Dialogue: 0,0:20:07.28,0:20:09.28,Default,,0000,0000,0000,,我在读书呀
Dialogue: 0,0:20:09.28,0:20:12.28,Default,,0000,0000,0000,,读书
Dialogue: 0,0:20:13.48,0:20:17.11,Default,,0000,0000,0000,,你看 他刚刚射了
Dialogue: 0,0:20:22.41,0:20:26.45,Default,,0000,0000,0000,,我有点兴奋呢
Dialogue: 0,0:20:27.41,0:20:30.68,Default,,0000,0000,0000,,不是读书吗？
Dialogue: 0,0:20:31.38,0:20:34.41,Default,,0000,0000,0000,,刚刚没有爽呢
Dialogue: 0,0:20:38.35,0:20:41.71,Default,,0000,0000,0000,,来跟我做爱吧
Dialogue: 0,0:20:41.71,0:20:44.65,Default,,0000,0000,0000,,什么呀？ -来做
Dialogue: 0,0:20:48.45,0:20:51.28,Default,,0000,0000,0000,,住手呀
Dialogue: 0,0:20:51.28,0:20:54.35,Default,,0000,0000,0000,,来吧
Dialogue: 0,0:20:56.48,0:20:59.31,Default,,0000,0000,0000,,乳头硬了哟
Dialogue: 0,0:20:59.31,0:21:02.31,Default,,0000,0000,0000,,什么呀？
Dialogue: 0,0:21:02.31,0:21:05.31,Default,,0000,0000,0000,,硬了哟
Dialogue: 0,0:21:07.35,0:21:10.75,Default,,0000,0000,0000,,这里也硬了
Dialogue: 0,0:21:12.38,0:21:15.45,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:21:15.45,0:21:19.38,Default,,0000,0000,0000,,你很想要吧
Dialogue: 0,0:21:28.31,0:21:31.31,Default,,0000,0000,0000,,乳头很硬唷
Dialogue: 0,0:21:31.31,0:21:34.01,Default,,0000,0000,0000,,怎么啦？
Dialogue: 0,0:21:34.45,0:21:37.11,Default,,0000,0000,0000,,没什么
Dialogue: 0,0:21:41.48,0:21:44.48,Default,,0000,0000,0000,,住手
Dialogue: 0,0:21:59.45,0:22:02.38,Default,,0000,0000,0000,,这里真厉害
Dialogue: 0,0:22:02.38,0:22:05.31,Default,,0000,0000,0000,,硬了
Dialogue: 0,0:22:11.35,0:22:14.38,Default,,0000,0000,0000,,不可以啦
Dialogue: 0,0:22:31.38,0:22:34.41,Default,,0000,0000,0000,,做什么
Dialogue: 0,0:22:46.41,0:22:49.38,Default,,0000,0000,0000,,你的很大呢
Dialogue: 0,0:22:49.38,0:22:52.28,Default,,0000,0000,0000,,才没有
Dialogue: 0,0:22:52.28,0:22:55.38,Default,,0000,0000,0000,,很棒呢
Dialogue: 0,0:22:57.35,0:23:00.35,Default,,0000,0000,0000,,舒服吗？
Dialogue: 0,0:23:02.35,0:23:05.35,Default,,0000,0000,0000,,碰到了哟
Dialogue: 0,0:23:06.41,0:23:09.15,Default,,0000,0000,0000,,真厉害
Dialogue: 0,0:23:11.48,0:23:14.41,Default,,0000,0000,0000,,好舒服
Dialogue: 0,0:23:19.41,0:23:22.31,Default,,0000,0000,0000,,喜欢吧？
Dialogue: 0,0:23:29.51,0:23:32.38,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:23:34.31,0:23:37.35,Default,,0000,0000,0000,,反应很大呢
Dialogue: 0,0:23:53.45,0:23:56.38,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:23:57.38,0:24:00.38,Default,,0000,0000,0000,,这样会不行
Dialogue: 0,0:24:04.28,0:24:07.41,Default,,0000,0000,0000,,很舒服呀？ -不是的
Dialogue: 0,0:24:20.41,0:24:23.35,Default,,0000,0000,0000,,没关系吧
Dialogue: 0,0:24:23.35,0:24:26.35,Default,,0000,0000,0000,,不是啦
Dialogue: 0,0:24:26.35,0:24:29.28,Default,,0000,0000,0000,,想看吧？ -不是
Dialogue: 0,0:24:33.48,0:24:36.65,Default,,0000,0000,0000,,果然喜欢呢
Dialogue: 0,0:24:37.41,0:24:40.35,Default,,0000,0000,0000,,想看淫穴呀？
Dialogue: 0,0:24:46.61,0:24:49.38,Default,,0000,0000,0000,,真厉害呢
Dialogue: 0,0:24:49.38,0:24:52.48,Default,,0000,0000,0000,,变好大呀
Dialogue: 0,0:24:56.48,0:24:59.85,Default,,0000,0000,0000,,让我看你的肉棒
Dialogue: 0,0:25:12.48,0:25:15.35,Default,,0000,0000,0000,,好厉害
Dialogue: 0,0:25:15.35,0:25:18.41,Default,,0000,0000,0000,,班长肉棒很大呢
Dialogue: 0,0:25:20.35,0:25:23.15,Default,,0000,0000,0000,,真厉害
Dialogue: 0,0:25:23.15,0:25:26.41,Default,,0000,0000,0000,,不可以啦
Dialogue: 0,0:25:27.38,0:25:30.45,Default,,0000,0000,0000,,舔舔看吧
