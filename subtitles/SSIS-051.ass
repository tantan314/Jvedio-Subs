Dialogue: 0,0:01:09.65,0:01:14.11,Default,,0,0,0,,（熟女最爽的刺激）
Dialogue: 0,0:01:14.16,0:01:17.53,Default,,0,0,0,,（感覺到自己的極限）
Dialogue: 0,0:01:17.96,0:01:23.73,Default,,0,0,0,,（失禁覺醒色情得受不了）
Dialogue: 0,0:01:26.10,0:01:28.94,Default,,0,0,0,,市內某攝影棚
Dialogue: 0,0:01:29.04,0:01:30.70,Default,,0,0,0,, -準備好了嗎 -準備好了
Dialogue: 0,0:01:30.98,0:01:34.17,Default,,0,0,0,, -今天好快 -在家洗澡了
Dialogue: 0,0:01:34.55,0:01:38.48,Default,,0,0,0,, -就馬上能幹了 -看著相機
Dialogue: 0,0:01:39.22,0:01:42.41,Default,,0,0,0,,感覺非常的帥
Dialogue: 0,0:01:42.92,0:01:45.32,Default,,0,0,0,, -感覺非常的帥 -是嗎
Dialogue: 0,0:01:47.09,0:01:52.72,Default,,0,0,0,,新的相機買了 想更有\N效率的拍下流的東西
Dialogue: 0,0:01:53.10,0:01:56.23,Default,,0,0,0,, -非常好的東西 -什麼
Dialogue: 0,0:01:56.33,0:01:58.60,Default,,0,0,0,,（導演選的媚藥）
Dialogue: 0,0:02:00.27,0:02:04.00,Default,,0,0,0,, -這些 -這些東西嗎
Dialogue: 0,0:02:05.11,0:02:08.17,Default,,0,0,0,,這個不行 挑喜歡的
Dialogue: 0,0:02:08.61,0:02:12.14,Default,,0,0,0,, -非常喜歡的東西 -什麼
Dialogue: 0,0:02:13.65,0:02:16.18,Default,,0,0,0,,這個很危險
Dialogue: 0,0:02:17.99,0:02:19.12,Default,,0,0,0,,很厲害
Dialogue: 0,0:02:20.43,0:02:23.92,Default,,0,0,0,, -等一下這個 -早安
Dialogue: 0,0:02:24.53,0:02:27.76,Default,,0,0,0,, -好久不見 -早安
Dialogue: 0,0:02:27.87,0:02:30.16,Default,,0,0,0,, -還好吧 -很好
Dialogue: 0,0:02:30.67,0:02:34.07,Default,,0,0,0,,見過這樣的相機嗎
Dialogue: 0,0:02:35.24,0:02:38.30,Default,,0,0,0,, -新東西 -反應很大
Dialogue: 0,0:02:38.64,0:02:41.41,Default,,0,0,0,, -到了就看到了 -謝謝
Dialogue: 0,0:02:41.71,0:02:44.15,Default,,0,0,0,,是的今天開始用
Dialogue: 0,0:02:44.52,0:02:47.42,Default,,0,0,0,, -是嗎 用這個來
Dialogue: 0,0:02:47.72,0:02:49.38,Default,,0,0,0,, -好厲害 -是吧
Dialogue: 0,0:02:49.62,0:02:51.75,Default,,0,0,0,, -很久不見 -很久不見
Dialogue: 0,0:02:51.79,0:02:57.99,Default,,0,0,0,,最近都穿成這樣嗎
Dialogue: 0,0:02:58.30,0:03:00.96,Default,,0,0,0,, -什麼 -人妻樣子
Dialogue: 0,0:03:01.87,0:03:04.13,Default,,0,0,0,, -沒有戒指嗎 -沒有
Dialogue: 0,0:03:04.50,0:03:08.06,Default,,0,0,0,, -拍完就忘記戴回去了是吧\N -有過一次
Dialogue: 0,0:03:08.54,0:03:10.70,Default,,0,0,0,, -回去了 -果然是
Dialogue: 0,0:03:11.61,0:03:15.24,Default,,0,0,0,, -已經好了 -好的
Dialogue: 0,0:03:15.38,0:03:19.94,Default,,0,0,0,, -好的 -你拍那種很多
Dialogue: 0,0:03:20.05,0:03:25.05,Default,,0,0,0,, -我想拍那種用力的\N -今天就是這樣的嗎
Dialogue: 0,0:03:25.42,0:03:29.22,Default,,0,0,0,,用力的 讓他過來了
Dialogue: 0,0:03:29.36,0:03:31.29,Default,,0,0,0,, -看起來這麼健康很好\N -很健康
Dialogue: 0,0:03:32.33,0:03:37.13,Default,,0,0,0,, -到裡面去看吧 -好的
Dialogue: 0,0:03:37.87,0:03:41.57,Default,,0,0,0,,剛來不知道弄好沒有
Dialogue: 0,0:03:41.84,0:03:44.64,Default,,0,0,0,, -需要準備 -是呀
Dialogue: 0,0:03:45.31,0:03:47.57,Default,,0,0,0,, -來看 -好厲害
Dialogue: 0,0:03:47.81,0:03:53.15,Default,,0,0,0,, -今天有人妻的感覺嗎\N-非常有 套裝的
Dialogue: 0,0:03:53.28,0:03:56.48,Default,,0,0,0,, -非常棒 -非常棒
Dialogue: 0,0:03:56.59,0:04:01.62,Default,,0,0,0,, -沒有像這樣的吧 -沒有
Dialogue: 0,0:04:01.79,0:04:04.02,Default,,0,0,0,, -這裡也沒有床 -是吧
Dialogue: 0,0:04:04.36,0:04:07.35,Default,,0,0,0,, -就是普通的擺放 -是的
Dialogue: 0,0:04:08.80,0:04:11.79,Default,,0,0,0,, -去坐一下吧 -可以嗎
Dialogue: 0,0:04:12.10,0:04:14.97,Default,,0,0,0,, -給我放好吧 -謝謝
Dialogue: 0,0:04:15.81,0:04:19.17,Default,,0,0,0,, -這麼樣 -脫了可以嗎
Dialogue: 0,0:04:19.81,0:04:21.18,Default,,0,0,0,, -沒事嗎 -好熱
Dialogue: 0,0:04:21.35,0:04:25.68,Default,,0,0,0,, -熱了嗎 不好意思 -謝謝
Dialogue: 0,0:04:25.75,0:04:29.62,Default,,0,0,0,, -拍的地方要熱 -是的
Dialogue: 0,0:04:29.82,0:04:33.09,Default,,0,0,0,,這個相機是第一次
Dialogue: 0,0:04:33.69,0:04:36.82,Default,,0,0,0,, -試鏡 -練習
Dialogue: 0,0:04:36.89,0:04:39.92,Default,,0,0,0,,是呀好漂亮
Dialogue: 0,0:04:40.47,0:04:41.59,Default,,0,0,0,,畫面
Dialogue: 0,0:04:42.87,0:04:47.53,Default,,0,0,0,, -是這樣的\N -還在說相機的狀況
Dialogue: 0,0:04:47.77,0:04:50.40,Default,,0,0,0,, -這個不是電視劇 -嗯
Dialogue: 0,0:04:50.74,0:04:57.31,Default,,0,0,0,,這次要看你下流到\N什麼樣的程度
Dialogue: 0,0:04:57.38,0:04:58.58,Default,,0,0,0,,這麼說
Dialogue: 0,0:04:58.98,0:05:02.95,Default,,0,0,0,, -想讓你挑戰 -好的
Dialogue: 0,0:05:03.02,0:05:06.12,Default,,0,0,0,, -是的 -沒事吧
Dialogue: 0,0:05:06.29,0:05:09.16,Default,,0,0,0,, -沒有設定嗎 -沒有
Dialogue: 0,0:05:09.16,0:05:11.36,Default,,0,0,0,,看你自己了
Dialogue: 0,0:05:11.73,0:05:14.56,Default,,0,0,0,, -很久沒有 -要保護婚戒
Dialogue: 0,0:05:14.70,0:05:16.03,Default,,0,0,0,, -是呀 -這樣說
Dialogue: 0,0:05:16.17,0:05:20.04,Default,,0,0,0,, -沒有逃跑的台詞 -是的
Dialogue: 0,0:05:20.44,0:05:23.97,Default,,0,0,0,,看你自己 要是設定了的話
Dialogue: 0,0:05:24.41,0:05:29.51,Default,,0,0,0,, -就有故意的感覺 -嗯
Dialogue: 0,0:05:30.68,0:05:34.88,Default,,0,0,0,,這次想看你這樣
Dialogue: 0,0:05:35.22,0:05:39.88,Default,,0,0,0,, -不害羞嗎\N -是呀 這個很害羞
Dialogue: 0,0:05:40.26,0:05:47.89,Default,,0,0,0,,很久沒拍了\N對粉絲說些什麼吧
Dialogue: 0,0:05:48.30,0:05:52.24,Default,,0,0,0,, -好的 -簡單就行
Dialogue: 0,0:05:52.67,0:05:57.07,Default,,0,0,0,,在看的大家你們好
Dialogue: 0,0:05:57.44,0:06:01.47,Default,,0,0,0,,電視劇類型的比較多
Dialogue: 0,0:06:01.81,0:06:06.31,Default,,0,0,0,,這次盡力做
Dialogue: 0,0:06:06.92,0:06:10.38,Default,,0,0,0,,想認真做
Dialogue: 0,0:06:10.56,0:06:12.58,Default,,0,0,0,,這麼認真的
Dialogue: 0,0:06:13.19,0:06:15.89,Default,,0,0,0,, -是認真的時間呀 -這個
Dialogue: 0,0:06:17.26,0:06:19.09,Default,,0,0,0,, -不行 -怎麼了
Dialogue: 0,0:06:19.80,0:06:22.10,Default,,0,0,0,, -今天是這樣的嗎\N -什麼樣的
Dialogue: 0,0:06:22.50,0:06:25.37,Default,,0,0,0,,已經習慣了嗎
Dialogue: 0,0:06:25.74,0:06:29.14,Default,,0,0,0,,就這樣開始了嗎
Dialogue: 0,0:06:29.67,0:06:32.27,Default,,0,0,0,, -你覺得了呢 -我覺得是
Dialogue: 0,0:06:34.85,0:06:37.97,Default,,0,0,0,,反應很好這裡
Dialogue: 0,0:06:41.82,0:06:45.45,Default,,0,0,0,,等一下 感覺很好嗎
Dialogue: 0,0:06:51.36,0:06:53.30,Default,,0,0,0,, -好厲害 -害羞
Dialogue: 0,0:06:55.17,0:06:58.19,Default,,0,0,0,,這樣感覺怎麼樣
Dialogue: 0,0:07:03.14,0:07:08.04,Default,,0,0,0,, -很久沒拍了 這樣很興 吧\N -是呀
Dialogue: 0,0:07:20.59,0:07:22.72,Default,,0,0,0,,來直接摸吧
Dialogue: 0,0:07:33.50,0:07:35.17,Default,,0,0,0,,熱了嗎
Dialogue: 0,0:07:43.18,0:07:44.24,Default,,0,0,0,,這樣
Dialogue: 0,0:07:50.29,0:07:53.59,Default,,0,0,0,, -這樣也不壞吧 -是的
Dialogue: 0,0:07:57.90,0:07:59.69,Default,,0,0,0,,好好感覺
Dialogue: 0,0:08:01.13,0:08:06.07,Default,,0,0,0,, -就這樣高潮\N -對不起什麼
Dialogue: 0,0:08:06.40,0:08:09.00,Default,,0,0,0,,剛才沒聽到
Dialogue: 0,0:08:09.11,0:08:11.10,Default,,0,0,0,, -忍住再高潮 -忍住嗎
Dialogue: 0,0:08:11.38,0:08:13.40,Default,,0,0,0,,忍住之後很爽的
Dialogue: 0,0:08:16.11,0:08:17.78,Default,,0,0,0,,就這樣來
Dialogue: 0,0:08:55.12,0:08:56.62,Default,,0,0,0,,熱了
Dialogue: 0,0:08:58.56,0:08:59.75,Default,,0,0,0,,再來
Dialogue: 0,0:09:14.24,0:09:15.47,Default,,0,0,0,,這裡
Dialogue: 0,0:09:33.02,0:09:35.05,Default,,0,0,0,,這樣很興奮吧
Dialogue: 0,0:09:35.89,0:09:38.05,Default,,0,0,0,,是這樣的
Dialogue: 0,0:09:50.91,0:09:52.41,Default,,0,0,0,,興奮了嗎
Dialogue: 0,0:09:56.01,0:09:57.48,Default,,0,0,0,,好快
Dialogue: 0,0:10:08.39,0:10:10.35,Default,,0,0,0,,開了 開關
Dialogue: 0,0:10:19.17,0:10:21.66,Default,,0,0,0,,腰動起來了
Dialogue: 0,0:10:33.08,0:10:33.95,Default,,0,0,0,,這裡
Dialogue: 0,0:10:41.29,0:10:42.88,Default,,0,0,0,,圩舒服
Dialogue: 0,0:10:46.70,0:10:47.86,Default,,0,0,0,,很敏感
Dialogue: 0,0:10:49.53,0:10:50.80,Default,,0,0,0,,不爽嗎
Dialogue: 0,0:10:51.97,0:10:54.53,Default,,0,0,0,, -好厲害 -好舒服好舒服
Dialogue: 0,0:10:57.91,0:10:59.84,Default,,0,0,0,,怎麼了來看
Dialogue: 0,0:11:00.51,0:11:02.57,Default,,0,0,0,,好舒服
