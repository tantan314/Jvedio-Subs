Dialogue: 0,0:00:01.40,0:00:07.13,Default,,0,0,0,,家庭教師奈緒老師\N一直說淫聲浪語誘惑我中出
Dialogue: 0,0:00:16.68,0:00:18.94,Default,,0,0,0,,你好
Dialogue: 0,0:00:22.15,0:00:24.62,Default,,0,0,0,,我是新來的家教
Dialogue: 0,0:00:24.62,0:00:27.02,Default,,0,0,0,,神宮寺奈緒
Dialogue: 0,0:00:27.16,0:00:29.28,Default,,0,0,0,,你好
Dialogue: 0,0:00:29.49,0:00:31.29,Default,,0,0,0,,可以進去嗎？
Dialogue: 0,0:00:31.96,0:00:34.83,Default,,0,0,0,,打擾了
Dialogue: 0,0:00:41.77,0:00:44.90,Default,,0,0,0,,好漂亮的房間
Dialogue: 0,0:00:46.98,0:00:50.91,Default,,0,0,0,,氣氛真好
Dialogue: 0,0:00:57.19,0:00:58.91,Default,,0,0,0,,怎啦？
Dialogue: 0,0:01:00.79,0:01:03.78,Default,,0,0,0,,請帶我到房間
Dialogue: 0,0:01:09.73,0:01:12.46,Default,,0,0,0,,總之
Dialogue: 0,0:01:12.67,0:01:15.47,Default,,0,0,0,,先看看你的程度
Dialogue: 0,0:01:15.80,0:01:18.27,Default,,0,0,0,,先做這個
Dialogue: 0,0:01:59.51,0:02:01.31,Default,,0,0,0,,寫好了？
Dialogue: 0,0:02:05.65,0:02:08.05,Default,,0,0,0,,我看看
Dialogue: 0,0:02:12.46,0:02:14.93,Default,,0,0,0,,都空白耶
Dialogue: 0,0:02:15.06,0:02:17.86,Default,,0,0,0,,你有認真寫嗎？
Dialogue: 0,0:02:25.27,0:02:27.54,Default,,0,0,0,,無法專心嗎？
Dialogue: 0,0:02:29.48,0:02:31.34,Default,,0,0,0,,說啊
Dialogue: 0,0:02:35.82,0:02:38.48,Default,,0,0,0,,你看的不是考卷
Dialogue: 0,0:02:39.75,0:02:40.81,Default,,0,0,0,,是我吧
Dialogue: 0,0:02:40.82,0:02:42.62,Default,,0,0,0,,是我吧
Dialogue: 0,0:02:46.36,0:02:48.89,Default,,0,0,0,,我早就發現了
Dialogue: 0,0:02:48.90,0:02:50.23,Default,,0,0,0,,我早就發現了
Dialogue: 0,0:02:55.30,0:02:57.57,Default,,0,0,0,,怎啦？
Dialogue: 0,0:03:00.11,0:03:02.77,Default,,0,0,0,,怎啦？
Dialogue: 0,0:03:10.32,0:03:12.65,Default,,0,0,0,,無法專心的話
Dialogue: 0,0:03:12.85,0:03:16.31,Default,,0,0,0,,我來教你
Dialogue: 0,0:03:16.72,0:03:19.25,Default,,0,0,0,,這個
Dialogue: 0,0:03:22.53,0:03:24.73,Default,,0,0,0,,你看
Dialogue: 0,0:03:24.73,0:03:28.13,Default,,0,0,0,,專心一點
Dialogue: 0,0:03:28.34,0:03:31.13,Default,,0,0,0,,來吧
Dialogue: 0,0:03:34.48,0:03:37.60,Default,,0,0,0,,快拿筆
Dialogue: 0,0:03:50.02,0:03:51.95,Default,,0,0,0,,快點
Dialogue: 0,0:03:57.90,0:04:00.63,Default,,0,0,0,,這麼在意我的內褲？
Dialogue: 0,0:04:04.31,0:04:08.11,Default,,0,0,0,,這樣怎麼用功啊
Dialogue: 0,0:04:11.18,0:04:15.37,Default,,0,0,0,,一直偷看我
Dialogue: 0,0:04:19.25,0:04:21.59,Default,,0,0,0,,能專心嗎？
Dialogue: 0,0:04:40.21,0:04:41.47,Default,,0,0,0,,這啥？
Dialogue: 0,0:04:44.08,0:04:48.41,Default,,0,0,0,,我這麼認真教你
Dialogue: 0,0:04:48.82,0:04:53.41,Default,,0,0,0,,這是怎樣？
Dialogue: 0,0:05:01.03,0:05:03.83,Default,,0,0,0,,我好失望
Dialogue: 0,0:05:04.50,0:05:06.83,Default,,0,0,0,,學生竟然
Dialogue: 0,0:05:09.57,0:05:11.90,Default,,0,0,0,,這麼不認真
Dialogue: 0,0:05:12.24,0:05:15.97,Default,,0,0,0,,怎麼辦呢
Dialogue: 0,0:05:25.79,0:05:28.78,Default,,0,0,0,,怎啦？
Dialogue: 0,0:05:29.72,0:05:33.18,Default,,0,0,0,,看了我的內褲
Dialogue: 0,0:05:34.73,0:05:36.99,Default,,0,0,0,,你也要給我看肉棒
Dialogue: 0,0:05:56.22,0:05:58.41,Default,,0,0,0,,這啥？
Dialogue: 0,0:06:00.09,0:06:03.89,Default,,0,0,0,,好色唷
Dialogue: 0,0:06:05.49,0:06:09.69,Default,,0,0,0,,你想怎樣啊
Dialogue: 0,0:06:14.37,0:06:17.10,Default,,0,0,0,,你這麼笨
Dialogue: 0,0:06:17.57,0:06:21.91,Default,,0,0,0,,肉棒得優秀才行
Dialogue: 0,0:06:24.25,0:06:28.84,Default,,0,0,0,,說 媽媽對不起
Dialogue: 0,0:06:37.33,0:06:40.78,Default,,0,0,0,,好大晴
Dialogue: 0,0:06:42.13,0:06:45.46,Default,,0,0,0,,只有肉棒優秀呢
Dialogue: 0,0:06:45.47,0:06:47.46,Default,,0,0,0,,那麼
Dialogue: 0,0:06:47.74,0:06:52.67,Default,,0,0,0,,我讓你更優秀吧
Dialogue: 0,0:07:14.36,0:07:16.69,Default,,0,0,0,,我看看
Dialogue: 0,0:07:21.64,0:07:25.37,Default,,0,0,0,,好硬晴
Dialogue: 0,0:07:35.12,0:07:37.11,Default,,0,0,0,,變溼了
Dialogue: 0,0:07:40.79,0:07:43.99,Default,,0,0,0,,很想要吧
Dialogue: 0,0:07:44.79,0:07:46.99,Default,,0,0,0,,你這笨蛋
Dialogue: 0,0:07:46.99,0:07:51.40,Default,,0,0,0,,只有這方面可以
Dialogue: 0,0:07:53.60,0:07:57.33,Default,,0,0,0,,如何？
Dialogue: 0,0:08:01.61,0:08:05.07,Default,,0,0,0,,希望我摸啊
Dialogue: 0,0:08:05.75,0:08:09.08,Default,,0,0,0,,你該不會是處男？
Dialogue: 0,0:08:09.95,0:08:12.68,Default,,0,0,0,,果然
Dialogue: 0,0:08:13.09,0:08:17.42,Default,,0,0,0,,難怪一直偷看我 處男
Dialogue: 0,0:08:31.57,0:08:33.63,Default,,0,0,0,,痛嗎？
Dialogue: 0,0:08:35.04,0:08:37.77,Default,,0,0,0,,很爽吧
Dialogue: 0,0:08:38.18,0:08:41.91,Default,,0,0,0,,你看
Dialogue: 0,0:08:42.18,0:08:45.98,Default,,0,0,0,,怎麼啦？
Dialogue: 0,0:08:52.59,0:08:56.32,Default,,0,0,0,,快秀出優秀的肉棒
Dialogue: 0,0:09:07.94,0:09:09.53,Default,,0,0,0,,啥？
Dialogue: 0,0:09:09.94,0:09:13.54,Default,,0,0,0,,很爽嗎？
Dialogue: 0,0:09:41.51,0:09:46.85,Default,,0,0,0,,好硬唷
Dialogue: 0,0:09:49.18,0:09:53.12,Default,,0,0,0,,沒有被摸過吧
Dialogue: 0,0:09:53.32,0:09:57.45,Default,,0,0,0,,我是第一個
Dialogue: 0,0:10:06.07,0:10:08.93,Default,,0,0,0,,好燙唷
Dialogue: 0,0:10:12.61,0:10:15.74,Default,,0,0,0,,爽吧
Dialogue: 0,0:10:18.35,0:10:22.21,Default,,0,0,0,,可以看唷
Dialogue: 0,0:10:22.22,0:10:26.74,Default,,0,0,0,,你最愛的內褲
Dialogue: 0,0:10:29.02,0:10:31.82,Default,,0,0,0,,感覺怎樣？
Dialogue: 0,0:10:32.36,0:10:35.49,Default,,0,0,0,,看著我的內褲
Dialogue: 0,0:10:35.50,0:10:40.16,Default,,0,0,0,,被打手槍
Dialogue: 0,0:10:40.17,0:10:43.83,Default,,0,0,0,,害羞嗎？
Dialogue: 0,0:10:47.38,0:10:50.17,Default,,0,0,0,,再來
Dialogue: 0,0:10:57.32,0:11:00.45,Default,,0,0,0,,爽吧
Dialogue: 0,0:11:03.52,0:11:06.46,Default,,0,0,0,,爽吧
Dialogue: 0,0:11:09.20,0:11:11.93,Default,,0,0,0,,老師特別
Dialogue: 0,0:11:11.93,0:11:15.73,Default,,0,0,0,,幫你打手槍
Dialogue: 0,0:11:16.07,0:11:20.06,Default,,0,0,0,,你得用功才行唷
Dialogue: 0,0:11:21.68,0:11:25.87,Default,,0,0,0,,好硬
Dialogue: 0,0:11:26.15,0:11:29.01,Default,,0,0,0,,怎啦？
Dialogue: 0,0:11:29.02,0:11:32.14,Default,,0,0,0,,爽吧
Dialogue: 0,0:11:35.22,0:11:39.02,Default,,0,0,0,,好硬
Dialogue: 0,0:11:41.96,0:11:49.30,Default,,0,0,0,,爽吧
Dialogue: 0,0:11:52.24,0:11:55.30,Default,,0,0,0,,怎啦？
Dialogue: 0,0:12:08.66,0:12:11.59,Default,,0,0,0,,真是的
Dialogue: 0,0:12:11.99,0:12:15.46,Default,,0,0,0,,去要講啊
Dialogue: 0,0:12:15.80,0:12:18.53,Default,,0,0,0,,處男
Dialogue: 0,0:12:21.00,0:12:24.33,Default,,0,0,0,,弄髒了
Dialogue: 0,0:12:24.41,0:12:27.47,Default,,0,0,0,,沾到了
Dialogue: 0,0:12:28.61,0:12:30.27,Default,,0,0,0,,這個
Dialogue: 0,0:12:30.54,0:12:33.14,Default,,0,0,0,,怎麼辦？
Dialogue: 0,0:12:33.41,0:12:36.01,Default,,0,0,0,,髒死了
Dialogue: 0,0:12:36.22,0:12:39.21,Default,,0,0,0,,爛透了
Dialogue: 0,0:12:39.22,0:12:43.16,Default,,0,0,0,,我很喜歡耶
Dialogue: 0,0:12:47.09,0:12:49.76,Default,,0,0,0,,沒辦法
Dialogue: 0,0:12:50.03,0:12:54.09,Default,,0,0,0,,弄乾淨吧
Dialogue: 0,0:13:00.78,0:13:04.04,Default,,0,0,0,,得弄乾淨
Dialogue: 0,0:13:12.85,0:13:15.79,Default,,0,0,0,,你看
Dialogue: 0,0:13:16.12,0:13:18.92,Default,,0,0,0,,我的絲襪
Dialogue: 0,0:13:19.26,0:13:22.20,Default,,0,0,0,,丟這囉
Dialogue: 0,0:13:22.60,0:13:27.00,Default,,0,0,0,,你想怎麼做都行
Dialogue: 0,0:13:37.55,0:13:41.35,Default,,0,0,0,,剛剛那是為了讓你用功的
Dialogue: 0,0:13:41.35,0:13:43.34,Default,,0,0,0,,特別做法
Dialogue: 0,0:13:43.75,0:13:46.02,Default,,0,0,0,,別誤會
Dialogue: 0,0:14:14.72,0:14:17.12,Default,,0,0,0,,造啥？
Dialogue: 0,0:14:21.32,0:14:27.45,Default,,0,0,0,,很硬晴
Dialogue: 0,0:14:32.40,0:14:35.13,Default,,0,0,0,,這個
Dialogue: 0,0:14:37.94,0:14:40.27,Default,,0,0,0,,剛剛
Dialogue: 0,0:14:41.01,0:14:46.00,Default,,0,0,0,,才射過耶
Dialogue: 0,0:14:48.75,0:14:52.81,Default,,0,0,0,,你真是槽糕
Dialogue: 0,0:15:04.03,0:15:08.97,Default,,0,0,0,,得好好指導你
Dialogue: 0,0:15:18.65,0:15:21.77,Default,,0,0,0,,有洗嗎？
Dialogue: 0,0:15:22.05,0:15:25.99,Default,,0,0,0,,剛剛超臭的
Dialogue: 0,0:15:41.20,0:15:44.67,Default,,0,0,0,,你這處男
Dialogue: 0,0:15:44.87,0:15:48.33,Default,,0,0,0,,得弄乾淨
Dialogue: 0,0:15:48.88,0:15:52.68,Default,,0,0,0,,會被討厭晴
Dialogue: 0,0:16:01.09,0:16:04.49,Default,,0,0,0,,剛剛是用腳
Dialogue: 0,0:16:09.56,0:16:11.83,Default,,0,0,0,,想被舔吧
Dialogue: 0,0:16:21.91,0:16:23.97,Default,,0,0,0,,那麼
Dialogue: 0,0:16:25.51,0:16:28.78,Default,,0,0,0,,我幫你口交 你得考好晴
Dialogue: 0,0:16:29.45,0:16:33.11,Default,,0,0,0,,說好囉
Dialogue: 0,0:16:41.46,0:16:43.93,Default,,0,0,0,,說好囉
Dialogue: 0,0:16:48.54,0:16:50.33,Default,,0,0,0,,開始囉
Dialogue: 0,0:17:08.16,0:17:12.09,Default,,0,0,0,,沒那麼簡單
Dialogue: 0,0:17:27.17,0:17:29.90,Default,,0,0,0,,很硬唷
Dialogue: 0,0:17:32.25,0:17:35.44,Default,,0,0,0,,都碰到了
Dialogue: 0,0:17:36.12,0:17:39.57,Default,,0,0,0,,好臭唷
Dialogue: 0,0:17:42.66,0:17:45.78,Default,,0,0,0,,好 來
Dialogue: 0,0:17:56.07,0:17:59.06,Default,,0,0,0,,如何？
Dialogue: 0,0:18:05.35,0:18:08.41,Default,,0,0,0,,爽吧
Dialogue: 0,0:18:24.30,0:18:28.43,Default,,0,0,0,,好濃的精液味
Dialogue: 0,0:18:30.97,0:18:34.70,Default,,0,0,0,,這是特別做法唷
Dialogue: 0,0:18:43.52,0:18:46.38,Default,,0,0,0,,處男
Dialogue: 0,0:18:47.65,0:18:51.45,Default,,0,0,0,,喜歡看AV
Dialogue: 0,0:18:52.66,0:18:55.32,Default,,0,0,0,,想怎樣被舔？
Dialogue: 0,0:19:09.08,0:19:12.01,Default,,0,0,0,,這樣？
Dialogue: 0,0:19:20.42,0:19:24.08,Default,,0,0,0,,還是要前端？
Dialogue: 0,0:19:35.84,0:19:39.64,Default,,0,0,0,,好否重唷
Dialogue: 0,0:19:39.77,0:19:43.50,Default,,0,0,0,,這麼爽？
Dialogue: 0,0:20:11.07,0:20:15.60,Default,,0,0,0,,好色晴
Dialogue: 0,0:20:15.61,0:20:17.60,Default,,0,0,0,,爽吧
Dialogue: 0,0:20:17.95,0:20:21.81,Default,,0,0,0,,剛剛才射過耶
Dialogue: 0,0:20:48.18,0:20:51.11,Default,,0,0,0,,爽吧
Dialogue: 0,0:20:59.39,0:21:02.98,Default,,0,0,0,,一直抖呢
Dialogue: 0,0:21:06.39,0:21:10.12,Default,,0,0,0,,剛剛才射過
Dialogue: 0,0:21:10.13,0:21:12.12,Default,,0,0,0,,忍得住嗎？
Dialogue: 0,0:21:22.54,0:21:25.88,Default,,0,0,0,,好多唷
Dialogue: 0,0:21:34.15,0:21:38.02,Default,,0,0,0,,真是糟糕的肉棒
Dialogue: 0,0:21:41.16,0:21:43.69,Default,,0,0,0,,剛剛射過耶
Dialogue: 0,0:21:47.17,0:21:50.23,Default,,0,0,0,,我怎麼回家啊？
Dialogue: 0,0:21:55.78,0:21:57.90,Default,,0,0,0,,太扯了
Dialogue: 0,0:21:57.91,0:22:00.90,Default,,0,0,0,,我得好好教你
Dialogue: 0,0:22:01.32,0:22:04.58,Default,,0,0,0,,功課要寫啊
Dialogue: 0,0:22:09.32,0:22:13.99,Default,,0,0,0,,隔週的授課
Dialogue: 0,0:22:26.47,0:22:29.14,Default,,0,0,0,,好了？
Dialogue: 0,0:22:53.97,0:22:56.90,Default,,0,0,0,,很好
Dialogue: 0,0:23:10.78,0:23:14.05,Default,,0,0,0,,你看哪啊 噁心
Dialogue: 0,0:23:30.14,0:23:34.20,Default,,0,0,0,,都答對了
Dialogue: 0,0:23:38.68,0:23:40.74,Default,,0,0,0,,你有用功呢
Dialogue: 0,0:23:42.15,0:23:45.74,Default,,0,0,0,,休息下吧
Dialogue: 0,0:23:46.29,0:23:48.08,Default,,0,0,0,,你做的很好
Dialogue: 0,0:23:48.09,0:23:52.42,Default,,0,0,0,,休息下再繼續
Dialogue: 0,0:23:58.43,0:24:01.49,Default,,0,0,0,,我用這杯子囉
Dialogue: 0,0:24:12.51,0:24:15.97,Default,,0,0,0,,你成績進步
Dialogue: 0,0:24:15.98,0:24:20.25,Default,,0,0,0,,我有獎勵給你
Dialogue: 0,0:24:41.74,0:24:44.54,Default,,0,0,0,,這蛋糕很好吃晴
Dialogue: 0,0:24:44.54,0:24:47.60,Default,,0,0,0,,喜歡蛋糕嗎？
Dialogue: 0,0:24:54.09,0:24:57.15,Default,,0,0,0,,紅茶也好喝唷
Dialogue: 0,0:25:30.26,0:25:32.59,Default,,0,0,0,,好喝嗎？
Dialogue: 0,0:25:35.06,0:25:37.26,Default,,0,0,0,,好喝
Dialogue: 0,0:25:42.54,0:25:44.94,Default,,0,0,0,,快吃啊
Dialogue: 0,0:25:46.27,0:25:49.00,Default,,0,0,0,,很好吃晴
Dialogue: 0,0:25:57.15,0:25:59.28,Default,,0,0,0,,如何？
Dialogue: 0,0:26:03.62,0:26:06.15,Default,,0,0,0,,好吃嗎？
Dialogue: 0,0:26:11.23,0:26:15.03,Default,,0,0,0,,果然用功就想吃甜的
Dialogue: 0,0:26:15.30,0:26:18.17,Default,,0,0,0,,我也吃吧
Dialogue: 0,0:26:33.59,0:26:36.11,Default,,0,0,0,,開動了
Dialogue: 0,0:27:11.09,0:27:14.69,Default,,0,0,0,,弄掉了
Dialogue: 0,0:27:28.04,0:27:30.51,Default,,0,0,0,,怎啦？
Dialogue: 0,0:27:32.58,0:27:35.31,Default,,0,0,0,,你怎麼啦？
Dialogue: 0,0:27:41.19,0:27:43.59,Default,,0,0,0,,來
Dialogue: 0,0:27:46.93,0:27:50.26,Default,,0,0,0,,黏黏的
Dialogue: 0,0:27:56.07,0:27:58.40,Default,,0,0,0,,你一直看呢
Dialogue: 0,0:28:02.34,0:28:04.67,Default,,0,0,0,,我的內褲
Dialogue: 0,0:28:07.35,0:28:10.81,Default,,0,0,0,,丟掉
Dialogue: 0,0:28:15.42,0:28:17.69,Default,,0,0,0,,你真的
Dialogue: 0,0:28:18.02,0:28:20.82,Default,,0,0,0,,很好色
Dialogue: 0,0:28:21.43,0:28:25.23,Default,,0,0,0,,我來幫你
Dialogue: 0,0:28:25.23,0:28:27.70,Default,,0,0,0,,清潔腦部吧
Dialogue: 0,0:28:38.51,0:28:41.24,Default,,0,0,0,,啥？
Dialogue: 0,0:28:42.05,0:28:44.92,Default,,0,0,0,,這啥？
Dialogue: 0,0:28:47.79,0:28:50.92,Default,,0,0,0,,好
