Dialogue: 0,0:20:34.52,0:20:37.52,Default,,0,0,0,,{\b1\fn华文楷体\fs20}你女儿在看
Dialogue: 0,0:20:45.53,0:20:48.53,Default,,0,0,0,,{\b1\fn华文楷体\fs20}真赞
Dialogue: 0,0:20:53.54,0:20:56.54,Default,,0,0,0,,{\b1\fn华文楷体\fs20}看不出来生过小孩
