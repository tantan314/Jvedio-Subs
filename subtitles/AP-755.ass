Dialogue: 0,0:00:00.73,0:00:03.07,Default,,0,0,0,,在畫什麼啊
Dialogue: 0,0:00:03.09,0:00:05.09,Default,,0,0,0,,好好学习啊
Dialogue: 0,0:00:05.87,0:00:07.87,Default,,0,0,0,,這不是在學習啊
Dialogue: 0,0:00:07.87,0:00:11.54,Default,,0,0,0,,這不是爸爸的新照相機嗎
Dialogue: 0,0:00:11.67,0:00:12.07,Default,,0,0,0,,真的嗎
Dialogue: 0,0:00:12.21,0:00:12.54,Default,,0,0,0,,真的嗎
Dialogue: 0,0:00:13.01,0:00:13.61,Default,,0,0,0,,真的嗎
Dialogue: 0,0:00:13.61,0:00:17.35,Default,,0,0,0,,這個是為了好好拍你們
Dialogue: 0,0:00:17.35,0:00:18.81,Default,,0,0,0,,買的新照相機
Dialogue: 0,0:00:18.95,0:00:21.15,Default,,0,0,0,,這樣啊
Dialogue: 0,0:00:21.22,0:00:26.29,Default,,0,0,0,,之前的 黑暗的時候拍不清
Dialogue: 0,0:00:26.29,0:00:31.09,Default,,0,0,0,,現在的這個可以拍清晰
Dialogue: 0,0:00:31.09,0:00:38.50,Default,,0,0,0,,現在這裡就可以了
Dialogue: 0,0:00:38.50,0:00:47.51,Default,,0,0,0,,現在還沒到 不過可以拍清晰
Dialogue: 0,0:00:47.51,0:00:49.71,Default,,0,0,0,,這樣啊
Dialogue: 0,0:00:49.84,0:00:53.58,Default,,0,0,0,,爸爸可以拍跑步嗎\N不可以啊
Dialogue: 0,0:00:53.65,0:00:56.58,Default,,0,0,0,,為什麼啊
Dialogue: 0,0:00:56.58,0:00:59.12,Default,,0,0,0,,不行嗎\N這樣哦
Dialogue: 0,0:00:59.12,0:01:03.39,Default,,0,0,0,,就是這樣拍的哦
Dialogue: 0,0:01:03.46,0:01:05.13,Default,,0,0,0,,姐姐跑的很快的
Dialogue: 0,0:01:05.13,0:01:08.46,Default,,0,0,0,,是呢
Dialogue: 0,0:01:08.53,0:01:10.27,Default,,0,0,0,,但是我也很快哦
Dialogue: 0,0:01:10.27,0:01:13.74,Default,,0,0,0,,姐姐也可以的\N真的嗎
Dialogue: 0,0:01:13.74,0:01:16.40,Default,,0,0,0,,我沒有見過
Dialogue: 0,0:01:16.40,0:01:18.07,Default,,0,0,0,,下次看看吧
Dialogue: 0,0:01:18.07,0:01:19.87,Default,,0,0,0,,下次一起去嗎
Dialogue: 0,0:01:19.87,0:01:21.28,Default,,0,0,0,,家人一起\N是的
Dialogue: 0,0:01:21.28,0:01:22.61,Default,,0,0,0,,大家一起哦
Dialogue: 0,0:01:22.61,0:01:23.48,Default,,0,0,0,,這樣啊
Dialogue: 0,0:01:23.48,0:01:23.75,Default,,0,0,0,,這樣啊
Dialogue: 0,0:01:26.55,0:01:29.15,Default,,0,0,0,,看著哦
Dialogue: 0,0:01:29.15,0:01:32.62,Default,,0,0,0,,看啊\N效果很好啊
Dialogue: 0,0:01:32.62,0:01:34.49,Default,,0,0,0,,在拍著呢
Dialogue: 0,0:01:34.49,0:01:36.49,Default,,0,0,0,,給我吧\N可以的
Dialogue: 0,0:01:36.49,0:01:38.63,Default,,0,0,0,,給我吧
Dialogue: 0,0:01:38.63,0:01:40.23,Default,,0,0,0,,我想著
Dialogue: 0,0:01:40.23,0:01:41.83,Default,,0,0,0,,給我吧
Dialogue: 0,0:01:41.90,0:01:43.10,Default,,0,0,0,,好重啊
Dialogue: 0,0:01:43.10,0:01:44.90,Default,,0,0,0,,很棒的哦
Dialogue: 0,0:01:44.90,0:01:45.90,Default,,0,0,0,,要這樣嗎
Dialogue: 0,0:01:45.90,0:01:47.44,Default,,0,0,0,,是的
Dialogue: 0,0:01:47.44,0:01:49.50,Default,,0,0,0,,拍著姐姐呢
Dialogue: 0,0:01:49.50,0:01:50.71,Default,,0,0,0,,還有爸爸
Dialogue: 0,0:01:50.71,0:01:51.51,Default,,0,0,0,,是呢
Dialogue: 0,0:01:51.57,0:01:54.51,Default,,0,0,0,,很容易操作
Dialogue: 0,0:01:54.51,0:01:55.44,Default,,0,0,0,,是的
Dialogue: 0,0:01:55.51,0:01:56.91,Default,,0,0,0,,好厲害
Dialogue: 0,0:01:56.98,0:01:59.45,Default,,0,0,0,,拍的很漂亮哦
Dialogue: 0,0:01:59.51,0:02:01.05,Default,,0,0,0,,不錯啊
Dialogue: 0,0:02:01.12,0:02:02.58,Default,,0,0,0,,好美啊
Dialogue: 0,0:02:02.65,0:02:03.99,Default,,0,0,0,,好有趣啊
Dialogue: 0,0:02:03.99,0:02:05.05,Default,,0,0,0,,爸爸在這裡哦
Dialogue: 0,0:02:05.05,0:02:06.32,Default,,0,0,0,,爸爸
Dialogue: 0,0:02:06.39,0:02:07.52,Default,,0,0,0,,拍爸爸和姐姐
Dialogue: 0,0:02:07.52,0:02:09.06,Default,,0,0,0,,好有趣啊
Dialogue: 0,0:02:09.06,0:02:10.06,Default,,0,0,0,,很貴嗎
Dialogue: 0,0:02:10.39,0:02:10.46,Default,,0,0,0,,很貴嗎
Dialogue: 0,0:02:10.53,0:02:12.19,Default,,0,0,0,,有點吧
Dialogue: 0,0:02:12.19,0:02:14.40,Default,,0,0,0,,弄壞了 不行嗎
Dialogue: 0,0:02:14.40,0:02:15.20,Default,,0,0,0,,不行啊
Dialogue: 0,0:02:15.20,0:02:18.87,Default,,0,0,0,,弄壞的話晚飯就沒有了哦
Dialogue: 0,0:02:18.93,0:02:20.47,Default,,0,0,0,,好可怕
Dialogue: 0,0:02:21.67,0:02:22.87,Default,,0,0,0,,好可怕
Dialogue: 0,0:02:23.54,0:02:26.07,Default,,0,0,0,,這個防水嗎
Dialogue: 0,0:02:26.07,0:02:27.81,Default,,0,0,0,,不行的
Dialogue: 0,0:02:27.81,0:02:29.08,Default,,0,0,0,,不可以濕啊
Dialogue: 0,0:02:29.08,0:02:31.48,Default,,0,0,0,,不行哦 一般的照相機不行的
Dialogue: 0,0:02:32.28,0:02:35.35,Default,,0,0,0,,我回來了\N不可以啊
Dialogue: 0,0:02:35.35,0:02:36.42,Default,,0,0,0,,回來了啊
Dialogue: 0,0:02:36.42,0:02:38.29,Default,,0,0,0,,回來了
Dialogue: 0,0:02:38.29,0:02:38.75,Default,,0,0,0,,歡迎回來
Dialogue: 0,0:02:38.75,0:02:40.62,Default,,0,0,0,,我回來了\N姐姐
Dialogue: 0,0:02:40.62,0:02:41.62,Default,,0,0,0,,這是什麼
Dialogue: 0,0:02:41.62,0:02:43.63,Default,,0,0,0,,這是爸爸買的新照相機
Dialogue: 0,0:02:43.63,0:02:45.36,Default,,0,0,0,,買的啊
Dialogue: 0,0:02:45.36,0:02:50.97,Default,,0,0,0,,在拍嗎\N是的
Dialogue: 0,0:02:50.97,0:02:52.63,Default,,0,0,0,,還沒做好飯嗎
Dialogue: 0,0:02:52.63,0:02:55.37,Default,,0,0,0,,在做呢
Dialogue: 0,0:02:55.37,0:02:57.91,Default,,0,0,0,,是的
Dialogue: 0,0:02:57.97,0:02:59.24,Default,,0,0,0,,這樣啊
Dialogue: 0,0:02:59.31,0:03:02.04,Default,,0,0,0,,探訪一下吧
Dialogue: 0,0:03:02.04,0:03:02.84,Default,,0,0,0,,探訪啊
Dialogue: 0,0:03:02.84,0:03:04.05,Default,,0,0,0,,姐姐
Dialogue: 0,0:03:05.45,0:03:07.32,Default,,0,0,0,,怎麼了
Dialogue: 0,0:03:09.72,0:03:11.12,Default,,0,0,0,,美緒啊
Dialogue: 0,0:03:11.12,0:03:13.72,Default,,0,0,0,,在幹嘛呢
Dialogue: 0,0:03:13.72,0:03:15.39,Default,,0,0,0,,姐姐好無趣啊
Dialogue: 0,0:03:15.39,0:03:19.39,Default,,0,0,0,,搞笑漫畫\N搞笑漫畫啊
Dialogue: 0,0:03:19.39,0:03:21.46,Default,,0,0,0,,拍了嗎
Dialogue: 0,0:03:21.46,0:03:22.40,Default,,0,0,0,,喜歡這樣的啊
Dialogue: 0,0:03:22.40,0:03:24.33,Default,,0,0,0,,好可怕 感覺要掉了
Dialogue: 0,0:03:24.33,0:03:27.20,Default,,0,0,0,,好好拿著
Dialogue: 0,0:03:27.20,0:03:28.87,Default,,0,0,0,,來吧
Dialogue: 0,0:03:30.21,0:03:34.61,Default,,0,0,0,,拍美緒
Dialogue: 0,0:03:34.61,0:03:36.21,Default,,0,0,0,,那裡
Dialogue: 0,0:03:36.28,0:03:39.48,Default,,0,0,0,,就是這樣
Dialogue: 0,0:03:39.55,0:03:40.82,Default,,0,0,0,,按著
Dialogue: 0,0:03:40.88,0:03:43.55,Default,,0,0,0,,就是這樣哦\N拍著呢
Dialogue: 0,0:03:43.55,0:03:45.02,Default,,0,0,0,,是呢
Dialogue: 0,0:03:45.09,0:03:48.16,Default,,0,0,0,,好美啊
Dialogue: 0,0:03:48.22,0:03:50.63,Default,,0,0,0,,真的好棒啊
Dialogue: 0,0:03:50.63,0:03:53.36,Default,,0,0,0,,是的
Dialogue: 0,0:03:53.43,0:03:57.70,Default,,0,0,0,,這個晃動也沒有關傑的
Dialogue: 0,0:03:57.70,0:03:58.83,Default,,0,0,0,,好厲害
Dialogue: 0,0:03:58.90,0:04:00.03,Default,,0,0,0,,不可以那樣哦
Dialogue: 0,0:04:02.04,0:04:04.64,Default,,0,0,0,,不可以哦
Dialogue: 0,0:04:04.77,0:04:06.57,Default,,0,0,0,,在動呢
Dialogue: 0,0:04:06.57,0:04:07.71,Default,,0,0,0,,不行順
Dialogue: 0,0:04:07.71,0:04:08.58,Default,,0,0,0,,是啊
Dialogue: 0,0:04:08.64,0:04:10.45,Default,,0,0,0,,爸爸這個該怎麼做啊
Dialogue: 0,0:04:10.45,0:04:12.38,Default,,0,0,0,,給我吧
Dialogue: 0,0:04:12.45,0:04:14.52,Default,,0,0,0,,好的
Dialogue: 0,0:04:14.65,0:04:16.65,Default,,0,0,0,,我看看
Dialogue: 0,0:04:18.52,0:04:21.26,Default,,0,0,0,,要拍嗎
Dialogue: 0,0:04:21.32,0:04:24.19,Default,,0,0,0,,是的
Dialogue: 0,0:04:24.26,0:04:28.46,Default,,0,0,0,,我幫忙吧
Dialogue: 0,0:04:28.53,0:04:30.93,Default,,0,0,0,,你不行啊
Dialogue: 0,0:04:31.00,0:04:34.94,Default,,0,0,0,,你們坐在一起了
Dialogue: 0,0:04:34.94,0:04:35.87,Default,,0,0,0,,好可愛
Dialogue: 0,0:04:35.94,0:04:38.27,Default,,0,0,0,,要吃飯了
Dialogue: 0,0:04:38.34,0:04:40.28,Default,,0,0,0,,來哦吧
Dialogue: 0,0:04:40.41,0:04:43.21,Default,,0,0,0,,小春也來吧
Dialogue: 0,0:04:43.21,0:04:45.41,Default,,0,0,0,,爸爸問啊 好搞笑啊
Dialogue: 0,0:04:45.41,0:04:48.22,Default,,0,0,0,,不知道
Dialogue: 0,0:04:48.35,0:04:55.36,Default,,0,0,0,,這樣啊
Dialogue: 0,0:04:55.36,0:04:56.22,Default,,0,0,0,,沒事的
Dialogue: 0,0:04:56.29,0:04:57.76,Default,,0,0,0,,吃飯吧
Dialogue: 0,0:04:57.83,0:05:00.50,Default,,0,0,0,,要是弄濕了 怎麼辦啊
Dialogue: 0,0:05:00.50,0:05:01.30,Default,,0,0,0,,來吧
Dialogue: 0,0:05:01.43,0:05:02.43,Default,,0,0,0,,確實
Dialogue: 0,0:05:02.50,0:05:03.97,Default,,0,0,0,,吃飯吧
Dialogue: 0,0:05:04.03,0:05:05.50,Default,,0,0,0,,要吃飯嗎
Dialogue: 0,0:05:05.50,0:05:08.17,Default,,0,0,0,,來吧
Dialogue: 0,0:05:08.24,0:05:09.57,Default,,0,0,0,,好厲害
Dialogue: 0,0:05:09.70,0:05:11.77,Default,,0,0,0,,不得了
Dialogue: 0,0:05:11.84,0:05:13.44,Default,,0,0,0,,一起吧
Dialogue: 0,0:05:13.51,0:05:15.18,Default,,0,0,0,,當然了
Dialogue: 0,0:05:15.24,0:05:16.91,Default,,0,0,0,,拍著呢
Dialogue: 0,0:05:16.98,0:05:19.58,Default,,0,0,0,,這是為了姐姐買的哦
Dialogue: 0,0:05:19.58,0:05:22.45,Default,,0,0,0,,我媽\N是的
Dialogue: 0,0:05:22.45,0:05:23.12,Default,,0,0,0,,真的嗎
Dialogue: 0,0:05:23.12,0:05:23.99,Default,,0,0,0,,是的
Dialogue: 0,0:05:24.05,0:05:26.12,Default,,0,0,0,,為了我啊
Dialogue: 0,0:05:26.19,0:05:28.72,Default,,0,0,0,,以為是在給你開玩笑嗎\N是的
Dialogue: 0,0:05:29.12,0:05:30.66,Default,,0,0,0,,我也要
Dialogue: 0,0:05:30.66,0:05:32.66,Default,,0,0,0,,來吧 留下回憶哦
Dialogue: 0,0:05:35.26,0:05:36.86,Default,,0,0,0,,我加油
Dialogue: 0,0:05:36.93,0:05:38.07,Default,,0,0,0,,很好吃的樣子啊
Dialogue: 0,0:05:38.07,0:05:39.27,Default,,0,0,0,,來吧
Dialogue: 0,0:05:39.33,0:05:40.74,Default,,0,0,0,,好美味
Dialogue: 0,0:05:40.80,0:05:42.40,Default,,0,0,0,,可以嗎
Dialogue: 0,0:05:42.47,0:05:43.87,Default,,0,0,0,,我也要
Dialogue: 0,0:05:43.94,0:05:47.28,Default,,0,0,0,,這樣嗎
Dialogue: 0,0:05:47.34,0:05:49.14,Default,,0,0,0,,要喝的嗎
Dialogue: 0,0:05:49.21,0:05:53.21,Default,,0,0,0,,我也要\N肚子餓了吧
Dialogue: 0,0:05:53.21,0:05:56.22,Default,,0,0,0,,來吧
Dialogue: 0,0:05:56.28,0:05:58.09,Default,,0,0,0,,吃吧
Dialogue: 0,0:05:58.15,0:05:59.95,Default,,0,0,0,,這是什麼
Dialogue: 0,0:06:00.02,0:06:02.82,Default,,0,0,0,,我拍著哦
Dialogue: 0,0:06:02.89,0:06:04.36,Default,,0,0,0,,不行啊
Dialogue: 0,0:06:04.49,0:06:06.09,Default,,0,0,0,,可以吧
Dialogue: 0,0:06:06.16,0:06:08.43,Default,,0,0,0,,不行啊
Dialogue: 0,0:06:08.50,0:06:10.23,Default,,0,0,0,,灑了嗎
Dialogue: 0,0:06:10.30,0:06:12.90,Default,,0,0,0,,不行啊
Dialogue: 0,0:06:13.03,0:06:14.10,Default,,0,0,0,,沒事的
Dialogue: 0,0:06:14.17,0:06:17.04,Default,,0,0,0,,我也想吃的
Dialogue: 0,0:06:17.04,0:06:19.04,Default,,0,0,0,,這裡濕了沒辦法吧
Dialogue: 0,0:06:19.04,0:06:21.31,Default,,0,0,0,,爸爸先吃了嗎
Dialogue: 0,0:06:21.31,0:06:22.78,Default,,0,0,0,,不是的
Dialogue: 0,0:06:22.84,0:06:23.98,Default,,0,0,0,,只是這裡灌了我才吃的
Dialogue: 0,0:06:23.98,0:06:25.25,Default,,0,0,0,,好狡猾啊
Dialogue: 0,0:06:25.25,0:06:26.91,Default,,0,0,0,,沒有
Dialogue: 0,0:06:26.91,0:06:27.65,Default,,0,0,0,,好狡猾啊
Dialogue: 0,0:06:27.65,0:06:29.85,Default,,0,0,0,,要嘛
Dialogue: 0,0:06:29.92,0:06:30.92,Default,,0,0,0,,我要
Dialogue: 0,0:06:30.99,0:06:32.45,Default,,0,0,0,,幫忙吧
Dialogue: 0,0:06:32.52,0:06:34.66,Default,,0,0,0,,我就在這裡吧
Dialogue: 0,0:06:37.19,0:06:39.66,Default,,0,0,0,,好好拍
Dialogue: 0,0:06:42.33,0:06:42.86,Default,,0,0,0,,不錯
Dialogue: 0,0:06:42.86,0:06:45.00,Default,,0,0,0,,不錯
Dialogue: 0,0:06:45.53,0:06:47.00,Default,,0,0,0,,姐姐
Dialogue: 0,0:06:47.07,0:06:48.94,Default,,0,0,0,,怎麼了\N還有嗎
Dialogue: 0,0:06:48.94,0:06:50.20,Default,,0,0,0,,久等了
Dialogue: 0,0:06:50.27,0:06:54.61,Default,,0,0,0,,墊一下吧
Dialogue: 0,0:06:54.68,0:06:55.54,Default,,0,0,0,,快點吧
Dialogue: 0,0:06:55.61,0:06:57.35,Default,,0,0,0,,那裡
Dialogue: 0,0:06:59.28,0:07:01.15,Default,,0,0,0,,幾張
Dialogue: 0,0:07:01.22,0:07:03.62,Default,,0,0,0,,打開吧
Dialogue: 0,0:07:03.62,0:07:04.42,Default,,0,0,0,,就是這樣
Dialogue: 0,0:07:04.49,0:07:06.02,Default,,0,0,0,,快點啊\N對不起
Dialogue: 0,0:07:06.22,0:07:08.49,Default,,0,0,0,,來吧
Dialogue: 0,0:07:08.56,0:07:09.29,Default,,0,0,0,,好大啊
Dialogue: 0,0:07:09.29,0:07:11.76,Default,,0,0,0,,好大
Dialogue: 0,0:07:12.76,0:07:14.56,Default,,0,0,0,,嚇到了
Dialogue: 0,0:07:14.76,0:07:16.23,Default,,0,0,0,,盤子
Dialogue: 0,0:07:17.90,0:07:20.30,Default,,0,0,0,,給你
Dialogue: 0,0:07:20.37,0:07:22.70,Default,,0,0,0,,好厲害
Dialogue: 0,0:07:22.77,0:07:23.70,Default,,0,0,0,,好美味的樣子啊
Dialogue: 0,0:07:24.11,0:07:26.04,Default,,0,0,0,,我也想吃啊
Dialogue: 0,0:07:26.04,0:07:28.58,Default,,0,0,0,,來吧
Dialogue: 0,0:07:28.64,0:07:30.58,Default,,0,0,0,,對不起
Dialogue: 0,0:07:30.65,0:07:32.38,Default,,0,0,0,,來吧
Dialogue: 0,0:07:32.45,0:07:33.31,Default,,0,0,0,,給我吧，
Dialogue: 0,0:07:33.38,0:07:35.18,Default,,0,0,0,,我拍一下
Dialogue: 0,0:07:35.18,0:07:36.45,Default,,0,0,0,,好的
Dialogue: 0,0:07:36.52,0:07:38.12,Default,,0,0,0,,好熱啊
