Dialogue: 0,0:00:03.16,0:00:06.15,ASS,,0,0,0,,老样子不怎么跟丈夫交流啊
Dialogue: 0,0:00:06.97,0:00:10.03,ASS,,0,0,0,,是啊\N本来我们话题就少呢
Dialogue: 0,0:00:10.84,0:00:12.57,ASS,,0,0,0,,还有\N你们一直没性爱吧
Dialogue: 0,0:00:14.97,0:00:18.17,ASS,,0,0,0,,是啊\N（山岸 琴音）
Dialogue: 0,0:00:27.65,0:00:29.18,ASS,,0,0,0,,又是约会网站啊
Dialogue: 0,0:00:30.32,0:00:33.66,ASS,,0,0,0,,聊天真有趣呢\N你也注册吧
Dialogue: 0,0:00:34.66,0:00:36.39,ASS,,0,0,0,,我算啦
Dialogue: 0,0:00:37.86,0:00:43.06,ASS,,0,0,0,,为了缓解婚后的压力\N还是注册聊天释放压力吧
Dialogue: 0,0:00:44.47,0:00:46.06,ASS,,0,0,0,,我没兴趣呢
Dialogue: 0,0:00:49.74,0:00:50.67,ASS,,0,0,0,,明明超有趣呢
Dialogue: 0,0:01:00.82,0:01:07.02,ASS,,0,0,0,,我决定注册试试看啦
Dialogue: 0,0:03:23.30,0:03:25.76,ASS,,0,0,0,,明明朋友迷恋约会网站\N我应该阻止的呢
Dialogue: 0,0:03:26.63,0:03:28.43,ASS,,0,0,0,,我应该引起警戒呢
Dialogue: 0,0:03:34.77,0:03:42.58,ASS,,0,0,0,,（平日1点到5点我会变成女人）
Dialogue: 0,0:03:49.32,0:03:51.05,ASS,,0,0,0,,对了\N联系不动产公司了吗
Dialogue: 0,0:03:52.73,0:03:54.25,ASS,,0,0,0,,还没呢\N记得联系啦
Dialogue: 0,0:03:55.53,0:03:58.59,ASS,,0,0,0,,找不到买主的话\N我们无法搬家吧
Dialogue: 0,0:03:59.73,0:04:04.80,ASS,,0,0,0,,知道啦 我走啦\N路上慢点
Dialogue: 0,0:05:55.25,0:05:57.37,ASS,,0,0,0,,对了\N不动产公司那边有消息了吗
Dialogue: 0,0:05:59.25,0:05:59.98,ASS,,0,0,0,,明天过来呢
Dialogue: 0,0:06:00.85,0:06:01.98,ASS,,0,0,0,,好的
Dialogue: 0,0:06:23.48,0:06:26.93,ASS,,0,0,0,,你好\N我是山下不动产公司的业务员
Dialogue: 0,0:06:30.42,0:06:31.07,ASS,,0,0,0,,怎么啦
Dialogue: 0,0:06:33.49,0:06:34.47,ASS,,0,0,0,,没事 请进
Dialogue: 0,0:06:35.75,0:06:36.48,ASS,,0,0,0,,打扰
Dialogue: 0,0:07:08.05,0:07:09.52,ASS,,0,0,0,,请喝茶\N谢谢
Dialogue: 0,0:07:12.06,0:07:13.79,ASS,,0,0,0,,老房子啦
Dialogue: 0,0:07:14.93,0:07:17.52,ASS,,0,0,0,,还是半价出售吧
Dialogue: 0,0:07:19.33,0:07:25.00,ASS,,0,0,0,,夫妻两个人住的话非常不错呢\N我觉得很快能卖出去呢
Dialogue: 0,0:07:26.87,0:07:27.74,ASS,,0,0,0,,拜托
Dialogue: 0,0:07:30.14,0:07:35.21,ASS,,0,0,0,,我们会按照您的要求卖出好价钱\N请放心
Dialogue: 0,0:07:36.28,0:07:37.34,ASS,,0,0,0,,请多关照
Dialogue: 0,0:07:40.09,0:07:44.35,ASS,,0,0,0,,关于厨房的整理问题\N我还有问题再确认清楚
Dialogue: 0,0:08:56.43,0:08:58.23,ASS,,0,0,0,,你好\N你好
Dialogue: 0,0:09:02.90,0:09:04.03,ASS,,0,0,0,,怎么啦
Dialogue: 0,0:09:07.24,0:09:09.83,ASS,,0,0,0,,有客户想买房子我过来看下
Dialogue: 0,0:09:12.58,0:09:16.78,ASS,,0,0,0,,好的 请进\N打扰
Dialogue: 0,0:09:46.41,0:09:47.40,ASS,,0,0,0,,有事吗
Dialogue: 0,0:09:49.15,0:09:50.34,ASS,,0,0,0,,没事
Dialogue: 0,0:10:16.98,0:10:18.97,ASS,,0,0,0,,不动产公司还没找到合适买主吗
Dialogue: 0,0:10:21.71,0:10:24.18,ASS,,0,0,0,,还有好多的细节问题呢
Dialogue: 0,0:10:25.38,0:10:26.37,ASS,,0,0,0,,真麻烦啊
Dialogue: 0,0:10:35.59,0:10:36.19,ASS,,0,0,0,,谁来的短信呀
Dialogue: 0,0:10:38.60,0:10:40.19,ASS,,0,0,0,,大学同学
Dialogue: 0,0:11:13.83,0:11:16.10,ASS,,0,0,0,,请喝咖啡\N谢谢
Dialogue: 0,0:11:31.65,0:11:32.64,ASS,,0,0,0,,有事吗
Dialogue: 0,0:11:34.19,0:11:35.05,ASS,,0,0,0,,没事
Dialogue: 0,0:11:36.45,0:11:40.52,ASS,,0,0,0,,上次的事情考虑的如何呢
Dialogue: 0,0:11:41.73,0:11:43.92,ASS,,0,0,0,,我了解过好多呢
Dialogue: 0,0:11:45.13,0:11:46.53,ASS,,0,0,0,,不知道该怎么办呢
Dialogue: 0,0:11:47.47,0:11:49.06,ASS,,0,0,0,,交给你们吧
Dialogue: 0,0:11:50.47,0:11:52.99,ASS,,0,0,0,,好的\N真的可以吗
Dialogue: 0,0:11:54.61,0:11:59.34,ASS,,0,0,0,,这件事情交给拓也\N我们非常放心呢
Dialogue: 0,0:12:04.75,0:12:05.81,ASS,,0,0,0,,怎么啦
Dialogue: 0,0:12:08.29,0:12:11.28,ASS,,0,0,0,,刚才称呼我 拓也
Dialogue: 0,0:12:15.63,0:12:18.43,ASS,,0,0,0,,夫人就是优子啊
Dialogue: 0,0:12:21.97,0:12:22.76,ASS,,0,0,0,,抱歉
Dialogue: 0,0:12:26.17,0:12:29.44,ASS,,0,0,0,,我们在约会网站聊天的吧
Dialogue: 0,0:12:31.78,0:12:32.44,ASS,,0,0,0,,是我
Dialogue: 0,0:12:36.65,0:12:45.39,ASS,,0,0,0,,我对夫人是一见钟情呢
Dialogue: 0,0:12:47.13,0:12:49.59,ASS,,0,0,0,,我知道这样的做法不对呢
Dialogue: 0,0:12:50.60,0:12:52.39,ASS,,0,0,0,,抱歉\N让我好为难呢
Dialogue: 0,0:12:54.07,0:12:56.26,ASS,,0,0,0,,我结婚啦\N我知道啊
Dialogue: 0,0:13:18.49,0:13:22.43,ASS,,0,0,0,,抱歉\N我无法控制自己的情绪
Dialogue: 0,0:13:36.24,0:13:40.18,ASS,,0,0,0,,我不管你是否结婚呢
Dialogue: 0,0:13:49.99,0:13:51.79,ASS,,0,0,0,,我对夫儿一见钟情呀
Dialogue: 0,0:14:13.81,0:14:15.54,ASS,,0,0,0,,胸部真丰满啊
Dialogue: 0,0:14:18.62,0:14:21.08,ASS,,0,0,0,,胸部让我看看啊
Dialogue: 0,0:14:33.83,0:14:37.03,ASS,,0,0,0,,不妙啊 这样让我好为难呢\N怎么啦
Dialogue: 0,0:14:38.57,0:14:43.03,ASS,,0,0,0,,为什么为难啊\N我结婚啦 我知道啊
Dialogue: 0,0:14:52.58,0:14:55.18,ASS,,0,0,0,,乳头好可爱啊
Dialogue: 0,0:14:57.19,0:14:58.66,ASS,,0,0,0,,不讨厌我吧
Dialogue: 0,0:15:11.27,0:15:14.00,ASS,,0,0,0,,别舔乳头啦\N怎么啦
Dialogue: 0,0:15:23.01,0:15:24.28,ASS,,0,0,0,,优子
Dialogue: 0,0:15:31.02,0:15:32.49,ASS,,0,0,0,,不想要爽吗
Dialogue: 0,0:15:35.23,0:15:38.56,ASS,,0,0,0,,乳头爽吗
Dialogue: 0,0:15:43.10,0:15:45.04,ASS,,0,0,0,,我说不出口啊
Dialogue: 0,0:15:45.97,0:15:47.84,ASS,,0,0,0,,说不出口就是爽啊
Dialogue: 0,0:15:49.51,0:15:50.70,ASS,,0,0,0,,爽吗
Dialogue: 0,0:15:52.38,0:15:53.37,ASS,,0,0,0,,不爽吗
Dialogue: 0,0:16:11.46,0:16:12.79,ASS,,0,0,0,,我们一起变爽吧
Dialogue: 0,0:16:13.87,0:16:15.06,ASS,,0,0,0,,好吗
Dialogue: 0,0:16:24.54,0:16:25.60,ASS,,0,0,0,,胸部真丰满啊
Dialogue: 0,0:16:31.55,0:16:32.88,ASS,,0,0,0,,乳头勃起啦
Dialogue: 0,0:16:53.04,0:16:54.37,ASS,,0,0,0,,我们一起变爽吧
Dialogue: 0,0:17:12.26,0:17:13.92,ASS,,0,0,0,,别舔乳头啦
Dialogue: 0,0:17:19.33,0:17:19.99,ASS,,0,0,0,,爽吗
Dialogue: 0,0:17:31.81,0:17:33.47,ASS,,0,0,0,,接下来 挑逗小穴啦
Dialogue: 0,0:17:35.75,0:17:36.87,ASS,,0,0,0,,不妙啊
Dialogue: 0,0:17:40.29,0:17:44.88,ASS,,0,0,0,,不妙啊 小穴变热啦
Dialogue: 0,0:17:58.77,0:18:00.36,ASS,,0,0,0,,爽吗
Dialogue: 0,0:18:14.72,0:18:19.92,ASS,,0,0,0,,不要不要啊
Dialogue: 0,0:18:35.14,0:18:36.20,ASS,,0,0,0,,小穴爽吗
Dialogue: 0,0:18:48.89,0:18:51.15,ASS,,0,0,0,,阴蒂好敏感吧
Dialogue: 0,0:19:21.79,0:19:23.19,ASS,,0,0,0,,好色情的味道啊
Dialogue: 0,0:19:35.33,0:19:36.20,ASS,,0,0,0,,爽吗
Dialogue: 0,0:20:06.23,0:20:07.49,ASS,,0,0,0,,看我
Dialogue: 0,0:20:31.92,0:20:33.45,ASS,,0,0,0,,我忍不住啦
Dialogue: 0,0:20:46.80,0:20:48.07,ASS,,0,0,0,,想舔小穴啦
Dialogue: 0,0:21:23.98,0:21:26.38,ASS,,0,0,0,,小穴爽吗\N好爽啊
Dialogue: 0,0:21:39.26,0:21:41.92,ASS,,0,0,0,,小穴湿哒哒啦
Dialogue: 0,0:21:43.93,0:21:45.59,ASS,,0,0,0,,为什么湿透啦
Dialogue: 0,0:21:48.73,0:21:50.33,ASS,,0,0,0,,因为你舔小穴啦
Dialogue: 0,0:21:52.47,0:21:55.74,ASS,,0,0,0,,阴蒂
Dialogue: 0,0:21:56.47,0:21:58.27,ASS,,0,0,0,,小穴湿哒哒啦
Dialogue: 0,0:22:09.62,0:22:11.28,ASS,,0,0,0,,丈夫能让你爽吗
Dialogue: 0,0:22:13.29,0:22:14.09,ASS,,0,0,0,,不能啊
Dialogue: 0,0:22:15.16,0:22:17.02,ASS,,0,0,0,,其实超想要性爱吧
Dialogue: 0,0:22:23.77,0:22:24.96,ASS,,0,0,0,,想要了吧
Dialogue: 0,0:22:27.77,0:22:28.90,ASS,,0,0,0,,憋得我好难受啦
Dialogue: 0,0:22:37.72,0:22:39.58,ASS,,0,0,0,,手指插入小穴啦
Dialogue: 0,0:23:04.48,0:23:05.41,ASS,,0,0,0,,要去了
Dialogue: 0,0:23:06.88,0:23:07.81,ASS,,0,0,0,,不妙啊
Dialogue: 0,0:23:10.41,0:23:11.28,ASS,,0,0,0,,不妙啊
Dialogue: 0,0:23:30.23,0:23:31.22,ASS,,0,0,0,,好爽啊
Dialogue: 0,0:23:51.86,0:23:52.65,ASS,,0,0,0,,要去啦
Dialogue: 0,0:24:03.53,0:24:04.52,ASS,,0,0,0,,淫水真多啊
Dialogue: 0,0:24:07.27,0:24:08.26,ASS,,0,0,0,,真色情呢
Dialogue: 0,0:24:11.21,0:24:12.47,ASS,,0,0,0,,好色情的淫水啊
Dialogue: 0,0:24:18.62,0:24:20.35,ASS,,0,0,0,,让我们一起变爽吧
Dialogue: 0,0:24:24.96,0:24:26.29,ASS,,0,0,0,,喜欢性爱吧
Dialogue: 0,0:24:27.56,0:24:28.75,ASS,,0,0,0,,胸罩脱掉啦
Dialogue: 0,0:24:30.90,0:24:32.69,ASS,,0,0,0,,身体转过去\N屁股翘高啊
Dialogue: 0,0:24:34.83,0:24:36.82,ASS,,0,0,0,,夫人色情的部位全部让我看见啦
Dialogue: 0,0:24:39.57,0:24:40.90,ASS,,0,0,0,,翘高点啊
Dialogue: 0,0:24:46.44,0:24:47.64,ASS,,0,0,0,,一清二楚呢
Dialogue: 0,0:24:54.52,0:24:55.78,ASS,,0,0,0,,真害羞呢
Dialogue: 0,0:24:56.65,0:24:57.92,ASS,,0,0,0,,想要变爽吧
Dialogue: 0,0:25:01.19,0:25:02.06,ASS,,0,0,0,,不想要爽吗
Dialogue: 0,0:25:03.73,0:25:05.06,ASS,,0,0,0,,我想变爽呢
Dialogue: 0,0:25:17.48,0:25:21.88,ASS,,0,0,0,,别乱动啊\N好好享受吧
Dialogue: 0,0:25:28.35,0:25:31.62,ASS,,0,0,0,,夹击的真紧啊
Dialogue: 0,0:25:38.90,0:25:41.63,ASS,,0,0,0,,G点爽吗\N真爽啊
Dialogue: 0,0:25:59.92,0:26:01.51,ASS,,0,0,0,,想要继续挑逗吗
Dialogue: 0,0:26:04.99,0:26:06.12,ASS,,0,0,0,,想要变爽吧
Dialogue: 0,0:26:10.26,0:26:11.73,ASS,,0,0,0,,2根手指插入
Dialogue: 0,0:26:13.60,0:26:15.00,ASS,,0,0,0,,2根手指插入啦
Dialogue: 0,0:26:32.22,0:26:33.88,ASS,,0,0,0,,脸部露出来啊
Dialogue: 0,0:26:42.16,0:26:44.42,ASS,,0,0,0,,怎么啦\N要去啦
Dialogue: 0,0:27:08.72,0:27:09.45,ASS,,0,0,0,,不妙啊
Dialogue: 0,0:27:17.33,0:27:18.73,ASS,,0,0,0,,好多淫水啊
Dialogue: 0,0:27:24.20,0:27:25.07,ASS,,0,0,0,,我忍不住啦
Dialogue: 0,0:27:30.34,0:27:34.14,ASS,,0,0,0,,双腿劈开\N小穴变得好敏感呢
Dialogue: 0,0:27:36.41,0:27:38.40,ASS,,0,0,0,,掰开大点呢
Dialogue: 0,0:27:42.35,0:27:43.41,ASS,,0,0,0,,咕叽咕叽的声音啦
Dialogue: 0,0:28:11.38,0:28:14.11,ASS,,0,0,0,,小穴爽吗\N真爽呢
Dialogue: 0,0:28:31.00,0:28:33.80,ASS,,0,0,0,,屁股翘高点吧
Dialogue: 0,0:28:38.01,0:28:39.00,ASS,,0,0,0,,看我
Dialogue: 0,0:28:46.02,0:28:47.21,ASS,,0,0,0,,咕叽咕叽的声音啦
Dialogue: 0,0:28:49.62,0:28:52.49,ASS,,0,0,0,,要去了\N爽吗
Dialogue: 0,0:29:08.44,0:29:09.50,ASS,,0,0,0,,湿哒哒的淫水啊
Dialogue: 0,0:29:16.18,0:29:17.77,ASS,,0,0,0,,舌头伸出来
Dialogue: 0,0:29:50.48,0:29:51.41,ASS,,0,0,0,,夫人好色情呢
Dialogue: 0,0:30:01.56,0:30:03.03,ASS,,0,0,0,,让我爽吧
Dialogue: 0,0:30:16.37,0:30:17.31,ASS,,0,0,0,,看我
Dialogue: 0,0:30:23.05,0:30:24.04,ASS,,0,0,0,,抚摸肉棒啦
Dialogue: 0,0:30:26.58,0:30:28.11,ASS,,0,0,0,,怎么样啦\N真粗大呢
Dialogue: 0,0:30:33.26,0:30:35.38,ASS,,0,0,0,,抚摸肉棒真爽呢
Dialogue: 0,0:30:37.53,0:30:38.59,ASS,,0,0,0,,真硬啊
Dialogue: 0,0:30:46.80,0:30:48.80,ASS,,0,0,0,,真爽呢
Dialogue: 0,0:31:08.76,0:31:09.62,ASS,,0,0,0,,好爽呢
Dialogue: 0,0:31:23.24,0:31:24.10,ASS,,0,0,0,,裤子脱掉啦
Dialogue: 0,0:31:32.38,0:31:35.78,ASS,,0,0,0,,夫人 舔乳头啦
Dialogue: 0,0:31:45.00,0:31:46.26,ASS,,0,0,0,,舔肉棒吧
Dialogue: 0,0:32:46.79,0:32:47.59,ASS,,0,0,0,,真爽呢
Dialogue: 0,0:33:13.55,0:33:14.14,ASS,,0,0,0,,舔肉棒吧
Dialogue: 0,0:33:28.70,0:33:29.56,ASS,,0,0,0,,好爽呢 夫人
Dialogue: 0,0:33:34.44,0:33:35.96,ASS,,0,0,0,,手臂揉捏肉棒呀
Dialogue: 0,0:33:40.78,0:33:41.30,ASS,,0,0,0,,看我
Dialogue: 0,0:34:19.22,0:34:19.94,ASS,,0,0,0,,真爽呢
Dialogue: 0,0:34:26.76,0:34:28.22,ASS,,0,0,0,,我们互舔吧
Dialogue: 0,0:34:29.43,0:34:30.29,ASS,,0,0,0,,趴下
Dialogue: 0,0:34:33.56,0:34:39.30,ASS,,0,0,0,,转圈 屁股给我
Dialogue: 0,0:34:50.71,0:34:53.05,ASS,,0,0,0,,肉棒含进嘴巴吧
Dialogue: 0,0:35:54.85,0:35:55.78,ASS,,0,0,0,,要去啦
Dialogue: 0,0:36:18.94,0:36:19.59,ASS,,0,0,0,,我忍不住啦
Dialogue: 0,0:36:22.21,0:36:23.60,ASS,,0,0,0,,让我插入吧
Dialogue: 0,0:36:29.01,0:36:29.74,ASS,,0,0,0,,躺好啦
Dialogue: 0,0:36:34.75,0:36:38.81,ASS,,0,0,0,,夫人 想要肉棒插入吧
Dialogue: 0,0:36:39.96,0:36:41.22,ASS,,0,0,0,,我想要啊\N想要吧
Dialogue: 0,0:36:47.70,0:36:48.49,ASS,,0,0,0,,插入啦
Dialogue: 0,0:37:00.71,0:37:01.70,ASS,,0,0,0,,真爽呢
Dialogue: 0,0:37:24.74,0:37:26.86,ASS,,0,0,0,,爽吗\N好爽啊
Dialogue: 0,0:37:36.75,0:37:37.94,ASS,,0,0,0,,爽吗
Dialogue: 0,0:37:59.57,0:38:01.23,ASS,,0,0,0,,爽吗\N真爽呢
Dialogue: 0,0:38:03.91,0:38:08.71,ASS,,0,0,0,,要去啦
Dialogue: 0,0:38:22.33,0:38:23.31,ASS,,0,0,0,,看我
