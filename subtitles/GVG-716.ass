Dialogue: 0,0:00:09.11,0:00:12.04,Default,,0000,0000,0000,,（正片开始）
Dialogue: 0,0:00:12.04,0:00:15.11,Default,,0000,0000,0000,,我儿子秀太郎脑袋是还不错
Dialogue: 0,0:00:15.11,0:00:18.05,Default,,0000,0000,0000,,但是太爱恶作剧了
Dialogue: 0,0:00:18.05,0:00:21.12,Default,,0000,0000,0000,,都不认真念书
Dialogue: 0,0:00:24.06,0:00:27.13,Default,,0000,0000,0000,,听说妳过去提升了很多学生的成绩
Dialogue: 0,0:00:28.06,0:00:31.00,Default,,0000,0000,0000,,是很能干的家庭教师
Dialogue: 0,0:00:32.06,0:00:35.00,Default,,0000,0000,0000,,能让我们家秀太郎认真念书吗
Dialogue: 0,0:00:35.00,0:00:38.07,Default,,0000,0000,0000,,交给我吧
Dialogue: 0,0:00:39.00,0:00:42.07,Default,,0000,0000,0000,,我一定会提升秀太郎的成绩
Dialogue: 0,0:00:44.08,0:00:47.01,Default,,0000,0000,0000,,（她虽然能干但却有非常危险的性癖）
Dialogue: 0,0:01:10.10,0:01:13.04,Default,,0000,0000,0000,,秀太郎好慢啊
Dialogue: 0,0:01:19.04,0:01:22.11,Default,,0000,0000,0000,,老师我迟到了
Dialogue: 0,0:01:23.05,0:01:26.12,Default,,0000,0000,0000,,是秀太郎的弟弟吗
Dialogue: 0,0:01:26.12,0:01:29.05,Default,,0000,0000,0000,,我要跟秀太郎念书了
Dialogue: 0,0:01:30.12,0:01:33.06,Default,,0000,0000,0000,,知道他在哪吗妳在说什么
Dialogue: 0,0:01:34.13,0:01:37.06,Default,,0000,0000,0000,,我就是秀太郎啊
Dialogue: 0,0:01:38.00,0:01:41.07,Default,,0000,0000,0000,,你就是秀太郎
Dialogue: 0,0:01:45.07,0:01:48.01,Default,,0000,0000,0000,,老师
Dialogue: 0,0:01:48.01,0:01:51.08,Default,,0000,0000,0000,,没是原来妳就就是秀太郎
Dialogue: 0,0:01:52.01,0:01:55.08,Default,,0000,0000,0000,,请多指教
Dialogue: 0,0:02:00.02,0:02:03.09,Default,,0000,0000,0000,,老师妳脸好红
Dialogue: 0,0:02:06.02,0:02:09.09,Default,,0000,0000,0000,,别在意
Dialogue: 0,0:02:09.09,0:02:12.03,Default,,0000,0000,0000,,开始上课吧
Dialogue: 0,0:02:14.03,0:02:17.10,Default,,0000,0000,0000,,（没错她非常喜欢欢正太）
Dialogue: 0,0:02:20.04,0:02:23.11,Default,,0000,0000,0000,,接着学习人类如何诞生
Dialogue: 0,0:02:25.11,0:02:28.05,Default,,0000,0000,0000,,我开始念了
Dialogue: 0,0:02:28.05,0:02:31.12,Default,,0000,0000,0000,,受精和受精卵
Dialogue: 0,0:02:31.12,0:02:34.05,Default,,0000,0000,0000,,女性的卵好跟男性的糈好结合后
Dialogue: 0,0:02:35.12,0:02:38.06,Default,,0000,0000,0000,,称为受精卵
Dialogue: 0,0:02:42.06,0:02:45.00,Default,,0000,0000,0000,,受谠卵宫在好宫成长
Dialogue: 0,0:02:46.06,0:02:49.00,Default,,0000,0000,0000,,子宫里的小孩会通过胎盘
Dialogue: 0,0:02:50.07,0:02:53.00,Default,,0000,0000,0000,,传送成长所需的养分
Dialogue: 0,0:02:55.01,0:02:58.08,Default,,0000,0000,0000,,受精卵后约38周小孩会出生
Dialogue: 0,0:03:02.08,0:03:05.02,Default,,0000,0000,0000,,听得懂吗
Dialogue: 0,0:03:07.02,0:03:10.09,Default,,0000,0000,0000,,老师 这好无聊
Dialogue: 0,0:03:11.02,0:03:14.09,Default,,0000,0000,0000,,这根本没用
Dialogue: 0,0:03:14.09,0:03:17.03,Default,,0000,0000,0000,,说什么啊这很重要喔
Dialogue: 0,0:03:18.10,0:03:21.03,Default,,0000,0000,0000,,下次可能会考
Dialogue: 0,0:03:22.10,0:03:25.04,Default,,0000,0000,0000,,不用了我将来要当运动选手
Dialogue: 0,0:03:30.11,0:03:33.04,Default,,0000,0000,0000,,'不用学习他行
Dialogue: 0,0:03:34.11,0:03:37.05,Default,,0000,0000,0000,,老师来玩吧 不行
Dialogue: 0,0:03:38.12,0:03:41.05,Default,,0000,0000,0000,,你爸妈他说你想做还是能做到
Dialogue: 0,0:03:43.05,0:03:46.12,Default,,0000,0000,0000,,加油吧
Dialogue: 0,0:03:49.06,0:03:52.00,Default,,0000,0000,0000,,如果妳这样讲的话能加油吗
Dialogue: 0,0:03:53.06,0:03:56.00,Default,,0000,0000,0000,,稍微的话
Dialogue: 0,0:03:56.00,0:03:59.07,Default,,0000,0000,0000,,读书的确可能对未来没有帮助
Dialogue: 0,0:03:59.07,0:04:02.01,Default,,0000,0000,0000,,但考试成结对将来很有帮助喔
Dialogue: 0,0:04:02.01,0:04:05.08,Default,,0000,0000,0000,,努力念书吧
Dialogue: 0,0:04:08.01,0:04:11.08,Default,,0000,0000,0000,,接着是这样
Dialogue: 0,0:04:11.08,0:04:14.02,Default,,0000,0000,0000,,男性跟受精
Dialogue: 0,0:04:16.02,0:04:19.09,Default,,0000,0000,0000,,就是这样
Dialogue: 0,0:04:19.09,0:04:25.10,Default,,0000,0000,0000,,男性的睾丸会制造精好
Dialogue: 0,0:04:26.03,0:04:29.10,Default,,0000,0000,0000,,刚才他教过
Dialogue: 0,0:04:29.10,0:04:32.04,Default,,0000,0000,0000,,人会在母亲的好宫里长大并出生
Dialogue: 0,0:04:41.11,0:04:44.05,Default,,0000,0000,0000,,关于男性跟女性受精
Dialogue: 0,0:04:45.12,0:04:48.05,Default,,0000,0000,0000,,男性的睾丸会制造精好
Dialogue: 0,0:04:50.06,0:04:53.12,Default,,0000,0000,0000,,女性的卵巢宫制造卵好
Dialogue: 0,0:04:54.06,0:04:57.00,Default,,0000,0000,0000,,总之先来个小考吧
Dialogue: 0,0:05:00.07,0:05:03.00,Default,,0000,0000,0000,,咦什么 有听课话这些很简单啦
Dialogue: 0,0:05:12.08,0:05:15.01,Default,,0000,0000,0000,,跟老师一起做吧
Dialogue: 0,0:05:29.03,0:05:32.10,Default,,0000,0000,0000,,刚才有听的话很简单啦
Dialogue: 0,0:05:35.03,0:05:38.10,Default,,0000,0000,0000,,从上面开始
Dialogue: 0,0:05:39.04,0:05:42.11,Default,,0000,0000,0000,,这我知道这样对吧
Dialogue: 0,0:05:44.11,0:05:47.05,Default,,0000,0000,0000,,你写什么
Dialogue: 0,0:05:51.05,0:05:54.12,Default,,0000,0000,0000,,不对 你有听嘛？
Dialogue: 0,0:05:54.12,0:05:57.06,Default,,0000,0000,0000,,要认真点啦
Dialogue: 0,0:05:58.12,0:06:01.06,Default,,0000,0000,0000,,不是吗 刚才没讲这个啊
Dialogue: 0,0:06:04.00,0:06:07.07,Default,,0000,0000,0000,,这样比较好懂啊
Dialogue: 0,0:06:07.07,0:06:10.00,Default,,0000,0000,0000,,要认真点
Dialogue: 0,0:06:11.07,0:06:14.01,Default,,0000,0000,0000,,这边他有讲对吧
Dialogue: 0,0:06:14.01,0:06:17.08,Default,,0000,0000,0000,,受精后的卵好
Dialogue: 0,0:06:23.08,0:06:26.02,Default,,0000,0000,0000,,没错吧
Dialogue: 0,0:06:26.02,0:06:29.09,Default,,0000,0000,0000,,女性的小穴跟男性的肉棒
Dialogue: 0,0:06:29.09,0:06:32.02,Default,,0000,0000,0000,,在体内结合后叫受精
Dialogue: 0,0:06:32.02,0:06:35.09,Default,,0000,0000,0000,,受精的卵叫中出
Dialogue: 0,0:06:36.03,0:06:39.10,Default,,0000,0000,0000,,对啦?
Dialogue: 0,0:06:39.10,0:06:42.03,Default,,0000,0000,0000,,接着呢
Dialogue: 0,0:06:47.11,0:06:50.04,Default,,0000,0000,0000,,对吧
Dialogue: 0,0:06:52.04,0:06:55.11,Default,,0000,0000,0000,,这刚才教过呀
Dialogue: 0,0:06:57.12,0:07:00.05,Default,,0000,0000,0000,,好宫里充满了淫氷
Dialogue: 0,0:07:02.05,0:07:05.12,Default,,0000,0000,0000,,刚才没说这个啊
Dialogue: 0,0:07:05.12,0:07:08.06,Default,,0000,0000,0000,,学校里大家都这样记的啦
Dialogue: 0,0:07:08.06,0:07:11.00,Default,,0000,0000,0000,,为什么要写这个
Dialogue: 0,0:07:12.06,0:07:15.00,Default,,0000,0000,0000,,这个呢 这简单
Dialogue: 0,0:07:26.08,0:07:29.01,Default,,0000,0000,0000,,秀太郎不能写这个
Dialogue: 0,0:07:31.02,0:07:34.09,Default,,0000,0000,0000,,精液太难懂了所以写交啊
Dialogue: 0,0:07:34.09,0:07:37.02,Default,,0000,0000,0000,,知道精液就写精液啊 我不会写汉字
Dialogue: 0,0:07:39.02,0:07:42.09,Default,,0000,0000,0000,,用平假名他行啦
Dialogue: 0,0:07:42.09,0:07:45.03,Default,,0000,0000,0000,,受精卵呢 这简单
Dialogue: 0,0:07:50.10,0:07:53.04,Default,,0000,0000,0000,,不对啦 对呀
Dialogue: 0,0:07:53.04,0:07:56.11,Default,,0000,0000,0000,,在好宫周围充满了淫水
Dialogue: 0,0:07:58.11,0:08:01.05,Default,,0000,0000,0000,,不是啦
Dialogue: 0,0:08:01.05,0:08:04.12,Default,,0000,0000,0000,,男性的精巢制造了交
Dialogue: 0,0:08:07.05,0:08:10.12,Default,,0000,0000,0000,,女性的卵巢制造了淫水
Dialogue: 0,0:08:14.13,0:08:17.06,Default,,0000,0000,0000,,秀太郎不能这样讲
Dialogue: 0,0:08:18.00,0:08:21.07,Default,,0000,0000,0000,,受精卵会在小穴里成长
Dialogue: 0,0:08:24.00,0:08:27.07,Default,,0000,0000,0000,,不对啦
Dialogue: 0,0:08:27.07,0:08:30.01,Default,,0000,0000,0000,,最后一题
Dialogue: 0,0:08:32.01,0:08:35.08,Default,,0000,0000,0000,,这个是这样
Dialogue: 0,0:08:42.02,0:08:45.09,Default,,0000,0000,0000,,你在哪学这些的
Dialogue: 0,0:08:49.09,0:08:52.03,Default,,0000,0000,0000,,做爱后
Dialogue: 0,0:08:52.03,0:08:55.10,Default,,0000,0000,0000,,精好就会和卵好结合为受精卵
Dialogue: 0,0:08:59.10,0:09:02.04,Default,,0000,0000,0000,,然后创造生命 不对啦
Dialogue: 0,0:09:04.04,0:09:07.11,Default,,0000,0000,0000,,秀太郎    认真点
Dialogue: 0,0:09:07.11,0:09:10.05,Default,,0000,0000,0000,,我写完了   不对
Dialogue: 0,0:09:11.12,0:09:14.05,Default,,0000,0000,0000,,明明就是对的    再重新想想
Dialogue: 0,0:09:16.05,0:09:19.12,Default,,0000,0000,0000,,明明就对了
Dialogue: 0,0:09:25.00,0:09:28.07,Default,,0000,0000,0000,,这样怎么记得住   重头再来一次
Dialogue: 0,0:09:32.07,0:09:35.01,Default,,0000,0000,0000,,女性的卵巢  小穴
Dialogue: 0,0:09:36.07,0:09:39.01,Default,,0000,0000,0000,,不对 男性的精好 肉棒
Dialogue: 0,0:09:40.08,0:09:43.01,Default,,0000,0000,0000,,不对 结合后叫受精 中出
Dialogue: 0,0:09:47.02,0:09:50.09,Default,,0000,0000,0000,,不对 叫受精卵
Dialogue: 0,0:09:54.09,0:09:57.03,Default,,0000,0000,0000,,你写什么
Dialogue: 0,0:09:58.10,0:10:01.03,Default,,0000,0000,0000,,不多写点不记得呀
Dialogue: 0,0:10:04.10,0:10:07.04,Default,,0000,0000,0000,,"	秀太郎
Dialogue: 0,0:10:07.04,0:10:10.11,Default,,0000,0000,0000,,不能写这些
Dialogue: 0,0:10:10.11,0:10:13.04,Default,,0000,0000,0000,,不是肉棒跟小穴吗
Dialogue: 0,0:10:14.11,0:10:17.05,Default,,0000,0000,0000,,是卵好跟精好
Dialogue: 0,0:10:17.05,0:10:20.12,Default,,0000,0000,0000,,精好跟卵好结合叫中出
Dialogue: 0,0:10:22.12,0:10:25.06,Default,,0000,0000,0000,,叫受精卵
Dialogue: 0,0:10:26.12,0:10:29.06,Default,,0000,0000,0000,,认真写 我不会写汉字
Dialogue: 0,0:10:33.06,0:10:36.00,Default,,0000,0000,0000,,这好难记
Dialogue: 0,0:10:41.07,0:10:44.01,Default,,0000,0000,0000,,不能这样讲
Dialogue: 0,0:10:44.01,0:10:47.08,Default,,0000,0000,0000,,精好的汉字好难写
Dialogue: 0,0:10:51.08,0:10:54.02,Default,,0000,0000,0000,,我哪知道啊
Dialogue: 0,0:10:57.09,0:11:00.02,Default,,0000,0000,0000,,不就是无套做爱中出吗
Dialogue: 0,0:11:01.09,0:11:04.03,Default,,0000,0000,0000,,不是这样	-
Dialogue: 0,0:11:04.03,0:11:07.10,Default,,0000,0000,0000,,这不检查不行吧
Dialogue: 0,0:11:12.04,0:11:15.11,Default,,0000,0000,0000,,老师怎么了’
Dialogue: 0,0:11:15.11,0:11:18.04,Default,,0000,0000,0000,,我有问题_
Dialogue: 0,0:11:18.04,0:11:21.11,Default,,0000,0000,0000,,生小孩要怎么做
Dialogue: 0,0:11:25.12,0:11:28.05,Default,,0000,0000,0000,,怎么做
Dialogue: 0,0:11:28.05,0:11:31.12,Default,,0000,0000,0000,,男人跟女人
Dialogue: 0,0:11:32.06,0:11:35.13,Default,,0000,0000,0000,,这样吗
Dialogue: 0,0:11:35.13,0:11:38.06,Default,,0000,0000,0000,,不行啦
Dialogue: 0,0:11:40.06,0:11:43.00,Default,,0000,0000,0000,,在学校男生跟女生都这样戳
Dialogue: 0,0:11:48.07,0:11:51.01,Default,,0000,0000,0000,,学校哪有教这种事
Dialogue: 0,0:12:06.09,0:12:09.03,Default,,0000,0000,0000,,这样对吧
Dialogue: 0,0:12:27.04,0:12:30.11,Default,,0000,0000,0000,,不要这样
Dialogue: 0,0:12:31.05,0:12:34.12,Default,,0000,0000,0000,,老师 怎么变硬了
Dialogue: 0,0:12:49.07,0:12:52.00,Default,,0000,0000,0000,,为什么变硬了
Dialogue: 0,0:13:05.08,0:13:08.02,Default,,0000,0000,0000,,好好玩喔
Dialogue: 0,0:13:24.04,0:13:27.10,Default,,0000,0000,0000,,越来越硬了
Dialogue: 0,0:13:31.11,0:13:34.05,Default,,0000,0000,0000,,好好玩
Dialogue: 0,0:13:39.12,0:13:42.05,Default,,0000,0000,0000,,还有这样对吧
Dialogue: 0,0:13:50.06,0:13:53.00,Default,,0000,0000,0000,,不能摸这里嘛
Dialogue: 0,0:13:54.07,0:13:57.00,Default,,0000,0000,0000,,不是摸这里吗
Dialogue: 0,0:14:04.08,0:14:07.01,Default,,0000,0000,0000,,这样不舒服吗 不能摸
Dialogue: 0,0:14:11.02,0:14:14.09,Default,,0000,0000,0000,,为什么不行
Dialogue: 0,0:14:16.09,0:14:19.02,Default,,0000,0000,0000,,不是摸这里吗
Dialogue: 0,0:14:24.10,0:14:27.03,Default,,0000,0000,0000,,这边叫小穴对吧
Dialogue: 0,0:14:28.10,0:14:31.04,Default,,0000,0000,0000,,刚才不是学过吗?
Dialogue: 0,0:14:44.12,0:14:47.05,Default,,0000,0000,0000,,老师 怎么了
Dialogue: 0,0:14:51.06,0:14:54.13,Default,,0000,0000,0000,,秀太郎 你想知道男人跟女人怎么做吗
Dialogue: 0,0:14:59.06,0:15:02.00,Default,,0000,0000,0000,,让老师教你吧
Dialogue: 0,0:15:05.07,0:15:08.01,Default,,0000,0000,0000,,手伸出来
Dialogue: 0,0:15:10.01,0:15:13.08,Default,,0000,0000,0000,,像这样摸胸部
Dialogue: 0,0:15:16.01,0:15:19.08,Default,,0000,0000,0000,,这样摸才正确哦
Dialogue: 0,0:15:20.02,0:15:23.09,Default,,0000,0000,0000,,知道了嘛
Dialogue: 0,0:15:25.09,0:15:28.03,Default,,0000,0000,0000,,变硬了对吧
Dialogue: 0,0:15:29.09,0:15:32.03,Default,,0000,0000,0000,,这叫乳头
Dialogue: 0,0:15:34.03,0:15:37.10,Default,,0000,0000,0000,,摸了会很舒服喔
Dialogue: 0,0:15:39.10,0:15:42.04,Default,,0000,0000,0000,,尽情摸吧
Dialogue: 0,0:15:46.04,0:15:49.11,Default,,0000,0000,0000,,做得很好
Dialogue: 0,0:15:57.12,0:16:00.06,Default,,0000,0000,0000,,把这脱掉吧
Dialogue: 0,0:16:02.06,0:16:05.00,Default,,0000,0000,0000,,想看胸部吗
Dialogue: 0,0:16:10.07,0:16:13.00,Default,,0000,0000,0000,,像刚才这样摸
Dialogue: 0,0:16:18.08,0:16:21.01,Default,,0000,0000,0000,,用摸的
Dialogue: 0,0:16:25.02,0:16:28.09,Default,,0000,0000,0000,,做得很好
Dialogue: 0,0:16:31.02,0:16:34.09,Default,,0000,0000,0000,,捏乳头
Dialogue: 0,0:16:37.03,0:16:40.10,Default,,0000,0000,0000,,好舒服
Dialogue: 0,0:16:41.03,0:16:44.10,Default,,0000,0000,0000,,不会痛吗
Dialogue: 0,0:16:54.11,0:16:57.05,Default,,0000,0000,0000,,这才是正确的摸法
Dialogue: 0,0:17:02.12,0:17:05.06,Default,,0000,0000,0000,,知道了吗
Dialogue: 0,0:17:05.06,0:17:08.13,Default,,0000,0000,0000,,还有什么 小穴跟肉棒
Dialogue: 0,0:17:22.01,0:17:25.08,Default,,0000,0000,0000,,受精需要小穴
Dialogue: 0,0:17:35.09,0:17:38.02,Default,,0000,0000,0000,,摸摸看
Dialogue: 0,0:17:45.10,0:17:48.03,Default,,0000,0000,0000,,是不是湿了 为什么湿了
Dialogue: 0,0:17:51.10,0:17:54.04,Default,,0000,0000,0000,,因为秀太郎摸了我的胸部
Dialogue: 0,0:17:57.11,0:18:00.04,Default,,0000,0000,0000,,小穴 才会流出淫水喔
Dialogue: 0,0:18:02.05,0:18:05.12,Default,,0000,0000,0000,,这就是淫水吗
Dialogue: 0,0:18:07.12,0:18:10.05,Default,,0000,0000,0000,,实际看看吧
Dialogue: 0,0:18:19.00,0:18:22.07,Default,,0000,0000,0000,,仔细看
Dialogue: 0,0:18:25.00,0:18:28.07,Default,,0000,0000,0000,,这边就是小穴哦
Dialogue: 0,0:18:31.01,0:18:34.08,Default,,0000,0000,0000,,湿了吗    好湿
Dialogue: 0,0:18:37.01,0:18:40.08,Default,,0000,0000,0000,,这就是淫水   湿透了耶
Dialogue: 0,0:18:45.02,0:18:48.09,Default,,0000,0000,0000,,听得到声音吗
Dialogue: 0,0:18:52.10,0:18:55.03,Default,,0000,0000,0000,,这对受精来说很重要喔
Dialogue: 0,0:19:04.11,0:19:07.04,Default,,0000,0000,0000,,仔细看
Dialogue: 0,0:19:11.05,0:19:14.12,Default,,0000,0000,0000,,又看到这边嘛
Dialogue: 0,0:19:19.06,0:19:22.13,Default,,0000,0000,0000,,那是什么
Dialogue: 0,0:19:22.13,0:19:25.06,Default,,0000,0000,0000,,这叫阴蒂
Dialogue: 0,0:19:26.00,0:19:29.07,Default,,0000,0000,0000,,摸了会流出硬多的淫水哦
Dialogue: 0,0:19:32.00,0:19:35.07,Default,,0000,0000,0000,,要记住喔
Dialogue: 0,0:19:40.01,0:19:43.08,Default,,0000,0000,0000,,为了受精   知道要怎么做吗
Dialogue: 0,0:19:45.08,0:19:48.02,Default,,0000,0000,0000,,知道了
Dialogue: 0,0:19:48.02,0:19:51.09,Default,,0000,0000,0000,,这次换你来摸
Dialogue: 0,0:19:55.09,0:19:58.03,Default,,0000,0000,0000,,像刚才那样摸
Dialogue: 0,0:20:07.10,0:20:10.04,Default,,0000,0000,0000,,就是这边
Dialogue: 0,0:20:12.04,0:20:15.11,Default,,0000,0000,0000,,这边是阴蒂
Dialogue: 0,0:20:21.12,0:20:24.05,Default,,0000,0000,0000,,继续摸
Dialogue: 0,0:20:28.06,0:20:31.00,Default,,0000,0000,0000,,就是这里
Dialogue: 0,0:20:35.00,0:20:38.07,Default,,0000,0000,0000,,好舒服
Dialogue: 0,0:20:48.08,0:20:51.02,Default,,0000,0000,0000,,老师怎么了
Dialogue: 0,0:20:52.08,0:20:55.02,Default,,0000,0000,0000,,刚才说过精还需要甚么
Dialogue: 0,0:21:01.03,0:21:04.09,Default,,0000,0000,0000,,女人的小穴跟男人的肉棒
Dialogue: 0,0:21:07.03,0:21:10.10,Default,,0000,0000,0000,,老师干嘛摸这里
Dialogue: 0,0:21:10.10,0:21:13.04,Default,,0000,0000,0000,,你不是学吗
Dialogue: 0,0:21:15.04,0:21:18.11,Default,,0000,0000,0000,,腰抬起来
Dialogue: 0,0:21:23.05,0:21:26.12,Default,,0000,0000,0000,,得认这边制造很多精液
Dialogue: 0,0:21:48.01,0:21:51.08,Default,,0000,0000,0000,,好害羞
Dialogue: 0,0:21:51.08,0:21:54.01,Default,,0000,0000,0000,,秀太郎的肉棒好可爱
Dialogue: 0,0:21:57.08,0:22:00.02,Default,,0000,0000,0000,,我不知道
Dialogue: 0,0:22:03.09,0:22:06.02,Default,,0000,0000,0000,,告诉老师怎么做会舒服
Dialogue: 0,0:22:09.09,0:22:12.03,Default,,0000,0000,0000,,我没摸过   是吗
Dialogue: 0,0:22:14.03,0:22:17.10,Default,,0000,0000,0000,,让老师摸吧
Dialogue: 0,0:22:23.11,0:22:26.04,Default,,0000,0000,0000,,刚说过    不制造精液没办法受精
Dialogue: 0,0:22:31.12,0:22:34.05,Default,,0000,0000,0000,,我们来制造硬多糈液吧
Dialogue: 0,0:22:38.06,0:22:41.13,Default,,0000,0000,0000,,你的乳头舒服吗
Dialogue: 0,0:22:43.13,0:22:46.06,Default,,0000,0000,0000,,好痒
Dialogue: 0,0:22:48.07,0:22:51.00,Default,,0000,0000,0000,,不只是摸女人的乳头
Dialogue: 0,0:22:53.00,0:22:56.07,Default,,0000,0000,0000,,他要这样帮男人摸哦
Dialogue: 0,0:23:01.01,0:23:04.08,Default,,0000,0000,0000,,舒服吗    感觉好怪
Dialogue: 0,0:23:13.02,0:23:16.09,Default,,0000,0000,0000,,舒服吗
Dialogue: 0,0:23:16.09,0:23:19.03,Default,,0000,0000,0000,,麻麻的
Dialogue: 0,0:23:26.10,0:23:29.04,Default,,0000,0000,0000,,这表示舒服喔
Dialogue: 0,0:23:35.05,0:23:38.12,Default,,0000,0000,0000,,好舒服
Dialogue: 0,0:23:56.00,0:23:59.07,Default,,0000,0000,0000,,老师   好舒服
Dialogue: 0,0:24:01.07,0:24:04.01,Default,,0000,0000,0000,,好舒服的话这里就会制造硬多精液喔
Dialogue: 0,0:24:16.02,0:24:19.09,Default,,0000,0000,0000,,变得好滑
Dialogue: 0,0:24:22.03,0:24:25.10,Default,,0000,0000,0000,,像是老师的小穴一样
Dialogue: 0,0:24:28.03,0:24:31.10,Default,,0000,0000,0000,,秀太郎的肉棒觉得舒服他会变湿
Dialogue: 0,0:24:50.05,0:24:53.12,Default,,0000,0000,0000,,肉棒变得好硬
Dialogue: 0,0:24:57.13,0:25:00.06,Default,,0000,0000,0000,,你看起来好舒服
Dialogue: 0,0:25:03.00,0:25:06.07,Default,,0000,0000,0000,,来复习吧
Dialogue: 0,0:25:07.00,0:25:10.07,Default,,0000,0000,0000,,要怎么摸胸部
Dialogue: 0,0:25:14.08,0:25:17.01,Default,,0000,0000,0000,,对  要摸乳头
Dialogue: 0,0:25:19.02,0:25:22.09,Default,,0000,0000,0000,,好舒服
Dialogue: 0,0:25:26.09,0:25:29.03,Default,,0000,0000,0000,,舒服吗
Dialogue: 0,0:25:33.03,0:25:36.10,Default,,0000,0000,0000,,让我看你可爱的脸
Dialogue: 0,0:25:43.04,0:25:46.11,Default,,0000,0000,0000,,好舒服
Dialogue: 0,0:26:09.07,0:26:12.00,Default,,0000,0000,0000,,好舒服
Dialogue: 0,0:26:31.09,0:26:34.02,Default,,0000,0000,0000,,摸这逛
Dialogue: 0,0:26:46.04,0:26:49.11,Default,,0000,0000,0000,,好可爱
Dialogue: 0,0:26:57.11,0:27:00.05,Default,,0000,0000,0000,,好舒服喔
Dialogue: 0,0:27:01.12,0:27:04.05,Default,,0000,0000,0000,,老师好舒服     好好享受吧
Dialogue: 0,0:27:09.13,0:27:12.06,Default,,0000,0000,0000,,秀太郎好可爱
Dialogue: 0,0:27:18.07,0:27:21.00,Default,,0000,0000,0000,,感觉好怪
Dialogue: 0,0:27:23.01,0:27:26.08,Default,,0000,0000,0000,,不用忍耐没关系喔
Dialogue: 0,0:27:29.01,0:27:32.08,Default,,0000,0000,0000,,老师会仔细看着
Dialogue: 0,0:27:43.03,0:27:46.10,Default,,0000,0000,0000,,秀太郎好可爱
Dialogue: 0,0:27:56.11,0:27:59.04,Default,,0000,0000,0000,,要尿尿了我忍不住
Dialogue: 0,0:28:00.11,0:28:03.05,Default,,0000,0000,0000,,射出来吧
Dialogue: 0,0:28:17.06,0:28:20.00,Default,,0000,0000,0000,,射了好多
Dialogue: 0,0:28:23.07,0:28:26.00,Default,,0000,0000,0000,,这叫精液喔
Dialogue: 0,0:28:28.00,0:28:31.07,Default,,0000,0000,0000,,这对受精是很种要的东西
Dialogue: 0,0:28:41.08,0:28:44.02,Default,,0000,0000,0000,,你看射了这么多
Dialogue: 0,0:28:47.09,0:28:50.03,Default,,0000,0000,0000,,这很重要喔
Dialogue: 0,0:28:53.10,0:28:56.03,Default,,0000,0000,0000,,黏黏的
Dialogue: 0,0:29:12.05,0:29:15.12,Default,,0000,0000,0000,,讨厌   我竟然做这种事
Dialogue: 0,0:29:21.12,0:29:24.06,Default,,0000,0000,0000,,我没资格当老师
Dialogue: 0,0:29:46.08,0:29:49.02,Default,,0000,0000,0000,,今天来学汉字吧
Dialogue: 0,0:29:50.09,0:29:53.02,Default,,0000,0000,0000,,即使汉字一样念法他不一样相同
Dialogue: 0,0:29:55.03,0:29:58.09,Default,,0000,0000,0000,,还有同个汉字意思他不同
Dialogue: 0,0:29:58.09,0:30:01.03,Default,,0000,0000,0000,,比较这个是很有趣哦
Dialogue: 0,0:30:01.03,0:30:04.10,Default,,0000,0000,0000,,来学吧
Dialogue: 0,0:30:04.10,0:30:07.04,Default,,0000,0000,0000,,好麻烦
Dialogue: 0,0:30:07.04,0:30:10.11,Default,,0000,0000,0000,,不会啦学这个很有趣喔
Dialogue: 0,0:30:12.11,0:30:15.05,Default,,0000,0000,0000,,开始吧
Dialogue: 0,0:30:16.11,0:30:19.05,Default,,0000,0000,0000,,我有准备讲义
Dialogue: 0,0:30:20.12,0:30:23.05,Default,,0000,0000,0000,,今天看这个上课
Dialogue: 0,0:30:27.06,0:30:30.13,Default,,0000,0000,0000,,都是汉字不会很难啦
Dialogue: 0,0:30:32.00,0:30:35.07,Default,,0000,0000,0000,,先从两个个字的词开始
Dialogue: 0,0:30:38.00,0:30:41.07,Default,,0000,0000,0000,,然后跟后面做接龙
Dialogue: 0,0:30:46.01,0:30:49.08,Default,,0000,0000,0000,,是这个练习
Dialogue: 0,0:30:55.09,0:30:58.02,Default,,0000,0000,0000,,然后习
Dialogue: 0,0:31:01.09,0:31:04.03,Default,,0000,0000,0000,,习字
Dialogue: 0,0:31:04.03,0:31:07.10,Default,,0000,0000,0000,,还有呢
Dialogue: 0,0:31:08.03,0:31:11.10,Default,,0000,0000,0000,,外交
Dialogue: 0,0:31:12.04,0:31:12.17,Default,,0000,0000,0000,,交字
Dialogue: 0,0:31:17.11,0:31:20.04,Default,,0000,0000,0000,,交流
Dialogue: 0,0:31:20.04,0:31:23.11,Default,,0000,0000,0000,,像这样的文字接龙 好玩吗
Dialogue: 0,0:31:24.05,0:31:27.12,Default,,0000,0000,0000,,从会的地方开始吧
Dialogue: 0,0:31:30.05,0:31:33.12,Default,,0000,0000,0000,,从哪个开始啊
Dialogue: 0,0:31:33.12,0:31:36.06,Default,,0000,0000,0000,,都可以喔  从简单的开始
Dialogue: 0,0:31:40.06,0:31:43.00,Default,,0000,0000,0000,,那20号
Dialogue: 0,0:31:49.01,0:31:52.08,Default,,0000,0000,0000,,好难喔
Dialogue: 0,0:32:02.09,0:32:05.02,Default,,0000,0000,0000,,误爆
Dialogue: 0,0:32:14.10,0:32:17.03,Default,,0000,0000,0000,,这样  秀太郎
Dialogue: 0,0:32:20.10,0:32:23.04,Default,,0000,0000,0000,,这样 他对吧
Dialogue: 0,0:32:25.04,0:32:28.11,Default,,0000,0000,0000,,是没错
Dialogue: 0,0:32:34.12,0:32:37.05,Default,,0000,0000,0000,,老师讨厌爆乳吗
Dialogue: 0,0:32:39.06,0:32:42.13,Default,,0000,0000,0000,,不是讨不讨厌的问题
Dialogue: 0,0:32:46.00,0:32:49.07,Default,,0000,0000,0000,,换个题吧
Dialogue: 0,0:32:50.00,0:32:53.07,Default,,0000,0000,0000,,换哪个
Dialogue: 0,0:33:00.01,0:33:03.08,Default,,0000,0000,0000,,7号
Dialogue: 0,0:33:19.10,0:33:22.03,Default,,0000,0000,0000,,好了
Dialogue: 0,0:33:22.03,0:33:25.10,Default,,0000,0000,0000,,又写这种东西
Dialogue: 0,0:33:29.11,0:33:32.04,Default,,0000,0000,0000,,是没错啦
Dialogue: 0,0:33:32.04,0:33:35.11,Default,,0000,0000,0000,,总有其他的东西可以写吧
Dialogue: 0,0:33:35.11,0:33:38.05,Default,,0000,0000,0000,,是这边吧
Dialogue: 0,0:33:39.12,0:33:42.05,Default,,0000,0000,0000,,上次看到过
Dialogue: 0,0:33:47.12,0:33:50.06,Default,,0000,0000,0000,,秀太郎    不对嘛
Dialogue: 0,0:33:51.13,0:33:54.06,Default,,0000,0000,0000,,乳晕在这边对吧
Dialogue: 0,0:33:58.07,0:34:01.00,Default,,0000,0000,0000,,今天要认真点
Dialogue: 0,0:34:03.01,0:34:06.08,Default,,0000,0000,0000,,接着呢
Dialogue: 0,0:34:06.08,0:34:09.01,Default,,0000,0000,0000,,那5号吧
Dialogue: 0,0:34:10.08,0:34:13.02,Default,,0000,0000,0000,,欠如  这念欠如喔
Dialogue: 0,0:34:21.02,0:34:24.09,Default,,0000,0000,0000,,你会写这个好厉害
Dialogue: 0,0:34:27.03,0:34:30.10,Default,,0000,0000,0000,,好了
Dialogue: 0,0:34:32.10,0:34:35.04,Default,,0000,0000,0000,,不对喔
Dialogue: 0,0:34:35.04,0:34:38.11,Default,,0000,0000,0000,,汉字写错了
Dialogue: 0,0:34:39.04,0:34:42.11,Default,,0000,0000,0000,,这样可以吧 这个意思不一样
Dialogue: 0,0:34:46.12,0:34:49.05,Default,,0000,0000,0000,,这有个口
Dialogue: 0,0:34:53.06,0:34:56.13,Default,,0000,0000,0000,,这个念 女体
Dialogue: 0,0:34:56.13,0:34:59.06,Default,,0000,0000,0000,,那女体加个口就好啊
Dialogue: 0,0:35:00.00,0:35:03.07,Default,,0000,0000,0000,,没有这种字  好难哦
Dialogue: 0,0:35:09.07,0:35:12.01,Default,,0000,0000,0000,,我喜欢女体
Dialogue: 0,0:35:14.01,0:35:17.08,Default,,0000,0000,0000,,不是喜不喜欢的问题
Dialogue: 0,0:35:17.08,0:35:20.02,Default,,0000,0000,0000,,老师的身体就是女体吧
Dialogue: 0,0:35:24.02,0:35:27.09,Default,,0000,0000,0000,,我很喜欢哦
Dialogue: 0,0:35:27.09,0:35:30.03,Default,,0000,0000,0000,,不行  为什么
Dialogue: 0,0:35:30.03,0:35:33.10,Default,,0000,0000,0000,,今天不行 要认真念书
Dialogue: 0,0:35:34.03,0:35:37.10,Default,,0000,0000,0000,,还有昵
Dialogue: 0,0:35:37.10,0:35:40.04,Default,,0000,0000,0000,,都好难喔
Dialogue: 0,0:35:43.11,0:35:46.04,Default,,0000,0000,0000,,慢慢想就好了
Dialogue: 0,0:35:47.11,0:35:50.05,Default,,0000,0000,0000,,30号
Dialogue: 0,0:35:50.05,0:35:53.12,Default,,0000,0000,0000,,恋爱
Dialogue: 0,0:35:56.05,0:35:59.12,Default,,0000,0000,0000,,我不会写这个  写对了
Dialogue: 0,0:36:07.00,0:36:10.07,Default,,0000,0000,0000,,笔顺他对了
Dialogue: 0,0:36:10.07,0:36:13.00,Default,,0000,0000,0000,,想做还是做得到啊
Dialogue: 0,0:36:26.08,0:36:29.02,Default,,0000,0000,0000,,秀太郎
Dialogue: 0,0:36:32.09,0:36:35.02,Default,,0000,0000,0000,,不能写这个
Dialogue: 0,0:36:36.09,0:36:39.03,Default,,0000,0000,0000,,上次不是学过个吗
Dialogue: 0,0:36:41.03,0:36:44.10,Default,,0000,0000,0000,,是没错啦   但不能了写这个
Dialogue: 0,0:36:45.03,0:36:48.10,Default,,0000,0000,0000,,还有不能跟其他人讲   为什么
Dialogue: 0,0:36:49.04,0:36:52.11,Default,,0000,0000,0000,,老师的爱液是从这边流出来吧
Dialogue: 0,0:36:52.11,0:36:55.04,Default,,0000,0000,0000,,不行
Dialogue: 0,0:37:00.12,0:37:03.05,Default,,0000,0000,0000,,妳不是说很很重要吗
Dialogue: 0,0:37:06.12,0:37:09.06,Default,,0000,0000,0000,,这边对吧
Dialogue: 0,0:37:15.06,0:37:18.00,Default,,0000,0000,0000,,老师的爱液要流出来了吗
Dialogue: 0,0:37:37.09,0:37:40.02,Default,,0000,0000,0000,,不行
Dialogue: 0,0:37:40.02,0:37:43.09,Default,,0000,0000,0000,,接着换其他题
Dialogue: 0,0:37:48.03,0:37:51.10,Default,,0000,0000,0000,,写出同样念法的其他单字
Dialogue: 0,0:37:55.10,0:37:58.04,Default,,0000,0000,0000,,这比刚才还难   很简单
Dialogue: 0,0:37:58.04,0:38:01.11,Default,,0000,0000,0000,,像是这个
Dialogue: 0,0:38:01.11,0:38:04.05,Default,,0000,0000,0000,,21号的试验
Dialogue: 0,0:38:14.06,0:38:17.13,Default,,0000,0000,0000,,像是这个
Dialogue: 0,0:38:23.00,0:38:26.07,Default,,0000,0000,0000,,还有25号踏破
Dialogue: 0,0:38:39.02,0:38:42.09,Default,,0000,0000,0000,,同样多的念法
Dialogue: 0,0:38:44.09,0:38:47.02,Default,,0000,0000,0000,,但是汉字不一样
Dialogue: 0,0:38:47.02,0:38:50.09,Default,,0000,0000,0000,,很好玩吧  找一下就有很多哦
Dialogue: 0,0:38:54.10,0:38:57.03,Default,,0000,0000,0000,,来找吧
Dialogue: 0,0:39:01.04,0:39:04.11,Default,,0000,0000,0000,,要从哪个昵
Dialogue: 0,0:39:05.04,0:39:08.11,Default,,0000,0000,0000,,12号吧
Dialogue: 0,0:39:10.11,0:39:13.05,Default,,0000,0000,0000,,朱印
Dialogue: 0,0:39:22.13,0:39:25.06,Default,,0000,0000,0000,,有找到词吗
Dialogue: 0,0:39:32.00,0:39:35.07,Default,,0000,0000,0000,,秀太郎 这个字你从哪里学的
Dialogue: 0,0:39:37.07,0:39:40.01,Default,,0000,0000,0000,,忘了
Dialogue: 0,0:39:44.01,0:39:47.08,Default,,0000,0000,0000,,老师知道意思吗
Dialogue: 0,0:39:47.08,0:39:50.02,Default,,0000,0000,0000,,知道是知道
Dialogue: 0,0:39:50.02,0:39:53.09,Default,,0000,0000,0000,,这是什么意思
Dialogue: 0,0:39:54.02,0:39:57.09,Default,,0000,0000,0000,,这个嘛
Dialogue: 0,0:39:58.03,0:40:01.10,Default,,0000,0000,0000,,老师应该知道吧
Dialogue: 0,0:40:02.03,0:40:05.10,Default,,0000,0000,0000,,知道是知道
Dialogue: 0,0:40:07.10,0:40:10.04,Default,,0000,0000,0000,,就是指自己的那里
Dialogue: 0,0:40:10.04,0:40:13.11,Default,,0000,0000,0000,,哪里
Dialogue: 0,0:40:18.05,0:40:21.12,Default,,0000,0000,0000,,女生的话就是摸小穴
Dialogue: 0,0:40:26.06,0:40:29.13,Default,,0000,0000,0000,,小穴
Dialogue: 0,0:40:30.06,0:40:33.00,Default,,0000,0000,0000,,是啊
Dialogue: 0,0:40:34.06,0:40:37.00,Default,,0000,0000,0000,,男人的话就是摸
Dialogue: 0,0:40:40.07,0:40:43.01,Default,,0000,0000,0000,,哪里
Dialogue: 0,0:40:50.08,0:40:53.02,Default,,0000,0000,0000,,鸡巴
Dialogue: 0,0:40:54.08,0:40:57.02,Default,,0000,0000,0000,,用手摸
Dialogue: 0,0:40:58.09,0:41:01.02,Default,,0000,0000,0000,,这就叫手淫
Dialogue: 0,0:41:01.02,0:41:04.09,Default,,0000,0000,0000,,原来是这样啊
Dialogue: 0,0:41:06.10,0:41:09.03,Default,,0000,0000,0000,,这叫手淫喔
Dialogue: 0,0:41:10.10,0:41:13.04,Default,,0000,0000,0000,,原来如此
Dialogue: 0,0:41:14.10,0:41:17.04,Default,,0000,0000,0000,,认真点念书吧
Dialogue: 0,0:41:19.04,0:41:22.11,Default,,0000,0000,0000,,知逭这是什么吗
Dialogue: 0,0:41:24.11,0:41:27.05,Default,,0000,0000,0000,,9号
Dialogue: 0,0:41:30.12,0:41:33.06,Default,,0000,0000,0000,,9号是归投
Dialogue: 0,0:41:54.01,0:41:57.08,Default,,0000,0000,0000,,对嘛  你写什么呀
Dialogue: 0,0:41:59.08,0:42:02.02,Default,,0000,0000,0000,,这不是念龟头吗
Dialogue: 0,0:42:03.09,0:42:06.02,Default,,0000,0000,0000,,是啊   答对了吗
Dialogue: 0,0:42:06.02,0:42:09.09,Default,,0000,0000,0000,,对了  太好了
Dialogue: 0,0:42:10.03,0:42:13.10,Default,,0000,0000,0000,,龟头是什么
Dialogue: 0,0:42:14.03,0:42:17.10,Default,,0000,0000,0000,,不知道还写吗
Dialogue: 0,0:42:18.03,0:42:21.10,Default,,0000,0000,0000,,爸爸的书跟杂志有写
Dialogue: 0,0:42:25.11,0:42:28.04,Default,,0000,0000,0000,,你看你爸爸的杂志呀
Dialogue: 0,0:42:28.04,0:42:31.11,Default,,0000,0000,0000,,不能这样喔   为什么
Dialogue: 0,0:42:35.12,0:42:38.05,Default,,0000,0000,0000,,那要等长大才能看
Dialogue: 0,0:42:42.06,0:42:45.13,Default,,0000,0000,0000,,我已经是大人了
Dialogue: 0,0:42:51.00,0:42:54.07,Default,,0000,0000,0000,,龟头是什么
Dialogue: 0,0:42:59.01,0:43:02.08,Default,,0000,0000,0000,,男人的
Dialogue: 0,0:43:04.08,0:43:07.02,Default,,0000,0000,0000,,鸡巴
