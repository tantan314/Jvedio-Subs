Dialogue: 0,0:00:04.56,0:00:06.35,Default,,0,0,0,,(BIG BOX)
Dialogue: 0,0:00:06.52,0:00:09.12,Default,,0,0,0,,（高田馬場站）
Dialogue: 0,0:00:35.45,0:00:36.82,Default,,0,0,0,,是高田馬場
Dialogue: 0,0:00:36.95,0:00:38.48,Default,,0,0,0,,有學生在呢
Dialogue: 0,0:00:38.52,0:00:40.58,Default,,0,0,0,,有很多年輕女孩子呢
Dialogue: 0,0:00:41.16,0:00:43.63,Default,,0,0,0,,就這麼看也挺多的
Dialogue: 0,0:00:43.93,0:00:48.46,Default,,0,0,0,,就是那樣 那今天不還是冬天\N還很冷嘛
Dialogue: 0,0:00:48.67,0:00:51.29,Default,,0,0,0,, -很冷呢 -所以我啊
Dialogue: 0,0:00:51.54,0:00:54.94,Default,,0,0,0,, -把這個帶來了 -這是什麼
Dialogue: 0,0:00:55.31,0:00:56.83,Default,,0,0,0,,你看一下
Dialogue: 0,0:01:01.18,0:01:03.61,Default,,0,0,0,, -跟暖寶寶一樣的 -是的
Dialogue: 0,0:01:03.88,0:01:09.91,Default,,0,0,0,,是暖寶寶因為很冷嘛\N就對年輕女孩發放暖寶寶
Dialogue: 0,0:01:10.09,0:01:14.89,Default,,0,0,0,,以此為契機能說上話然後搭訕
Dialogue: 0,0:01:15.13,0:01:17.99,Default,,0,0,0,, -用這個為契機變得友好\N -是的
Dialogue: 0,0:01:18.16,0:01:20.60,Default,,0,0,0,, -也冷說不定正好 -是吧
Dialogue: 0,0:01:20.83,0:01:24.20,Default,,0,0,0,,正好也有很多年輕女孩\N讓我們試試吧
Dialogue: 0,0:01:24.44,0:01:25.90,Default,,0,0,0,,也是
Dialogue: 0,0:01:30.48,0:01:33.67,Default,,0,0,0,, -算了 -不順利呢
Dialogue: 0,0:01:34.85,0:01:40.94,Default,,0,0,0,, -不會討厭白拿暖寶寶嘛\N -不會討厭的
Dialogue: 0,0:01:41.55,0:01:43.54,Default,,0,0,0,, -讓我們繼續吧 -是呢
Dialogue: 0,0:01:43.72,0:01:46.35,Default,,0,0,0,,小姐姐我們在發暖寶瀆\N需要嗎
Dialogue: 0,0:01:49.46,0:01:51.09,Default,,0,0,0,,又這樣
Dialogue: 0,0:01:51.30,0:01:54.13,Default,,0,0,0,,我們在發暖寶寶小姐姐
Dialogue: 0,0:01:54.27,0:01:57.46,Default,,0,0,0,,我們在發暖寶寶免費的哦
Dialogue: 0,0:01:57.84,0:01:59.74,Default,,0,0,0,,我們在發暖寶寶
Dialogue: 0,0:02:08.88,0:02:10.91,Default,,0,0,0,,小姐姐我們在發暖寶寶
Dialogue: 0,0:02:15.75,0:02:17.58,Default,,0,0,0,,要暖寶寶嗎
Dialogue: 0,0:02:18.56,0:02:20.82,Default,,0,0,0,,不要嗎 暖寶寶
Dialogue: 0,0:02:22.19,0:02:23.72,Default,,0,0,0,,過去吧
Dialogue: 0,0:02:24.36,0:02:25.89,Default,,0,0,0,,不妙
Dialogue: 0,0:02:26.60,0:02:28.06,Default,,0,0,0,,很可愛呢
Dialogue: 0,0:02:35.41,0:02:36.87,Default,,0,0,0,,不行啊
Dialogue: 0,0:02:39.31,0:02:43.01,Default,,0,0,0,, -這樣是要放棄嗎\N -放棄啊
Dialogue: 0,0:02:43.58,0:02:45.71,Default,,0,0,0,,那個女孩有點
Dialogue: 0,0:03:22.49,0:03:24.25,Default,,0,0,0,,不好意思 你好
Dialogue: 0,0:03:24.96,0:03:28.15,Default,,0,0,0,,感謝你收下暖寶寶
Dialogue: 0,0:03:28.46,0:03:30.98,Default,,0,0,0,,正好需要暖寶寶
Dialogue: 0,0:03:31.13,0:03:32.72,Default,,0,0,0,,太好了
Dialogue: 0,0:03:32.73,0:03:34.89,Default,,0,0,0,,今天確實很冷啊
Dialogue: 0,0:03:34.93,0:03:36.33,Default,,0,0,0,,再來一個
Dialogue: 0,0:03:37.77,0:03:42.60,Default,,0,0,0,,我們的網上節目\N正好有發放暖寶寶的企劃
Dialogue: 0,0:03:42.64,0:03:48.91,Default,,0,0,0,,今天很冷嘛就想對在這寒冷中\N還在努力的各位發放
Dialogue: 0,0:03:49.18,0:03:51.01,Default,,0,0,0,,小姐姐非常感謝你收下
Dialogue: 0,0:03:51.32,0:03:53.68,Default,,0,0,0,, -很高興 -真的高興
Dialogue: 0,0:03:54.49,0:03:56.32,Default,,0,0,0,,然後順便啊
Dialogue: 0,0:03:56.75,0:04:00.16,Default,,0,0,0,,想知道是怎樣的人會收下
Dialogue: 0,0:04:00.32,0:04:03.12,Default,,0,0,0,,也有對收下的人進行採訪
Dialogue: 0,0:04:03.43,0:04:06.99,Default,,0,0,0,,如果可以的話\N能回應我們的採訪嗎
Dialogue: 0,0:04:08.10,0:04:09.90,Default,,0,0,0,, -可以嗎 -非常感謝
Dialogue: 0,0:04:10.00,0:04:13.20,Default,,0,0,0,, -好溫柔 -非常溫柔啊
Dialogue: 0,0:04:14.81,0:04:17.57,Default,,0,0,0,,有暖寶寶這裡也很冷嘛
Dialogue: 0,0:04:17.78,0:04:20.61,Default,,0,0,0,,附近有個採訪室
Dialogue: 0,0:04:20.98,0:04:26.04,Default,,0,0,0,,可以在那裡稍微進行\N5 10分鐘左右的採訪嗎
Dialogue: 0,0:04:29.45,0:04:30.89,Default,,0,0,0,,再來一個
Dialogue: 0,0:04:33.26,0:04:34.82,Default,,0,0,0,, -怎麼樣 -我知道了
Dialogue: 0,0:04:34.83,0:04:37.26,Default,,0,0,0,, -非常感謝 -非常感謝
Dialogue: 0,0:04:40.60,0:04:43.00,Default,,0,0,0,,請坐這裡
Dialogue: 0,0:04:43.30,0:04:46.43,Default,,0,0,0,,外面很冷麻\N在暖和點的地方比較好
Dialogue: 0,0:04:46.74,0:04:48.87,Default,,0,0,0,,在那麼冷的地方也採訪不了
Dialogue: 0,0:04:49.04,0:04:50.91,Default,,0,0,0,,這裡怎麼樣
Dialogue: 0,0:04:52.58,0:04:55.38,Default,,0,0,0,, -在緊張嗎 -要掉了
Dialogue: 0,0:04:55.55,0:04:59.81,Default,,0,0,0,,因為只有我們兩個\N要是能放鬆一點就好了
Dialogue: 0,0:05:00.15,0:05:03.55,Default,,0,0,0,,雖然不是朋友關係\N適當的聊一聊吧
Dialogue: 0,0:05:05.26,0:05:07.88,Default,,0,0,0,,這麼看非常較小呢
Dialogue: 0,0:05:11.30,0:05:13.02,Default,,0,0,0,,可以問下身高嗎
Dialogue: 0,0:05:14.13,0:05:16.07,Default,,0,0,0,,147
Dialogue: 0,0:05:16.30,0:05:18.86,Default,,0,0,0,, -真的嗎 -好較小
Dialogue: 0,0:05:19.97,0:05:22.50,Default,,0,0,0,,容貌很可愛呢
Dialogue: 0,0:05:24.14,0:05:26.70,Default,,0,0,0,,就會以這樣的感覺進行採訪
Dialogue: 0,0:05:27.58,0:05:31.05,Default,,0,0,0,,那麼事不宜遲\N可以開始採訪嗎
Dialogue: 0,0:05:32.32,0:05:34.88,Default,,0,0,0,, -那麼請多指教 -請多指教
Dialogue: 0,0:05:37.69,0:05:40.21,Default,,0,0,0,,那麼先從名字開始
Dialogue: 0,0:05:41.83,0:05:44.42,Default,,0,0,0,,可以先問下你的名字嗎
Dialogue: 0,0:05:45.10,0:05:46.50,Default,,0,0,0,,苗依
Dialogue: 0,0:05:46.66,0:05:50.29,Default,,0,0,0,, -苗依小姐 -順便一問
Dialogue: 0,0:05:50.74,0:05:53.07,Default,,0,0,0,,剛才是正在做什麼
Dialogue: 0,0:05:54.87,0:05:57.53,Default,,0,0,0,,從學校回來
Dialogue: 0,0:05:58.08,0:06:00.51,Default,,0,0,0,, -從學校回來 -是學生啊
Dialogue: 0,0:06:00.68,0:06:02.48,Default,,0,0,0,,是的 大學生
Dialogue: 0,0:06:05.05,0:06:06.91,Default,,0,0,0,,年齡現在多少歲
Dialogue: 0,0:06:07.32,0:06:08.79,Default,,0,0,0,,21
Dialogue: 0,0:06:10.42,0:06:12.45,Default,,0,0,0,,那麼是3年級嗎
Dialogue: 0,0:06:14.16,0:06:19.32,Default,,0,0,0,,說白了我以為是18歲左右
Dialogue: 0,0:06:19.63,0:06:23.33,Default,,0,0,0,, -是的呢 -因為這麼的
Dialogue: 0,0:06:24.00,0:06:25.99,Default,,0,0,0,,好嬌小呢
Dialogue: 0,0:06:26.47,0:06:33.78,Default,,0,0,0,, -大學生啊\N -感覺喝酒的時候會被人說
Dialogue: 0,0:06:33.88,0:06:35.47,Default,,0,0,0,,實際上怎麼樣
Dialogue: 0,0:06:36.28,0:06:39.61,Default,,0,0,0,,我不怎麼喝酒的
Dialogue: 0,0:06:39.95,0:06:43.98,Default,,0,0,0,,社團的酒會開到很晚呢
Dialogue: 0,0:06:44.32,0:06:46.15,Default,,0,0,0,, -我都不去的 -不去啊
Dialogue: 0,0:06:48.69,0:06:54.03,Default,,0,0,0,,去居酒屋絕對會被確認年齡
Dialogue: 0,0:06:54.30,0:06:56.06,Default,,0,0,0,,會被確認的樣子
Dialogue: 0,0:06:58.04,0:07:02.30,Default,,0,0,0,,這樣子深夜在外面\N感覺都會被人說
Dialogue: 0,0:07:03.61,0:07:05.24,Default,,0,0,0,,有什麼嗎
Dialogue: 0,0:07:06.81,0:07:08.47,Default,,0,0,0,, -沒有 -沒有啊
Dialogue: 0,0:07:08.61,0:07:12.11,Default,,0,0,0,,感覺說不定會被當成大小姐
Dialogue: 0,0:07:12.32,0:07:18.35,Default,,0,0,0,,什麼那個專業是什麼
Dialogue: 0,0:07:20.19,0:07:21.89,Default,,0,0,0,,教育系
Dialogue: 0,0:07:23.73,0:07:28.36,Default,,0,0,0,,教育系啊\N那將來的目標是當老師嗎
Dialogue: 0,0:07:28.57,0:07:29.90,Default,,0,0,0,,是的
Dialogue: 0,0:07:30.84,0:07:35.30,Default,,0,0,0,,但與其說老師\N感覺會被當成學生
Dialogue: 0,0:07:36.24,0:07:39.68,Default,,0,0,0,, -就身高而言 -是這樣呢
Dialogue: 0,0:07:42.28,0:07:44.65,Default,,0,0,0,,學科可以告訴我嗎
Dialogue: 0,0:07:49.55,0:07:52.11,Default,,0,0,0,,保育類的
Dialogue: 0,0:07:53.59,0:07:57.39,Default,,0,0,0,,這樣啊 不是中學或者高中
Dialogue: 0,0:07:57.63,0:08:03.23,Default,,0,0,0,,很小的孩子的老師啊
Dialogue: 0,0:08:04.54,0:08:05.93,Default,,0,0,0,,你喜歡小孩嗎
Dialogue: 0,0:08:08.37,0:08:10.03,Default,,0,0,0,,算喜歡吧
Dialogue: 0,0:08:12.81,0:08:13.90,Default,,0,0,0,,想要被教學呢
Dialogue: 0,0:08:13.91,0:08:17.24,Default,,0,0,0,,這麼溫柔的樣子
Dialogue: 0,0:08:17.45,0:08:19.88,Default,,0,0,0,,我也好想被教學呢
Dialogue: 0,0:08:19.98,0:08:22.48,Default,,0,0,0,, -如果是幼兒園的時候\N -是啊
Dialogue: 0,0:08:25.02,0:08:27.18,Default,,0,0,0,,感覺不會被發火
Dialogue: 0,0:08:27.33,0:08:30.92,Default,,0,0,0,,對小孩子的話\N有時候非得發火才行嘛
Dialogue: 0,0:08:31.70,0:08:33.69,Default,,0,0,0,,老師身體接觸
Dialogue: 0,0:08:36.33,0:08:38.06,Default,,0,0,0,,這個怎麼樣
Dialogue: 0,0:08:38.67,0:08:40.93,Default,,0,0,0,,如果是小孩的話
Dialogue: 0,0:08:41.94,0:08:43.91,Default,,0,0,0,,是小孩就沒問題
Dialogue: 0,0:08:44.71,0:08:49.65,Default,,0,0,0,, -那這樣也可以啊\N -身體接觸摸是吧
Dialogue: 0,0:08:50.25,0:08:53.68,Default,,0,0,0,, -那個沒問題嗎\N -如果是小孩的話
Dialogue: 0,0:08:53.85,0:08:55.28,Default,,0,0,0,,是大人的話
Dialogue: 0,0:08:56.12,0:08:59.42,Default,,0,0,0,,那個有點果然
Dialogue: 0,0:08:59.72,0:09:03.82,Default,,0,0,0,,對不起等下
Dialogue: 0,0:09:04.23,0:09:10.53,Default,,0,0,0,, -沒什麼深意 -開玩笑的
Dialogue: 0,0:09:10.57,0:09:12.13,Default,,0,0,0,, -對不起 -不好意思
Dialogue: 0,0:09:12.27,0:09:14.80,Default,,0,0,0,,沒那個意思
Dialogue: 0,0:09:15.27,0:09:17.76,Default,,0,0,0,,就稍微問一下
Dialogue: 0,0:09:21.55,0:09:23.48,Default,,0,0,0,,是獨自生活嗎
Dialogue: 0,0:09:24.22,0:09:25.72,Default,,0,0,0,,是的
Dialogue: 0,0:09:27.75,0:09:30.59,Default,,0,0,0,,那麼平時會自己做飯嗎
Dialogue: 0,0:09:31.42,0:09:33.39,Default,,0,0,0,,不怎麼做呢
Dialogue: 0,0:09:34.56,0:09:36.72,Default,,0,0,0,,那麼買現成的嗎
Dialogue: 0,0:09:39.40,0:09:41.99,Default,,0,0,0,,喜歡食物是什麼
Dialogue: 0,0:09:43.10,0:09:47.00,Default,,0,0,0,, -肉 -喜歡揉啊
Dialogue: 0,0:09:47.41,0:09:51.21,Default,,0,0,0,,烤肉嗎喜歡什麼部位
Dialogue: 0,0:09:51.41,0:09:53.90,Default,,0,0,0,, -膽 -不錯呢
Dialogue: 0,0:09:54.08,0:09:56.21,Default,,0,0,0,,膽確實很好吃呢
Dialogue: 0,0:09:56.78,0:09:59.51,Default,,0,0,0,, -喜歡膽 -喜歡膽
Dialogue: 0,0:09:59.65,0:10:01.85,Default,,0,0,0,,那個地方有很多美味的店吧
Dialogue: 0,0:10:02.29,0:10:05.15,Default,,0,0,0,, -我不是很清楚 -真的嗎
Dialogue: 0,0:10:05.46,0:10:06.75,Default,,0,0,0,,我來告訴你吧
Dialogue: 0,0:10:10.13,0:10:12.93,Default,,0,0,0,, -我也想一起去 -想去呢
Dialogue: 0,0:10:13.16,0:10:15.96,Default,,0,0,0,,和朋友不去那些地方嗎
Dialogue: 0,0:10:17.54,0:10:19.83,Default,,0,0,0,,我沒朋友
Dialogue: 0,0:10:20.00,0:10:22.00,Default,,0,0,0,, -騙人 -騙人的吧
Dialogue: 0,0:10:22.31,0:10:28.30,Default,,0,0,0,,一般都有朋友吧\N而且你看起來挺受歡迎的
Dialogue: 0,0:10:30.95,0:10:33.61,Default,,0,0,0,,真的嗎這個長相
Dialogue: 0,0:10:35.62,0:10:37.99,Default,,0,0,0,,那男朋友呢
Dialogue: 0,0:10:38.16,0:10:40.85,Default,,0,0,0,, -沒有 -沒有啊
Dialogue: 0,0:10:41.26,0:10:43.82,Default,,0,0,0,,騙人絕對有吧
Dialogue: 0,0:10:45.36,0:10:47.13,Default,,0,0,0,,有多久沒有
Dialogue: 0,0:10:49.37,0:10:52.10,Default,,0,0,0,, -半年左右\N -那半年前有的啊
Dialogue: 0,0:10:52.94,0:10:54.96,Default,,0,0,0,, -這樣啊 -算了
Dialogue: 0,0:10:55.27,0:10:59.18,Default,,0,0,0,,那這半年都是一個人\N真的假的
Dialogue: 0,0:10:59.54,0:11:01.57,Default,,0,0,0,,周圍的人會放不下吧
Dialogue: 0,0:11:01.91,0:11:05.35,Default,,0,0,0,, -感覺每周會告白一次\N -確實會的呢
Dialogue: 0,0:11:05.92,0:11:10.22,Default,,0,0,0,, -在學校會被邀請去告白吧\N -完全沒有
Dialogue: 0,0:11:11.29,0:11:12.65,Default,,0,0,0,,沒有嗎
Dialogue: 0,0:11:15.43,0:11:19.42,Default,,0,0,0,,那半年前的男朋友\N是在哪裡認識的
Dialogue: 0,0:11:22.83,0:11:26.60,Default,,0,0,0,, -有點忘記了\N -這樣啊 去異世界了
Dialogue: 0,0:11:29.71,0:11:36.41,Default,,0,0,0,,但雖然這麼說\N但其實還是有邂逅的吧
Dialogue: 0,0:11:37.65,0:11:39.28,Default,,0,0,0,,理想很高之類的
Dialogue: 0,0:11:42.95,0:11:44.15,Default,,0,0,0,,喜歡的類型是
Dialogue: 0,0:11:44.99,0:11:47.65,Default,,0,0,0,,喜歡可愛的人
Dialogue: 0,0:11:48.26,0:11:50.06,Default,,0,0,0,, -可愛的人 -可愛的人
Dialogue: 0,0:11:51.33,0:11:53.73,Default,,0,0,0,,不是帥的是可愛的人
Dialogue: 0,0:11:56.53,0:11:57.97,Default,,0,0,0,,可愛的人
Dialogue: 0,0:11:58.17,0:12:02.14,Default,,0,0,0,,順便問下是怎麼可愛的人
Dialogue: 0,0:12:03.57,0:12:05.67,Default,,0,0,0,,什麼感覺啊
Dialogue: 0,0:12:06.48,0:12:07.88,Default,,0,0,0,,像嬰兒一樣的
Dialogue: 0,0:12:08.55,0:12:12.00,Default,,0,0,0,,嬰兒喜歡愛撒嬌的人嗎
Dialogue: 0,0:12:13.22,0:12:15.69,Default,,0,0,0,,母性很強
Dialogue: 0,0:12:15.89,0:12:19.25,Default,,0,0,0,,有點嬰兒臉的人吧
Dialogue: 0,0:12:20.96,0:12:23.26,Default,,0,0,0,,那他這樣的怎麼樣
Dialogue: 0,0:12:24.63,0:12:26.96,Default,,0,0,0,, -挺可愛的 -真的嗎
Dialogue: 0,0:12:29.00,0:12:31.96,Default,,0,0,0,,可以有嗎 雖然非常大叔
Dialogue: 0,0:12:32.84,0:12:36.27,Default,,0,0,0,, -對不起 -我也喜歡吃烤肉
Dialogue: 0,0:12:36.67,0:12:39.04,Default,,0,0,0,, -挺合得來的 -合得來
Dialogue: 0,0:12:40.81,0:12:43.44,Default,,0,0,0,,感覺好球區挺廣的呢
Dialogue: 0,0:12:44.95,0:12:47.85,Default,,0,0,0,,和多少人交往過
Dialogue: 0,0:12:51.16,0:12:53.65,Default,,0,0,0,, -4人左右 -4人啊
Dialogue: 0,0:12:53.76,0:12:55.35,Default,,0,0,0,,全都是年上的嗎
Dialogue: 0,0:12:58.46,0:13:00.26,Default,,0,0,0,,不有同年的
Dialogue: 0,0:13:00.80,0:13:02.86,Default,,0,0,0,,年下的也有嗎
Dialogue: 0,0:13:03.33,0:13:06.79,Default,,0,0,0,,好厲害 範圍廣呢
Dialogue: 0,0:13:08.37,0:13:10.20,Default,,0,0,0,,大家都跟嬰兒一樣的
Dialogue: 0,0:13:10.54,0:13:13.57,Default,,0,0,0,, -全都不是的 -不是嗎
Dialogue: 0,0:13:13.88,0:13:18.82,Default,,0,0,0,,那交往後會怎麼跟\N男朋友接觸呢
Dialogue: 0,0:13:19.62,0:13:25.18,Default,,0,0,0,, -乖乖乖之類的嗎\N -可能是相反的
Dialogue: 0,0:13:26.52,0:13:32.16,Default,,0,0,0,, -是怎麼樣的\N -我這邊變得跟嬰兒一樣
Dialogue: 0,0:13:32.30,0:13:37.13,Default,,0,0,0,, -變成嬰兒 -是指撒嬌嗎
Dialogue: 0,0:13:37.17,0:13:40.43,Default,,0,0,0,, -那 -邊嗎 -撒嬌啊
Dialogue: 0,0:13:40.71,0:13:42.07,Default,,0,0,0,,這樣啊
Dialogue: 0,0:13:42.97,0:13:46.81,Default,,0,0,0,,會跳到男朋友身上嗎
Dialogue: 0,0:13:49.48,0:13:52.38,Default,,0,0,0,, -抱上去 -讓把你抱起來
Dialogue: 0,0:13:54.99,0:13:56.89,Default,,0,0,0,,原來如此
Dialogue: 0,0:13:57.22,0:14:00.69,Default,,0,0,0,,那半年都沒有男朋友\N很寂寞吧
Dialogue: 0,0:14:03.70,0:14:08.03,Default,,0,0,0,,稍微暖和起來然後想約會
Dialogue: 0,0:14:09.30,0:14:12.33,Default,,0,0,0,,地點也問了
Dialogue: 0,0:14:14.14,0:14:18.11,Default,,0,0,0,,會去哪裡玩耍嗎
Dialogue: 0,0:14:20.08,0:14:21.84,Default,,0,0,0,,哪裡啊
Dialogue: 0,0:14:21.88,0:14:24.25,Default,,0,0,0,,去飯店什麼的
Dialogue: 0,0:14:25.82,0:14:30.05,Default,,0,0,0,,比起遊樂園更想去飯店
Dialogue: 0,0:14:33.39,0:14:36.66,Default,,0,0,0,,那去吃肉可能最好呢
Dialogue: 0,0:14:44.67,0:14:47.07,Default,,0,0,0,,真的很受歡迎的樣子
Dialogue: 0,0:14:47.34,0:14:51.10,Default,,0,0,0,,相反的\N看你很遊刃有餘的樣子
Dialogue: 0,0:14:51.54,0:14:54.48,Default,,0,0,0,,都21了
Dialogue: 0,0:14:54.68,0:14:59.21,Default,,0,0,0,,半年啊 我想到一個事兒
Dialogue: 0,0:14:59.35,0:15:05.98,Default,,0,0,0,,不是沒有男朋友嘛\N其實是不是有在玩的人
Dialogue: 0,0:15:06.66,0:15:12.82,Default,,0,0,0,,說白了就是大學生的內情
Dialogue: 0,0:15:12.86,0:15:18.36,Default,,0,0,0,,相處得好就一起睡什麼的\N那些事情可以說一下嗎
Dialogue: 0,0:15:19.54,0:15:22.90,Default,,0,0,0,,不是半年沒有男朋友嘛
Dialogue: 0,0:15:23.41,0:15:26.10,Default,,0,0,0,,有一起玩的人嗎
Dialogue: 0,0:15:27.95,0:15:30.88,Default,,0,0,0,, -不沒有 -真的嗎
Dialogue: 0,0:15:31.08,0:15:32.52,Default,,0,0,0,, -沒有 -騙人
Dialogue: 0,0:15:35.09,0:15:40.99,Default,,0,0,0,, -那這半年和人肌膚接觸呢\N -沒有
Dialogue: 0,0:15:40.99,0:15:42.19,Default,,0,0,0,,沒有啊
Dialogue: 0,0:15:44.16,0:15:48.43,Default,,0,0,0,,要說到21歲的大學生
Dialogue: 0,0:15:49.03,0:15:54.77,Default,,0,0,0,, -我們當時也懵懵懂懂的\N -對那些很有興趣
Dialogue: 0,0:15:55.74,0:16:01.27,Default,,0,0,0,,有男朋友的時候身體接觸啊\N色情的事情是怎麼樣的
Dialogue: 0,0:16:04.78,0:16:09.22,Default,,0,0,0,, -怎麼樣是 -次數什麼的
Dialogue: 0,0:16:09.72,0:16:11.88,Default,,0,0,0,,或者自己主動什麼的
Dialogue: 0,0:16:13.19,0:16:14.75,Default,,0,0,0,,或者被尋求
Dialogue: 0,0:16:15.99,0:16:19.66,Default,,0,0,0,, -大概一周一次 -一周一次
Dialogue: 0,0:16:20.63,0:16:24.12,Default,,0,0,0,, -被尋求是指 -做啊
Dialogue: 0,0:16:24.40,0:16:25.73,Default,,0,0,0,,做什麼
Dialogue: 0,0:16:28.31,0:16:30.57,Default,,0,0,0,,就是那回事啊
Dialogue: 0,0:16:32.11,0:16:40.04,Default,,0,0,0,,一周一次能滿足嗎\N我的話是想每天做
Dialogue: 0,0:16:40.55,0:16:42.35,Default,,0,0,0,,如果是大學生的時候
Dialogue: 0,0:16:44.62,0:16:46.06,Default,,0,0,0,,就苗依而言呢
Dialogue: 0,0:16:50.63,0:16:53.06,Default,,0,0,0,, -就在這裡說下 -是的呢
Dialogue: 0,0:16:53.97,0:16:57.26,Default,,0,0,0,,節目上會消音的
Dialogue: 0,0:16:57.47,0:17:03.77,Default,,0,0,0,,能問到正在的做愛事情就好了
Dialogue: 0,0:17:07.08,0:17:09.88,Default,,0,0,0,,感覺有點不夠吧
Dialogue: 0,0:17:10.82,0:17:12.48,Default,,0,0,0,,一周一次有點不夠
Dialogue: 0,0:17:14.49,0:17:17.85,Default,,0,0,0,,那種時候會怎麼做
Dialogue: 0,0:17:19.76,0:17:23.89,Default,,0,0,0,, -怎麼做啊\N -因為一周就做一次嘛
Dialogue: 0,0:17:25.70,0:17:30.76,Default,,0,0,0,,會自慰嗎還是找其他對象呢
Dialogue: 0,0:17:33.67,0:17:36.11,Default,,0,0,0,,就自己一個人
Dialogue: 0,0:17:37.68,0:17:39.73,Default,,0,0,0,,自慰啊
Dialogue: 0,0:17:39.94,0:17:43.61,Default,,0,0,0,, -自慰是 -用手指嗎
Dialogue: 0,0:17:44.32,0:17:48.45,Default,,0,0,0,, -用的玩具\N -是什麼樣的 想問問呢
Dialogue: 0,0:17:51.26,0:17:54.66,Default,,0,0,0,,普通的電動棒
Dialogue: 0,0:17:57.03,0:18:01.23,Default,,0,0,0,, -是電動棒啊 -沒想到啊
Dialogue: 0,0:18:02.07,0:18:03.93,Default,,0,0,0,,喜歡那樣的嗎
Dialogue: 0,0:18:05.27,0:18:08.43,Default,,0,0,0,,一周自慰幾次呢
Dialogue: 0,0:18:09.47,0:18:11.27,Default,,0,0,0,,自慰啊
Dialogue: 0,0:18:12.28,0:18:14.47,Default,,0,0,0,,多的話1周5次
Dialogue: 0,0:18:14.65,0:18:17.05,Default,,0,0,0,,-1周5次 -好多呢
Dialogue: 0,0:18:17.42,0:18:22.01,Default,,0,0,0,, -會很久嗎 -很快就結束了
Dialogue: 0,0:18:22.49,0:18:23.78,Default,,0,0,0,,自慰嗎
Dialogue: 0,0:18:25.09,0:18:28.72,Default,,0,0,0,, -那麼\N -現在沒有男朋友的話
Dialogue: 0,0:18:29.66,0:18:31.75,Default,,0,0,0,,是每天都做嗎
Dialogue: 0,0:18:34.27,0:18:38.20,Default,,0,0,0,, -如果不累的話 -好厲害
Dialogue: 0,0:18:38.64,0:18:42.33,Default,,0,0,0,,最近一次做是什麼時候
Dialogue: 0,0:18:45.58,0:18:49.27,Default,,0,0,0,, -最近 -最近什麼時候做了
Dialogue: 0,0:18:49.55,0:18:50.67,Default,,0,0,0,,告訴我吧
Dialogue: 0,0:18:53.35,0:18:54.72,Default,,0,0,0,,大前天
Dialogue: 0,0:18:55.32,0:18:58.81,Default,,0,0,0,, -大前天 -2天前啊
Dialogue: 0,0:19:00.06,0:19:02.82,Default,,0,0,0,, -很適合你呢 -不適合
Dialogue: 0,0:19:03.19,0:19:04.53,Default,,0,0,0,,在睡之前嗎
Dialogue: 0,0:19:05.16,0:19:06.49,Default,,0,0,0,,是的呢
Dialogue: 0,0:19:07.87,0:19:10.23,Default,,0,0,0,,都想著什麼事情
Dialogue: 0,0:19:13.30,0:19:17.33,Default,,0,0,0,,普通的看AV
Dialogue: 0,0:19:17.58,0:19:19.37,Default,,0,0,0,,一邊看一邊自慰
Dialogue: 0,0:19:19.61,0:19:22.48,Default,,0,0,0,, -看AV -真的嗎
Dialogue: 0,0:19:23.92,0:19:29.41,Default,,0,0,0,,可以深挖一下嗎\N有喜歡的類別嗎
Dialogue: 0,0:19:31.29,0:19:32.95,Default,,0,0,0,,喜歡的類別
Dialogue: 0,0:19:39.70,0:19:43.39,Default,,0,0,0,,輕微的強姦類的
Dialogue: 0,0:19:48.24,0:19:52.80,Default,,0,0,0,,那種被強迫做愛的嗎
Dialogue: 0,0:19:58.15,0:20:00.98,Default,,0,0,0,, -是那種 -之後呢
Dialogue: 0,0:20:01.55,0:20:05.42,Default,,0,0,0,, -不記得了\N -高潮了就忘了嗎
Dialogue: 0,0:20:05.69,0:20:09.35,Default,,0,0,0,,有想被迫做愛的願望嗎
Dialogue: 0,0:20:12.50,0:20:14.73,Default,,0,0,0,,但感覺我能懂
Dialogue: 0,0:20:18.67,0:20:21.33,Default,,0,0,0,,順便一提是這個吧
Dialogue: 0,0:20:23.41,0:20:26.94,Default,,0,0,0,, -是這個嗎 -是這樣的
Dialogue: 0,0:20:28.38,0:20:32.61,Default,,0,0,0,,順便一提 這個先拿著吧
Dialogue: 0,0:20:32.85,0:20:34.82,Default,,0,0,0,,就拿著嗎
Dialogue: 0,0:20:39.19,0:20:43.59,Default,,0,0,0,, -用這個怎麼做 -不是這個嗎
Dialogue: 0,0:20:44.86,0:20:46.52,Default,,0,0,0,,這樣子
Dialogue: 0,0:20:48.40,0:20:50.33,Default,,0,0,0,,雙手拿著看看
Dialogue: 0,0:20:51.77,0:20:53.40,Default,,0,0,0,,不妙嗎
Dialogue: 0,0:20:56.64,0:21:02.24,Default,,0,0,0,,想著現在的女生是不是\N都有這個 姑且準備了
Dialogue: 0,0:21:03.58,0:21:07.45,Default,,0,0,0,,想看看你是怎麼弄的
Dialogue: 0,0:21:08.32,0:21:10.34,Default,,0,0,0,,是怎麼碰的呢
Dialogue: 0,0:21:10.49,0:21:15.12,Default,,0,0,0,,女孩子比起這邊\N大都先從這邊開始吧
Dialogue: 0,0:21:16.93,0:21:19.80,Default,,0,0,0,, -這邊不會弄 -不會嗎
Dialogue: 0,0:21:20.03,0:21:22.43,Default,,0,0,0,,那一上來就弄這裡嗎
Dialogue: 0,0:21:23.37,0:21:24.80,Default,,0,0,0,,這樣子
Dialogue: 0,0:21:25.40,0:21:28.37,Default,,0,0,0,,強度呢
Dialogue: 0,0:21:28.81,0:21:31.30,Default,,0,0,0,, -強度啊\N -上來就開到最大嗎
Dialogue: 0,0:21:31.51,0:21:34.24,Default,,0,0,0,,最大是這樣嗎
Dialogue: 0,0:21:34.91,0:21:37.35,Default,,0,0,0,, -這樣子 -不妙
Dialogue: 0,0:21:37.35,0:21:39.01,Default,,0,0,0,,果然強力點比較好
Dialogue: 0,0:21:41.15,0:21:43.14,Default,,0,0,0,,還是稍微低二點
Dialogue: 0,0:21:45.89,0:21:47.92,Default,,0,0,0,,比這個要低一點
Dialogue: 0,0:21:49.13,0:21:52.06,Default,,0,0,0,,那一開始全碰嗎
Dialogue: 0,0:21:52.20,0:21:53.72,Default,,0,0,0,,這個怎麼樣 -
Dialogue: 0,0:21:56.07,0:21:59.30,Default,,0,0,0,, -不壞嗎 -舒服嗎
Dialogue: 0,0:22:00.30,0:22:03.50,Default,,0,0,0,, -有點麻\N -有點麻的比較好嗎
Dialogue: 0,0:22:06.81,0:22:10.21,Default,,0,0,0,,怎麼樣喜歡陰蒂嗎
Dialogue: 0,0:22:13.89,0:22:15.72,Default,,0,0,0,,等下
Dialogue: 0,0:22:17.02,0:22:20.35,Default,,0,0,0,,隔著衣服都這麼有感覺的話
Dialogue: 0,0:22:20.53,0:22:22.86,Default,,0,0,0,,直接的話有點不妙呢
Dialogue: 0,0:22:25.16,0:22:28.03,Default,,0,0,0,,最舒服的是這裡嗎
Dialogue: 0,0:22:32.24,0:22:33.97,Default,,0,0,0,,是哪裡啊
Dialogue: 0,0:22:40.68,0:22:44.65,Default,,0,0,0,,是內衣的 可愛的內衣
Dialogue: 0,0:22:45.12,0:22:48.42,Default,,0,0,0,,可以稍微看一下嗎
Dialogue: 0,0:22:49.55,0:22:51.32,Default,,0,0,0,,稍微
Dialogue: 0,0:22:53.56,0:22:56.12,Default,,0,0,0,,看一下好嗎
Dialogue: 0,0:22:59.13,0:23:01.83,Default,,0,0,0,, -好可愛 -好可愛
Dialogue: 0,0:23:02.83,0:23:04.70,Default,,0,0,0,,這樣子
Dialogue: 0,0:23:12.21,0:23:16.17,Default,,0,0,0,, -舒服嗎 -有點
Dialogue: 0,0:23:18.45,0:23:21.51,Default,,0,0,0,,這樣啊平時都是直接的
Dialogue: 0,0:23:35.33,0:23:36.93,Default,,0,0,0,,這個後面是怎麼樣的
Dialogue: 0,0:23:37.70,0:23:40.43,Default,,0,0,0,, -後面 -後面嗎
Dialogue: 0,0:23:41.21,0:23:44.66,Default,,0,0,0,,後面也很時髦吧
Dialogue: 0,0:23:45.14,0:23:48.57,Default,,0,0,0,,說不定 可以轉過來一下嗎
Dialogue: 0,0:23:49.71,0:23:50.94,Default,,0,0,0,,在這裡
Dialogue: 0,0:24:05.20,0:24:06.39,Default,,0,0,0,,好可愛
Dialogue: 0,0:24:08.60,0:24:11.69,Default,,0,0,0,,可愛但有點性感
Dialogue: 0,0:24:13.60,0:24:16.23,Default,,0,0,0,, -緊身褲不妙呢 -不妙啊
Dialogue: 0,0:24:21.21,0:24:23.24,Default,,0,0,0,,內衣也很下心思呢
Dialogue: 0,0:24:28.39,0:24:30.01,Default,,0,0,0,,這樣
Dialogue: 0,0:24:36.56,0:24:37.89,Default,,0,0,0,,稍微
Dialogue: 0,0:24:44.80,0:24:46.74,Default,,0,0,0,,形狀很漂亮呢
Dialogue: 0,0:24:48.17,0:24:52.27,Default,,0,0,0,, -很軟呢 -好柔軟呢
Dialogue: 0,0:24:56.61,0:24:58.61,Default,,0,0,0,,有奇怪的聲音呢
Dialogue: 0,0:25:18.10,0:25:20.26,Default,,0,0,0,,屁股很小呢
Dialogue: 0,0:25:20.47,0:25:22.37,Default,,0,0,0,,但形狀很漂亮
Dialogue: 0,0:25:22.57,0:25:24.04,Default,,0,0,0,,很漂亮呢
Dialogue: 0,0:25:24.51,0:25:27.31,Default,,0,0,0,,稍微把月逸這樣
Dialogue: 0,0:25:31.18,0:25:32.81,Default,,0,0,0,,好厲害
Dialogue: 0,0:25:33.02,0:25:34.54,Default,,0,0,0,,身材很好呢
Dialogue: 0,0:25:34.72,0:25:36.24,Default,,0,0,0,,稍微
Dialogue: 0,0:25:47.50,0:25:48.93,Default,,0,0,0,,舒服嗎
Dialogue: 0,0:25:53.67,0:25:56.64,Default,,0,0,0,,陰蒂有點感覺到了
Dialogue: 0,0:26:08.72,0:26:11.12,Default,,0,0,0,,這邊也很在意啊
Dialogue: 0,0:26:20.16,0:26:22.10,Default,,0,0,0,,不討厭啊
Dialogue: 0,0:26:50.70,0:26:53.10,Default,,0,0,0,,怎麼樣胸部在被揉哦
Dialogue: 0,0:26:54.77,0:26:57.13,Default,,0,0,0,,還是說喜歡直接的
Dialogue: 0,0:27:21.26,0:27:23.12,Default,,0,0,0,,好可愛的內衣
Dialogue: 0,0:27:26.63,0:27:28.46,Default,,0,0,0,,真可愛呢
Dialogue: 0,0:27:30.17,0:27:31.60,Default,,0,0,0,,非常的
Dialogue: 0,0:27:39.01,0:27:41.21,Default,,0,0,0,,好可愛的胸部
Dialogue: 0,0:27:43.35,0:27:45.94,Default,,0,0,0,,乳頭是不是有點立起來了
Dialogue: 0,0:27:46.42,0:27:50.18,Default,,0,0,0,,立起來了啊
Dialogue: 0,0:27:53.66,0:27:55.49,Default,,0,0,0,,色情啊
Dialogue: 0,0:28:00.90,0:28:02.99,Default,,0,0,0,,碰到了
Dialogue: 0,0:28:07.14,0:28:08.70,Default,,0,0,0,,這邊也看看吧
Dialogue: 0,0:28:16.55,0:28:20.31,Default,,0,0,0,, -好厲害 -好精神呢
Dialogue: 0,0:28:20.79,0:28:23.48,Default,,0,0,0,,好精神呢
Dialogue: 0,0:28:28.23,0:28:29.75,Default,,0,0,0,,喜歡乳頭嗎
Dialogue: 0,0:28:34.87,0:28:36.99,Default,,0,0,0,,乳頭沒沉默呢
Dialogue: 0,0:28:46.38,0:28:48.37,Default,,0,0,0,,漂亮的形狀呢
Dialogue: 0,0:28:49.08,0:28:50.88,Default,,0,0,0,,有被誇獎過吧
Dialogue: 0,0:28:52.28,0:28:55.55,Default,,0,0,0,,沒被誇獎過嗎\N有被誇獎過吧
Dialogue: 0,0:28:56.45,0:28:57.82,Default,,0,0,0,,你看
Dialogue: 0,0:28:58.29,0:29:00.99,Default,,0,0,0,,雖然有點難為情
Dialogue: 0,0:29:02.93,0:29:05.26,Default,,0,0,0,,頭抬起來
Dialogue: 0,0:29:06.10,0:29:11.30,Default,,0,0,0,, -很棒的胸部啊\N -漂亮的形狀呢
Dialogue: 0,0:29:22.51,0:29:26.07,Default,,0,0,0,,這邊好可愛呢
Dialogue: 0,0:29:28.35,0:29:30.62,Default,,0,0,0,,好厲害
