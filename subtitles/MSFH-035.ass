Dialogue: 0,0:00:14.16,0:00:17.30,Default,,0,0,0,,新时代的好女人
Dialogue: 0,0:00:38.82,0:00:40.25,Default,,0,0,0,,大家好  我叫吉永美好  25岁
Dialogue: 0,0:00:40.25,0:00:42.25,Default,,0,0,0,,在咨询公司工作
Dialogue: 0,0:00:42.25,0:00:47.96,Default,,0,0,0,,企业要涉足新行业或新计划时
Dialogue: 0,0:00:47.96,0:00:54.27,Default,,0,0,0,,请我们帮他们提出意见和建议
Dialogue: 0,0:00:55.80,0:00:58.60,Default,,0,0,0,,东京出生和长大
Dialogue: 0,0:00:58.60,0:01:03.04,Default,,0,0,0,,人生顺风水水
Dialogue: 0,0:01:03.04,0:01:07.98,Default,,0,0,0,,周围的人都认为是纯洁的乖乖女
Dialogue: 0,0:01:07.98,0:01:12.48,Default,,0,0,0,,请看真正的我
Dialogue: 0,0:01:12.48,0:01:17.32,Default,,0,0,0,,喜欢工作结束后喝啤酒
Dialogue: 0,0:01:17.99,0:01:21.79,Default,,0,0,0,,不喜欢周一拥挤的电车
Dialogue: 0,0:01:21.79,0:01:26.47,Default,,0,0,0,,兴趣：高尔夫（初学者）
Dialogue: 0,0:01:26.47,0:01:31.17,Default,,0,0,0,,收藏了300部AV
Dialogue: 0,0:01:35.77,0:01:40.41,Default,,0,0,0,,开会的时候会想些色情的事
Dialogue: 0,0:01:49.62,0:01:54.26,Default,,0,0,0,,想试试激烈的做爱
Dialogue: 0,0:02:06.61,0:02:08.84,Default,,0,0,0,,为什么想拍AV？
Dialogue: 0,0:02:08.84,0:02:12.88,Default,,0,0,0,,私底下很认真，自己也不知道理由
Dialogue: 0,0:02:12.88,0:02:17.92,Default,,0,0,0,,也许是自己实际比较骚吧
Dialogue: 0,0:02:17.92,0:02:20.99,Default,,0,0,0,,普通的做爱已经不能满足我了
Dialogue: 0,0:02:20.99,0:02:26.53,Default,,0,0,0,,所以想试试拍AV
Dialogue: 0,0:02:55.99,0:03:02.86,Default,,0,0,0,,丸之内职业女性  吉永好美
Dialogue: 0,0:03:19.91,0:03:27.15,Default,,0,0,0,,丸之内职业女性吉永好美究竟是什么样的人
Dialogue: 0,0:03:27.65,0:03:30.96,Default,,0,0,0,,预备，开始
Dialogue: 0,0:03:30.96,0:03:31.96,Default,,0,0,0,,紧张吗？
Dialogue: 0,0:03:31.96,0:03:34.16,Default,,0,0,0,,很紧张
Dialogue: 0,0:03:34.16,0:03:38.06,Default,,0,0,0,,在你的人生中拍第几紧张
Dialogue: 0,0:03:38.06,0:03:40.80,Default,,0,0,0,,数一数二吧
Dialogue: 0,0:03:43.04,0:03:44.80,Default,,0,0,0,,我叫吉永好美
Dialogue: 0,0:03:44.80,0:03:47.57,Default,,0,0,0,,好美小姐还是好美酱
Dialogue: 0,0:03:47.57,0:03:50.01,Default,,0,0,0,,好美酱吧
Dialogue: 0,0:03:50.01,0:03:55.81,Default,,0,0,0,,该叫好美还是豪美
Dialogue: 0,0:03:55.81,0:03:57.88,Default,,0,0,0,,该叫好美
Dialogue: 0,0:03:57.88,0:04:00.75,Default,,0,0,0,,25岁
Dialogue: 0,0:04:00.75,0:04:05.62,Default,,0,0,0,,在丸之内的咨询公司工作
Dialogue: 0,0:04:05.62,0:04:07.99,Default,,0,0,0,,咨询公司是干什么的
Dialogue: 0,0:04:07.99,0:04:18.57,Default,,0,0,0,,企业涉及新行业时提供建议
Dialogue: 0,0:04:18.57,0:04:24.61,Default,,0,0,0,,身高166厘米，体重53公斤
Dialogue: 0,0:04:24.61,0:04:26.34,Default,,0,0,0,,身体状况如何
Dialogue: 0,0:04:26.34,0:04:29.78,Default,,0,0,0,,不好也不坏，很普通
Dialogue: 0,0:04:29.78,0:04:34.99,Default,,0,0,0,,对自己身体有满意的地方和也有讨厌的部分
Dialogue: 0,0:04:34.99,0:04:37.06,Default,,0,0,0,,满意哪部分
Dialogue: 0,0:04:37.06,0:04:39.22,Default,,0,0,0,,胸和腰
Dialogue: 0,0:04:39.22,0:04:41.22,Default,,0,0,0,,讨厌的呢？
Dialogue: 0,0:04:41.22,0:04:42.79,Default,,0,0,0,,下半身
Dialogue: 0,0:04:46.93,0:04:48.90,Default,,0,0,0,,放假的时候喜欢做什么
Dialogue: 0,0:04:48.90,0:04:54.34,Default,,0,0,0,,大多数时候宅在家里看书
Dialogue: 0,0:04:54.34,0:05:01.31,Default,,0,0,0,,最近读了东京23区女人的书
Dialogue: 0,0:05:01.31,0:05:13.73,Default,,0,0,0,,那个东京23区拥有自己的历史
Dialogue: 0,0:05:13.73,0:05:17.10,Default,,0,0,0,,喜欢那种书吗？  对
Dialogue: 0,0:05:17.10,0:05:21.40,Default,,0,0,0,,看这种书跟你的外表不相称啊
Dialogue: 0,0:05:22.93,0:05:26.10,Default,,0,0,0,,还有其他兴趣吗？
Dialogue: 0,0:05:26.10,0:05:28.61,Default,,0,0,0,,还喜欢散步
Dialogue: 0,0:05:28.61,0:05:32.21,Default,,0,0,0,,最近喜欢打高尔夫
Dialogue: 0,0:05:34.95,0:05:45.19,Default,,0,0,0,,请看高尔夫挥杆
Dialogue: 0,0:05:45.19,0:05:48.36,Default,,0,0,0,,像这样挥杆
Dialogue: 0,0:05:58.30,0:05:59.00,Default,,0,0,0,,自己感觉挥得如何
Dialogue: 0,0:05:59.00,0:06:04.11,Default,,0,0,0,,改进点还很多
Dialogue: 0,0:06:04.11,0:06:07.61,Default,,0,0,0,,何时开始打高尔夫的
Dialogue: 0,0:06:07.61,0:06:10.15,Default,,0,0,0,,大约去年秋天的时候
Dialogue: 0,0:06:10.15,0:06:12.58,Default,,0,0,0,,成绩是多少
Dialogue: 0,0:06:12.58,0:06:17.06,Default,,0,0,0,,差得不好意思说
Dialogue: 0,0:06:27.60,0:06:29.57,Default,,0,0,0,,进入社会几年了
Dialogue: 0,0:06:29.57,0:06:31.10,Default,,0,0,0,,3年了
Dialogue: 0,0:06:31.10,0:06:32.70,Default,,0,0,0,,工作地点在哪里
Dialogue: 0,0:06:32.70,0:06:34.37,Default,,0,0,0,,丸之内
Dialogue: 0,0:06:34.37,0:06:37.51,Default,,0,0,0,,午餐是在时尚区域吧？
Dialogue: 0,0:06:37.51,0:06:40.55,Default,,0,0,0,,一般，都是随便找地方吃点
Dialogue: 0,0:06:40.55,0:06:44.45,Default,,0,0,0,,自己觉得是大家印象中的丸子内职业女性吗
Dialogue: 0,0:06:44.45,0:06:47.79,Default,,0,0,0,,是印象中的样子
Dialogue: 0,0:06:47.79,0:06:52.22,Default,,0,0,0,,但一直很普通，没什么亮点
Dialogue: 0,0:06:52.22,0:06:54.22,Default,,0,0,0,,和丸之内其他职业女性相比还有什么不足
Dialogue: 0,0:06:54.22,0:07:00.00,Default,,0,0,0,,哪里呢？发型还是气质呢？
Dialogue: 0,0:07:00.00,0:07:03.04,Default,,0,0,0,,自己的幸运色是什么？
Dialogue: 0,0:07:03.04,0:07:05.54,Default,,0,0,0,,什么颜色呢
Dialogue: 0,0:07:05.54,0:07:10.08,Default,,0,0,0,,咖啡色吧
Dialogue: 0,0:07:10.08,0:07:15.45,Default,,0,0,0,,咖啡色是我喜欢的颜色
Dialogue: 0,0:07:20.62,0:07:26.53,Default,,0,0,0,,请用小学2年级都能听得懂的话介绍你的工作
Dialogue: 0,0:07:26.53,0:07:32.73,Default,,0,0,0,,好，因为是小学2年级
Dialogue: 0,0:07:32.73,0:07:36.70,Default,,0,0,0,,那叫什么名字啊？
Dialogue: 0,0:07:36.70,0:07:39.77,Default,,0,0,0,,叫好吃君。好吃君
Dialogue: 0,0:07:39.77,0:07:44.71,Default,,0,0,0,,假设你要运营公园
Dialogue: 0,0:07:44.71,0:07:49.95,Default,,0,0,0,,然后的话，你到我这里来咨询。
Dialogue: 0,0:07:49.95,0:07:52.02,Default,,0,0,0,,知道了
Dialogue: 0,0:07:58.62,0:08:00.62,Default,,0,0,0,,好吃君，你要新涉足公园运营
Dialogue: 0,0:08:00.62,0:08:04.46,Default,,0,0,0,,因为你没做过，就由我来帮你策划吧
Dialogue: 0,0:08:04.46,0:08:09.67,Default,,0,0,0,,要先做调查和进行选址
Dialogue: 0,0:08:09.67,0:08:11.57,Default,,0,0,0,,这就是我的工作
Dialogue: 0,0:08:11.57,0:08:13.57,Default,,0,0,0,,好吃君想要做那种类型的公园
Dialogue: 0,0:08:13.57,0:08:23.85,Default,,0,0,0,,因为是公园，要能有很多人来才行
Dialogue: 0,0:08:23.85,0:08:27.65,Default,,0,0,0,,这怎么说呢
Dialogue: 0,0:08:27.65,0:08:31.49,Default,,0,0,0,,就是要能够有潜力
Dialogue: 0,0:08:31.49,0:08:33.93,Default,,0,0,0,,一边调研，一边决定
Dialogue: 0,0:08:33.93,0:08:35.83,Default,,0,0,0,,是
Dialogue: 0,0:08:35.83,0:08:38.83,Default,,0,0,0,,一个很棒的公园完成的时候
Dialogue: 0,0:08:38.83,0:08:42.57,Default,,0,0,0,,要变成一个新闻点进行宣传
Dialogue: 0,0:08:42.57,0:08:47.67,Default,,0,0,0,,制造新闻，完成大计划
Dialogue: 0,0:08:47.67,0:08:53.08,Default,,0,0,0,,当新闻变成话题时，就会带来流量
Dialogue: 0,0:08:53.08,0:08:56.52,Default,,0,0,0,,有没有觉得很棒
Dialogue: 0,0:08:56.52,0:08:59.72,Default,,0,0,0,,好难哦
Dialogue: 0,0:08:59.72,0:09:01.65,Default,,0,0,0,,工作有辛苦的地方吗
Dialogue: 0,0:09:01.65,0:09:04.56,Default,,0,0,0,,辛苦的地方……因为还是新人
Dialogue: 0,0:09:04.56,0:09:09.59,Default,,0,0,0,,市场调查工作很多
Dialogue: 0,0:09:09.59,0:09:18.87,Default,,0,0,0,,很花时间，而且工作量大，常常工作到很晚
Dialogue: 0,0:09:18.87,0:09:23.61,Default,,0,0,0,,很累，很费体力，很辛苦
Dialogue: 0,0:09:23.61,0:09:27.35,Default,,0,0,0,,工作和生活时间比例大概是多少
Dialogue: 0,0:09:27.35,0:09:37.66,Default,,0,0,0,,5:2吧，一周工作5天
Dialogue: 0,0:09:37.66,0:09:42.56,Default,,0,0,0,,周六、周日休息
Dialogue: 0,0:10:04.62,0:10:05.98,Default,,0,0,0,,今天拍摄什么
Dialogue: 0,0:10:05.98,0:10:09.25,Default,,0,0,0,,AV
Dialogue: 0,0:10:09.25,0:10:11.19,Default,,0,0,0,,开始问关于性的问题了
Dialogue: 0,0:10:11.19,0:10:13.66,Default,,0,0,0,,关于性的问题？
Dialogue: 0,0:10:13.66,0:10:16.36,Default,,0,0,0,,会跟朋友或同事聊性的话题么？
Dialogue: 0,0:10:16.36,0:10:20.13,Default,,0,0,0,,完全不会
Dialogue: 0,0:10:20.13,0:10:22.10,Default,,0,0,0,,周围的人会认为你是个骚婆娘么
Dialogue: 0,0:10:22.10,0:10:24.50,Default,,0,0,0,,完全不会
Dialogue: 0,0:10:24.50,0:10:26.51,Default,,0,0,0,,跟多少人日过
Dialogue: 0,0:10:28.11,0:10:30.11,Default,,0,0,0,,4人
Dialogue: 0,0:10:30.11,0:10:30.81,Default,,0,0,0,,算多还是少
Dialogue: 0,0:10:30.81,0:10:33.25,Default,,0,0,0,,很普通吧
Dialogue: 0,0:10:37.98,0:10:39.98,Default,,0,0,0,,年纪大的男人还是年纪小的男人对你更有吸引力
Dialogue: 0,0:10:39.98,0:10:41.98,Default,,0,0,0,,觉得还是年纪大的更有吸引力
Dialogue: 0,0:10:41.98,0:10:46.16,Default,,0,0,0,,年纪多大能和你在一起
Dialogue: 0,0:10:49.53,0:10:51.53,Default,,0,0,0,,没怎么考虑过这个问题
Dialogue: 0,0:10:55.30,0:10:57.30,Default,,0,0,0,,只要喜欢，年龄不是问题
Dialogue: 0,0:11:00.47,0:11:00.70,Default,,0,0,0,,多久自慰一次
Dialogue: 0,0:11:06.48,0:11:08.48,Default,,0,0,0,,不论多忙，一周都要自慰两次
Dialogue: 0,0:11:08.48,0:11:12.25,Default,,0,0,0,,这个主要是顺从本能
Dialogue: 0,0:11:12.25,0:11:15.45,Default,,0,0,0,,怎样自慰
Dialogue: 0,0:11:18.69,0:11:20.69,Default,,0,0,0,,大多时候穿着衣服的
Dialogue: 0,0:11:20.69,0:11:23.60,Default,,0,0,0,,下面是穿着内裤的
Dialogue: 0,0:11:26.03,0:11:28.03,Default,,0,0,0,,是从上面往下哦
Dialogue: 0,0:11:28.03,0:11:31.24,Default,,0,0,0,,做的时候要看什么吗
Dialogue: 0,0:11:31.24,0:11:36.01,Default,,0,0,0,,有时候也边看AV边自慰
Dialogue: 0,0:11:36.01,0:11:46.02,Default,,0,0,0,,最新买的作品
Dialogue: 0,0:11:46.02,0:11:47.45,Default,,0,0,0,,为什么呢
Dialogue: 0,0:11:47.45,0:11:54.49,Default,,0,0,0,,也想知道自己演出的是怎样的作品
Dialogue: 0,0:11:54.49,0:11:57.60,Default,,0,0,0,,想研究看看
Dialogue: 0,0:11:57.60,0:11:58.93,Default,,0,0,0,,有喜欢的女生吗
Dialogue: 0,0:11:58.93,0:12:03.00,Default,,0,0,0,,有一个很骚的女生，很喜欢
Dialogue: 0,0:12:03.00,0:12:06.44,Default,,0,0,0,,是谁啊
Dialogue: 0,0:12:06.44,0:12:09.04,Default,,0,0,0,,前田
Dialogue: 0,0:12:09.04,0:12:11.54,Default,,0,0,0,,哪里很骚
Dialogue: 0,0:12:11.54,0:12:15.75,Default,,0,0,0,,气质就透出骚来
Dialogue: 0,0:12:15.75,0:12:20.99,Default,,0,0,0,,还有身材很性感
Dialogue: 0,0:12:20.99,0:12:25.59,Default,,0,0,0,,很漂亮
Dialogue: 0,0:12:25.59,0:12:30.50,Default,,0,0,0,,过去做爱怎么样？
Dialogue: 0,0:12:30.50,0:12:40.01,Default,,0,0,0,,很普通，迄今为止都很普通
Dialogue: 0,0:12:40.01,0:12:42.04,Default,,0,0,0,,有个特别的性经验么
Dialogue: 0,0:12:42.04,0:12:46.98,Default,,0,0,0,,有试试看的想法
Dialogue: 0,0:12:47.95,0:12:49.95,Default,,0,0,0,,想试试？
Dialogue: 0,0:12:50.98,0:12:52.98,Default,,0,0,0,,是的
Dialogue: 0,0:12:52.98,0:12:54.99,Default,,0,0,0,,在AV中有什么想尝试的吗？
Dialogue: 0,0:12:54.99,0:13:00.63,Default,,0,0,0,,想试试3P
Dialogue: 0,0:13:00.63,0:13:04.63,Default,,0,0,0,,我觉得这是只有在AV里才能做的事
Dialogue: 0,0:13:04.63,0:13:06.90,Default,,0,0,0,,想挑战一下
Dialogue: 0,0:13:06.90,0:13:10.64,Default,,0,0,0,,有特殊性癖么
Dialogue: 0,0:13:10.64,0:13:20.98,Default,,0,0,0,,像是穿着内衣干，穿着内衣会很兴奋
Dialogue: 0,0:13:22.91,0:13:24.91,Default,,0,0,0,,为什么喜欢穿着内衣干
Dialogue: 0,0:13:24.91,0:13:30.92,Default,,0,0,0,,把内裤拉开的时候感觉很兴奋
Dialogue: 0,0:13:32.66,0:13:34.79,Default,,0,0,0,,吉永好美是怎样的人
Dialogue: 0,0:13:34.79,0:13:47.87,Default,,0,0,0,,很活泼，很认真，很闷骚
Dialogue: 0,0:13:47.87,0:13:48.97,Default,,0,0,0,,吉永美好觉得怎样的女人才是好女人
Dialogue: 0,0:13:48.97,0:13:53.11,Default,,0,0,0,,能工作，性感
Dialogue: 0,0:13:53.11,0:13:57.02,Default,,0,0,0,,骚
Dialogue: 0,0:13:57.02,0:13:58.62,Default,,0,0,0,,吉永美好按好女人的标准能得几分
Dialogue: 0,0:13:58.62,0:14:05.99,Default,,0,0,0,,50分吧，工作还可以，其它的
Dialogue: 0,0:14:05.99,0:14:08.56,Default,,0,0,0,,那人认为的好女人标准是什么
Dialogue: 0,0:14:08.56,0:14:13.60,Default,,0,0,0,,平常一起工作的都是女性
Dialogue: 0,0:14:13.60,0:14:21.34,Default,,0,0,0,,其实都很骚
Dialogue: 0,0:14:21.34,0:14:24.61,Default,,0,0,0,,会变成几分
Dialogue: 0,0:14:24.61,0:14:27.31,Default,,0,0,0,,100分
Dialogue: 0,0:14:30.88,0:14:33.55,Default,,0,0,0,,评价好像有点过高了
Dialogue: 0,0:14:36.15,0:14:38.15,Default,,0,0,0,,为什么是100分
Dialogue: 0,0:14:38.15,0:14:43.30,Default,,0,0,0,,平常没有发现的地方还很多
Dialogue: 0,0:14:43.30,0:14:46.97,Default,,0,0,0,,觉得比任何人都骚
Dialogue: 0,0:14:46.97,0:14:50.54,Default,,0,0,0,,想让人看
Dialogue: 0,0:14:51.77,0:14:53.00,Default,,0,0,0,,为什么想拍AV
Dialogue: 0,0:14:53.00,0:14:57.48,Default,,0,0,0,,最大的原因还是对AV有兴趣
Dialogue: 0,0:14:57.48,0:15:01.58,Default,,0,0,0,,私下对AV很痴迷
Dialogue: 0,0:15:01.58,0:15:05.15,Default,,0,0,0,,也不知道算理由吗
Dialogue: 0,0:15:05.15,0:15:10.52,Default,,0,0,0,,其次，自己也很骚
Dialogue: 0,0:15:10.52,0:15:13.53,Default,,0,0,0,,性生活也很普通
Dialogue: 0,0:15:13.53,0:15:22.10,Default,,0,0,0,,只有AV才能有刺激的体验，所有想来拍拍看
Dialogue: 0,0:15:22.10,0:15:23.77,Default,,0,0,0,,用一句话描述下现在的心情
Dialogue: 0,0:15:23.77,0:15:27.64,Default,,0,0,0,,一句话？
Dialogue: 0,0:15:27.64,0:15:33.61,Default,,0,0,0,,很紧张，也很期待
Dialogue: 0,0:15:33.61,0:15:36.72,Default,,0,0,0,,也让人兴奋
Dialogue: 0,0:15:36.72,0:15:38.65,Default,,0,0,0,,用一个汉字表示
Dialogue: 0,0:15:38.65,0:15:42.05,Default,,0,0,0,,一个汉字？
Dialogue: 0,0:15:42.05,0:15:46.59,Default,,0,0,0,,热
Dialogue: 0,0:15:46.59,0:15:51.33,Default,,0,0,0,,那就这样了
Dialogue: 0,0:15:51.33,0:15:55.07,Default,,0,0,0,,是，今天请多指教
Dialogue: 0,0:15:55.07,0:16:06.08,Default,,0,0,0,,丸之内的职业女性裸体是什么样子的呢？
Dialogue: 0,0:16:06.08,0:16:10.65,Default,,0,0,0,,要看哪里好呢？
Dialogue: 0,0:16:10.65,0:16:15.39,Default,,0,0,0,,看镜头就好
Dialogue: 0,0:16:19.93,0:16:25.93,Default,,0,0,0,,要开始了 预备  开始
Dialogue: 0,0:16:29.94,0:16:34.11,Default,,0,0,0,,按指示做
Dialogue: 0,0:16:35.71,0:16:37.68,Default,,0,0,0,,刚刚访谈怎么样
Dialogue: 0,0:16:37.68,0:16:41.61,Default,,0,0,0,,工作内容问得很细
Dialogue: 0,0:16:41.61,0:16:49.29,Default,,0,0,0,,关于自己的也稍微说了一点
Dialogue: 0,0:16:49.29,0:16:50.59,Default,,0,0,0,,还有没说到的么
Dialogue: 0,0:16:50.59,0:16:57.33,Default,,0,0,0,,觉得自己的骚还没表现出来
Dialogue: 0,0:16:57.33,0:17:01.77,Default,,0,0,0,,接下来，就要越来越骚了
Dialogue: 0,0:17:01.77,0:17:04.60,Default,,0,0,0,,让人看到我的骚样就好了
Dialogue: 0,0:17:04.60,0:17:05.54,Default,,0,0,0,,接下来吉永要做什么
Dialogue: 0,0:17:05.54,0:17:08.31,Default,,0,0,0,,要把衣服脱掉
Dialogue: 0,0:17:08.31,0:17:12.58,Default,,0,0,0,,在摄像机和很多人面前哦
Dialogue: 0,0:17:12.58,0:17:16.62,Default,,0,0,0,,请展示你的裸体
Dialogue: 0,0:17:16.62,0:17:19.42,Default,,0,0,0,,现在感觉如何
Dialogue: 0,0:17:19.42,0:17:22.25,Default,,0,0,0,,很紧张
Dialogue: 0,0:17:28.49,0:17:28.52,Default,,0,0,0,,从喜欢的顺序开始脱吧
Dialogue: 0,0:17:28.52,0:17:31.66,Default,,0,0,0,,开始脱吧
Dialogue: 0,0:17:31.66,0:17:34.60,Default,,0,0,0,,是
Dialogue: 0,0:17:34.60,0:17:41.81,Default,,0,0,0,,接下来欣赏一刀未剪的脱衣裸体展示吧
Dialogue: 0,0:19:06.83,0:19:09.73,Default,,0,0,0,,觉得大家现在在看哪里
Dialogue: 0,0:19:09.73,0:19:12.43,Default,,0,0,0,,身体
Dialogue: 0,0:19:12.43,0:19:16.03,Default,,0,0,0,,再看乳沟
Dialogue: 0,0:19:16.03,0:19:21.51,Default,,0,0,0,,还有腰身
Dialogue: 0,0:19:53.04,0:19:56.38,Default,,0,0,0,,变成全裸了吗
Dialogue: 0,0:19:56.38,0:20:01.25,Default,,0,0,0,,要靠近拍了哦
Dialogue: 0,0:20:17.26,0:20:21.87,Default,,0,0,0,,请揉奶给大家看
Dialogue: 0,0:20:21.87,0:20:26.67,Default,,0,0,0,,请告诉大家你奶的柔软度
Dialogue: 0,0:20:26.67,0:20:29.84,Default,,0,0,0,,弹性刚刚好
Dialogue: 0,0:20:34.21,0:20:36.72,Default,,0,0,0,,请描述乳房的感觉
Dialogue: 0,0:20:36.72,0:20:39.89,Default,,0,0,0,,乳头很敏感
Dialogue: 0,0:20:39.89,0:20:45.86,Default,,0,0,0,,按你喜欢的方式来摸吧
Dialogue: 0,0:20:45.86,0:20:55.30,Default,,0,0,0,,喜欢右边的乳头啊
Dialogue: 0,0:20:55.30,0:20:57.54,Default,,0,0,0,,两边都喜欢
Dialogue: 0,0:20:57.54,0:21:04.74,Default,,0,0,0,,让我们看看你的腋窝
Dialogue: 0,0:21:10.68,0:21:15.62,Default,,0,0,0,,两边都让大家看
Dialogue: 0,0:21:25.13,0:21:26.50,Default,,0,0,0,,有没有这样让人看过
Dialogue: 0,0:21:26.50,0:21:28.17,Default,,0,0,0,,没有
Dialogue: 0,0:21:51.26,0:21:55.86,Default,,0,0,0,,下面让我们看腰身
Dialogue: 0,0:21:55.86,0:22:02.40,Default,,0,0,0,,请原地转圈
Dialogue: 0,0:22:02.40,0:22:10.78,Default,,0,0,0,,想遮挡哪里
Dialogue: 0,0:22:10.78,0:22:12.54,Default,,0,0,0,,这里
Dialogue: 0,0:22:12.54,0:22:16.11,Default,,0,0,0,,想遮住吗
Dialogue: 0,0:22:16.11,0:22:18.95,Default,,0,0,0,,请到这边来
Dialogue: 0,0:22:22.39,0:22:24.92,Default,,0,0,0,,让我们在看看你下面
Dialogue: 0,0:22:24.92,0:22:27.43,Default,,0,0,0,,觉得要怎么让人看
Dialogue: 0,0:22:27.43,0:22:29.23,Default,,0,0,0,,坐下让人看吧
Dialogue: 0,0:22:31.56,0:22:36.54,Default,,0,0,0,,丸之内职业女性的裸体鉴赏
Dialogue: 0,0:23:34.96,0:23:39.00,Default,,0,0,0,,做过这样的姿势么
Dialogue: 0,0:23:39.00,0:23:40.00,Default,,0,0,0,,心情如何？
Dialogue: 0,0:23:40.00,0:23:42.77,Default,,0,0,0,,有点发骚的感觉
Dialogue: 0,0:23:42.77,0:23:48.71,Default,,0,0,0,,可以仔细看你的小穴吗
Dialogue: 0,0:23:57.98,0:24:01.45,Default,,0,0,0,, 有羞人
Dialogue: 0,0:24:15.13,0:24:17.70,Default,,0,0,0,,阴毛整理过吗
Dialogue: 0,0:24:17.70,0:24:20.07,Default,,0,0,0,,做过脱毛
Dialogue: 0,0:24:20.07,0:24:23.44,Default,,0,0,0,,你的性器官有什么是你讨厌的么
Dialogue: 0,0:24:31.52,0:24:34.82,Default,,0,0,0,,再粉一点就好了
Dialogue: 0,0:24:34.82,0:24:37.59,Default,,0,0,0,,你的小穴是什么颜色的呢
Dialogue: 0,0:24:37.59,0:24:41.59,Default,,0,0,0,,分红、咖啡还带点黑色
Dialogue: 0,0:25:10.66,0:25:13.63,Default,,0,0,0,,摆过这样的姿势吗
Dialogue: 0,0:25:13.63,0:25:15.49,Default,,0,0,0,,第一次
Dialogue: 0,0:25:15.49,0:25:21.50,Default,,0,0,0,,害羞吗
Dialogue: 0,0:25:21.50,0:25:25.67,Default,,0,0,0,,请看我的裸体
Dialogue: 0,0:26:01.57,0:26:04.31,Default,,0,0,0,,谢谢
Dialogue: 0,0:26:08.55,0:26:11.58,Default,,0,0,0,,笑什么呢
Dialogue: 0,0:26:11.58,0:26:13.49,Default,,0,0,0,,好紧张
Dialogue: 0,0:26:13.49,0:26:15.75,Default,,0,0,0,,最紧张的是什么呢
Dialogue: 0,0:26:15.75,0:26:20.33,Default,,0,0,0,,掰开小穴和屁股的时候好紧张
Dialogue: 0,0:26:41.55,0:26:43.28,Default,,0,0,0,,在意摄像机吗
Dialogue: 0,0:26:43.28,0:26:45.02,Default,,0,0,0,,没问题
Dialogue: 0,0:26:45.02,0:26:51.56,Default,,0,0,0,,没问题吗？可以开始了吗？
Dialogue: 0,0:26:51.56,0:26:52.59,Default,,0,0,0,,是
Dialogue: 0,0:26:52.59,0:26:58.16,Default,,0,0,0,,马上就第一次拍摄做爱了，她非常紧张
Dialogue: 0,0:26:58.16,0:27:01.37,Default,,0,0,0,,要活动下脸部吗
Dialogue: 0,0:27:05.77,0:27:08.17,Default,,0,0,0,,好，那就开始了哦
Dialogue: 0,0:27:08.17,0:27:18.55,Default,,0,0,0,,预备，开始
Dialogue: 0,0:27:18.55,0:27:24.46,Default,,0,0,0,,那么吉永，接下来要做什么呢
Dialogue: 0,0:27:24.46,0:27:27.23,Default,,0,0,0,,要做色情的事情
Dialogue: 0,0:27:27.23,0:27:31.46,Default,,0,0,0,,笑得非常好看
Dialogue: 0,0:27:31.46,0:27:38.90,Default,,0,0,0,,紧张 期待 不安，现在最强烈的感受是什么
Dialogue: 0,0:27:38.90,0:27:40.74,Default,,0,0,0,,紧张
Dialogue: 0,0:27:40.74,0:27:42.67,Default,,0,0,0,,紧张？
Dialogue: 0,0:27:42.67,0:27:44.81,Default,,0,0,0,,紧张
Dialogue: 0,0:27:44.81,0:27:47.01,Default,,0,0,0,,有请男优
Dialogue: 0,0:27:47.01,0:27:48.01,Default,,0,0,0,,可以进来了吗？
Dialogue: 0,0:27:48.01,0:27:49.25,Default,,0,0,0,,好
Dialogue: 0,0:27:49.25,0:27:52.35,Default,,0,0,0,,自己叫男优进来吧
Dialogue: 0,0:27:52.35,0:27:54.39,Default,,0,0,0,,拜托了
Dialogue: 0,0:27:54.39,0:27:59.46,Default,,0,0,0,,失礼了，可以在旁边吗
Dialogue: 0,0:27:59.46,0:28:06.47,Default,,0,0,0,,幸会，请多指教
Dialogue: 0,0:28:06.47,0:28:08.27,Default,,0,0,0,,我叫玉木
Dialogue: 0,0:28:08.27,0:28:10.70,Default,,0,0,0,,我叫吉永，请多指教
Dialogue: 0,0:28:10.70,0:28:12.17,Default,,0,0,0,,名字是什么
Dialogue: 0,0:28:12.17,0:28:13.61,Default,,0,0,0,,好美
Dialogue: 0,0:28:13.61,0:28:14.61,Default,,0,0,0,,好美酱
Dialogue: 0,0:28:14.61,0:28:18.44,Default,,0,0,0,,非常紧张啊
Dialogue: 0,0:28:18.44,0:28:24.72,Default,,0,0,0,,听说你好像是丸之内的职业女性
Dialogue: 0,0:28:24.72,0:28:25.98,Default,,0,0,0,,对
Dialogue: 0,0:28:25.98,0:28:30.22,Default,,0,0,0,,为什么要来拍AV
Dialogue: 0,0:28:32.56,0:28:35.36,Default,,0,0,0,,因为太骚
Dialogue: 0,0:28:35.36,0:28:43.87,Default,,0,0,0,,那是在上班的时候都一直发骚了哦？
Dialogue: 0,0:28:43.87,0:28:45.54,Default,,0,0,0,,对
Dialogue: 0,0:28:45.54,0:28:52.14,Default,,0,0,0,,就是忍不住了，就来这里了
Dialogue: 0,0:28:52.14,0:28:53.81,Default,,0,0,0,,是的
Dialogue: 0,0:28:53.81,0:28:56.95,Default,,0,0,0,,喜欢做爱
Dialogue: 0,0:28:56.95,0:28:58.55,Default,,0,0,0,,喜欢
Dialogue: 0,0:28:58.55,0:29:01.49,Default,,0,0,0,,说得很自信哦
Dialogue: 0,0:29:01.49,0:29:09.56,Default,,0,0,0,,既然难得来，那喜欢怎样做爱
Dialogue: 0,0:29:09.56,0:29:14.40,Default,,0,0,0,,那么说出自己的想法
Dialogue: 0,0:29:14.40,0:29:15.97,Default,,0,0,0,,有什么想的吗
Dialogue: 0,0:29:15.97,0:29:22.27,Default,,0,0,0,,因为总是普通的性爱
Dialogue: 0,0:29:22.27,0:29:26.51,Default,,0,0,0,,希望能比平常激烈点
Dialogue: 0,0:29:26.51,0:29:32.72,Default,,0,0,0,,激烈的性爱？是抽插激烈点么
Dialogue: 0,0:29:39.32,0:29:43.92,Default,,0,0,0,,抽插也包含在内
Dialogue: 0,0:29:43.92,0:29:49.17,Default,,0,0,0,,碰到膝盖了，可以靠近点么
Dialogue: 0,0:29:49.17,0:29:52.50,Default,,0,0,0,,有什么喜欢的么
Dialogue: 0,0:29:52.50,0:29:56.38,Default,,0,0,0,,喜欢穿着内衣干
Dialogue: 0,0:29:57.51,0:29:59.41,Default,,0,0,0,,想要你这样做
Dialogue: 0,0:29:59.41,0:30:01.21,Default,,0,0,0,,为什么呢
Dialogue: 0,0:30:01.21,0:30:03.45,Default,,0,0,0,,内裤被拉开干的时候会很兴奋
Dialogue: 0,0:30:06.08,0:30:08.22,Default,,0,0,0,,拉开内裤会兴奋啊？
Dialogue: 0,0:30:08.22,0:30:11.56,Default,,0,0,0,,嗯
Dialogue: 0,0:30:11.56,0:30:17.56,Default,,0,0,0,,第一次插入，要拉开内裤插插看哦
Dialogue: 0,0:30:27.64,0:30:30.81,Default,,0,0,0,,要开始干了哦
Dialogue: 0,0:30:34.71,0:30:37.38,Default,,0,0,0,,可以了吗？
Dialogue: 0,0:30:40.72,0:30:45.49,Default,,0,0,0,,看这边，对
Dialogue: 0,0:30:45.49,0:30:53.00,Default,,0,0,0,,亲了哦
Dialogue: 0,0:31:29.67,0:31:33.37,Default,,0,0,0,,刚刚亲你全被拍下来了哦
Dialogue: 0,0:31:33.37,0:31:40.28,Default,,0,0,0,,一直看着我眼睛，可以吗？
Dialogue: 0,0:31:42.65,0:31:44.92,Default,,0,0,0,,看这边，对
Dialogue: 0,0:32:16.72,0:32:22.95,Default,,0,0,0,,有发骚的感觉了没？看看旁边
Dialogue: 0,0:32:24.92,0:32:26.53,Default,,0,0,0,,有床哦
Dialogue: 0,0:32:28.79,0:32:31.10,Default,,0,0,0,,要过去看看么？
Dialogue: 0,0:32:44.64,0:32:47.78,Default,,0,0,0,,那我要多干点哦
Dialogue: 0,0:33:17.71,0:33:20.71,Default,,0,0,0,,多告诉我点你的性感带
Dialogue: 0,0:33:20.71,0:33:22.68,Default,,0,0,0,,喜欢我摸哪里？
Dialogue: 0,0:33:22.68,0:33:24.22,Default,,0,0,0,,乳头
Dialogue: 0,0:33:24.22,0:33:29.12,Default,,0,0,0,,喜欢摸乳头啊，现在还不行哦
Dialogue: 0,0:33:44.70,0:33:48.37,Default,,0,0,0,,要多摸点哦
Dialogue: 0,0:34:05.76,0:34:08.63,Default,,0,0,0,,发出淫荡的声音了哦
Dialogue: 0,0:34:17.70,0:34:21.64,Default,,0,0,0,,啊，这是什么
Dialogue: 0,0:34:21.64,0:34:22.74,Default,,0,0,0,,乳头
Dialogue: 0,0:34:22.74,0:34:24.71,Default,,0,0,0,,是乳头啊
Dialogue: 0,0:34:24.71,0:34:43.66,Default,,0,0,0,,还有摸哪里会爽啊？
Dialogue: 0,0:34:45.76,0:34:48.13,Default,,0,0,0,,这里
Dialogue: 0,0:34:48.13,0:34:51.00,Default,,0,0,0,,喜欢摸这里啊
Dialogue: 0,0:35:00.91,0:35:03.28,Default,,0,0,0,,这里吗？
Dialogue: 0,0:35:21.87,0:35:24.44,Default,,0,0,0,,好棒
Dialogue: 0,0:35:30.74,0:35:32.41,Default,,0,0,0,,怎么样了
Dialogue: 0,0:35:32.41,0:35:35.11,Default,,0,0,0,,好爽。   好爽？
Dialogue: 0,0:35:41.69,0:35:44.59,Default,,0,0,0,,好湿了哦
Dialogue: 0,0:35:54.60,0:35:57.30,Default,,0,0,0,,被摸后感觉怎么样？
Dialogue: 0,0:35:57.30,0:35:59.97,Default,,0,0,0,,好爽
Dialogue: 0,0:35:59.97,0:36:01.67,Default,,0,0,0,,好爽吗？
Dialogue: 0,0:36:06.88,0:36:09.51,Default,,0,0,0,,好骚啊
Dialogue: 0,0:36:10.62,0:36:13.59,Default,,0,0,0,,来，脱掉吧
Dialogue: 0,0:36:33.00,0:36:35.57,Default,,0,0,0,,好漂亮的胸
Dialogue: 0,0:36:35.57,0:36:45.78,Default,,0,0,0,,隔着胸罩摸，很爽吗？
Dialogue: 0,0:36:59.56,0:37:02.57,Default,,0,0,0,,隔着胸罩摸就满足了么？
Dialogue: 0,0:37:03.97,0:37:06.61,Default,,0,0,0,,想怎么做，自己告诉我
Dialogue: 0,0:37:06.61,0:37:09.01,Default,,0,0,0,,想你直接摸
Dialogue: 0,0:37:09.01,0:37:10.51,Default,,0,0,0,,听不见哦
Dialogue: 0,0:37:10.51,0:37:12.51,Default,,0,0,0,,想要你直接摸
Dialogue: 0,0:37:12.51,0:37:15.41,Default,,0,0,0,,直接？那还要看哦
Dialogue: 0,0:37:26.69,0:37:28.63,Default,,0,0,0,,漂亮的奶子
Dialogue: 0,0:37:33.77,0:37:36.27,Default,,0,0,0,,好棒
Dialogue: 0,0:37:45.64,0:37:47.58,Default,,0,0,0,,怎么了？
Dialogue: 0,0:37:47.58,0:37:48.61,Default,,0,0,0,,好爽
Dialogue: 0,0:37:57.59,0:38:00.26,Default,,0,0,0,,摸就好了么？
Dialogue: 0,0:38:00.26,0:38:02.73,Default,,0,0,0,,求我啊
Dialogue: 0,0:38:02.73,0:38:05.03,Default,,0,0,0,,请舔我，想要你舔
Dialogue: 0,0:38:15.84,0:38:18.54,Default,,0,0,0,,是这样吗
Dialogue: 0,0:38:41.87,0:38:43.47,Default,,0,0,0,,我再舔你咪咪头哦
Dialogue: 0,0:39:01.59,0:39:04.46,Default,,0,0,0,,爽吧
Dialogue: 0,0:39:27.68,0:39:30.28,Default,,0,0,0,,真敏感啊
Dialogue: 0,0:39:40.76,0:39:43.83,Default,,0,0,0,,你这里想要我怎么干
Dialogue: 0,0:39:43.83,0:39:45.83,Default,,0,0,0,,想要你舔
Dialogue: 0,0:39:45.83,0:39:49.50,Default,,0,0,0,,也想要你舔。     也想要我舔？
Dialogue: 0,0:39:52.80,0:39:55.27,Default,,0,0,0,,那脱掉吧
Dialogue: 0,0:40:21.77,0:40:25.30,Default,,0,0,0,,要拉开内裤看里面了哦
Dialogue: 0,0:40:37.78,0:40:39.92,Default,,0,0,0,,看到了哦
Dialogue: 0,0:40:46.76,0:40:49.39,Default,,0,0,0,,看得很清楚哦
Dialogue: 0,0:40:49.39,0:40:53.00,Default,,0,0,0,,怎么了？
Dialogue: 0,0:40:53.00,0:40:58.70,Default,,0,0,0,,好羞人哦。     害羞了么？要停下来吗？
Dialogue: 0,0:41:00.71,0:41:03.68,Default,,0,0,0,,做了，就停不下来了哦
Dialogue: 0,0:41:06.81,0:41:09.41,Default,,0,0,0,,想我舔吗？
Dialogue: 0,0:41:44.68,0:41:46.32,Default,,0,0,0,,感觉如何，告诉我
Dialogue: 0,0:41:46.32,0:41:48.49,Default,,0,0,0,,好爽
Dialogue: 0,0:42:33.70,0:42:36.94,Default,,0,0,0,,爽吗？    爽
Dialogue: 0,0:43:19.75,0:43:24.38,Default,,0,0,0,,来，再多来点
Dialogue: 0,0:43:28.02,0:43:32.59,Default,,0,0,0,,内裤拉开了，手指也插进去了哦
Dialogue: 0,0:43:44.84,0:43:47.41,Default,,0,0,0,,手指在你小穴里插着哦
Dialogue: 0,0:43:59.75,0:44:03.66,Default,,0,0,0,,爽不爽？   好爽
Dialogue: 0,0:44:09.70,0:44:12.50,Default,,0,0,0,,好棒
Dialogue: 0,0:44:12.50,0:44:19.44,Default,,0,0,0,,插两根手指了哦。
Dialogue: 0,0:44:22.01,0:44:25.68,Default,,0,0,0,,看这边
Dialogue: 0,0:44:36.62,0:44:39.79,Default,,0,0,0,,好爽
Dialogue: 0,0:44:45.30,0:44:48.43,Default,,0,0,0,,用力了哦
Dialogue: 0,0:44:50.67,0:44:57.21,Default,,0,0,0,,还要吗？   还要
Dialogue: 0,0:46:16.89,0:46:19.59,Default,,0,0,0,,好爽
Dialogue: 0,0:46:22.66,0:46:25.13,Default,,0,0,0,,抖得好厉害
Dialogue: 0,0:46:32.77,0:46:35.81,Default,,0,0,0,,来这边
Dialogue: 0,0:46:55.73,0:46:59.83,Default,,0,0,0,,来舔我看看
Dialogue: 0,0:46:59.83,0:47:07.37,Default,,0,0,0,,多舔点哦
Dialogue: 0,0:47:20.65,0:47:24.86,Default,,0,0,0,,看着我舔哈
Dialogue: 0,0:47:42.97,0:47:46.45,Default,,0,0,0,,真鸡巴爽
Dialogue: 0,0:48:01.56,0:48:05.80,Default,,0,0,0,,看看男人爽，你感觉怎么样
Dialogue: 0,0:48:05.80,0:48:08.60,Default,,0,0,0,,有点兴奋
Dialogue: 0,0:48:08.60,0:48:12.40,Default,,0,0,0,,兴奋？那你就看着
Dialogue: 0,0:48:12.97,0:48:14.97,Default,,0,0,0,,怎么了？
Dialogue: 0,0:48:17.84,0:48:19.14,Default,,0,0,0,,翘起来了
Dialogue: 0,0:48:19.14,0:48:22.98,Default,,0,0,0,,看到鸡鸡翘起来了，你开心么
Dialogue: 0,0:48:22.98,0:48:26.15,Default,,0,0,0,,可以脱掉内裤了哦
Dialogue: 0,0:48:36.80,0:48:39.56,Default,,0,0,0,,凑近点看看
Dialogue: 0,0:48:51.64,0:48:54.08,Default,,0,0,0,,舔吧
Dialogue: 0,0:49:19.81,0:49:22.94,Default,,0,0,0,,看着我舔，对
Dialogue: 0,0:49:26.18,0:49:28.55,Default,,0,0,0,,真可爱
Dialogue: 0,0:49:40.79,0:49:43.70,Default,,0,0,0,,喜欢什么样的鸡鸡
Dialogue: 0,0:49:43.70,0:49:47.97,Default,,0,0,0,,硬的，喜欢梆硬的鸡鸡
Dialogue: 0,0:49:47.97,0:49:52.54,Default,,0,0,0,,硬的么？再舔硬一点
Dialogue: 0,0:50:15.76,0:50:18.43,Default,,0,0,0,,好鸡巴爽
Dialogue: 0,0:50:37.65,0:50:40.52,Default,,0,0,0,,好鸡巴爽哦
Dialogue: 0,0:50:52.90,0:50:56.17,Default,,0,0,0,,好棒
Dialogue: 0,0:51:02.64,0:51:06.91,Default,,0,0,0,,看着我，对，一直看着我，对
Dialogue: 0,0:51:06.91,0:51:09.55,Default,,0,0,0,,好鸡巴爽哦
Dialogue: 0,0:51:40.71,0:51:45.32,Default,,0,0,0,,用手撸，对
Dialogue: 0,0:51:51.99,0:51:55.36,Default,,0,0,0,,好湿哦，你感觉到了么？
Dialogue: 0,0:52:01.87,0:52:05.50,Default,,0,0,0,,用力撸
Dialogue: 0,0:52:25.66,0:52:28.39,Default,,0,0,0,,想要鸡鸡干什么了
Dialogue: 0,0:52:28.39,0:52:32.03,Default,,0,0,0,,想要鸡鸡插我
Dialogue: 0,0:52:32.03,0:52:34.20,Default,,0,0,0,,想要插了吗
Dialogue: 0,0:52:34.20,0:52:39.24,Default,,0,0,0,,全部过程都拍下来可以吗
Dialogue: 0,0:52:39.24,0:52:47.71,Default,,0,0,0,,那躺下吧，自己拉开让我看看小穴
Dialogue: 0,0:53:06.77,0:53:08.83,Default,,0,0,0,,要日了哦
Dialogue: 0,0:53:21.75,0:53:24.52,Default,,0,0,0,,龟头进去了哦
Dialogue: 0,0:53:27.75,0:53:30.39,Default,,0,0,0,,就这样可以吗
Dialogue: 0,0:53:37.66,0:53:40.70,Default,,0,0,0,,给我将，想要我怎么做
Dialogue: 0,0:53:40.70,0:53:43.04,Default,,0,0,0,,插到深处
Dialogue: 0,0:53:43.04,0:53:45.00,Default,,0,0,0,,再插深点么
Dialogue: 0,0:53:54.71,0:53:57.78,Default,,0,0,0,,全部插进去了哦
Dialogue: 0,0:53:57.78,0:54:01.29,Default,,0,0,0,,怎样？   好爽哦
Dialogue: 0,0:54:01.29,0:54:03.49,Default,,0,0,0,,爽吗？
Dialogue: 0,0:54:15.70,0:54:18.34,Default,,0,0,0,,好爽啊
Dialogue: 0,0:54:45.63,0:54:47.37,Default,,0,0,0,,插到底了哦
Dialogue: 0,0:54:52.70,0:54:55.27,Default,,0,0,0,,很想这么插吗
Dialogue: 0,0:55:20.00,0:55:24.97,Default,,0,0,0,,还要更多吗？    要去了
Dialogue: 0,0:55:33.01,0:55:37.22,Default,,0,0,0,,去了    爽哦
Dialogue: 0,0:55:50.66,0:55:53.10,Default,,0,0,0,,好爽
Dialogue: 0,0:56:03.68,0:56:07.31,Default,,0,0,0,,要去了      要去了？
Dialogue: 0,0:56:11.95,0:56:15.52,Default,,0,0,0,,要去了
Dialogue: 0,0:56:29.70,0:56:32.44,Default,,0,0,0,,好棒哦
Dialogue: 0,0:56:35.71,0:56:38.51,Default,,0,0,0,,没事吧
Dialogue: 0,0:56:42.88,0:56:45.55,Default,,0,0,0,,还要来吗
Dialogue: 0,0:56:58.76,0:57:03.27,Default,,0,0,0,,要继续日了哦，自己抱着腿
Dialogue: 0,0:57:30.70,0:57:33.73,Default,,0,0,0,,爽吗   嗯
Dialogue: 0,0:58:18.71,0:58:22.45,Default,,0,0,0,,要去了
Dialogue: 0,0:58:38.80,0:58:41.33,Default,,0,0,0,,真骚
Dialogue: 0,0:58:48.71,0:58:51.48,Default,,0,0,0,,真骚啊，爽了吗？
Dialogue: 0,0:58:56.95,0:58:59.48,Default,,0,0,0,,再来继续日哦
Dialogue: 0,0:59:11.73,0:59:13.93,Default,,0,0,0,,看这边
Dialogue: 0,0:59:13.93,0:59:20.24,Default,,0,0,0,,插得好深
Dialogue: 0,0:59:26.71,0:59:29.51,Default,,0,0,0,,真鸡巴爽
Dialogue: 0,1:00:19.00,1:00:22.23,Default,,0,0,0,,好爽哦
Dialogue: 0,1:00:25.70,1:00:28.44,Default,,0,0,0,,要去了
Dialogue: 0,1:00:32.61,1:00:35.41,Default,,0,0,0,,过来
Dialogue: 0,1:00:51.93,1:00:54.40,Default,,0,0,0,,很敏感了哦
Dialogue: 0,1:00:57.70,1:01:01.57,Default,,0,0,0,,动起来
Dialogue: 0,1:01:11.78,1:01:16.49,Default,,0,0,0,,弄会爽的地方哈。               好爽哦
Dialogue: 0,1:01:43.65,1:01:47.12,Default,,0,0,0,,怎么了
Dialogue: 0,1:01:58.70,1:02:01.03,Default,,0,0,0,,我从下面日，可以吗
Dialogue: 0,1:02:14.58,1:02:18.95,Default,,0,0,0,,你也在动哦，好棒
Dialogue: 0,1:03:27.72,1:03:30.32,Default,,0,0,0,,爽死了
Dialogue: 0,1:03:42.73,1:03:47.64,Default,,0,0,0,,从后面日，可以吗
Dialogue: 0,1:03:52.84,1:03:55.18,Default,,0,0,0,,要日了哦
Dialogue: 0,1:04:27.81,1:04:31.32,Default,,0,0,0,,从后面日，感觉如何？    好爽
Dialogue: 0,1:04:33.95,1:04:38.26,Default,,0,0,0,,把手给我
Dialogue: 0,1:05:39.82,1:05:42.29,Default,,0,0,0,,不行了
Dialogue: 0,1:06:30.84,1:06:32.60,Default,,0,0,0,,要去了
Dialogue: 0,1:07:01.87,1:07:05.30,Default,,0,0,0,,如何？   爽死了
Dialogue: 0,1:07:23.79,1:07:26.76,Default,,0,0,0,,好棒，腰还在扭哦
Dialogue: 0,1:07:46.01,1:07:48.55,Default,,0,0,0,,插到底了哦
Dialogue: 0,1:07:57.82,1:08:01.93,Default,,0,0,0,,好爽
Dialogue: 0,1:09:02.99,1:09:05.92,Default,,0,0,0,,不行，要去了
Dialogue: 0,1:09:05.92,1:09:08.93,Default,,0,0,0,,我也要射了
Dialogue: 0,1:09:37.96,1:09:41.63,Default,,0,0,0,,清理干净
Dialogue: 0,1:10:22.63,1:10:25.50,Default,,0,0,0,,好了，辛苦了
Dialogue: 0,1:10:30.61,1:10:33.88,Default,,0,0,0,,这个表情表示什么啊？
Dialogue: 0,1:10:33.88,1:10:36.21,Default,,0,0,0,,爽死了
Dialogue: 0,1:10:36.21,1:10:37.98,Default,,0,0,0,,很爽吗？说说感想吧。
Dialogue: 0,1:10:37.98,1:10:42.99,Default,,0,0,0,,虽然很紧张，但是比平时要兴奋
Dialogue: 0,1:10:42.99,1:10:47.36,Default,,0,0,0,,比平时兴奋啊。最爽的是什么？
Dialogue: 0,1:10:47.36,1:10:51.60,Default,,0,0,0,,从后面猛日的时候
Dialogue: 0,1:10:51.60,1:10:56.00,Default,,0,0,0,,喜欢从后面日啊。辛苦了
Dialogue: 0,1:10:56.00,1:11:01.01,Default,,0,0,0,,初次拍摄就让人感觉她有巨大的潜能
Dialogue: 0,1:11:29.03,1:11:31.10,Default,,0,0,0,,想要试试在哪里做爱
Dialogue: 0,1:11:31.10,1:11:32.57,Default,,0,0,0,,公司
Dialogue: 0,1:11:32.57,1:11:34.11,Default,,0,0,0,,幻想过在公司做爱吗
Dialogue: 0,1:11:34.11,1:11:36.11,Default,,0,0,0,,有过几次
Dialogue: 0,1:11:36.11,1:11:37.58,Default,,0,0,0,,是怎样的幻想
Dialogue: 0,1:11:37.58,1:11:42.05,Default,,0,0,0,,幻想和公司老同事做
Dialogue: 0,1:11:42.05,1:11:49.05,Default,,0,0,0,,丸子内职业女性幻想过在公司和老同事干淫荡的是
Dialogue: 0,1:11:49.05,1:11:52.16,Default,,0,0,0,,预备，开始
Dialogue: 0,1:11:52.16,1:11:58.60,Default,,0,0,0,,第2次了哦。   是的
Dialogue: 0,1:11:58.60,1:12:03.50,Default,,0,0,0,,心情怎么样
Dialogue: 0,1:12:03.50,1:12:08.21,Default,,0,0,0,,紧张情绪有所缓解
Dialogue: 0,1:12:08.21,1:12:13.25,Default,,0,0,0,,期待下次能更享受性爱
Dialogue: 0,1:12:13.25,1:12:16.38,Default,,0,0,0,,用一个汉字表达心情
Dialogue: 0,1:12:16.38,1:12:21.39,Default,,0,0,0,,快乐的快
Dialogue: 0,1:12:29.46,1:12:33.40,Default,,0,0,0,,幸会
Dialogue: 0,1:12:33.40,1:12:38.97,Default,,0,0,0,,笑容好漂亮哦，我已经受不了了
Dialogue: 0,1:12:38.97,1:12:42.61,Default,,0,0,0,,谢谢
Dialogue: 0,1:12:42.61,1:12:45.88,Default,,0,0,0,,很棒
Dialogue: 0,1:12:45.88,1:12:54.39,Default,,0,0,0,,想要问一下，好美，平常做什么工作
Dialogue: 0,1:12:54.39,1:12:58.59,Default,,0,0,0,,在咨询公司工作
Dialogue: 0,1:12:58.59,1:13:01.09,Default,,0,0,0,,咨询公司？
Dialogue: 0,1:13:01.09,1:13:11.74,Default,,0,0,0,,咨询是指什么，我不了解
Dialogue: 0,1:13:11.74,1:13:20.61,Default,,0,0,0,,企业计划计及建议什么的，收集各种调查意见和情报
Dialogue: 0,1:13:20.61,1:13:27.79,Default,,0,0,0,,然后提建议和改善意见
Dialogue: 0,1:13:27.79,1:13:32.59,Default,,0,0,0,,原来如此，果然很聪明呢
Dialogue: 0,1:13:32.59,1:13:35.63,Default,,0,0,0,,过奖过奖
Dialogue: 0,1:13:35.63,1:13:47.54,Default,,0,0,0,,感觉很厉害呢，而且人也很漂亮，在公司也很了不起，常常被撩把
Dialogue: 0,1:13:47.54,1:13:49.41,Default,,0,0,0,,没有没有
Dialogue: 0,1:13:49.41,1:13:55.58,Default,,0,0,0,,不，我觉得是哦，你是防备心很强吧
Dialogue: 0,1:13:55.58,1:13:59.48,Default,,0,0,0,,防备心是很强的
Dialogue: 0,1:13:59.48,1:14:03.79,Default,,0,0,0,,是吗？了解
Dialogue: 0,1:14:03.79,1:14:09.06,Default,,0,0,0,,很难搭讪吗
Dialogue: 0,1:14:09.06,1:14:12.76,Default,,0,0,0,,我没有这样的感觉
Dialogue: 0,1:14:12.76,1:14:20.27,Default,,0,0,0,,觉得男人哪里最性感
Dialogue: 0,1:14:20.27,1:14:28.41,Default,,0,0,0,,声音，体贴什么的
Dialogue: 0,1:14:28.41,1:14:31.75,Default,,0,0,0,,对那些能感到性感
Dialogue: 0,1:14:31.75,1:14:33.75,Default,,0,0,0,,说得是呢
Dialogue: 0,1:14:33.75,1:14:40.69,Default,,0,0,0,,若是感到性感，被强暴也没关系吧
Dialogue: 0,1:14:40.69,1:14:41.89,Default,,0,0,0,,是的
Dialogue: 0,1:14:41.89,1:14:46.06,Default,,0,0,0,,哦！自己不会太主动吗
Dialogue: 0,1:14:46.06,1:14:54.51,Default,,0,0,0,,是的，通常都是被动，自己没有主动追求过
Dialogue: 0,1:14:54.51,1:14:58.98,Default,,0,0,0,,老实说的话，关于色情的行为如何？
Dialogue: 0,1:14:58.98,1:15:03.35,Default,,0,0,0,,很喜欢
Dialogue: 0,1:15:03.35,1:15:09.55,Default,,0,0,0,,好棒，说出了自己喜欢
Dialogue: 0,1:15:09.55,1:15:20.17,Default,,0,0,0,,好美你觉得一个月或一周做几次比较理想
Dialogue: 0,1:15:20.17,1:15:28.61,Default,,0,0,0,,一周两到三次吧
Dialogue: 0,1:15:28.61,1:15:38.62,Default,,0,0,0,,觉得应该这个频次哦，好棒，原来如此
Dialogue: 0,1:15:38.62,1:15:49.53,Default,,0,0,0,,你觉得做爱应该是怎样的万法呢，或者你喜欢怎样
Dialogue: 0,1:15:49.53,1:15:55.63,Default,,0,0,0,,被细心的脱掉衣服，会很兴奋，很喜欢这样
Dialogue: 0,1:15:55.63,1:16:02.77,Default,,0,0,0,,仔细的？把手给我，很棒哦
Dialogue: 0,1:16:02.77,1:16:05.91,Default,,0,0,0,,比如这样摸手吗
Dialogue: 0,1:16:08.65,1:16:11.85,Default,,0,0,0,,这样也喜欢么
Dialogue: 0,1:16:11.85,1:16:13.29,Default,,0,0,0,,喜欢
Dialogue: 0,1:16:13.29,1:16:38.84,Default,,0,0,0,,好棒，能感觉到心跳加速了
Dialogue: 0,1:16:44.65,1:16:47.85,Default,,0,0,0,,觉得自己性欲强吗
Dialogue: 0,1:16:47.85,1:16:49.82,Default,,0,0,0,,强
Dialogue: 0,1:17:08.77,1:17:11.91,Default,,0,0,0,,慢慢的感觉吧
Dialogue: 0,1:17:25.99,1:17:31.93,Default,,0,0,0,,真漂亮，我要尽情的干了哦
Dialogue: 0,1:18:10.57,1:18:16.07,Default,,0,0,0,,好棒，舌头很软哦
Dialogue: 0,1:18:16.07,1:18:19.04,Default,,0,0,0,,让我多看点
Dialogue: 0,1:18:50.64,1:18:54.15,Default,,0,0,0,,好棒
Dialogue: 0,1:18:57.88,1:19:00.39,Default,,0,0,0,,过来
Dialogue: 0,1:19:12.73,1:19:16.67,Default,,0,0,0,,有在在办公室干过这样的事吗
Dialogue: 0,1:19:16.67,1:19:18.80,Default,,0,0,0,,没有
Dialogue: 0,1:19:18.80,1:19:22.54,Default,,0,0,0,,没听见，大声点
Dialogue: 0,1:19:22.54,1:19:25.94,Default,,0,0,0,,没有
Dialogue: 0,1:19:25.94,1:19:30.52,Default,,0,0,0,,穿成这样被日是不是很兴奋
Dialogue: 0,1:19:43.66,1:19:51.67,Default,,0,0,0,,那，继续了哦，摩擦下吧
Dialogue: 0,1:19:51.67,1:19:56.71,Default,,0,0,0,,对，用屁股摩擦
Dialogue: 0,1:19:56.71,1:19:59.48,Default,,0,0,0,,有感觉吗
Dialogue: 0,1:19:59.48,1:20:02.25,Default,,0,0,0,,有感觉吗
Dialogue: 0,1:20:02.25,1:20:03.68,Default,,0,0,0,,有
Dialogue: 0,1:20:03.68,1:20:06.45,Default,,0,0,0,,那就继续吧
Dialogue: 0,1:20:19.70,1:20:22.53,Default,,0,0,0,,就这样，继续
Dialogue: 0,1:20:22.53,1:20:29.51,Default,,0,0,0,,再猛点
Dialogue: 0,1:20:43.86,1:20:48.23,Default,,0,0,0,,看这边，对的
Dialogue: 0,1:20:48.23,1:20:53.37,Default,,0,0,0,,好棒，很漂亮哦
Dialogue: 0,1:21:30.00,1:21:35.64,Default,,0,0,0,,好漂亮哦，在奔放点
Dialogue: 0,1:21:35.64,1:21:39.18,Default,,0,0,0,,对，很棒
Dialogue: 0,1:21:45.95,1:21:49.45,Default,,0,0,0,,失礼了哦
Dialogue: 0,1:22:51.92,1:22:53.02,Default,,0,0,0,,喜欢被舔吧？
Dialogue: 0,1:22:53.02,1:22:55.62,Default,,0,0,0,,是的，喜欢
Dialogue: 0,1:22:55.62,1:22:58.39,Default,,0,0,0,,想听好美你请我舔哦
Dialogue: 0,1:22:58.39,1:23:04.53,Default,,0,0,0,,请你舔我哟
Dialogue: 0,1:23:04.53,1:23:08.73,Default,,0,0,0,,好的，让我看你的小穴
Dialogue: 0,1:23:16.98,1:23:20.48,Default,,0,0,0,,在看好美的阴蒂哦
Dialogue: 0,1:23:25.78,1:23:28.82,Default,,0,0,0,,就这样
Dialogue: 0,1:23:52.74,1:23:55.05,Default,,0,0,0,,很爽的话就告诉我哈
Dialogue: 0,1:25:01.81,1:25:04.42,Default,,0,0,0,,好吃，太好吃了
Dialogue: 0,1:25:25.00,1:25:26.91,Default,,0,0,0,,漂亮
Dialogue: 0,1:25:37.65,1:25:41.39,Default,,0,0,0,,脱掉胸罩，就这样
Dialogue: 0,1:25:52.90,1:25:55.97,Default,,0,0,0,,让我舔舔这里哈
Dialogue: 0,1:26:29.63,1:26:32.47,Default,,0,0,0,,有感觉了吗？    有
Dialogue: 0,1:26:55.96,1:26:59.77,Default,,0,0,0,,好淫荡哦
Dialogue: 0,1:26:59.77,1:27:05.64,Default,,0,0,0,,还害羞吗
Dialogue: 0,1:27:05.64,1:27:14.08,Default,,0,0,0,,这里也要舔哦
Dialogue: 0,1:28:10.80,1:28:13.31,Default,,0,0,0,,这里吗
Dialogue: 0,1:28:32.66,1:28:41.43,Default,,0,0,0,,让我看着你的表情，对
Dialogue: 0,1:29:40.79,1:29:42.79,Default,,0,0,0,,爽死了
Dialogue: 0,1:29:42.79,1:29:45.66,Default,,0,0,0,,喜欢干这里吗
Dialogue: 0,1:29:49.84,1:29:53.21,Default,,0,0,0,,继续哈
Dialogue: 0,1:30:16.53,1:30:20.67,Default,,0,0,0,,好爽
Dialogue: 0,1:30:44.62,1:30:48.23,Default,,0,0,0,,嘢，是潮吹了么
Dialogue: 0,1:30:52.70,1:30:54.90,Default,,0,0,0,,让我舔干净
Dialogue: 0,1:31:18.92,1:31:24.00,Default,,0,0,0,,屁股翘高，很巴适哦
Dialogue: 0,1:31:24.00,1:31:28.20,Default,,0,0,0,,对，脸朝这边
Dialogue: 0,1:31:41.78,1:31:44.18,Default,,0,0,0,,想看看鸡鸡吗？    想
Dialogue: 0,1:32:54.02,1:32:56.69,Default,,0,0,0,,跪下
Dialogue: 0,1:33:57.82,1:34:00.92,Default,,0,0,0,,好美你能舔哪里呢
Dialogue: 0,1:34:00.92,1:34:06.26,Default,,0,0,0,,舔这里也没关系吧
Dialogue: 0,1:34:23.01,1:34:25.38,Default,,0,0,0,,好棒
Dialogue: 0,1:34:36.72,1:34:39.79,Default,,0,0,0,,在往下一点也可以吗
Dialogue: 0,1:34:39.79,1:34:49.87,Default,,0,0,0,,那这样舔吧
Dialogue: 0,1:34:49.87,1:34:53.74,Default,,0,0,0,,好棒
Dialogue: 0,1:35:25.74,1:35:28.27,Default,,0,0,0,, 好棒
Dialogue: 0,1:35:32.74,1:35:38.62,Default,,0,0,0,,鸡鸡也一起鲁哈
Dialogue: 0,1:35:50.83,1:35:52.66,Default,,0,0,0,,好棒
Dialogue: 0,1:36:21.76,1:36:24.60,Default,,0,0,0,,好棒
Dialogue: 0,1:36:52.69,1:36:55.13,Default,,0,0,0,,好棒
Dialogue: 0,1:37:03.67,1:37:06.51,Default,,0,0,0,,好鸡巴爽
Dialogue: 0,1:37:50.85,1:37:58.02,Default,,0,0,0,,刚刚舔的太多了，手撑起来
Dialogue: 0,1:38:03.83,1:38:06.50,Default,,0,0,0,,看这边
Dialogue: 0,1:39:10.00,1:39:14.07,Default,,0,0,0,,爽的话就说出啦啊
Dialogue: 0,1:39:23.98,1:39:26.88,Default,,0,0,0,,想你日我了
Dialogue: 0,1:39:29.68,1:39:33.22,Default,,0,0,0,,在说哈，我想听
Dialogue: 0,1:39:39.76,1:39:42.86,Default,,0,0,0,,继续说
Dialogue: 0,1:39:42.86,1:39:46.73,Default,,0,0,0,,想要你日我了
Dialogue: 0,1:39:46.73,1:39:56.54,Default,,0,0,0,,用这个吗
Dialogue: 0,1:40:20.97,1:40:24.44,Default,,0,0,0,,在日了哦
Dialogue: 0,1:40:47.96,1:40:51.66,Default,,0,0,0,,好爽哦
Dialogue: 0,1:40:55.70,1:40:58.07,Default,,0,0,0,,好爽
Dialogue: 0,1:41:23.76,1:41:25.70,Default,,0,0,0,,继续哈
Dialogue: 0,1:41:43.65,1:41:47.45,Default,,0,0,0,,好爽哦
Dialogue: 0,1:41:59.77,1:42:02.73,Default,,0,0,0,,要去了，要去了
Dialogue: 0,1:42:31.86,1:42:35.40,Default,,0,0,0,,跪下，屁股朝这边
Dialogue: 0,1:42:45.74,1:42:49.48,Default,,0,0,0,,鸡鸡日进去哦
Dialogue: 0,1:43:07.07,1:43:10.10,Default,,0,0,0,,好爽哦
Dialogue: 0,1:43:20.85,1:43:23.25,Default,,0,0,0,,好爽
Dialogue: 0,1:44:01.82,1:44:03.32,Default,,0,0,0,,好爽哦
Dialogue: 0,1:45:04.72,1:45:07.82,Default,,0,0,0,,好爽哦
Dialogue: 0,1:45:26.84,1:45:28.54,Default,,0,0,0,,好爽
Dialogue: 0,1:45:51.76,1:45:59.20,Default,,0,0,0,,好爽哦，要去了
Dialogue: 0,1:46:33.00,1:46:35.97,Default,,0,0,0,,脱掉
Dialogue: 0,1:46:57.03,1:47:01.80,Default,,0,0,0,,手扶这里，腿张开
Dialogue: 0,1:47:16.78,1:47:19.18,Default,,0,0,0,,好爽
Dialogue: 0,1:47:30.86,1:47:33.60,Default,,0,0,0,,好爽
Dialogue: 0,1:47:42.97,1:47:45.64,Default,,0,0,0,,你来动
Dialogue: 0,1:47:57.82,1:47:59.66,Default,,0,0,0,,好爽哦
Dialogue: 0,1:48:07.73,1:48:10.67,Default,,0,0,0,,好爽
Dialogue: 0,1:48:14.14,1:48:19.81,Default,,0,0,0,,在插进去
Dialogue: 0,1:48:28.72,1:48:31.19,Default,,0,0,0,,好爽哦
Dialogue: 0,1:48:48.81,1:48:51.08,Default,,0,0,0,,好棒哦
Dialogue: 0,1:49:06.83,1:49:10.36,Default,,0,0,0,,继续哈
Dialogue: 0,1:50:05.75,1:50:07.45,Default,,0,0,0,,好棒
Dialogue: 0,1:50:14.83,1:50:16.76,Default,,0,0,0,,好爽哦
Dialogue: 0,1:52:02.83,1:52:04.84,Default,,0,0,0,,好爽哦
Dialogue: 0,1:52:17.85,1:52:20.39,Default,,0,0,0,,好爽
Dialogue: 0,1:52:46.95,1:52:50.08,Default,,0,0,0,,要射了，要射了
Dialogue: 0,1:52:55.69,1:52:59.06,Default,,0,0,0,,要射了
Dialogue: 0,1:53:18.81,1:53:26.85,Default,,0,0,0,,舔干净吧
Dialogue: 0,1:53:57.55,1:53:59.02,Default,,0,0,0,,如何？
Dialogue: 0,1:53:59.02,1:54:05.56,Default,,0,0,0,,在桌子边从后面日的时候很爽
Dialogue: 0,1:54:05.56,1:54:07.83,Default,,0,0,0,,体验很不错吧
Dialogue: 0,1:54:07.83,1:54:10.36,Default,,0,0,0,,很棒
Dialogue: 0,1:54:11.70,1:54:17.44,Default,,0,0,0,,好，结束，辛苦了
Dialogue: 0,1:54:38.66,1:54:41.99,Default,,0,0,0,,拍摄第2舔
Dialogue: 0,1:54:41.99,1:54:48.33,Default,,0,0,0,,为了增进了解，决定让她请我们看她最近入迷的高尔夫
Dialogue: 0,1:55:02.68,1:55:07.09,Default,,0,0,0,,半年前开始打高尔夫
Dialogue: 0,1:55:15.36,1:55:19.70,Default,,0,0,0,,因为工作的关系迷上打高尔夫
Dialogue: 0,1:55:19.70,1:55:25.47,Default,,0,0,0,,好像很喜欢运动
Dialogue: 0,1:55:25.47,1:55:28.74,Default,,0,0,0,,好
Dialogue: 0,1:55:42.99,1:55:51.00,Default,,0,0,0,,握杆的姿势令人印象深刻
Dialogue: 0,1:55:51.00,1:55:59.27,Default,,0,0,0,,不过在高尔夫经验0 的导演眼里是看不出好坏的
Dialogue: 0,1:56:07.71,1:56:15.72,Default,,0,0,0,,但是学的时候，看到了吉永认真的个性
Dialogue: 0,1:56:26.87,1:56:32.74,Default,,0,0,0,,是这样，腰要这样
Dialogue: 0,1:56:46.95,1:56:50.39,Default,,0,0,0,,就是要这样
Dialogue: 0,1:56:50.39,1:56:54.73,Default,,0,0,0,,最后依然能感觉到了吉永的谦虚
Dialogue: 0,1:56:54.73,1:57:01.57,Default,,0,0,0,,没问题吧？马上要正式开拍了
Dialogue: 0,1:57:01.57,1:57:07.44,Default,,0,0,0,,丸之内职业女性的淫语。预备，开始
Dialogue: 0,1:57:07.44,1:57:11.71,Default,,0,0,0,,大家好，我是吉永好美
Dialogue: 0,1:57:11.71,1:57:17.52,Default,,0,0,0,,下面我要说淫荡的话了
Dialogue: 0,1:57:17.52,1:57:27.53,Default,,0,0,0,,淫荡的话，因为第一次说，可能有说不好的地方
Dialogue: 0,1:57:27.53,1:57:33.23,Default,,0,0,0,,请多多包涵
Dialogue: 0,1:57:33.23,1:57:37.64,Default,,0,0,0,,虽然这样说
Dialogue: 0,1:57:37.64,1:57:40.71,Default,,0,0,0,,因为缺乏淫荡话的知识
Dialogue: 0,1:57:40.71,1:57:45.61,Default,,0,0,0,,就先由导演准备了笔记
Dialogue: 0,1:57:45.61,1:57:54.02,Default,,0,0,0,,就从笔记里开始说了
Dialogue: 0,1:57:57.56,1:58:03.36,Default,,0,0,0,,人生第一次的色情词汇
Dialogue: 0,1:58:06.60,1:58:11.67,Default,,0,0,0,,第一次，第一次，嗯
Dialogue: 0,1:58:11.67,1:58:17.51,Default,,0,0,0,,好难，需要回想过去
Dialogue: 0,1:58:17.51,1:58:24.55,Default,,0,0,0,,色情词汇，原本知道的一些词汇
Dialogue: 0,1:58:24.55,1:58:29.62,Default,,0,0,0,,渐渐的已经发生变化了
Dialogue: 0,1:58:29.62,1:58:34.46,Default,,0,0,0,,现在感觉到色情的词汇
Dialogue: 0,1:58:34.46,1:58:38.60,Default,,0,0,0,,可能和大家知道的不一样
Dialogue: 0,1:58:38.60,1:59:21.01,Default,,0,0,0,,最开始的淫荡词汇以女的视觉是有性别特征的：胸部
Dialogue: 0,1:59:18.80,1:59:26.78,Default,,0,0,0,,这是最开始学会的色情词汇
Dialogue: 0,1:59:26.78,1:59:32.48,Default,,0,0,0,,接着说
Dialogue: 0,1:59:32.48,1:59:41.06,Default,,0,0,0,,自己觉得最色情的词汇
Dialogue: 0,1:59:41.06,1:59:52.60,Default,,0,0,0,,最色的词？有很多哦……因为现在知道了很多色情的词汇
Dialogue: 0,1:59:52.60,1:59:56.81,Default,,0,0,0,,虽然都很色
Dialogue: 0,1:59:56.81,2:00:09.65,Default,,0,0,0,,我觉得只有自己觉得很色的事情，虽然没人懂
Dialogue: 0,2:00:09.65,2:00:17.56,Default,,0,0,0,,只是自己认为是淫荡的话，虽然不知道大家认为是不是淫荡的话
Dialogue: 0,2:00:17.56,2:00:31.91,Default,,0,0,0,,那就是贯穿蓝天的曼珠沙华
Dialogue: 0,2:00:31.91,2:00:41.59,Default,,0,0,0,,贯穿，让人联想到很多东西
Dialogue: 0,2:00:41.59,2:00:57.64,Default,,0,0,0,,蓝天被贯穿之后，有点深奥
Dialogue: 0,2:00:57.64,2:01:13.72,Default,,0,0,0,,曼珠沙华其实本跟色情无关
Dialogue: 0,2:01:13.72,2:01:22.09,Default,,0,0,0,,就是第一次理解之后就像失去了纯真
Dialogue: 0,2:01:22.09,2:01:27.23,Default,,0,0,0,,就变得色情了
Dialogue: 0,2:01:27.23,2:01:32.64,Default,,0,0,0,,接着说
Dialogue: 0,2:01:32.64,2:01:36.27,Default,,0,0,0,,最近学会的色情词汇
Dialogue: 0,2:01:36.27,2:01:45.98,Default,,0,0,0,,最近真的学会的词是经过这次拍摄学会的
Dialogue: 0,2:01:45.98,2:01:53.23,Default,,0,0,0,,那我就说说哈，大家比我知识丰富
Dialogue: 0,2:01:53.23,2:02:01.17,Default,,0,0,0,,我想大家已经知道了，请自己脑补下
Dialogue: 0,2:02:01.17,2:02:05.90,Default,,0,0,0,,油油的胸部
Dialogue: 0,2:02:05.90,2:02:20.45,Default,,0,0,0,,就是胸部油满出来了，很有画面感
Dialogue: 0,2:02:20.45,2:02:23.79,Default,,0,0,0,,这是最近学会的淫荡话
Dialogue: 0,2:02:23.79,2:02:40.61,Default,,0,0,0,,学生时代胸部是涨不起来的
Dialogue: 0,2:02:40.61,2:02:46.58,Default,,0,0,0,,到现在感觉很色
Dialogue: 0,2:02:46.58,2:02:57.69,Default,,0,0,0,,试着诱惑下银幕前的观众
Dialogue: 0,2:02:57.69,2:03:07.33,Default,,0,0,0,,思考3分钟
Dialogue: 0,2:03:07.33,2:03:19.75,Default,,0,0,0,,看我的片子
Dialogue: 0,2:03:19.75,2:03:28.59,Default,,0,0,0,,鸡鸡多射点精液出来，这样诱惑吗？
Dialogue: 0,2:03:28.59,2:03:33.53,Default,,0,0,0,,不对吗
Dialogue: 0,2:03:33.53,2:03:43.57,Default,,0,0,0,,色情的声音，请模仿下
Dialogue: 0,2:03:43.57,2:03:51.08,Default,,0,0,0,,色情的声音？很多种哦
Dialogue: 0,2:03:51.08,2:03:56.31,Default,,0,0,0,,我内裤湿了的事情
Dialogue: 0,2:03:56.31,2:04:01.05,Default,,0,0,0,,因为最喜欢这样的声音
Dialogue: 0,2:04:01.05,2:04:08.39,Default,,0,0,0,,咕叽咕叽
Dialogue: 0,2:04:08.39,2:04:12.36,Default,,0,0,0,,很湿
Dialogue: 0,2:04:12.36,2:04:15.17,Default,,0,0,0,,湿哒哒
Dialogue: 0,2:04:15.17,2:04:19.10,Default,,0,0,0,,湿滑湿滑
Dialogue: 0,2:04:19.10,2:04:31.85,Default,,0,0,0,,像这种，自己觉得很色情的声音，湿了的时候会发出来的
Dialogue: 0,2:04:31.85,2:04:36.49,Default,,0,0,0,,这些我都很喜欢
Dialogue: 0,2:04:36.49,2:04:44.30,Default,,0,0,0,,明明不色，但听起来很色的词汇
Dialogue: 0,2:04:44.30,2:04:47.53,Default,,0,0,0,,因为我喜欢高尔夫
Dialogue: 0,2:04:51.80,2:04:57.28,Default,,0,0,0,,接下来19栋是最后的洞了
Dialogue: 0,2:04:57.28,2:05:03.62,Default,,0,0,0,,女性的性器官叫什么
Dialogue: 0,2:05:10.82,2:05:14.26,Default,,0,0,0,,普通的叫法是小穴
Dialogue: 0,2:05:16.63,2:05:21.30,Default,,0,0,0,,请念一下女性性器官
Dialogue: 0,2:05:21.30,2:05:57.80,Default,,0,0,0,,有多少种念法我不清楚，刚刚说过的是小穴，那个地方，下面的嘴，花蕾，小缝
Dialogue: 0,2:05:57.80,2:06:08.05,Default,,0,0,0,,抱歉，就知道这些了
Dialogue: 0,2:06:10.68,2:06:12.55,Default,,0,0,0,,男性的性器官叫什么？
Dialogue: 0,2:06:12.55,2:06:38.84,Default,,0,0,0,,鸡鸡，接下来，把男性的性器官用各种语音来念
Dialogue: 0,2:06:38.84,2:06:43.52,Default,,0,0,0,,各位准备好了吗？
Dialogue: 0,2:06:43.52,2:06:48.22,Default,,0,0,0,,那么我开始了哦
Dialogue: 0,2:06:48.22,2:09:20.84,Default,,0,0,0,,鸡鸡，鸡巴，我的鸡鸡，鸡鸡，鸡巴，鸡儿，大鸡巴，大鸡鸡，阴茎，肉棒，大鸡鸡
Dialogue: 0,2:09:20.84,2:09:46.16,Default,,0,0,0,,小鸡吧，谢谢收听
Dialogue: 0,2:09:46.16,2:09:54.01,Default,,0,0,0,,好，停
Dialogue: 0,2:10:02.85,2:10:09.65,Default,,0,0,0,,很难受吗？    很难受
Dialogue: 0,2:10:09.65,2:10:15.53,Default,,0,0,0,,是吗？    要念出来吗
Dialogue: 0,2:10:15.53,2:10:18.53,Default,,0,0,0,,看起来平常不太说淫荡的话，但效果还是不错的
Dialogue: 0,2:10:55.73,2:10:58.44,Default,,0,0,0,,觉得最后会变成什么样
Dialogue: 0,2:10:58.44,2:11:04.88,Default,,0,0,0,,想更爽点
Dialogue: 0,2:11:04.88,2:11:10.65,Default,,0,0,0,,丸之内职业女性人生初次3P
Dialogue: 0,2:11:10.65,2:11:15.99,Default,,0,0,0,,能成为人生最爽的体验吗
Dialogue: 0,2:11:15.99,2:11:21.13,Default,,0,0,0,,是的，请多指教
Dialogue: 0,2:11:21.13,2:11:26.60,Default,,0,0,0,,脸放松点
Dialogue: 0,2:11:26.60,2:11:32.87,Default,,0,0,0,,这样就好
Dialogue: 0,2:11:32.87,2:11:44.72,Default,,0,0,0,,那开始做吧，没关系吧
Dialogue: 0,2:11:44.72,2:11:52.99,Default,,0,0,0,,要拍了哦，好
Dialogue: 0,2:11:52.99,2:12:00.07,Default,,0,0,0,,要开始了
Dialogue: 0,2:12:00.07,2:12:10.64,Default,,0,0,0,,真的可以开始了吗？
Dialogue: 0,2:12:10.64,2:12:18.22,Default,,0,0,0,,预备，开始。紧张了吗
Dialogue: 0,2:12:18.22,2:12:20.52,Default,,0,0,0,,是的
Dialogue: 0,2:12:20.52,2:12:25.42,Default,,0,0,0,,做爱被人看是什么感觉
Dialogue: 0,2:12:25.42,2:12:31.66,Default,,0,0,0,,虽然很害羞，但是很兴奋
Dialogue: 0,2:12:31.66,2:12:37.00,Default,,0,0,0,,兴奋了吗？被人看着？
Dialogue: 0,2:12:37.00,2:12:44.71,Default,,0,0,0,,无法想象做爱中自己的脸吧
Dialogue: 0,2:12:44.71,2:12:48.28,Default,,0,0,0,,看起来不像是很骚的样子啊
Dialogue: 0,2:12:48.28,2:12:51.45,Default,,0,0,0,,会自慰吗？
Dialogue: 0,2:12:51.45,2:12:52.88,Default,,0,0,0,,会
Dialogue: 0,2:12:52.88,2:12:58.12,Default,,0,0,0,,在人前自慰过吗？    没有。   没有吗？
Dialogue: 0,2:13:18.68,2:13:22.71,Default,,0,0,0,,想要你自慰给我看
Dialogue: 0,2:13:22.71,2:13:27.52,Default,,0,0,0,,可以吗？   好
Dialogue: 0,2:13:27.52,2:13:32.12,Default,,0,0,0,,张开腿
Dialogue: 0,2:13:35.76,2:13:39.80,Default,,0,0,0,,好骚啊
Dialogue: 0,2:13:39.80,2:13:43.20,Default,,0,0,0,,平常都怎么自慰
Dialogue: 0,2:13:43.20,2:13:46.87,Default,,0,0,0,,隔着内裤摸。    那我等着看了哦
Dialogue: 0,2:13:46.87,2:13:48.77,Default,,0,0,0,,好
Dialogue: 0,2:13:48.77,2:13:50.84,Default,,0,0,0,,喜欢用哪只手
Dialogue: 0,2:13:50.84,2:13:54.48,Default,,0,0,0,,右手
Dialogue: 0,2:13:54.48,2:13:58.12,Default,,0,0,0,,那做给我看
Dialogue: 0,2:14:22.77,2:14:27.68,Default,,0,0,0,,自慰的时候会幻想吗
Dialogue: 0,2:14:27.68,2:14:30.32,Default,,0,0,0,,想些什么呢
Dialogue: 0,2:14:30.32,2:14:36.72,Default,,0,0,0,,想和公司的人做爱
Dialogue: 0,2:14:36.72,2:14:40.63,Default,,0,0,0,,哦，那有做过吗
Dialogue: 0,2:14:40.63,2:14:42.66,Default,,0,0,0,,没有
Dialogue: 0,2:14:42.66,2:14:46.50,Default,,0,0,0,,幻想在哪里做
Dialogue: 0,2:14:46.50,2:14:52.17,Default,,0,0,0,,容易幻想，带上眼罩吧
Dialogue: 0,2:15:03.88,2:15:07.35,Default,,0,0,0,,仔细看着的哦
Dialogue: 0,2:15:24.77,2:15:27.97,Default,,0,0,0,,现在在摸哪里了
Dialogue: 0,2:15:27.97,2:15:29.57,Default,,0,0,0,,阴蒂
Dialogue: 0,2:15:29.57,2:15:36.05,Default,,0,0,0,,阴蒂什么感觉
Dialogue: 0,2:15:39.89,2:15:45.46,Default,,0,0,0,,手伸进里面摸摸看
Dialogue: 0,2:15:45.46,2:15:53.67,Default,,0,0,0,,摸阴蒂给我看
Dialogue: 0,2:16:09.75,2:16:14.09,Default,,0,0,0,,腰在扭动了，因为爽了吗
Dialogue: 0,2:16:18.92,2:16:21.36,Default,,0,0,0,,好骚啊
Dialogue: 0,2:16:36.78,2:16:42.41,Default,,0,0,0,,怎么了？开始叫了哦
Dialogue: 0,2:16:52.79,2:16:56.09,Default,,0,0,0,,开始振动了哦
Dialogue: 0,2:17:18.65,2:17:23.52,Default,,0,0,0,,被这样弄的话，现在阴蒂是什么感觉
Dialogue: 0,2:17:23.52,2:17:27.69,Default,,0,0,0,,好爽。   好爽？
Dialogue: 0,2:17:44.71,2:17:47.08,Default,,0,0,0,,很爽吧
Dialogue: 0,2:17:57.69,2:18:01.29,Default,,0,0,0,,公司的人用可能这样做吗
Dialogue: 0,2:18:01.29,2:18:05.43,Default,,0,0,0,,试试看吧
Dialogue: 0,2:18:05.43,2:18:11.44,Default,,0,0,0,,怎么了
Dialogue: 0,2:18:11.44,2:18:15.84,Default,,0,0,0,,腰扭得好厉害
Dialogue: 0,2:18:15.84,2:18:31.72,Default,,0,0,0,,小穴张这样啊，掰开给我看
Dialogue: 0,2:18:31.72,2:18:36.53,Default,,0,0,0,,用手掰开给我看
Dialogue: 0,2:18:36.53,2:18:45.67,Default,,0,0,0,,好淫荡
Dialogue: 0,2:19:04.79,2:19:09.06,Default,,0,0,0,,听到什么声音了吗
Dialogue: 0,2:19:09.06,2:19:13.40,Default,,0,0,0,,现在大家都听到了哦
Dialogue: 0,2:19:13.40,2:19:18.84,Default,,0,0,0,,大家听到你小穴湿了哦
Dialogue: 0,2:19:18.84,2:19:29.35,Default,,0,0,0,,戴眼罩觉得怎么样？
Dialogue: 0,2:19:29.35,2:19:35.99,Default,,0,0,0,,不兴奋了吗？   很兴奋
Dialogue: 0,2:19:35.99,2:19:42.86,Default,,0,0,0,,再给你玩更好玩的
Dialogue: 0,2:19:42.86,2:19:47.60,Default,,0,0,0,,手给我
Dialogue: 0,2:19:47.60,2:19:58.41,Default,,0,0,0,,这样，手就不能动了
Dialogue: 0,2:20:02.75,2:20:06.45,Default,,0,0,0,,哇，好淫荡
Dialogue: 0,2:20:46.76,2:20:49.66,Default,,0,0,0,,公司的人会这样做吗
Dialogue: 0,2:20:59.67,2:21:04.28,Default,,0,0,0,,爽吗   好爽
Dialogue: 0,2:21:10.85,2:21:13.42,Default,,0,0,0,,好淫荡哦
Dialogue: 0,2:21:18.82,2:21:23.26,Default,,0,0,0,,小穴湿了哦
Dialogue: 0,2:21:23.26,2:21:31.70,Default,,0,0,0,,看着，我用了两根手指插进去了哦
Dialogue: 0,2:21:31.70,2:21:34.64,Default,,0,0,0,,睁开眼睛看着
Dialogue: 0,2:21:34.64,2:22:05.00,Default,,0,0,0,,好棒，小穴好淫荡
Dialogue: 0,2:22:05.00,2:22:12.18,Default,,0,0,0,,睁开眼睛看着
Dialogue: 0,2:22:22.69,2:22:26.19,Default,,0,0,0,,这样尿尿不好哦
Dialogue: 0,2:22:29.93,2:22:34.23,Default,,0,0,0,,我帮你塞住
Dialogue: 0,2:22:38.87,2:22:42.61,Default,,0,0,0,,刚刚阴蒂也很爽吧
Dialogue: 0,2:22:42.61,2:22:48.48,Default,,0,0,0,,刺激下阴蒂好吧
Dialogue: 0,2:22:48.48,2:22:54.95,Default,,0,0,0,,只是这样插好吗
Dialogue: 0,2:22:54.95,2:23:05.60,Default,,0,0,0,,你看啊，这边也要来了哦
Dialogue: 0,2:23:12.97,2:23:17.61,Default,,0,0,0,,怎么了，腰开始扭动了
Dialogue: 0,2:23:17.61,2:23:20.78,Default,,0,0,0,,一爽就会扭动吗
Dialogue: 0,2:23:20.78,2:23:26.18,Default,,0,0,0,,那继续帮你爽哦。     要去了
Dialogue: 0,2:23:26.18,2:23:35.63,Default,,0,0,0,,要去了
Dialogue: 0,2:23:35.63,2:23:39.66,Default,,0,0,0,,抖得很厉害嘛。很爽是不是
Dialogue: 0,2:23:39.66,2:24:00.69,Default,,0,0,0,,好爽
Dialogue: 0,2:24:00.69,2:24:05.26,Default,,0,0,0,,怎么了，站起来吧
Dialogue: 0,2:24:05.26,2:24:10.26,Default,,0,0,0,,刚刚去了吗？
Dialogue: 0,2:24:10.26,2:24:18.04,Default,,0,0,0,,站起来，手举高，对对对
Dialogue: 0,2:24:18.04,2:24:24.74,Default,,0,0,0,,腿张开
Dialogue: 0,2:24:24.74,2:24:30.02,Default,,0,0,0,,对对对，淫荡的姿势。
Dialogue: 0,2:24:30.02,2:24:33.35,Default,,0,0,0,,好骚的姿势哦
Dialogue: 0,2:24:33.35,2:24:40.36,Default,,0,0,0,,要站着插入了哦
Dialogue: 0,2:24:46.83,2:24:49.80,Default,,0,0,0,,要站好哦
Dialogue: 0,2:24:53.67,2:24:57.34,Default,,0,0,0,,不能坐下哦
Dialogue: 0,2:24:57.34,2:25:11.69,Default,,0,0,0,,要去了
Dialogue: 0,2:25:11.69,2:25:19.97,Default,,0,0,0,,已经去了哦
Dialogue: 0,2:25:29.67,2:25:36.75,Default,,0,0,0,,好棒哦，站起来
Dialogue: 0,2:25:36.75,2:25:40.35,Default,,0,0,0,,说了不能坐下得嘛
Dialogue: 0,2:25:40.35,2:25:43.96,Default,,0,0,0,,好骚啊
Dialogue: 0,2:25:47.66,2:25:49.36,Default,,0,0,0,,有3P的经验吗
Dialogue: 0,2:25:49.36,2:25:51.50,Default,,0,0,0,,没有吗
Dialogue: 0,2:25:51.50,2:25:54.40,Default,,0,0,0,,期待吧
Dialogue: 0,2:26:03.51,2:26:09.25,Default,,0,0,0,,身材很好嘛
Dialogue: 0,2:26:15.59,2:26:19.46,Default,,0,0,0,,背上流了很多汗哟，怎么回事？
Dialogue: 0,2:26:19.46,2:26:25.56,Default,,0,0,0,,一抖一抖的，是怎么了？
Dialogue: 0,2:26:25.56,2:26:27.67,Default,,0,0,0,,好爽
Dialogue: 0,2:26:27.67,2:26:32.60,Default,,0,0,0,,我来舔你的汗水
Dialogue: 0,2:27:05.70,2:27:08.87,Default,,0,0,0,,去床上吧
Dialogue: 0,2:27:08.87,2:27:25.22,Default,,0,0,0,,好棒，能自己掰开给我看吗
Dialogue: 0,2:27:25.22,2:27:29.16,Default,,0,0,0,,好羞人啊，一览无余啊
Dialogue: 0,2:28:01.83,2:28:03.83,Default,,0,0,0,,玩具如何？    好爽
Dialogue: 0,2:28:03.83,2:28:07.27,Default,,0,0,0,,用过这种玩具没？没有吗
Dialogue: 0,2:28:07.27,2:28:10.17,Default,,0,0,0,,第一次用，很棒吧
Dialogue: 0,2:28:19.71,2:28:23.72,Default,,0,0,0,,爽吗？  好爽
Dialogue: 0,2:28:23.72,2:28:27.19,Default,,0,0,0,,怎么了？   不行了
Dialogue: 0,2:28:35.69,2:28:42.00,Default,,0,0,0,,要去了
Dialogue: 0,2:29:08.86,2:29:12.70,Default,,0,0,0,,怎样？   好爽
Dialogue: 0,2:29:12.70,2:29:18.70,Default,,0,0,0,,好爽
Dialogue: 0,2:29:18.70,2:29:23.78,Default,,0,0,0,,不行了
Dialogue: 0,2:29:23.78,2:29:29.58,Default,,0,0,0,,喷了好多啊。     要去了
Dialogue: 0,2:29:54.04,2:29:56.71,Default,,0,0,0,,坐这里来
Dialogue: 0,2:29:56.71,2:30:03.72,Default,,0,0,0,,来莫这边，那边一起摸
Dialogue: 0,2:30:03.72,2:30:08.02,Default,,0,0,0,,好爽
Dialogue: 0,2:30:19.73,2:30:23.90,Default,,0,0,0,,要舔舔看吗？
Dialogue: 0,2:30:35.75,2:30:37.98,Default,,0,0,0,,好爽
Dialogue: 0,2:30:49.70,2:30:53.33,Default,,0,0,0,,还有一根哦
Dialogue: 0,2:31:17.62,2:31:21.83,Default,,0,0,0,,口得很熟练嘛
Dialogue: 0,2:31:21.83,2:31:29.60,Default,,0,0,0,,来个深喉，好骚啊
Dialogue: 0,2:31:29.60,2:31:36.04,Default,,0,0,0,,这个鸡鸡很大吧。    好大
Dialogue: 0,2:31:36.04,2:31:41.35,Default,,0,0,0,,很大吧，换这根了
Dialogue: 0,2:31:54.83,2:32:00.03,Default,,0,0,0,,好厉害，两根同时舔
Dialogue: 0,2:32:10.68,2:32:13.61,Default,,0,0,0,,现在好骚啊
Dialogue: 0,2:32:13.61,2:32:19.25,Default,,0,0,0,,很大吧，不用手只用嘴试试看
Dialogue: 0,2:32:27.93,2:32:30.50,Default,,0,0,0,,站起来
Dialogue: 0,2:32:45.01,2:32:48.51,Default,,0,0,0,,看镜子
Dialogue: 0,2:32:48.51,2:32:53.59,Default,,0,0,0,,好淫荡哦，好骚的脸
Dialogue: 0,2:32:53.59,2:33:02.79,Default,,0,0,0,,脸靠近点看，再靠近点
Dialogue: 0,2:33:02.79,2:33:13.00,Default,,0,0,0,,鸡鸡插入的时候看着镜子了的自己，对着镜子说鸡鸡进来了
Dialogue: 0,2:33:13.00,2:33:16.58,Default,,0,0,0,,对，看自己的脸
Dialogue: 0,2:33:20.71,2:33:24.42,Default,,0,0,0,,鸡鸡日进来了。   日进去了？
Dialogue: 0,2:33:31.69,2:33:35.99,Default,,0,0,0,,好爽
Dialogue: 0,2:33:35.99,2:33:40.70,Default,,0,0,0,,看着镜子里的自己
Dialogue: 0,2:33:59.79,2:34:03.06,Default,,0,0,0,,镜子了自己的脸怎么样？
Dialogue: 0,2:34:03.06,2:34:05.86,Default,,0,0,0,,很骚
Dialogue: 0,2:34:05.86,2:34:13.63,Default,,0,0,0,,好鸡巴爽，看这边，对
Dialogue: 0,2:34:53.77,2:34:56.27,Default,,0,0,0,,好爽哦
Dialogue: 0,2:34:56.27,2:35:01.38,Default,,0,0,0,,喜欢吗？   喜欢
Dialogue: 0,2:35:04.62,2:35:09.76,Default,,0,0,0,,一日进去就知道你相当的骚啊
Dialogue: 0,2:35:09.76,2:35:11.59,Default,,0,0,0,,好爽哦
Dialogue: 0,2:35:11.59,2:35:15.66,Default,,0,0,0,,站好，对
Dialogue: 0,2:35:22.70,2:35:25.90,Default,,0,0,0,,要去了
Dialogue: 0,2:35:25.90,2:35:48.73,Default,,0,0,0,,好爽，你来动。   好爽
Dialogue: 0,2:35:56.74,2:35:59.50,Default,,0,0,0,,插到底了哦
Dialogue: 0,2:35:59.50,2:36:02.61,Default,,0,0,0,,会这样扭腰啊
Dialogue: 0,2:36:02.61,2:36:14.62,Default,,0,0,0,,爽死了
Dialogue: 0,2:36:26.93,2:36:31.87,Default,,0,0,0,,换个含鸡鸡含吧
Dialogue: 0,2:36:31.87,2:36:43.65,Default,,0,0,0,,小穴湿哒哒的了
Dialogue: 0,2:36:56.70,2:36:59.66,Default,,0,0,0,,哪里很爽？
Dialogue: 0,2:36:59.66,2:37:06.61,Default,,0,0,0,,深处。   深处？
Dialogue: 0,2:37:15.88,2:37:17.15,Default,,0,0,0,,要去了
Dialogue: 0,2:37:25.82,2:37:29.46,Default,,0,0,0,,来这边
Dialogue: 0,2:37:35.87,2:37:43.54,Default,,0,0,0,,主动亲上来了啊！为什么呢
Dialogue: 0,2:37:43.54,2:37:47.05,Default,,0,0,0,,感觉很爽吧
Dialogue: 0,2:37:59.76,2:38:02.83,Default,,0,0,0,,抱着我
Dialogue: 0,2:38:06.83,2:38:10.64,Default,,0,0,0,,爽死了
Dialogue: 0,2:38:10.64,2:38:13.81,Default,,0,0,0,,是不是自己在扭腰啊
Dialogue: 0,2:38:13.81,2:38:19.18,Default,,0,0,0,,好爽
Dialogue: 0,2:38:19.18,2:38:27.15,Default,,0,0,0,,想更爽吗？自己扭腰
Dialogue: 0,2:38:27.15,2:38:34.66,Default,,0,0,0,,好厉害哦
Dialogue: 0,2:38:34.66,2:38:39.66,Default,,0,0,0,,好厉害
Dialogue: 0,2:38:46.77,2:38:49.27,Default,,0,0,0,,抓好
Dialogue: 0,2:39:22.87,2:39:25.41,Default,,0,0,0,,好爽
Dialogue: 0,2:39:48.80,2:39:52.34,Default,,0,0,0,,好爽啊
Dialogue: 0,2:40:18.63,2:40:22.00,Default,,0,0,0,,要去了
Dialogue: 0,2:40:29.98,2:40:34.31,Default,,0,0,0,,撑起来，对
Dialogue: 0,2:40:40.75,2:40:43.66,Default,,0,0,0,,滑出来了
Dialogue: 0,2:40:43.66,2:40:48.99,Default,,0,0,0,,好棒，你来动
Dialogue: 0,2:40:48.99,2:40:54.70,Default,,0,0,0,,过来，放下膝盖
Dialogue: 0,2:40:54.70,2:40:59.81,Default,,0,0,0,,对，让我来爽
Dialogue: 0,2:40:59.81,2:41:13.09,Default,,0,0,0,,真几把骚
Dialogue: 0,2:41:40.15,2:41:43.12,Default,,0,0,0,,这里也舔舔
Dialogue: 0,2:41:50.89,2:41:55.69,Default,,0,0,0,,超棒的呢
Dialogue: 0,2:42:13.75,2:42:16.42,Default,,0,0,0,,要去了
Dialogue: 0,2:42:26.79,2:42:29.49,Default,,0,0,0,,说小穴的哪里爽
Dialogue: 0,2:42:29.49,2:42:31.10,Default,,0,0,0,,深处
Dialogue: 0,2:42:31.10,2:42:33.80,Default,,0,0,0,,那来插到深处哦
Dialogue: 0,2:42:44.94,2:42:48.65,Default,,0,0,0,,怎样，日进去了哦
Dialogue: 0,2:43:01.83,2:43:04.76,Default,,0,0,0,,有水喷出来了哦
Dialogue: 0,2:43:11.94,2:43:14.57,Default,,0,0,0,,好多水
Dialogue: 0,2:43:14.57,2:43:18.11,Default,,0,0,0,,不行了
Dialogue: 0,2:43:24.62,2:43:27.92,Default,,0,0,0,,要去了？
Dialogue: 0,2:43:43.84,2:43:48.94,Default,,0,0,0,,全部被看到了哦
Dialogue: 0,2:44:19.97,2:44:24.94,Default,,0,0,0,,好鸡巴爽，好骚
Dialogue: 0,2:44:46.80,2:44:50.20,Default,,0,0,0,,3P太爽啦
Dialogue: 0,2:44:50.20,2:44:52.70,Default,,0,0,0,,比平常更爽吧
Dialogue: 0,2:45:09.82,2:45:12.52,Default,,0,0,0,,好鸡巴爽
Dialogue: 0,2:45:52.00,2:45:54.83,Default,,0,0,0,,一览无余了哦
Dialogue: 0,2:46:00.77,2:46:04.78,Default,,0,0,0,,喷了好多水啊
Dialogue: 0,2:46:33.04,2:46:38.01,Default,,0,0,0,,来这里
Dialogue: 0,2:46:57.83,2:47:01.13,Default,,0,0,0,,好鸡巴爽
Dialogue: 0,2:47:10.81,2:47:13.28,Default,,0,0,0,,要去了
Dialogue: 0,2:47:21.72,2:47:24.29,Default,,0,0,0,,要射了
Dialogue: 0,2:47:46.04,2:47:49.38,Default,,0,0,0,,要去了
Dialogue: 0,2:47:53.65,2:47:56.89,Default,,0,0,0,,要射了
Dialogue: 0,2:48:31.62,2:48:33.73,Default,,0,0,0,,爽吗？
Dialogue: 0,2:48:42.87,2:48:45.40,Default,,0,0,0,,插到深处了哦
Dialogue: 0,2:48:54.68,2:48:59.08,Default,,0,0,0,,不行，要去了哦
Dialogue: 0,2:49:05.92,2:49:09.39,Default,,0,0,0,,要射在脸上哦
Dialogue: 0,2:49:18.74,2:49:23.84,Default,,0,0,0,,要去了？    要去了
Dialogue: 0,2:50:06.52,2:50:10.02,Default,,0,0,0,,我先躺一下
Dialogue: 0,2:50:15.36,2:50:21.30,Default,,0,0,0,,第一次3p结束了，很感动
Dialogue: 0,2:50:21.30,2:50:23.74,Default,,0,0,0,,没想到会这么爽
Dialogue: 0,2:50:23.74,2:50:25.74,Default,,0,0,0,,太好了
Dialogue: 0,2:50:25.74,2:50:28.91,Default,,0,0,0,,是人生中最爽的
Dialogue: 0,2:50:28.91,2:50:35.25,Default,,0,0,0,,是人生里最爽的，像是工作结束了的感觉
Dialogue: 0,2:50:35.25,2:50:42.05,Default,,0,0,0,,像是周五，想喝啤酒，结束了
Dialogue: 0,2:50:42.05,2:50:45.32,Default,,0,0,0,,吉永以结束工作的周五来比喻拍摄感想
Dialogue: 0,2:50:45.32,2:50:54.80,Default,,0,0,0,,到最后都是丸之内的职业女性啊
Dialogue: 0,2:51:23.60,2:51:27.47,Default,,0,0,0,,拍摄工作结束，一边喝着最爱的啤酒，一边问答。
Dialogue: 0,2:51:27.47,2:51:30.47,Default,,0,0,0,,什么是感到很难的？
Dialogue: 0,2:51:30.47,2:51:37.58,Default,,0,0,0,,问答环节是最难的
Dialogue: 0,2:51:37.58,2:51:40.98,Default,,0,0,0,,想好好说
Dialogue: 0,2:51:40.98,2:51:44.48,Default,,0,0,0,,关于访谈
Dialogue: 0,2:51:44.48,2:51:47.89,Default,,0,0,0,,想说只说一句话可以吗？
Dialogue: 0,2:51:47.89,2:51:51.49,Default,,0,0,0,,结果说了好多
Dialogue: 0,2:51:51.49,2:52:02.53,Default,,0,0,0,,就算说很多也没办法表达自己的感受，不能表达自己的感受，就是这样
Dialogue: 0,2:52:02.53,2:52:09.47,Default,,0,0,0,,真的觉得自己的语言能力很烂
Dialogue: 0,2:52:09.47,2:52:16.08,Default,,0,0,0,,觉得应该有更好的表达方式的
Dialogue: 0,2:52:16.08,2:52:19.28,Default,,0,0,0,,但是却想不出来
Dialogue: 0,2:52:19.28,2:52:23.56,Default,,0,0,0,,很难表达？   很难
Dialogue: 0,2:52:23.56,2:52:28.73,Default,,0,0,0,,访谈时最难的
Dialogue: 0,2:52:28.73,2:52:35.63,Default,,0,0,0,,把出道结束的感想说说呗
Dialogue: 0,2:52:35.63,2:52:40.61,Default,,0,0,0,,今天结束的感想？
Dialogue: 0,2:52:40.61,2:52:44.58,Default,,0,0,0,,觉得没什么好说的
Dialogue: 0,2:52:44.58,2:52:49.55,Default,,0,0,0,,一直都很爽
Dialogue: 0,2:52:49.55,2:52:54.62,Default,,0,0,0,,那今天的感想就是很爽哦
Dialogue: 0,2:52:54.62,2:52:59.83,Default,,0,0,0,,超出了预期
Dialogue: 0,2:52:59.83,2:53:03.70,Default,,0,0,0,,至今为止，包含所有交往过的人
Dialogue: 0,2:53:03.70,2:53:09.74,Default,,0,0,0,,日的时间这么长也是第一次
Dialogue: 0,2:53:09.74,2:53:17.21,Default,,0,0,0,,超出想象的爽
Dialogue: 0,2:53:17.21,2:53:21.75,Default,,0,0,0,,到了一种新的境界
Dialogue: 0,2:53:21.75,2:53:31.66,Default,,0,0,0,,冷静下来的话，可能性欲更上了一层吧
Dialogue: 0,2:53:31.66,2:53:43.07,Default,,0,0,0,,今天过后，以前的自己和以后的自己会改变很大吧。因为今天这一天
Dialogue: 0,2:53:43.07,2:53:49.74,Default,,0,0,0,,通过这次拍摄，吉永到了一个新境界
Dialogue: 0,2:53:49.74,2:53:51.94,Default,,0,0,0,,可以吃了吗
Dialogue: 0,2:53:51.94,2:53:54.45,Default,,0,0,0,,吃吧，没关系
Dialogue: 0,2:53:54.45,2:53:59.22,Default,,0,0,0,,她的深处还是个欲女

