Dialogue: 0,0:00:00.40,0:00:03.53,ASS,,0,0,0,,(绝望受胎)
Dialogue: 0,0:00:17.95,0:00:19.95,ASS,,0,0,0,,结婚六年
Dialogue: 0,0:00:20.42,0:00:23.75,ASS,,0,0,0,,三十后半的结婚
Dialogue: 0,0:00:24.95,0:00:28.42,ASS,,0,0,0,,母亲因脑溢血而倒下
Dialogue: 0,0:00:28.42,0:00:31.96,ASS,,0,0,0,,一边工作一边照顾母亲
Dialogue: 0,0:00:32.96,0:00:36.63,ASS,,0,0,0,,我在不知觉中\N就过了适婚年龄了
Dialogue: 0,0:00:38.90,0:00:42.64,ASS,,0,0,0,,这样的生活也过了七年
Dialogue: 0,0:00:43.44,0:00:45.71,ASS,,0,0,0,,母亲去世了
Dialogue: 0,0:00:47.91,0:00:51.38,ASS,,0,0,0,,我的年纪来到三十中段
Dialogue: 0,0:00:51.38,0:00:57.19,ASS,,0,0,0,,在相亲活动中和现在的老公\N阿彻先生相遇
Dialogue: 0,0:00:58.32,0:01:02.52,ASS,,0,0,0,,说好听点\N是位不吝小钱的社长
Dialogue: 0,0:01:03.46,0:01:06.93,ASS,,0,0,0,,说难听点\N是位富二代公子哥
Dialogue: 0,0:01:07.73,0:01:09.60,ASS,,0,0,0,,并不是坏人
Dialogue: 0,0:01:09.60,0:01:12.47,ASS,,0,0,0,,天真烂漫的好人
Dialogue: 0,0:01:13.27,0:01:16.74,ASS,,0,0,0,,阿彻先生是第二次的结婚
Dialogue: 0,0:01:16.74,0:01:19.01,ASS,,0,0,0,,而我是第一次
Dialogue: 0,0:01:19.94,0:01:24.01,ASS,,0,0,0,,对我而言\N没什么选择的余地
Dialogue: 0,0:01:25.41,0:01:31.09,ASS,,0,0,0,,生小孩与不用照护母亲的\N女人幸福
Dialogue: 0,0:01:31.95,0:01:34.82,ASS,,0,0,0,,很想要取回这些生活
Dialogue: 0,0:01:36.43,0:01:37.89,ASS,,0,0,0,,不过...
Dialogue: 0,0:01:38.43,0:01:42.90,ASS,,0,0,0,,每个月都接受不孕治疗
Dialogue: 0,0:01:42.90,0:01:47.44,ASS,,0,0,0,,还是没办法有小孩
Dialogue: 0,0:02:04.45,0:02:06.72,ASS,,0,0,0,,老公也...
Dialogue: 0,0:02:07.92,0:02:11.19,ASS,,0,0,0,,也接受了检查
Dialogue: 0,0:02:11.19,0:02:16.33,ASS,,0,0,0,,原因也许在他身上...
Dialogue: 0,0:02:16.33,0:02:22.20,ASS,,0,0,0,,因为无法对我说出囗
Dialogue: 0,0:02:45.43,0:02:46.56,ASS,,0,0,0,,亚纪
Dialogue: 0,0:02:46.56,0:02:48.30,ASS,,0,0,0,,对不起\N让你久等了
Dialogue: 0,0:02:48.30,0:02:50.77,ASS,,0,0,0,,天气真热耶
Dialogue: 0,0:02:51.43,0:02:54.57,ASS,,0,0,0,,今天的治疗如何呢
Dialogue: 0,0:02:56.24,0:02:59.11,ASS,,0,0,0,,倒是你这样没关系吗
Dialogue: 0,0:02:59.11,0:03:00.44,ASS,,0,0,0,,没关系的
Dialogue: 0,0:03:00.44,0:03:01.84,ASS,,0,0,0,,不好意思
Dialogue: 0,0:03:01.84,0:03:02.98,ASS,,0,0,0,,欢迎光临
Dialogue: 0,0:03:02.98,0:03:04.91,ASS,,0,0,0,,碳酸柠檬汁\N酸一点
Dialogue: 0,0:03:04.91,0:03:06.31,ASS,,0,0,0,,好\N请稍等
Dialogue: 0,0:03:06.31,0:03:09.38,ASS,,0,0,0,,孕吐真的很难受呢
Dialogue: 0,0:03:09.38,0:03:13.26,ASS,,0,0,0,,不过才怀孕三个月\N还无法轻松下来呢
Dialogue: 0,0:03:13.26,0:03:17.06,ASS,,0,0,0,,怀孕之后\N老公就被解雇
Dialogue: 0,0:03:17.06,0:03:18.79,ASS,,0,0,0,,还真笑不出来呢
Dialogue: 0,0:03:19.19,0:03:23.93,ASS,,0,0,0,,不过俊介虽温柔\N但年纪比我小 不可靠呢
Dialogue: 0,0:03:24.47,0:03:27.67,ASS,,0,0,0,,不过姐夫介绍俊介\N进去他们公司
Dialogue: 0,0:03:27.67,0:03:29.94,ASS,,0,0,0,,真的是很感谢
Dialogue: 0,0:03:29.94,0:03:34.28,ASS,,0,0,0,,姐姐是社长夫人\N真是帮上大忙了
Dialogue: 0,0:03:35.41,0:03:38.68,ASS,,0,0,0,,俊介听说很努力哦
Dialogue: 0,0:03:38.68,0:03:40.62,ASS,,0,0,0,,老公也说他帮上大忙呢
Dialogue: 0,0:03:40.62,0:03:42.55,ASS,,0,0,0,,真是非常抱歉
Dialogue: 0,0:03:42.55,0:03:46.76,ASS,,0,0,0,,不过明明是新人\N还拿这么好的薪水
Dialogue: 0,0:03:46.76,0:03:49.29,ASS,,0,0,0,,虽说已不担心钱的事了
Dialogue: 0,0:03:49.29,0:03:52.56,ASS,,0,0,0,,却很担心俊介会出去乱搞
Dialogue: 0,0:03:53.16,0:03:56.03,ASS,,0,0,0,,怀孕后完全都没碰面耶
Dialogue: 0,0:03:56.03,0:03:57.63,ASS,,0,0,0,,不过姐姐那边如何呢
Dialogue: 0,0:03:57.63,0:04:00.17,ASS,,0,0,0,,不孕治疗很辛苦吧
Dialogue: 0,0:04:00.17,0:04:02.24,ASS,,0,0,0,,感觉治疗会很痛
Dialogue: 0,0:04:02.24,0:04:05.44,ASS,,0,0,0,,身体上女孩子也比较辛苦呢
Dialogue: 0,0:04:06.17,0:04:07.31,ASS,,0,0,0,,没关系的
Dialogue: 0,0:04:09.24,0:04:11.58,ASS,,0,0,0,,都已经结婚了
Dialogue: 0,0:04:11.58,0:04:14.45,ASS,,0,0,0,,没办法\N自作自受嘛
Dialogue: 0,0:04:14.92,0:04:18.72,ASS,,0,0,0,,若姐姐也能得到幸福就好了呢
Dialogue: 0,0:04:18.72,0:04:22.79,ASS,,0,0,0,,妈妈的照料也都交给姐姐\N真的很抱歉呢
Dialogue: 0,0:04:23.46,0:04:29.33,ASS,,0,0,0,,不过 妈妈也很安心\N让美人又优秀的姐姐照顾呢
Dialogue: 0,0:04:29.33,0:04:32.53,ASS,,0,0,0,,所以才会延误结婚时机呢
Dialogue: 0,0:04:32.53,0:04:35.00,ASS,,0,0,0,,而另方面身为妹妹的我
Dialogue: 0,0:04:35.00,0:04:37.41,ASS,,0,0,0,,头脑又差又不适任
Dialogue: 0,0:04:37.41,0:04:39.27,ASS,,0,0,0,,什么都帮不上忙
Dialogue: 0,0:04:39.27,0:04:42.08,ASS,,0,0,0,,真是对不起呢
Dialogue: 0,0:04:43.08,0:04:49.42,ASS,,0,0,0,,不过妈妈 真的很骄傲\N有姐姐这样的女儿呢
Dialogue: 0,0:05:06.43,0:05:07.84,ASS,,0,0,0,,喂喂
Dialogue: 0,0:05:08.90,0:05:10.37,ASS,,0,0,0,,喂喂
Dialogue: 0,0:05:10.91,0:05:12.64,ASS,,0,0,0,,是优子吗
Dialogue: 0,0:05:13.44,0:05:15.18,ASS,,0,0,0,,妈妈
Dialogue: 0,0:05:16.44,0:05:20.25,ASS,,0,0,0,,今天是不孕治疗的日子吧
Dialogue: 0,0:05:20.25,0:05:21.98,ASS,,0,0,0,,是
Dialogue: 0,0:05:23.72,0:05:28.06,ASS,,0,0,0,,医生怎么说\N没说什么吗
Dialogue: 0,0:05:28.06,0:05:31.66,ASS,,0,0,0,,像是差不多能怀孕之类的
Dialogue: 0,0:05:35.93,0:05:36.87,ASS,,0,0,0,,没有
Dialogue: 0,0:05:36.87,0:05:38.67,ASS,,0,0,0,,是这样啊
Dialogue: 0,0:05:38.67,0:05:42.74,ASS,,0,0,0,,优子啊\N都和阿彻结婚六年了吧
Dialogue: 0,0:05:42.74,0:05:45.21,ASS,,0,0,0,,所以应该是41岁
Dialogue: 0,0:05:45.21,0:05:52.41,ASS,,0,0,0,,这样接下来要怀孕\N可就会越来越辛苦了呢
Dialogue: 0,0:05:52.41,0:05:56.55,ASS,,0,0,0,,亚纪你也不想\N因为这样而绝后吧
Dialogue: 0,0:05:56.55,0:05:58.95,ASS,,0,0,0,,快点延续香火啊
Dialogue: 0,0:05:58.95,0:06:02.49,ASS,,0,0,0,,我的孙子就看你了耶
Dialogue: 0,0:06:04.43,0:06:05.29,ASS,,0,0,0,,对了
Dialogue: 0,0:06:05.29,0:06:08.23,ASS,,0,0,0,,也让阿彻吃点活力的东西
Dialogue: 0,0:06:08.23,0:06:11.30,ASS,,0,0,0,,要好好激励他啊
Dialogue: 0,0:06:13.44,0:06:19.57,ASS,,0,0,0,,之后的不孕治疗也拜托了哦
Dialogue: 0,0:06:29.92,0:06:33.12,ASS,,0,0,0,,就算是社长夫人\N也会想哭吧
Dialogue: 0,0:06:33.12,0:06:34.26,ASS,,0,0,0,,对了
Dialogue: 0,0:06:34.26,0:06:35.79,ASS,,0,0,0,,现在去公司吧
Dialogue: 0,0:06:35.79,0:06:38.33,ASS,,0,0,0,,现在说的话刚好是坏事
Dialogue: 0,0:06:38.33,0:06:40.53,ASS,,0,0,0,,让姐夫生气吧
Dialogue: 0,0:06:40.53,0:06:42.80,ASS,,0,0,0,,真爱乱说
Dialogue: 0,0:06:42.80,0:06:44.20,ASS,,0,0,0,,好嘛
Dialogue: 0,0:06:50.94,0:06:52.34,ASS,,0,0,0,,给我付钱啊
Dialogue: 0,0:06:53.41,0:06:55.68,ASS,,0,0,0,,是想要我们做白工哦
Dialogue: 0,0:06:55.94,0:06:58.55,ASS,,0,0,0,,到底是怎么回事啊\N世野
Dialogue: 0,0:06:58.55,0:07:00.22,ASS,,0,0,0,,说啊
Dialogue: 0,0:07:01.35,0:07:02.82,ASS,,0,0,0,,就如同刚刚说的
Dialogue: 0,0:07:02.95,0:07:10.43,ASS,,0,0,0,,会想办法付款的
Dialogue: 0,0:07:10.43,0:07:11.96,ASS,,0,0,0,,世野
Dialogue: 0,0:07:11.96,0:07:14.36,ASS,,0,0,0,,一直说会想办法付款
Dialogue: 0,0:07:14.36,0:07:16.36,ASS,,0,0,0,,到底要我们等多久啊
Dialogue: 0,0:07:16.36,0:07:17.97,ASS,,0,0,0,,都三个月了耶
Dialogue: 0,0:07:17.97,0:07:22.57,ASS,,0,0,0,,再拖拖拉拉下去\N就要拿职员的薪水来抵了哦
Dialogue: 0,0:07:22.57,0:07:26.44,ASS,,0,0,0,,白木的公司被击溃后\N我们会被卖掉啊
Dialogue: 0,0:07:26.44,0:07:28.18,ASS,,0,0,0,,我们会被击溃
Dialogue: 0,0:07:28.18,0:07:30.25,ASS,,0,0,0,,可不要把我们当白痴啊
Dialogue: 0,0:07:30.25,0:07:33.38,ASS,,0,0,0,,我们都做了这么久的伙伴了
Dialogue: 0,0:07:33.38,0:07:35.65,ASS,,0,0,0,,三个月我们也有\N付出代价的啊
Dialogue: 0,0:07:35.65,0:07:36.79,ASS,,0,0,0,,社长不要生气
Dialogue: 0,0:07:36.79,0:07:40.92,ASS,,0,0,0,,我们建造的\N是不动产的共同住宅屋吧
Dialogue: 0,0:07:40.92,0:07:42.59,ASS,,0,0,0,,有没钱付的传言
Dialogue: 0,0:07:43.93,0:07:45.79,ASS,,0,0,0,,银行被冻结
Dialogue: 0,0:07:45.79,0:07:48.33,ASS,,0,0,0,,不就是建设途中\N出现的财政缺口吗
Dialogue: 0,0:07:48.33,0:07:52.27,ASS,,0,0,0,,所以一毛钱也付不出来吧
Dialogue: 0,0:07:52.27,0:07:55.14,ASS,,0,0,0,,可不要看我们好欺负啊
Dialogue: 0,0:07:55.14,0:07:57.27,ASS,,0,0,0,,冷静点
Dialogue: 0,0:07:57.27,0:08:00.54,ASS,,0,0,0,,银行那边答应通融
Dialogue: 0,0:08:00.54,0:08:02.74,ASS,,0,0,0,,再过一星期融资就会下来的
Dialogue: 0,0:08:02.74,0:08:05.01,ASS,,0,0,0,,到时候一定
Dialogue: 0,0:08:05.01,0:08:07.62,ASS,,0,0,0,,在这里向你们保证
Dialogue: 0,0:08:07.62,0:08:08.95,ASS,,0,0,0,,我说世野啊
Dialogue: 0,0:08:08.95,0:08:10.82,ASS,,0,0,0,,钱真的会下来
Dialogue: 0,0:08:10.82,0:08:11.62,ASS,,0,0,0,,这是当然的
Dialogue: 0,0:08:11.62,0:08:13.76,ASS,,0,0,0,,请相信我
Dialogue: 0,0:08:13.76,0:08:15.59,ASS,,0,0,0,,意思是可以拿到钱吗\N这当然
Dialogue: 0,0:08:15.59,0:08:16.39,ASS,,0,0,0,,等一下
Dialogue: 0,0:08:16.39,0:08:18.59,ASS,,0,0,0,,不要给我逃走啊
Dialogue: 0,0:08:26.53,0:08:27.54,ASS,,0,0,0,,对了
Dialogue: 0,0:08:27.54,0:08:28.64,ASS,,0,0,0,,忘记了
Dialogue: 0,0:08:28.90,0:08:30.04,ASS,,0,0,0,,亚纪\N对不起
Dialogue: 0,0:08:30.54,0:08:32.77,ASS,,0,0,0,,我先去拿慰劳品
Dialogue: 0,0:08:33.24,0:08:36.28,ASS,,0,0,0,,真不愧是社长夫人\N设想真周到
Dialogue: 0,0:08:36.91,0:08:39.95,ASS,,0,0,0,,你先上去\N那我先上去咯
Dialogue: 0,0:08:48.86,0:08:51.76,ASS,,0,0,0,,干嘛偷偷摸摸走掉
Dialogue: 0,0:08:53.93,0:08:55.56,ASS,,0,0,0,,你说话啊
Dialogue: 0,0:08:55.56,0:08:56.43,ASS,,0,0,0,,等等
Dialogue: 0,0:08:56.43,0:08:57.47,ASS,,0,0,0,,你干什么啊
Dialogue: 0,0:08:57.47,0:08:59.70,ASS,,0,0,0,,不好意思\N等等 冷静点
Dialogue: 0,0:09:00.60,0:09:03.77,ASS,,0,0,0,,叫你们白木社长快付钱啊
Dialogue: 0,0:09:03.77,0:09:05.47,ASS,,0,0,0,,等等
Dialogue: 0,0:09:05.47,0:09:07.11,ASS,,0,0,0,,老公
Dialogue: 0,0:09:07.11,0:09:08.24,ASS,,0,0,0,,你们在做什么
Dialogue: 0,0:09:08.24,0:09:10.65,ASS,,0,0,0,,等等
Dialogue: 0,0:09:10.65,0:09:12.61,ASS,,0,0,0,,老公 等等
Dialogue: 0,0:09:13.42,0:09:15.38,ASS,,0,0,0,,在做什么啊
Dialogue: 0,0:09:29.43,0:09:31.07,ASS,,0,0,0,,亚纪
Dialogue: 0,0:09:34.44,0:09:35.60,ASS,,0,0,0,,亚纪
Dialogue: 0,0:09:36.40,0:09:37.77,ASS,,0,0,0,,亚纪
Dialogue: 0,0:09:37.77,0:09:39.34,ASS,,0,0,0,,发生什么事了吗
Dialogue: 0,0:09:39.34,0:09:40.71,ASS,,0,0,0,,没事吧
Dialogue: 0,0:09:41.91,0:09:46.45,ASS,,0,0,0,,快点叫救护车啊
Dialogue: 0,0:09:46.45,0:09:47.95,ASS,,0,0,0,,亚纪
Dialogue: 0,0:09:47.95,0:09:52.72,ASS,,0,0,0,,快点叫救护车啊
Dialogue: 0,0:09:52.72,0:09:56.66,ASS,,0,0,0,,亚纪
Dialogue: 0,0:09:56.66,0:09:59.89,ASS,,0,0,0,,快点叫救护车啊
Dialogue: 0,0:09:59.89,0:10:04.30,ASS,,0,0,0,,亚纪
Dialogue: 0,0:10:42.94,0:10:44.34,ASS,,0,0,0,,来了
Dialogue: 0,0:10:48.91,0:10:50.38,ASS,,0,0,0,,姐姐
Dialogue: 0,0:10:50.38,0:10:51.75,ASS,,0,0,0,,你好
Dialogue: 0,0:10:51.95,0:10:53.31,ASS,,0,0,0,,怎么突然
Dialogue: 0,0:10:58.45,0:11:01.66,ASS,,0,0,0,,带了亚纪喜欢吃的过来
Dialogue: 0,0:11:01.66,0:11:03.29,ASS,,0,0,0,,谢谢
Dialogue: 0,0:11:09.40,0:11:10.77,ASS,,0,0,0,,亚纪呢
Dialogue: 0,0:11:12.93,0:11:17.14,ASS,,0,0,0,,亚纪她去住朋友家了
Dialogue: 0,0:11:17.14,0:11:21.94,ASS,,0,0,0,,说不想再看到我的脸了
Dialogue: 0,0:11:21.94,0:11:24.11,ASS,,0,0,0,,是这样啊
Dialogue: 0,0:11:27.92,0:11:29.15,ASS,,0,0,0,,那么...
Dialogue: 0,0:11:29.15,0:11:33.62,ASS,,0,0,0,,我就来帮忙整理一下吧
Dialogue: 0,0:11:34.42,0:11:36.59,ASS,,0,0,0,,人真好
Dialogue: 0,0:11:47.40,0:11:49.24,ASS,,0,0,0,,那边不用了
Dialogue: 0,0:11:49.24,0:11:50.51,ASS,,0,0,0,,没关系哦
Dialogue: 0,0:11:50.51,0:11:52.14,ASS,,0,0,0,,不用太在意
