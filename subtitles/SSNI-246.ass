Dialogue: 0,0:00:02.51,0:00:07.55,Default,,0,0,0,,（全身湿湿的 到润滑油海）\N（登上湿湿的小艇)
Dialogue: 0,0:00:08.27,0:00:14.39,Default,,0,0,0,,（距离天国最近的地方）\N（就在这里）
Dialogue: 0,0:00:20.87,0:00:26.27,Default,,0,0,0,,(S1出品)
Dialogue: 0,0:00:26.63,0:00:34.91,Default,,0,0,0,,（出演 葵)
Dialogue: 0,0:01:09.46,0:01:13.78,Default,,0,0,0,,（究极挑逗技术）\N（湿湿做爱专门风俗店）
Dialogue: 0,0:01:15.94,0:01:17.74,Default,,0,0,0,,(S1 葵)
Dialogue: 0,0:01:26.74,0:01:29.26,Default,,0,0,0,,好紧张
Dialogue: 0,0:01:31.78,0:01:33.22,Default,,0,0,0,,请进
Dialogue: 0,0:01:44.38,0:01:46.54,Default,,0,0,0,,久等了 我是葵
Dialogue: 0,0:01:49.06,0:01:53.38,Default,,0,0,0,,-是第一次见吧 -是的
Dialogue: 0,0:01:54.82,0:02:02.74,Default,,0,0,0,,我们店是不限时间的\N总之 我们开始吧
Dialogue: 0,0:02:03.82,0:02:04.90,Default,,0,0,0,,好的 知道了
Dialogue: 0,0:02:05.26,0:02:07.78,Default,,0,0,0,,我开始了
Dialogue: 0,0:02:29.01,0:02:30.81,Default,,0,0,0,,紧张吗？
Dialogue: 0,0:02:32.25,0:02:37.65,Default,,0,0,0,,第一次来这个店\N不知道该怎么办
Dialogue: 0,0:02:38.37,0:02:41.61,Default,,0,0,0,,-交给我就行了 -好的
Dialogue: 0,0:02:42.33,0:02:44.13,Default,,0,0,0,,我来了
Dialogue: 0,0:03:41.00,0:03:43.16,Default,,0,0,0,,好大 这是什么？
Dialogue: 0,0:03:46.04,0:03:48.20,Default,,0,0,0,,请多摸摸
Dialogue: 0,0:04:07.64,0:04:10.16,Default,,0,0,0,,好像有什么硬硬的顶着了
Dialogue: 0,0:04:13.76,0:04:14.84,Default,,0,0,0,,是的
Dialogue: 0,0:04:18.44,0:04:20.60,Default,,0,0,0,,你兴奋了吗？
Dialogue: 0,0:04:21.32,0:04:24.92,Default,,0,0,0,,是的 很兴奋
Dialogue: 0,0:04:31.40,0:04:37.15,Default,,0,0,0,,-要直接摸吗？ -好啊
Dialogue: 0,0:04:47.23,0:04:48.67,Default,,0,0,0,,好漂亮的奶子
Dialogue: 0,0:04:50.11,0:04:52.27,Default,,0,0,0,,摸我
Dialogue: 0,0:05:00.55,0:05:04.87,Default,,0,0,0,,-好可爱 -好舒服
Dialogue: 0,0:05:09.91,0:05:12.07,Default,,0,0,0,,喜欢奶子吧
Dialogue: 0,0:05:12.79,0:05:14.95,Default,,0,0,0,,是的 很喜欢
Dialogue: 0,0:05:16.03,0:05:17.83,Default,,0,0,0,,好舒服
Dialogue: 0,0:05:25.03,0:05:27.91,Default,,0,0,0,,摸得方式好色情啊
Dialogue: 0,0:05:36.55,0:05:38.71,Default,,0,0,0,,好舒服
Dialogue: 0,0:06:01.38,0:06:03.18,Default,,0,0,0,,软吗？
Dialogue: 0,0:06:04.26,0:06:08.22,Default,,0,0,0,,是的 非常软
Dialogue: 0,0:06:24.78,0:06:26.58,Default,,0,0,0,,好舒服
Dialogue: 0,0:06:54.29,0:06:56.09,Default,,0,0,0,,多舔一舔
Dialogue: 0,0:06:56.45,0:06:58.97,Default,,0,0,0,,可以吗？
Dialogue: 0,0:07:15.89,0:07:17.69,Default,,0,0,0,,好舒服
Dialogue: 0,0:07:33.17,0:07:34.97,Default,,0,0,0,,好舒服
Dialogue: 0,0:08:14.56,0:08:15.64,Default,,0,0,0,,好可爱
Dialogue: 0,0:08:17.08,0:08:19.24,Default,,0,0,0,,和婴儿一样
Dialogue: 0,0:08:21.04,0:08:28.60,Default,,0,0,0,,-可以多舔舔 喜欢吗？\N-是的
Dialogue: 0,0:08:36.16,0:08:37.60,Default,,0,0,0,,怎么了
Dialogue: 0,0:08:39.04,0:08:45.16,Default,,0,0,0,,我们店 有反向性骚扰服务
Dialogue: 0,0:08:45.88,0:08:50.56,Default,,0,0,0,,-试试吗？ -反向？
Dialogue: 0,0:08:52.00,0:08:55.24,Default,,0,0,0,,感觉你会喜欢
Dialogue: 0,0:08:57.76,0:08:59.56,Default,,0,0,0,,好 拜托了
Dialogue: 0,0:09:02.44,0:09:04.96,Default,,0,0,0,,这边要反向性骚扰
Dialogue: 0,0:09:08.92,0:09:11.07,Default,,0,0,0,,打扰了
Dialogue: 0,0:09:13.95,0:09:18.27,Default,,0,0,0,,好 谢谢
Dialogue: 0,0:09:19.35,0:09:24.03,Default,,0,0,0,,-手抬起来 -我抬起来\N-谢谢
Dialogue: 0,0:09:30.87,0:09:33.03,Default,,0,0,0,,可以吧
Dialogue: 0,0:09:34.83,0:09:37.35,Default,,0,0,0,,这边来
Dialogue: 0,0:09:50.31,0:09:53.19,Default,,0,0,0,,还有这边
Dialogue: 0,0:10:01.47,0:10:03.99,Default,,0,0,0,,这个服务很不错的哦
Dialogue: 0,0:10:07.59,0:10:10.47,Default,,0,0,0,,怎么了
Dialogue: 0,0:10:25.58,0:10:28.10,Default,,0,0,0,,不紧吧
Dialogue: 0,0:10:28.46,0:10:29.90,Default,,0,0,0,,是的
Dialogue: 0,0:10:41.42,0:10:43.58,Default,,0,0,0,,看不见了
Dialogue: 0,0:10:46.46,0:10:48.62,Default,,0,0,0,,看不见会很兴奋吧
Dialogue: 0,0:10:50.78,0:10:53.30,Default,,0,0,0,,会被摸哪呢
Dialogue: 0,0:12:34.81,0:12:36.96,Default,,0,0,0,,-紧张吗？ -是的
Dialogue: 0,0:12:40.20,0:12:42.72,Default,,0,0,0,,颤抖得好厉害
Dialogue: 0,0:13:38.88,0:13:41.04,Default,,0,0,0,,好舒服
Dialogue: 0,0:14:04.07,0:14:05.87,Default,,0,0,0,,脱了
Dialogue: 0,0:15:30.82,0:15:32.62,Default,,0,0,0,,全部看得见
Dialogue: 0,0:15:38.74,0:15:41.26,Default,,0,0,0,,还有这种服务吗？
Dialogue: 0,0:16:44.25,0:16:46.77,Default,,0,0,0,,怎么样？
Dialogue: 0,0:16:47.85,0:16:50.01,Default,,0,0,0,,好舒服
Dialogue: 0,0:16:53.61,0:16:55.41,Default,,0,0,0,,好舒服
Dialogue: 0,0:16:59.73,0:17:01.89,Default,,0,0,0,,好硬
Dialogue: 0,0:17:39.68,0:17:41.12,Default,,0,0,0,,湿湿的的
Dialogue: 0,0:20:05.82,0:20:09.06,Default,,0,0,0,,-舒服吗？ -是的
Dialogue: 0,0:21:08.45,0:21:10.25,Default,,0,0,0,,要射了
Dialogue: 0,0:21:16.37,0:21:19.61,Default,,0,0,0,,-要射了吗？ -是的
Dialogue: 0,0:21:24.65,0:21:27.17,Default,,0,0,0,,还不能射哦
Dialogue: 0,0:21:43.37,0:21:47.68,Default,,0,0,0,,-想射吗？ -想
Dialogue: 0,0:21:49.48,0:21:51.64,Default,,0,0,0,,那 我让你舒服
Dialogue: 0,0:22:01.00,0:22:03.16,Default,,0,0,0,,这是特别的哦
Dialogue: 0,0:22:10.72,0:22:12.52,Default,,0,0,0,,好硬
Dialogue: 0,0:23:01.11,0:23:06.87,Default,,0,0,0,,想像自己的肉棒被乳交
Dialogue: 0,0:23:10.11,0:23:15.51,Default,,0,0,0,,-好的 -舒服吧 -是的
Dialogue: 0,0:23:31.35,0:23:32.79,Default,,0,0,0,,好舒服
Dialogue: 0,0:23:37.11,0:23:38.91,Default,,0,0,0,,这么大了
Dialogue: 0,0:23:59.43,0:24:00.87,Default,,0,0,0,,好湿
Dialogue: 0,0:24:21.38,0:24:22.82,Default,,0,0,0,,舒服吗？
Dialogue: 0,0:24:30.74,0:24:32.18,Default,,0,0,0,,好硬
Dialogue: 0,0:25:13.21,0:25:15.37,Default,,0,0,0,,舒服吗？
Dialogue: 0,0:25:26.17,0:25:28.69,Default,,0,0,0,,颤抖得好厉害
Dialogue: 0,0:25:29.77,0:25:33.73,Default,,0,0,0,,好舒服 -要射了吗？
Dialogue: 0,0:25:36.61,0:25:38.41,Default,,0,0,0,,要射了
Dialogue: 0,0:25:52.09,0:25:53.89,Default,,0,0,0,,好热
Dialogue: 0,0:26:10.09,0:26:11.89,Default,,0,0,0,,好厉害
Dialogue: 0,0:26:47.52,0:26:51.12,Default,,0,0,0,,-射了好多 -是的
Dialogue: 0,0:26:52.20,0:26:57.60,Default,,0,0,0,,-要对店里保密哦 -好
Dialogue: 0,0:27:02.64,0:27:05.88,Default,,0,0,0,,(S1 葵)
Dialogue: 0,0:27:19.20,0:27:22.80,Default,,0,0,0,,我是葵 今天请多指教
Dialogue: 0,0:27:23.16,0:27:24.60,Default,,0,0,0,,请多指教
Dialogue: 0,0:27:24.96,0:27:28.56,Default,,0,0,0,,那么 我开始了
Dialogue: 0,0:27:36.83,0:27:38.27,Default,,0,0,0,,放松
Dialogue: 0,0:27:40.43,0:27:42.23,Default,,0,0,0,,好厉害
Dialogue: 0,0:27:43.67,0:27:45.11,Default,,0,0,0,,好热
Dialogue: 0,0:27:45.83,0:27:50.15,Default,,0,0,0,,-热吗？ -我也好热
Dialogue: 0,0:27:51.59,0:27:54.11,Default,,0,0,0,,冷静点了吗？
Dialogue: 0,0:27:54.47,0:27:55.91,Default,,0,0,0,,很冷静
Dialogue: 0,0:28:05.27,0:28:11.75,Default,,0,0,0,,-困吗？ -好紧张
Dialogue: 0,0:28:23.27,0:28:27.23,Default,,0,0,0,,-颤抖得好厉害 -是吗
Dialogue: 0,0:28:37.67,0:28:42.70,Default,,0,0,0,,好厉害 好舒服
Dialogue: 0,0:28:47.38,0:28:49.90,Default,,0,0,0,,-开始按摩了 -好
Dialogue: 0,0:28:51.34,0:28:52.42,Default,,0,0,0,,手伸直
Dialogue: 0,0:28:52.78,0:28:55.66,Default,,0,0,0,,手伸直
Dialogue: 0,0:29:06.10,0:29:07.54,Default,,0,0,0,,好舒服
Dialogue: 0,0:29:25.54,0:29:29.14,Default,,0,0,0,,-舒服吗？ -好舒服
Dialogue: 0,0:29:59.73,0:30:01.89,Default,,0,0,0,,什么顶着了
Dialogue: 0,0:30:03.33,0:30:06.21,Default,,0,0,0,,那个 奶子
Dialogue: 0,0:30:08.01,0:30:10.17,Default,,0,0,0,,没有顶着哦
Dialogue: 0,0:30:24.57,0:30:27.09,Default,,0,0,0,,按摩而已呀
Dialogue: 0,0:30:34.65,0:30:36.81,Default,,0,0,0,,好舒服
Dialogue: 0,0:30:41.85,0:30:44.01,Default,,0,0,0,,好舒服
Dialogue: 0,0:30:45.09,0:30:46.89,Default,,0,0,0,,那么
Dialogue: 0,0:30:48.69,0:30:52.65,Default,,0,0,0,,以这里为中心继续了哦
Dialogue: 0,0:31:36.20,0:31:37.64,Default,,0,0,0,,好僵硬
Dialogue: 0,0:31:38.72,0:31:41.96,Default,,0,0,0,,-真的吗？ -是的
Dialogue: 0,0:31:43.76,0:31:49.52,Default,,0,0,0,,-你知道吗？ -知道的
Dialogue: 0,0:31:59.60,0:32:02.84,Default,,0,0,0,,-转过来 -转过来吗？
Dialogue: 0,0:32:23.35,0:32:29.11,Default,,0,0,0,,-我给你涂油 -好
Dialogue: 0,0:32:43.15,0:32:46.03,Default,,0,0,0,,-好舒服 -舒服吗？
Dialogue: 0,0:32:48.55,0:32:50.35,Default,,0,0,0,,皮肤好光滑
Dialogue: 0,0:34:25.73,0:34:27.53,Default,,0,0,0,,好舒服
Dialogue: 0,0:35:17.93,0:35:20.09,Default,,0,0,0,,好舒服
Dialogue: 0,0:35:22.97,0:35:25.49,Default,,0,0,0,,好厉害
Dialogue: 0,0:35:49.24,0:35:53.92,Default,,0,0,0,,-油 -给你涂油\N-好的
Dialogue: 0,0:36:04.72,0:36:06.52,Default,,0,0,0,,好厉害
Dialogue: 0,0:36:09.76,0:36:11.56,Default,,0,0,0,,就在我眼前
Dialogue: 0,0:36:34.24,0:36:36.40,Default,,0,0,0,,好厉害
Dialogue: 0,0:37:13.47,0:37:15.27,Default,,0,0,0,,好厉害
Dialogue: 0,0:37:15.99,0:37:18.15,Default,,0,0,0,,好舒服
