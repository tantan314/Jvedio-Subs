Dialogue: 0,0:00:00.00,0:00:10.01,Default,,0,0,0,,(危機的狀況)\N(明裡紬)
Dialogue: 0,0:00:29.22,0:00:30.96,Default,,0,0,0,,謝謝你幫忙
Dialogue: 0,0:00:32.29,0:00:34.70,Default,,0,0,0,,感覺好久沒去野營了\N好期待
Dialogue: 0,0:00:35.36,0:00:36.30,Default,,0,0,0,,是嗎
Dialogue: 0,0:00:37.37,0:00:38.57,Default,,0,0,0,,結衣呢
Dialogue: 0,0:00:40.04,0:00:42.04,Default,,0,0,0,,應該還在化妝打扮吧
Dialogue: 0,0:00:42.57,0:00:44.04,Default,,0,0,0,,經常準備比較晚
Dialogue: 0,0:00:47.11,0:00:49.11,Default,,0,0,0,,健治君
Dialogue: 0,0:00:51.25,0:00:52.85,Default,,0,0,0,,好久不見  還好嗎
Dialogue: 0,0:00:53.38,0:00:54.05,Default,,0,0,0,,是
Dialogue: 0,0:00:54.85,0:00:55.92,Default,,0,0,0,,好慢\N(明裡紬)
Dialogue: 0,0:00:56.18,0:00:57.52,Default,,0,0,0,,在幹什麼
Dialogue: 0,0:00:58.45,0:01:00.86,Default,,0,0,0,,確認有沒有忘記東西
Dialogue: 0,0:01:07.13,0:01:09.13,Default,,0,0,0,,這個不帶著嗎
Dialogue: 0,0:01:10.60,0:01:12.20,Default,,0,0,0,,去山頂的話
Dialogue: 0,0:01:12.87,0:01:14.20,Default,,0,0,0,,不用吧
Dialogue: 0,0:01:15.94,0:01:16.87,Default,,0,0,0,,那個
Dialogue: 0,0:01:17.27,0:01:18.61,Default,,0,0,0,,天氣很好啊
Dialogue: 0,0:01:19.94,0:01:21.81,Default,,0,0,0,,絕對適合野營
Dialogue: 0,0:01:50.64,0:01:52.11,Default,,0,0,0,,辛苦了
Dialogue: 0,0:01:53.17,0:01:54.11,Default,,0,0,0,,給
Dialogue: 0,0:01:54.38,0:01:55.71,Default,,0,0,0,,謝謝
Dialogue: 0,0:01:59.71,0:02:00.78,Default,,0,0,0,,謝謝
Dialogue: 0,0:02:02.38,0:02:05.19,Default,,0,0,0,,什麼  這不是我喜歡的
Dialogue: 0,0:02:05.99,0:02:07.19,Default,,0,0,0,,不是吧
Dialogue: 0,0:02:08.26,0:02:11.06,Default,,0,0,0,,不記得你老公喜歡的東西嗎
Dialogue: 0,0:02:11.19,0:02:12.26,Default,,0,0,0,,真是的
Dialogue: 0,0:02:12.79,0:02:14.26,Default,,0,0,0,,那我自己喝吧
Dialogue: 0,0:02:16.93,0:02:18.93,Default,,0,0,0,,那個不要吵架
Dialogue: 0,0:02:20.67,0:02:21.74,Default,,0,0,0,,吵架嗎
Dialogue: 0,0:02:22.40,0:02:23.34,Default,,0,0,0,,才沒有
Dialogue: 0,0:02:24.14,0:02:25.34,Default,,0,0,0,,像平時那樣
Dialogue: 0,0:02:27.21,0:02:29.08,Default,,0,0,0,,影響到你  不好意思
Dialogue: 0,0:02:30.55,0:02:32.55,Default,,0,0,0,,野營的話  很期待吧
Dialogue: 0,0:02:53.77,0:02:54.97,Default,,0,0,0,,這個不錯
Dialogue: 0,0:02:54.97,0:02:55.90,Default,,0,0,0,,感覺好吃
Dialogue: 0,0:02:56.57,0:02:57.24,Default,,0,0,0,,是吧
Dialogue: 0,0:02:57.91,0:02:58.84,Default,,0,0,0,,是的
Dialogue: 0,0:03:00.31,0:03:02.04,Default,,0,0,0,,飯看著很好吃
Dialogue: 0,0:03:03.78,0:03:04.98,Default,,0,0,0,,是的
Dialogue: 0,0:03:06.31,0:03:07.65,Default,,0,0,0,,這個可以吧
Dialogue: 0,0:03:09.52,0:03:10.32,Default,,0,0,0,,怎麼樣
Dialogue: 0,0:03:10.59,0:03:11.65,Default,,0,0,0,,好吃吧
Dialogue: 0,0:03:15.52,0:03:16.59,Default,,0,0,0,,好吃
Dialogue: 0,0:03:17.26,0:03:18.33,Default,,0,0,0,,要吃嗎
Dialogue: 0,0:03:18.46,0:03:19.53,Default,,0,0,0,,好吃
Dialogue: 0,0:03:25.40,0:03:26.60,Default,,0,0,0,,好吃吧  -好吃
Dialogue: 0,0:03:47.82,0:03:48.76,Default,,0,0,0,,好吃
Dialogue: 0,0:03:50.89,0:03:52.36,Default,,0,0,0,,關東地區
Dialogue: 0,0:03:52.49,0:03:54.50,Default,,0,0,0,,的天氣報道
Dialogue: 0,0:03:54.76,0:03:58.63,Default,,0,0,0,,恐怕會受到大氣的影響
Dialogue: 0,0:03:58.77,0:04:06.51,Default,,0,0,0,,部分地區會有出現大雨的情況\N恐怕會不斷擴大
Dialogue: 0,0:04:07.31,0:04:08.78,Default,,0,0,0,,請注意一下
Dialogue: 0,0:04:15.45,0:04:17.45,Default,,0,0,0,,感覺天氣有點不太好
Dialogue: 0,0:04:59.36,0:05:00.83,Default,,0,0,0,,突然變天
Dialogue: 0,0:05:02.70,0:05:04.43,Default,,0,0,0,,好大的雨
Dialogue: 0,0:05:04.70,0:05:05.90,Default,,0,0,0,,還有
Dialogue: 0,0:05:08.57,0:05:09.77,Default,,0,0,0,,沒辦法了
Dialogue: 0,0:05:10.84,0:05:11.77,Default,,0,0,0,,不是吧
Dialogue: 0,0:05:19.65,0:05:20.72,Default,,0,0,0,,沒事吧
Dialogue: 0,0:05:23.65,0:05:24.85,Default,,0,0,0,,小心點
Dialogue: 0,0:05:46.21,0:05:47.28,Default,,0,0,0,,得救了
Dialogue: 0,0:05:48.61,0:05:50.21,Default,,0,0,0,,這樣好危險
Dialogue: 0,0:05:50.35,0:05:52.08,Default,,0,0,0,,在山裡面
Dialogue: 0,0:05:52.21,0:05:53.55,Default,,0,0,0,,有點
Dialogue: 0,0:05:54.35,0:05:55.55,Default,,0,0,0,,沒事的
Dialogue: 0,0:05:58.35,0:06:00.22,Default,,0,0,0,,暫且得救了
Dialogue: 0,0:06:05.43,0:06:06.63,Default,,0,0,0,,沒電了
Dialogue: 0,0:06:07.56,0:06:08.90,Default,,0,0,0,,怎麼辦
Dialogue: 0,0:06:10.50,0:06:11.83,Default,,0,0,0,,怎麼知道
Dialogue: 0,0:06:12.10,0:06:14.50,Default,,0,0,0,,剛剛你這樣說的吧
Dialogue: 0,0:06:15.17,0:06:16.90,Default,,0,0,0,,你不是也說了嗎
Dialogue: 0,0:06:19.57,0:06:21.58,Default,,0,0,0,,首先冷靜一下
Dialogue: 0,0:06:21.84,0:06:23.18,Default,,0,0,0,,好好說
Dialogue: 0,0:06:28.38,0:06:31.59,Default,,0,0,0,,我去找下人求救
Dialogue: 0,0:06:33.59,0:06:35.32,Default,,0,0,0,,一個人去可以嗎
Dialogue: 0,0:06:35.59,0:06:36.92,Default,,0,0,0,,不要吧
Dialogue: 0,0:06:39.33,0:06:41.46,Default,,0,0,0,,說的話還是我去吧
Dialogue: 0,0:06:44.80,0:06:46.80,Default,,0,0,0,,你們就在這裡等吧
Dialogue: 0,0:06:50.14,0:06:51.74,Default,,0,0,0,,那我去了
Dialogue: 0,0:07:10.29,0:07:11.36,Default,,0,0,0,,暫且
Dialogue: 0,0:07:11.76,0:07:13.09,Default,,0,0,0,,得救了
Dialogue: 0,0:07:13.36,0:07:14.43,Default,,0,0,0,,是吧
Dialogue: 0,0:07:37.12,0:07:38.32,Default,,0,0,0,,結衣的話
Dialogue: 0,0:07:38.72,0:07:39.92,Default,,0,0,0,,有點害羞吧
Dialogue: 0,0:07:41.79,0:07:42.72,Default,,0,0,0,,那個
Dialogue: 0,0:07:43.26,0:07:44.73,Default,,0,0,0,,會感冒的
Dialogue: 0,0:07:57.81,0:07:58.61,Default,,0,0,0,,謝謝
Dialogue: 0,0:08:13.02,0:08:14.62,Default,,0,0,0,,結衣用這個
Dialogue: 0,0:08:16.22,0:08:17.16,Default,,0,0,0,,太好了
Dialogue: 0,0:08:26.77,0:08:27.84,Default,,0,0,0,,謝謝
Dialogue: 0,0:08:43.85,0:08:44.92,Default,,0,0,0,,好慢
Dialogue: 0,0:08:45.32,0:08:46.39,Default,,0,0,0,,沒事吧
Dialogue: 0,0:08:47.59,0:08:49.19,Default,,0,0,0,,擔心嗎
Dialogue: 0,0:08:51.19,0:08:52.39,Default,,0,0,0,,都是我的錯
Dialogue: 0,0:08:53.06,0:08:55.33,Default,,0,0,0,,因為我是第一次來
Dialogue: 0,0:08:56.66,0:08:58.40,Default,,0,0,0,,不是結衣的錯
Dialogue: 0,0:08:58.53,0:08:59.73,Default,,0,0,0,,這也沒辦法
Dialogue: 0,0:09:02.40,0:09:04.54,Default,,0,0,0,,最近不太好
Dialogue: 0,0:09:06.27,0:09:08.14,Default,,0,0,0,,發生很多事情
Dialogue: 0,0:09:08.54,0:09:10.28,Default,,0,0,0,,不太好
Dialogue: 0,0:09:12.81,0:09:15.35,Default,,0,0,0,,本來以為2個人很期待
Dialogue: 0,0:09:18.02,0:09:19.49,Default,,0,0,0,,還是不行
Dialogue: 0,0:09:22.42,0:09:24.43,Default,,0,0,0,,到底是怎麼了
Dialogue: 0,0:09:26.56,0:09:28.30,Default,,0,0,0,,哥哥應該沒事的
Dialogue: 0,0:09:28.56,0:09:29.76,Default,,0,0,0,,肯定可以回來的
Dialogue: 0,0:09:31.23,0:09:32.83,Default,,0,0,0,,那麼
Dialogue: 0,0:09:33.23,0:09:35.37,Default,,0,0,0,,說點開心的事情吧
Dialogue: 0,0:09:40.84,0:09:42.84,Default,,0,0,0,,哥哥的話
Dialogue: 0,0:09:44.18,0:09:45.51,Default,,0,0,0,,剛剛
Dialogue: 0,0:09:46.58,0:09:49.25,Default,,0,0,0,,這樣的話
Dialogue: 0,0:09:58.99,0:10:00.19,Default,,0,0,0,,很冷吧
Dialogue: 0,0:10:01.66,0:10:04.87,Default,,0,0,0,,那個  我沒事的
Dialogue: 0,0:10:05.13,0:10:07.27,Default,,0,0,0,,別害羞  蓋著吧
Dialogue: 0,0:10:16.74,0:10:18.08,Default,,0,0,0,,健治君
Dialogue: 0,0:10:18.21,0:10:19.41,Default,,0,0,0,,很可靠
Dialogue: 0,0:10:19.68,0:10:20.75,Default,,0,0,0,,很好
Dialogue: 0,0:10:45.31,0:10:47.44,Default,,0,0,0,,播報天氣
Dialogue: 0,0:10:47.71,0:10:50.91,Default,,0,0,0,,大雨將會繼續持續
