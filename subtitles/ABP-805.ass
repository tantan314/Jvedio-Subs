Dialogue: 0,1:34:41.79,1:34:43.26,Default,,0,0,0,,屁股撅起来
Dialogue: 0,1:34:52.44,1:34:54.64,Default,,0,0,0,,自己看着自己
Dialogue: 0,1:34:59.04,1:35:00.14,Default,,0,0,0,,很色吧
Dialogue: 0,1:35:00.88,1:35:01.98,Default,,0,0,0,,舒服
Dialogue: 0,1:35:02.71,1:35:03.45,Default,,0,0,0,,看着
Dialogue: 0,1:35:15.56,1:35:17.76,Default,,0,0,0,,好舒服啊
Dialogue: 0,1:35:23.63,1:35:24.74,Default,,0,0,0,,好厉害
Dialogue: 0,1:35:40.89,1:35:43.45,Default,,0,0,0,,真的好厉害啊
Dialogue: 0,1:35:45.29,1:35:46.39,Default,,0,0,0,,这样
Dialogue: 0,1:35:47.49,1:35:48.59,Default,,0,0,0,,很好
Dialogue: 0,1:36:00.34,1:36:04.38,Default,,0,0,0,,-要不行了\N-要我动吗？
Dialogue: 0,1:36:05.48,1:36:06.94,Default,,0,0,0,,手给我
Dialogue: 0,1:36:20.16,1:36:21.26,Default,,0,0,0,,舒服
Dialogue: 0,1:36:49.89,1:36:50.99,Default,,0,0,0,,要出来了
Dialogue: 0,1:37:03.10,1:37:04.20,Default,,0,0,0,,舒服
Dialogue: 0,1:37:06.40,1:37:09.34,Default,,0,0,0,,给我打扫一下
Dialogue: 0,1:37:12.64,1:37:14.11,Default,,0,0,0,,就是这样
Dialogue: 0,1:37:17.05,1:37:18.15,Default,,0,0,0,,舒服
Dialogue: 0,1:37:28.43,1:37:29.53,Default,,0,0,0,,怎么样
Dialogue: 0,1:37:31.73,1:37:33.56,Default,,0,0,0,,很色啊
Dialogue: 0,1:37:40.17,1:37:41.64,Default,,0,0,0,,舒服吗？
Dialogue: 0,1:37:48.25,1:37:49.71,Default,,0,0,0,,不能出声啊
Dialogue: 0,1:37:51.55,1:37:52.65,Default,,0,0,0,,可以忍住吗？
Dialogue: 0,1:38:00.73,1:38:02.93,Default,,0,0,0,,要不行了
Dialogue: 0,1:38:30.09,1:38:31.19,Default,,0,0,0,,看这里
Dialogue: 0,1:38:34.13,1:38:35.23,Default,,0,0,0,,没事吧
Dialogue: 0,1:38:39.63,1:38:44.04,Default,,0,0,0,,好好看着啊
Dialogue: 0,1:38:44.77,1:38:48.07,Default,,0,0,0,,-没事 -那继续看
Dialogue: 0,1:38:51.38,1:38:53.58,Default,,0,0,0,,不能被听到啊
Dialogue: 0,1:39:02.02,1:39:03.49,Default,,0,0,0,,不行了
Dialogue: 0,1:39:37.99,1:39:39.46,Default,,0,0,0,,过来
Dialogue: 0,1:40:32.68,1:40:33.78,Default,,0,0,0,,不行了
Dialogue: 0,1:40:55.80,1:40:57.27,Default,,0,0,0,,要去了
Dialogue: 0,1:41:25.53,1:41:30.67,Default,,0,0,0,,要不行了 太舒服了
Dialogue: 0,1:41:31.40,1:41:35.44,Default,,0,0,0,,好舒服啊
Dialogue: 0,1:42:06.64,1:42:07.74,Default,,0,0,0,,继续
Dialogue: 0,1:42:43.71,1:42:46.28,Default,,0,0,0,,好舒服啊
Dialogue: 0,1:42:47.38,1:42:48.48,Default,,0,0,0,,不行了
Dialogue: 0,1:42:50.31,1:42:51.42,Default,,0,0,0,,要去了
Dialogue: 0,1:42:54.72,1:42:55.82,Default,,0,0,0,,去了
Dialogue: 0,1:43:32.52,1:43:34.36,Default,,0,0,0,,自己动
Dialogue: 0,1:43:49.41,1:43:50.51,Default,,0,0,0,,舒服
Dialogue: 0,1:44:16.20,1:44:17.30,Default,,0,0,0,,好舒服
Dialogue: 0,1:44:21.34,1:44:22.44,Default,,0,0,0,,怎么样
Dialogue: 0,1:44:46.30,1:44:47.40,Default,,0,0,0,,过来
Dialogue: 0,1:44:48.87,1:44:49.97,Default,,0,0,0,,舒服吗？
Dialogue: 0,1:44:53.64,1:44:55.84,Default,,0,0,0,,打扫一下
Dialogue: 0,1:45:21.53,1:45:22.63,Default,,0,0,0,,来这里
Dialogue: 0,1:45:25.20,1:45:26.30,Default,,0,0,0,,这里
Dialogue: 0,1:45:43.92,1:45:48.33,Default,,0,0,0,,在床上做还是站着做啊
Dialogue: 0,1:46:11.45,1:46:12.55,Default,,0,0,0,,很好
Dialogue: 0,1:46:13.65,1:46:15.85,Default,,0,0,0,,真舒服啊
Dialogue: 0,1:46:30.53,1:46:31.64,Default,,0,0,0,,好舒服
Dialogue: 0,1:46:33.47,1:46:34.94,Default,,0,0,0,,太舒服了
Dialogue: 0,1:46:52.19,1:46:53.66,Default,,0,0,0,,不行了
Dialogue: 0,1:47:02.10,1:47:03.93,Default,,0,0,0,,不行 要去了
Dialogue: 0,1:47:38.80,1:47:40.27,Default,,0,0,0,,不行啊
Dialogue: 0,1:47:40.64,1:47:43.94,Default,,0,0,0,,-进去了吗？ -好舒服
Dialogue: 0,1:47:55.32,1:47:56.42,Default,,0,0,0,,去了
Dialogue: 0,1:48:28.35,1:48:29.82,Default,,0,0,0,,好舒服
Dialogue: 0,1:48:32.76,1:48:34.22,Default,,0,0,0,,好舒服啊
Dialogue: 0,1:48:43.40,1:48:44.50,Default,,0,0,0,,舒服
Dialogue: 0,1:49:01.02,1:49:04.32,Default,,0,0,0,,要去了
Dialogue: 0,1:49:12.40,1:49:13.50,Default,,0,0,0,,好舒服
Dialogue: 0,1:49:16.43,1:49:17.90,Default,,0,0,0,,好厉害
Dialogue: 0,1:49:28.55,1:49:29.65,Default,,0,0,0,,舒服吧
Dialogue: 0,1:49:30.01,1:49:31.11,Default,,0,0,0,,不行了
Dialogue: 0,1:49:32.22,1:49:33.32,Default,,0,0,0,,看这里
Dialogue: 0,1:49:34.42,1:49:37.35,Default,,0,0,0,,不行了
Dialogue: 0,1:49:48.00,1:49:48.73,Default,,0,0,0,,好舒服
Dialogue: 0,1:49:53.87,1:49:57.17,Default,,0,0,0,,要去了
Dialogue: 0,1:50:16.63,1:50:17.36,Default,,0,0,0,,好舒服
Dialogue: 0,1:50:21.77,1:50:22.87,Default,,0,0,0,,不错啊
Dialogue: 0,1:50:29.11,1:50:30.57,Default,,0,0,0,,好舒服
Dialogue: 0,1:50:37.91,1:50:39.38,Default,,0,0,0,,舒服
Dialogue: 0,1:50:43.42,1:50:45.26,Default,,0,0,0,,要去了
Dialogue: 0,1:51:35.17,1:51:38.11,Default,,0,0,0,,要高潮了
Dialogue: 0,1:52:04.17,1:52:06.00,Default,,0,0,0,,出来了
Dialogue: 0,1:52:27.29,1:52:29.86,Default,,0,0,0,,很舒服吧
Dialogue: 0,1:52:32.80,1:52:34.26,Default,,0,0,0,,舒服
Dialogue: 0,1:53:24.92,1:53:26.38,Default,,0,0,0,,要去了
Dialogue: 0,1:54:35.75,1:54:37.59,Default,,0,0,0,,要高潮了
Dialogue: 0,1:56:20.72,1:56:21.83,Default,,0,0,0,,好舒服
Dialogue: 0,1:56:26.96,1:56:28.06,Default,,0,0,0,,怎么样
Dialogue: 0,1:56:45.68,1:56:46.78,Default,,0,0,0,,要去了
Dialogue: 0,1:58:06.43,1:58:08.26,Default,,0,0,0,,都差不多了
Dialogue: 0,1:58:14.87,1:58:15.97,Default,,0,0,0,,没事吧
Dialogue: 0,1:58:21.11,1:58:22.95,Default,,0,0,0,,没事吧
Dialogue: 0,1:58:24.41,1:58:28.08,Default,,0,0,0,,真的好厉害啊
Dialogue: 0,1:58:29.92,1:58:32.12,Default,,0,0,0,,今天就这样吧
Dialogue: 0,1:58:33.59,1:58:34.32,Default,,0,0,0,,好困
Dialogue: 0,1:58:34.32,1:58:37.26,Default,,0,0,0,,要在哪里睡啊
Dialogue: 0,1:58:37.63,1:58:42.77,Default,,0,0,0,,你给我等一下
Dialogue: 0,1:58:44.60,1:58:47.54,Default,,0,0,0,,你真是很快啊
Dialogue: 0,1:58:48.64,1:58:51.94,Default,,0,0,0,,刚才已经准备好了
Dialogue: 0,1:58:53.04,1:58:54.51,Default,,0,0,0,,这个时候很快啊
Dialogue: 0,1:58:55.98,1:59:04.42,Default,,0,0,0,,-当然 -麻里肯定睡这里
Dialogue: 0,1:59:04.79,1:59:07.36,Default,,0,0,0,,不是床我睡不着
Dialogue: 0,1:59:08.83,1:59:11.03,Default,,0,0,0,,而且年纪最大
Dialogue: 0,1:59:11.76,1:59:13.23,Default,,0,0,0,,晩安了
Dialogue: 0,1:59:15.80,1:59:22.04,Default,,0,0,0,,就这样决定了吗 一起睡吧
Dialogue: 0,1:59:30.48,1:59:35.25,Default,,0,0,0,,等一下啊 不行
Dialogue: 0,1:59:40.39,1:59:47.36,Default,,0,0,0,,今天就这样了吧 明天还有
Dialogue: 0,1:59:50.30,1:59:54.34,Default,,0,0,0,,为了明天还是早睡吧
Dialogue: 0,1:59:55.44,1:59:58.01,Default,,0,0,0,,明天还想要做吧
Dialogue: 0,2:00:02.78,2:00:06.45,Default,,0,0,0,,那么先去洗澡
Dialogue: 0,2:00:09.02,2:00:11.59,Default,,0,0,0,,流了很多汗吧
Dialogue: 0,2:00:15.26,2:00:17.83,Default,,0,0,0,,-今天谢谢了 -谢谢
Dialogue: 0,2:00:37.28,2:00:43.52,Default,,0,0,0,,(凌晨1点20)
Dialogue: 0,2:01:40.04,2:01:41.14,Default,,0,0,0,,晚上好
Dialogue: 0,2:01:43.35,2:01:44.45,Default,,0,0,0,,怎么了
Dialogue: 0,2:01:45.55,2:01:46.65,Default,,0,0,0,,没有睡吗？
Dialogue: 0,2:01:49.95,2:01:51.05,Default,,0,0,0,,睡不着吗？
Dialogue: 0,2:02:00.96,2:02:06.47,Default,,0,0,0,,自己在家也是这样吗？
Dialogue: 0,2:02:09.77,2:02:15.65,Default,,0,0,0,,平常和猫睡没有睡不着
Dialogue: 0,2:02:18.58,2:02:19.68,Default,,0,0,0,,今天怎么样
Dialogue: 0,2:02:28.12,2:02:34.00,Default,,0,0,0,,很开心但是也很紧张
Dialogue: 0,2:02:36.57,2:02:44.64,Default,,0,0,0,,现在还好 但是一开始很难熬
Dialogue: 0,2:02:45.74,2:02:50.51,Default,,0,0,0,,我平常不太和男优说话
Dialogue: 0,2:02:51.25,2:02:57.49,Default,,0,0,0,,是的 男优都是在别的地方等
Dialogue: 0,2:02:57.85,2:03:02.63,Default,,0,0,0,,-就只是见面 -是的
Dialogue: 0,2:03:03.73,2:03:12.54,Default,,0,0,0,,所以见面说话会很紧张
Dialogue: 0,2:03:13.27,2:03:15.84,Default,,0,0,0,,害羞不敢说话啊
Dialogue: 0,2:03:17.31,2:03:20.61,Default,,0,0,0,,-是啊 -这样慢慢聊天
Dialogue: 0,2:03:21.71,2:03:25.75,Default,,0,0,0,,感觉不是我擅长的
Dialogue: 0,2:03:27.22,2:03:28.68,Default,,0,0,0,,干这行多久了
Dialogue: 0,2:03:37.13,2:03:38.96,Default,,0,0,0,,一年以上了吧
Dialogue: 0,2:03:41.16,2:03:45.57,Default,,0,0,0,,已经拍了20多部了
Dialogue: 0,2:03:48.87,2:03:54.38,Default,,0,0,0,,感觉有什麽变化吗
Dialogue: 0,2:03:55.85,2:03:58.41,Default,,0,0,0,,第一次肯定紧张吧
Dialogue: 0,2:03:59.52,2:04:04.65,Default,,0,0,0,,最近越拍越多
Dialogue: 0,2:04:05.39,2:04:09.43,Default,,0,0,0,,自己有什么变化吗？
Dialogue: 0,2:04:10.89,2:04:15.67,Default,,0,0,0,,之前很认生
Dialogue: 0,2:04:17.13,2:04:21.90,Default,,0,0,0,,比起看剧本
Dialogue: 0,2:04:22.64,2:04:27.41,Default,,0,0,0,,会看会有谁和我一起拍
Dialogue: 0,2:04:28.88,2:04:36.95,Default,,0,0,0,,很在意如果是不认识的人
Dialogue: 0,2:04:37.69,2:04:41.72,Default,,0,0,0,,会比较困难
Dialogue: 0,2:04:42.83,2:04:47.23,Default,,0,0,0,,但是拍的多了
Dialogue: 0,2:04:48.70,2:04:50.90,Default,,0,0,0,,接触的人多了
Dialogue: 0,2:04:52.37,2:04:55.67,Default,,0,0,0,,是我认识的人很好
Dialogue: 0,2:04:56.77,2:05:04.11,Default,,0,0,0,,不会害怕去拍摄了
Dialogue: 0,2:05:04.85,2:05:06.68,Default,,0,0,0,,也会去参加活动吗？
Dialogue: 0,2:05:07.42,2:05:09.62,Default,,0,0,0,,每个月都会
Dialogue: 0,2:05:10.35,2:05:16.23,Default,,0,0,0,,-会有粉丝来吧 -是的
Dialogue: 0,2:05:17.69,2:05:19.90,Default,,0,0,0,,怎么样啊
Dialogue: 0,2:05:22.10,2:05:23.20,Default,,0,0,0,,和粉丝
Dialogue: 0,2:05:24.67,2:05:26.14,Default,,0,0,0,,是想见你才来的吧
Dialogue: 0,2:05:27.97,2:05:36.05,Default,,0,0,0,,想见你的人来到你面前
Dialogue: 0,2:05:37.88,2:05:39.35,Default,,0,0,0,,什么感觉
Dialogue: 0,2:05:40.45,2:05:47.79,Default,,0,0,0,,就是为了这个才工作的
Dialogue: 0,2:05:48.52,2:05:54.03,Default,,0,0,0,,-真的吗？\N-是的 见到粉丝
Dialogue: 0,2:05:56.23,2:05:56.97,Default,,0,0,0,,好像
Dialogue: 0,2:05:59.17,2:06:01.74,Default,,0,0,0,,会比较
Dialogue: 0,2:06:02.84,2:06:10.18,Default,,0,0,0,,粉丝希望我能更加性感一点
Dialogue: 0,2:06:10.55,2:06:14.95,Default,,0,0,0,,会想要看到我性感的样子
Dialogue: 0,2:06:16.05,2:06:20.46,Default,,0,0,0,,我一开始是这样想的
Dialogue: 0,2:06:21.56,2:06:23.39,Default,,0,0,0,,但是不是的
Dialogue: 0,2:06:28.16,2:06:36.24,Default,,0,0,0,,会担心我的身体情况
Dialogue: 0,2:06:38.07,2:06:43.95,Default,,0,0,0,,会非常关心我 我很开心
Dialogue: 0,2:06:44.68,2:06:50.55,Default,,0,0,0,,会治愈我 让我开心
Dialogue: 0,2:06:51.65,2:06:56.06,Default,,0,0,0,,真的参加活动的话
Dialogue: 0,2:06:57.89,2:07:02.30,Default,,0,0,0,,我觉得见粉丝很重要
Dialogue: 0,2:07:03.40,2:07:06.70,Default,,0,0,0,,虽然有时间限制
Dialogue: 0,2:07:08.17,2:07:10.74,Default,,0,0,0,,不能太
Dialogue: 0,2:07:12.21,2:07:16.25,Default,,0,0,0,,说很长时间的话
Dialogue: 0,2:07:18.81,2:07:19.92,Default,,0,0,0,,好像
Dialogue: 0,2:07:20.65,2:07:29.46,Default,,0,0,0,,见到很多人很开心 但是时间会短
Dialogue: 0,2:07:31.29,2:07:34.96,Default,,0,0,0,,现在在烦恼这个
Dialogue: 0,2:07:36.07,2:07:38.27,Default,,0,0,0,,现在有想要做的吗？
Dialogue: 0,2:07:39.37,2:07:40.47,Default,,0,0,0,,想做什么
Dialogue: 0,2:07:44.87,2:07:45.98,Default,,0,0,0,,什么呢
Dialogue: 0,2:07:48.54,2:07:52.21,Default,,0,0,0,,好像不太能
Dialogue: 0,2:07:54.05,2:08:01.02,Default,,0,0,0,,不是想要更加出名
Dialogue: 0,2:08:02.49,2:08:03.59,Default,,0,0,0,,不是的
Dialogue: 0,2:08:05.06,2:08:06.16,Default,,0,0,0,,这样
Dialogue: 0,2:08:08.73,2:08:10.20,Default,,0,0,0,,没有这种感觉
Dialogue: 0,2:08:11.30,2:08:14.24,Default,,0,0,0,,好像
Dialogue: 0,2:08:15.70,2:08:23.41,Default,,0,0,0,,对于一直支持我的人
Dialogue: 0,2:08:23.78,2:08:25.98,Default,,0,0,0,,不是很想出名
Dialogue: 0,2:08:28.18,2:08:29.29,Default,,0,0,0,,好像
Dialogue: 0,2:08:30.39,2:08:33.69,Default,,0,0,0,,我心里很脆弱
Dialogue: 0,2:08:34.79,2:08:39.20,Default,,0,0,0,,喜欢我的人越多
Dialogue: 0,2:08:40.30,2:08:43.60,Default,,0,0,0,,讨厌我的人也会增加
Dialogue: 0,2:08:45.43,2:08:52.78,Default,,0,0,0,,现在觉得不会很感动了
Dialogue: 0,2:08:57.55,2:08:59.01,Default,,0,0,0,,这个
Dialogue: 0,2:09:00.12,2:09:04.52,Default,,0,0,0,,不太感到幸福了
Dialogue: 0,2:09:05.25,2:09:10.03,Default,,0,0,0,,有段时间一直很抑郁
Dialogue: 0,2:09:12.96,2:09:18.47,Default,,0,0,0,,不知道要做什么
Dialogue: 0,2:09:18.47,2:09:22.14,Default,,0,0,0,,好像是这样的
Dialogue: 0,2:09:23.24,2:09:30.21,Default,,0,0,0,,那个时候是很烦恼
Dialogue: 0,2:09:33.15,2:09:34.62,Default,,0,0,0,,最近
Dialogue: 0,2:09:37.19,2:09:38.29,Default,,0,0,0,,没有了
Dialogue: 0,2:09:39.02,2:09:41.22,Default,,0,0,0,,不会那样了
Dialogue: 0,2:09:41.96,2:09:44.16,Default,,0,0,0,,已经习惯和人接触了
Dialogue: 0,2:09:45.26,2:09:51.13,Default,,0,0,0,,这个不是的
Dialogue: 0,2:09:52.23,2:09:58.11,Default,,0,0,0,,还不是很习惯的
Dialogue: 0,2:09:58.84,2:10:03.61,Default,,0,0,0,,人很多还是不习惯
Dialogue: 0,2:10:05.45,2:10:07.65,Default,,0,0,0,,环境还是很重要的
Dialogue: 0,2:10:09.49,2:10:10.95,Default,,0,0,0,,明天早起可以吗？
Dialogue: 0,2:10:15.36,2:10:16.46,Default,,0,0,0,,可以吗？
Dialogue: 0,2:10:16.83,2:10:17.93,Default,,0,0,0,,是啊
Dialogue: 0,2:10:28.94,2:10:31.87,Default,,0,0,0,,要快点睡觉哦
Dialogue: 0,2:10:33.34,2:10:36.28,Default,,0,0,0,,到了时间叫你
Dialogue: 0,2:10:39.21,2:10:40.32,Default,,0,0,0,,拜托了
Dialogue: 0,2:10:41.42,2:10:44.35,Default,,0,0,0,,不醒就要做了
Dialogue: 0,2:10:44.72,2:10:45.82,Default,,0,0,0,,会醒的
Dialogue: 0,2:10:46.92,2:10:48.39,Default,,0,0,0,,晩安了
Dialogue: 0,2:11:00.87,2:11:05.27,Default,,0,0,0,,(上午11点5分)
Dialogue: 0,2:11:07.11,2:11:08.21,Default,,0,0,0,,这之后
Dialogue: 0,2:11:09.31,2:11:10.41,Default,,0,0,0,,那个
Dialogue: 0,2:11:12.25,2:11:13.35,Default,,0,0,0,,去海里
Dialogue: 0,2:11:13.72,2:11:18.85,Default,,0,0,0,,(第二天去海边)\N是去海边吗？
Dialogue: 0,2:11:19.22,2:11:24.36,Default,,0,0,0,,你不能晒黑吧
Dialogue: 0,2:11:26.56,2:11:29.50,Default,,0,0,0,,是东京湾吗？
Dialogue: 0,2:11:29.50,2:11:34.64,Default,,0,0,0,,（目的地是东京湾）\N-东京湾吗？ -很近啊
Dialogue: 0,2:11:37.21,2:11:40.88,Default,,0,0,0,,真的是太近了
Dialogue: 0,2:11:41.61,2:11:44.55,Default,,0,0,0,,还是远点比较好啊
Dialogue: 0,2:11:48.58,2:11:54.46,Default,,0,0,0,,我今天发现了一件事
Dialogue: 0,2:11:55.19,2:11:58.13,Default,,0,0,0,,他很像远藤宪一
Dialogue: 0,2:11:58.86,2:12:01.06,Default,,0,0,0,,（很像远藤宪一）\N说的我吗？
Dialogue: 0,2:12:01.80,2:12:05.10,Default,,0,0,0,,你自己不觉得吗？
Dialogue: 0,2:12:05.10,2:12:08.40,Default,,0,0,0,,-这是第二次被说了\N-我觉得像
Dialogue: 0,2:12:08.40,2:12:10.61,Default,,0,0,0,,真的像吗
Dialogue: 0,2:12:10.97,2:12:15.01,Default,,0,0,0,,(不是特别像)\N也不是非常像
Dialogue: 0,2:12:15.38,2:12:21.62,Default,,0,0,0,,-那不错啊 -是的 我很喜欢
Dialogue: 0,2:12:21.98,2:12:27.49,Default,,0,0,0,,这是你的优点啊
Dialogue: 0,2:12:27.49,2:12:31.53,Default,,0,0,0,,-真的很像 -想要做什么
Dialogue: 0,2:12:31.89,2:12:33.73,Default,,0,0,0,,(休息日做什么)
Dialogue: 0,2:12:34.46,2:12:38.87,Default,,0,0,0,,-我没有问过 -粉丝问过我
Dialogue: 0,2:12:39.23,2:12:46.21,Default,,0,0,0,,其实我没什么休息
Dialogue: 0,2:12:47.68,2:12:56.49,Default,,0,0,0,,(其实没什么休息日)\N是因为不是拍摄就是在休息
Dialogue: 0,2:12:57.22,2:13:04.93,Default,,0,0,0,,如果要说的话就都在一起
Dialogue: 0,2:13:06.03,2:13:10.80,Default,,0,0,0,,-没有固定的休息日 -没有
Dialogue: 0,2:13:11.53,2:13:17.04,Default,,0,0,0,,喜欢的时候就可以休息了
Dialogue: 0,2:13:17.41,2:13:19.98,Default,,0,0,0,,(爱好呢)\N爱好是什么啊
Dialogue: 0,2:13:19.98,2:13:22.18,Default,,0,0,0,,没什么爱好
Dialogue: 0,2:13:24.01,2:13:25.11,Default,,0,0,0,,没有
Dialogue: 0,2:13:25.48,2:13:29.89,Default,,0,0,0,,有想要做的事情吗？
Dialogue: 0,2:13:32.82,2:13:40.16,Default,,0,0,0,,我最近也经常在说
Dialogue: 0,2:13:40.90,2:13:45.30,Default,,0,0,0,,因为太忙所以才有爱好
Dialogue: 0,2:13:45.30,2:13:53.38,Default,,0,0,0,,（因为太忙所以才有爱好）\N-我说不错吧 -为缓解压力
Dialogue: 0,2:13:53.74,2:14:01.08,Default,,0,0,0,,就是在不忙的时候做喜欢的事
Dialogue: 0,2:14:01.45,2:14:08.06,Default,,0,0,0,,不工作的时候去做自己想做的事
Dialogue: 0,2:14:09.89,2:14:13.20,Default,,0,0,0,,不忙的时候就不用去想了
Dialogue: 0,2:14:13.93,2:14:17.60,Default,,0,0,0,,确实是啊 你不喜欢旅行吗？
Dialogue: 0,2:14:18.33,2:14:22.37,Default,,0,0,0,,养了猫 不想离开它
Dialogue: 0,2:14:23.11,2:14:28.61,Default,,0,0,0,,(养了4只)\N-养了几只 -4只
Dialogue: 0,2:14:28.98,2:14:34.12,Default,,0,0,0,,-没有不好相处的吗？-没有
Dialogue: 0,2:14:34.48,2:14:38.89,Default,,0,0,0,,大家都是很小的时候养的
Dialogue: 0,2:14:40.72,2:14:41.82,Default,,0,0,0,,有驾照吗？
Dialogue: 0,2:14:41.82,2:14:43.29,Default,,0,0,0,,-没有 -没有啊
Dialogue: 0,2:14:45.13,2:14:46.60,Default,,0,0,0,,不想自己开车
Dialogue: 0,2:14:46.96,2:14:48.80,Default,,0,0,0,,一点也不想
Dialogue: 0,2:14:49.53,2:14:55.04,Default,,0,0,0,,开车好像更慢啊
Dialogue: 0,2:14:55.04,2:14:59.07,Default,,0,0,0,,在东京也不好开车
Dialogue: 0,2:14:59.07,2:15:01.64,Default,,0,0,0,,确实是这样
Dialogue: 0,2:15:03.48,2:15:04.21,Default,,0,0,0,,自行车呢
Dialogue: 0,2:15:04.95,2:15:09.72,Default,,0,0,0,,(平常坐巴士)\N-巴士 -很平民啊
Dialogue: 0,2:15:09.72,2:15:11.92,Default,,0,0,0,,巴士很不错啊
Dialogue: 0,2:15:12.65,2:15:18.16,Default,,0,0,0,,真的觉得只有巴士好坐
Dialogue: 0,2:15:20.00,2:15:24.77,Default,,0,0,0,,(已经过了40分钟)
Dialogue: 0,2:15:25.87,2:15:32.47,Default,,0,0,0,,好像有点凉啊 没事吧
Dialogue: 0,2:15:33.58,2:15:39.45,Default,,0,0,0,,-不行啊 -你转过去
Dialogue: 0,2:15:40.18,2:15:42.38,Default,,0,0,0,,没事吧
Dialogue: 0,2:15:46.42,2:15:47.52,Default,,0,0,0,,怎么了
Dialogue: 0,2:15:55.23,2:15:56.70,Default,,0,0,0,,没事吧
Dialogue: 0,2:16:00.37,2:16:06.61,Default,,0,0,0,,你现在在偷拍吧
Dialogue: 0,2:16:11.38,2:16:16.52,Default,,0,0,0,,看到内裤很兴奋啊
Dialogue: 0,2:16:17.25,2:16:23.86,Default,,0,0,0,,如果有导演好像不太开心啊
Dialogue: 0,2:16:24.23,2:16:26.06,Default,,0,0,0,,可以随便看啊
Dialogue: 0,2:16:27.90,2:16:29.00,Default,,0,0,0,,可以吗?
Dialogue: 0,2:16:29.73,2:16:31.20,Default,,0,0,0,,-可以 -是吗
Dialogue: 0,2:16:31.57,2:16:33.04,Default,,0,0,0,,这样可以
Dialogue: 0,2:16:34.50,2:16:40.01,Default,,0,0,0,,如果是穿裙子的话
Dialogue: 0,2:16:40.38,2:16:47.72,Default,,0,0,0,,上楼梯的时候或者有风的时候
Dialogue: 0,2:16:48.45,2:16:54.32,Default,,0,0,0,,被看到会很讨厌
Dialogue: 0,2:16:54.69,2:16:57.99,Default,,0,0,0,,不能看吗？
Dialogue: 0,2:16:58.73,2:17:02.40,Default,,0,0,0,,也不会叫出来吧
Dialogue: 0,2:17:03.50,2:17:10.84,Default,,0,0,0,,要是一下子掀起来了
Dialogue: 0,2:17:11.21,2:17:14.51,Default,,0,0,0,,被风吹开的话
Dialogue: 0,2:17:15.61,2:17:20.38,Default,,0,0,0,,就是这个时候
Dialogue: 0,2:17:21.12,2:17:26.62,Default,,0,0,0,,会有大叔提醒说内裤出来了
Dialogue: 0,2:17:28.46,2:17:35.43,Default,,0,0,0,,-有这种人吗？ -是的
Dialogue: 0,2:17:35.80,2:17:37.63,Default,,0,0,0,,是在看你的表情
Dialogue: 0,2:17:38.73,2:17:44.97,Default,,0,0,0,,你有经验吧
Dialogue: 0,2:17:44.97,2:17:48.64,Default,,0,0,0,,是在看你什么表情
Dialogue: 0,2:17:49.01,2:17:54.88,Default,,0,0,0,,-是想看反应 -是的
Dialogue: 0,2:17:54.88,2:17:57.82,Default,,0,0,0,,-是这样啊 -是的
Dialogue: 0,2:17:58.92,2:18:01.12,Default,,0,0,0,,-好可怕 -这样的话
Dialogue: 0,2:18:02.22,2:18:04.06,Default,,0,0,0,,告诉你后会走开吗？
Dialogue: 0,2:18:04.43,2:18:06.26,Default,,0,0,0,,只是说一下
Dialogue: 0,2:18:07.73,2:18:09.20,Default,,0,0,0,,被说过吗？
Dialogue: 0,2:18:09.56,2:18:12.87,Default,,0,0,0,,-其实很多 -我第一次听说
Dialogue: 0,2:18:15.07,2:18:19.47,Default,,0,0,0,,(中午12点15)
Dialogue: 0,2:18:20.58,2:18:23.15,Default,,0,0,0,,是这样啊
Dialogue: 0,2:18:24.61,2:18:26.45,Default,,0,0,0,,是这样啊
Dialogue: 0,2:18:29.02,2:18:31.22,Default,,0,0,0,,-第一次吧 -是的
Dialogue: 0,2:18:31.59,2:18:37.46,Default,,0,0,0,,来干杯吧
Dialogue: 0,2:18:42.96,2:18:44.43,Default,,0,0,0,,真不错啊
Dialogue: 0,2:18:46.64,2:18:52.51,Default,,0,0,0,,真是豪华啊 来吃吧
Dialogue: 0,2:18:55.08,2:18:58.01,Default,,0,0,0,,很好吃啊
Dialogue: 0,2:19:02.42,2:19:04.62,Default,,0,0,0,,很厉害啊
Dialogue: 0,2:19:08.66,2:19:15.26,Default,,0,0,0,,今天天气晴朗 太好了
Dialogue: 0,2:19:15.26,2:19:17.10,Default,,0,0,0,,你在做什么
Dialogue: 0,2:19:18.57,2:19:19.67,Default,,0,0,0,,这个人
Dialogue: 0,2:19:21.14,2:19:21.87,Default,,0,0,0,,是的
Dialogue: 0,2:19:24.07,2:19:25.17,Default,,0,0,0,,一直这样
Dialogue: 0,2:19:25.91,2:19:29.58,Default,,0,0,0,,是很奇葩的人
Dialogue: 0,2:19:30.68,2:19:31.78,Default,,0,0,0,,好害羞
Dialogue: 0,2:19:32.15,2:19:33.62,Default,,0,0,0,,很温柔啊
Dialogue: 0,2:19:38.75,2:19:43.16,Default,,0,0,0,,一直在晃啊
Dialogue: 0,2:19:43.53,2:19:47.93,Default,,0,0,0,,一直在晃啊
Dialogue: 0,2:19:55.64,2:20:02.61,Default,,0,0,0,,麻里 你看这里
Dialogue: 0,2:20:02.98,2:20:08.85,Default,,0,0,0,,(杉山已经晕船了)\N你要好好加油啊
Dialogue: 0,2:20:10.69,2:20:12.52,Default,,0,0,0,,没事吧
Dialogue: 0,2:20:14.72,2:20:18.39,Default,,0,0,0,,-没事吧 -好厉害
Dialogue: 0,2:20:19.13,2:20:23.16,Default,,0,0,0,,你看这个
Dialogue: 0,2:20:25.37,2:20:26.84,Default,,0,0,0,,已经这样了
Dialogue: 0,2:20:27.57,2:20:28.67,Default,,0,0,0,,是嘛
Dialogue: 0,2:20:30.87,2:20:34.18,Default,,0,0,0,,想要看外面吗？
Dialogue: 0,2:20:34.91,2:20:37.48,Default,,0,0,0,,看一下这里吧
Dialogue: 0,2:20:54.36,2:20:55.83,Default,,0,0,0,,是粉色的
Dialogue: 0,2:20:58.03,2:20:59.13,Default,,0,0,0,,很粉啊
Dialogue: 0,2:20:59.87,2:21:02.07,Default,,0,0,0,,要出去看看吗？
Dialogue: 0,2:21:04.27,2:21:05.74,Default,,0,0,0,,外面吗？
Dialogue: 0,2:21:06.47,2:21:10.51,Default,,0,0,0,,我们去看看吧
Dialogue: 0,2:21:10.88,2:21:11.98,Default,,0,0,0,,哪里
Dialogue: 0,2:21:12.35,2:21:13.45,Default,,0,0,0,,走吧
Dialogue: 0,2:21:16.38,2:21:17.12,Default,,0,0,0,,走
Dialogue: 0,2:21:18.59,2:21:22.99,Default,,0,0,0,,晃的好厉害啊
Dialogue: 0,2:21:24.83,2:21:29.23,Default,,0,0,0,,怎么忽然牵手了
Dialogue: 0,2:21:30.70,2:21:32.53,Default,,0,0,0,,好狡猾啊
Dialogue: 0,2:21:35.10,2:21:37.31,Default,,0,0,0,,好厉害啊
Dialogue: 0,2:21:42.81,2:21:43.55,Default,,0,0,0,,好厉害
Dialogue: 0,2:21:48.32,2:21:49.78,Default,,0,0,0,,很好看啊
Dialogue: 0,2:21:59.69,2:22:05.20,Default,,0,0,0,,对面在看什么啊
Dialogue: 0,2:22:08.87,2:22:10.71,Default,,0,0,0,,有人在打招呼吗？
Dialogue: 0,2:22:11.81,2:22:12.91,Default,,0,0,0,,没有人啊
Dialogue: 0,2:22:13.64,2:22:15.11,Default,,0,0,0,,怎么了
Dialogue: 0,2:22:25.39,2:22:31.63,Default,,0,0,0,,(忽然晕船了)\N晃的太厉害了
Dialogue: 0,2:22:31.99,2:22:35.30,Default,,0,0,0,,-不行了吗 -这里不行
Dialogue: 0,2:22:43.74,2:22:44.84,Default,,0,0,0,,要回去吗？
Dialogue: 0,2:22:46.31,2:22:49.61,Default,,0,0,0,,这里晃的太厉害了
Dialogue: 0,2:22:57.32,2:22:58.79,Default,,0,0,0,,怎么样
Dialogue: 0,2:22:59.89,2:23:06.86,Default,,0,0,0,,脸好像变的很红啊
Dialogue: 0,2:23:08.70,2:23:10.53,Default,,0,0,0,,很容易上脸
Dialogue: 0,2:23:12.37,2:23:16.77,Default,,0,0,0,,-远没有醉 -是吗
Dialogue: 0,2:23:17.87,2:23:22.64,Default,,0,0,0,,-很厉害 -真的很红吗
Dialogue: 0,2:23:22.64,2:23:27.78,Default,,0,0,0,,喝多了的话会变的比较红
Dialogue: 0,2:23:29.98,2:23:32.92,Default,,0,0,0,,最长喝过多久
Dialogue: 0,2:23:34.39,2:23:35.49,Default,,0,0,0,,几小时
Dialogue: 0,2:23:36.96,2:23:40.63,Default,,0,0,0,,时间最长的是
Dialogue: 0,2:23:41.00,2:23:49.44,Default,,0,0,0,,(晚上9点集合)\N先是晚上9点集合吃饭
Dialogue: 0,2:23:52.01,2:23:59.35,Default,,0,0,0,,(一直到第二天下午1点)\N连续喝到了第二天
Dialogue: 0,2:23:59.71,2:24:07.42,Default,,0,0,0,,是在店里没有在意外面
Dialogue: 0,2:24:08.16,2:24:11.09,Default,,0,0,0,,看了一下外面
Dialogue: 0,2:24:12.93,2:24:19.53,Default,,0,0,0,,还以为只是天亮了
Dialogue: 0,2:24:22.10,2:24:23.57,Default,,0,0,0,,你看已经晕了
Dialogue: 0,2:24:25.04,2:24:27.61,Default,,0,0,0,,很厉害啊
Dialogue: 0,2:24:32.38,2:24:33.85,Default,,0,0,0,,刚才一直这样
Dialogue: 0,2:24:33.85,2:24:38.99,Default,,0,0,0,,(杉山又晕船了)\N-一直不能说话了 -要缓缓
Dialogue: 0,2:24:40.09,2:24:41.56,Default,,0,0,0,,一直在晕啊
Dialogue: 0,2:24:44.13,2:24:49.26,Default,,0,0,0,,已经晕了吧
Dialogue: 0,2:24:51.10,2:24:56.60,Default,,0,0,0,,这样的话 晕船也可以
Dialogue: 0,2:24:57.34,2:25:01.74,Default,,0,0,0,,旁边的人也行动了
Dialogue: 0,2:25:07.25,2:25:12.39,Default,,0,0,0,,-还没有习惯 -没有习惯吗
Dialogue: 0,2:25:13.86,2:25:16.06,Default,,0,0,0,,是不是已经醉了
Dialogue: 0,2:25:17.89,2:25:23.77,Default,,0,0,0,,-没事吗 -我有点认生
Dialogue: 0,2:25:23.77,2:25:28.90,Default,,0,0,0,,说你还是生人呢
Dialogue: 0,2:25:29.27,2:25:35.88,Default,,0,0,0,,-这样还是不行啊\N-大家这样
Dialogue: 0,2:25:36.98,2:25:41.38,Default,,0,0,0,,来看我的眼睛
Dialogue: 0,2:25:42.48,2:25:48.72,Default,,0,0,0,,-感觉还是和你不熟\N-不是的
Dialogue: 0,2:25:49.09,2:25:55.33,Default,,0,0,0,,这个时候还是要会说话啊
Dialogue: 0,2:25:56.43,2:26:01.57,Default,,0,0,0,,但是我感觉差不多了
Dialogue: 0,2:26:02.30,2:26:03.40,Default,,0,0,0,,是吧
Dialogue: 0,2:26:05.24,2:26:06.34,Default,,0,0,0,,还不行啊
Dialogue: 0,2:26:06.71,2:26:08.91,Default,,0,0,0,,是吧
Dialogue: 0,2:26:10.75,2:26:12.95,Default,,0,0,0,,给我吧
Dialogue: 0,2:26:14.05,2:26:16.99,Default,,0,0,0,,已经喝了吗？
Dialogue: 0,2:26:17.35,2:26:18.09,Default,,0,0,0,,喝了
Dialogue: 0,2:26:22.86,2:26:23.96,Default,,0,0,0,,又来了
Dialogue: 0,2:26:25.79,2:26:29.46,Default,,0,0,0,,强硬的喝下去了
Dialogue: 0,2:26:34.24,2:26:41.58,Default,,0,0,0,,真的是很会玩啊
Dialogue: 0,2:26:41.94,2:26:43.04,Default,,0,0,0,,是啊
Dialogue: 0,2:26:44.15,2:26:48.92,Default,,0,0,0,,感觉他特别的色
Dialogue: 0,2:26:50.39,2:26:57.36,Default,,0,0,0,,也不是讨厌 就是很色
Dialogue: 0,2:26:59.56,2:27:05.43,Default,,0,0,0,,粉丝问我为什麽经常一起
Dialogue: 0,2:27:06.53,2:27:11.67,Default,,0,0,0,,问为什么和猩猩在一起
Dialogue: 0,2:27:12.77,2:27:16.08,Default,,0,0,0,,不好意思啊
Dialogue: 0,2:27:16.08,2:27:19.01,Default,,0,0,0,,因为我不能选择啊
Dialogue: 0,2:27:21.22,2:27:23.05,Default,,0,0,0,,是这样
Dialogue: 0,2:27:23.79,2:27:28.56,Default,,0,0,0,,我也要喝酒
Dialogue: 0,2:27:29.66,2:27:32.23,Default,,0,0,0,,你已经喝了吧
Dialogue: 0,2:27:42.87,2:27:43.97,Default,,0,0,0,,好喝吗？
Dialogue: 0,2:27:48.74,2:27:49.84,Default,,0,0,0,,在干什么
Dialogue: 0,2:27:57.92,2:28:00.49,Default,,0,0,0,,不要摸我啊
Dialogue: 0,2:28:01.96,2:28:05.26,Default,,0,0,0,,已经可以了吗？
Dialogue: 0,2:28:08.56,2:28:15.17,Default,,0,0,0,,(船一直往前行不知道要到哪里)
Dialogue: 0,2:28:17.37,2:28:18.84,Default,,0,0,0,,吃了很多
Dialogue: 0,2:28:19.21,2:28:25.45,Default,,0,0,0,,(下船在街上散步)\N-感觉不错 -你享受了吗？
Dialogue: 0,2:28:25.81,2:28:28.38,Default,,0,0,0,,有点晕船
Dialogue: 0,2:28:30.59,2:28:35.72,Default,,0,0,0,,麻里我们离开吧
Dialogue: 0,2:28:36.82,2:28:41.96,Default,,0,0,0,,-不好吧 -他们不会发现的
Dialogue: 0,2:28:42.33,2:28:48.57,Default,,0,0,0,,没事的就一会儿
Dialogue: 0,2:28:49.30,2:28:54.44,Default,,0,0,0,,就我们两个去换个心情
Dialogue: 0,2:28:55.91,2:28:58.48,Default,,0,0,0,,都喝醉了 没事的
Dialogue: 0,2:28:59.95,2:29:03.99,Default,,0,0,0,,坐出租车去别的地方吧
Dialogue: 0,2:29:04.72,2:29:05.82,Default,,0,0,0,,可以吗？
Dialogue: 0,2:29:09.49,2:29:10.59,Default,,0,0,0,,拜托了
Dialogue: 0,2:29:13.53,2:29:20.50,Default,,0,0,0,,(小田切离开去了宾馆)\N拜托了
Dialogue: 0,2:29:25.64,2:29:26.74,Default,,0,0,0,,什么
Dialogue: 0,2:29:27.11,2:29:28.94,Default,,0,0,0,,是粉色的啊
Dialogue: 0,2:29:36.28,2:29:38.12,Default,,0,0,0,,感觉不错吧
Dialogue: 0,2:29:39.95,2:29:41.79,Default,,0,0,0,,好久没来了
Dialogue: 0,2:29:43.62,2:29:46.93,Default,,0,0,0,,已经很多年没来了
Dialogue: 0,2:29:49.50,2:29:52.07,Default,,0,0,0,,里面很安静 不错
Dialogue: 0,2:29:53.17,2:29:55.00,Default,,0,0,0,,有种很久以前的感觉
Dialogue: 0,2:29:55.74,2:29:59.04,Default,,0,0,0,,是啊 不是很新的感觉
Dialogue: 0,2:29:59.77,2:30:02.71,Default,,0,0,0,,感觉不错吧
Dialogue: 0,2:30:04.55,2:30:07.48,Default,,0,0,0,,之前说的规则
Dialogue: 0,2:30:08.95,2:30:12.62,Default,,0,0,0,,要是有摄像机
Dialogue: 0,2:30:13.72,2:30:18.86,Default,,0,0,0,,就可以内射对吧
Dialogue: 0,2:30:19.96,2:30:21.06,Default,,0,0,0,,是的
Dialogue: 0,2:30:21.06,2:30:25.47,Default,,0,0,0,,那现在可以啊
Dialogue: 0,2:30:33.17,2:30:39.05,Default,,0,0,0,,-是吧 -那不要拍了吧
Dialogue: 0,2:30:40.15,2:30:41.62,Default,,0,0,0,,我看看
Dialogue: 0,2:30:46.02,2:30:50.79,Default,,0,0,0,,给我再看一下
Dialogue: 0,2:30:54.46,2:30:55.20,Default,,0,0,0,,放这里
Dialogue: 0,2:30:57.40,2:30:59.60,Default,,0,0,0,,站起来让我看看
Dialogue: 0,2:31:00.70,2:31:03.27,Default,,0,0,0,,-好害羞 -没事啊
Dialogue: 0,2:31:04.37,2:31:08.78,Default,,0,0,0,,-真的很害羞 -是吗
Dialogue: 0,2:31:08.78,2:31:12.81,Default,,0,0,0,,-好可爱 -好害羞
Dialogue: 0,2:31:15.75,2:31:17.59,Default,,0,0,0,,把腿分开我看看
Dialogue: 0,2:31:18.69,2:31:20.15,Default,,0,0,0,,没事的
Dialogue: 0,2:31:23.82,2:31:24.93,Default,,0,0,0,,我看看
Dialogue: 0,2:31:30.43,2:31:31.53,Default,,0,0,0,,不错
Dialogue: 0,2:31:33.00,2:31:39.24,Default,,0,0,0,,很兴奋啊 只有我们两个
Dialogue: 0,2:31:40.34,2:31:41.44,Default,,0,0,0,,很好
Dialogue: 0,2:31:48.78,2:31:54.66,Default,,0,0,0,,我摸摸看 不行了
Dialogue: 0,2:31:56.49,2:32:00.90,Default,,0,0,0,,真的忍不住了
Dialogue: 0,2:32:02.73,2:32:03.83,Default,,0,0,0,,好害羞
Dialogue: 0,2:32:07.13,2:32:08.24,Default,,0,0,0,,什么
Dialogue: 0,2:32:10.44,2:32:16.31,Default,,0,0,0,,-不要啊 -快点啊
Dialogue: 0,2:32:17.41,2:32:18.88,Default,,0,0,0,,快点啊
Dialogue: 0,2:32:21.82,2:32:22.92,Default,,0,0,0,,好害羞
Dialogue: 0,2:32:26.95,2:32:29.16,Default,,0,0,0,,为什么这么湿
Dialogue: 0,2:32:30.99,2:32:33.19,Default,,0,0,0,,已经这么湿了
Dialogue: 0,2:32:34.30,2:32:38.33,Default,,0,0,0,,-因为太热了 -是吗
Dialogue: 0,2:32:38.70,2:32:41.64,Default,,0,0,0,,是汗吗 不是吧
Dialogue: 0,2:32:44.57,2:32:45.67,Default,,0,0,0,,好厉害
Dialogue: 0,2:32:46.04,2:32:47.14,Default,,0,0,0,,好多啊
Dialogue: 0,2:32:47.88,2:32:48.98,Default,,0,0,0,,是汗
Dialogue: 0,2:32:52.65,2:32:53.75,Default,,0,0,0,,好害羞
Dialogue: 0,2:33:01.46,2:33:04.03,Default,,0,0,0,,好多汗啊
Dialogue: 0,2:33:11.00,2:33:12.10,Default,,0,0,0,,好多汗
Dialogue: 0,2:33:14.30,2:33:15.40,Default,,0,0,0,,不要
Dialogue: 0,2:33:17.97,2:33:19.07,Default,,0,0,0,,好厉害
Dialogue: 0,2:33:19.81,2:33:23.84,Default,,0,0,0,,来摸摸看怎么样
Dialogue: 0,2:33:25.68,2:33:27.88,Default,,0,0,0,,特别热
Dialogue: 0,2:33:28.62,2:33:29.72,Default,,0,0,0,,热吧
Dialogue: 0,2:33:30.45,2:33:32.29,Default,,0,0,0,,用嘴巴降温一下
Dialogue: 0,2:33:33.02,2:33:34.12,Default,,0,0,0,,嘴巴
Dialogue: 0,2:33:42.93,2:33:44.03,Default,,0,0,0,,舒服
Dialogue: 0,2:33:52.11,2:33:53.21,Default,,0,0,0,,好舒服
Dialogue: 0,2:34:07.89,2:34:09.72,Default,,0,0,0,,真的很舒服
Dialogue: 0,2:34:10.83,2:34:14.50,Default,,0,0,0,,这样好舒服啊
Dialogue: 0,2:34:15.60,2:34:16.33,Default,,0,0,0,,这里
Dialogue: 0,2:34:46.06,2:34:47.90,Default,,0,0,0,,-好舒服 -进去了
Dialogue: 0,2:35:01.11,2:35:02.21,Default,,0,0,0,,舒服
Dialogue: 0,2:35:07.35,2:35:08.45,Default,,0,0,0,,不行了
Dialogue: 0,2:35:09.18,2:35:10.28,Default,,0,0,0,,舒服
Dialogue: 0,2:35:19.09,2:35:20.19,Default,,0,0,0,,好湿啊
Dialogue: 0,2:35:21.30,2:35:22.40,Default,,0,0,0,,舒服
Dialogue: 0,2:35:28.27,2:35:29.37,Default,,0,0,0,,不行了
Dialogue: 0,2:35:35.98,2:35:37.08,Default,,0,0,0,,不行了
Dialogue: 0,2:35:39.28,2:35:43.32,Default,,0,0,0,,好舒服啊
Dialogue: 0,2:35:49.92,2:35:51.03,Default,,0,0,0,,不行
Dialogue: 0,2:36:06.07,2:36:08.28,Default,,0,0,0,,-这样舒服吧 -是的
Dialogue: 0,2:36:09.38,2:36:10.48,Default,,0,0,0,,喜欢吗？
Dialogue: 0,2:36:11.21,2:36:11.95,Default,,0,0,0,,喜欢
