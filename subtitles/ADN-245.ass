Dialogue: 0,0:21:46.37,0:21:50.17,Default2,,0,0,0,,張嘴
Dialogue: 0,0:21:57.18,0:22:00.71,Default2,,0,0,0,,快舔
Dialogue: 0,0:22:06.52,0:22:10.12,Default2,,0,0,0,,不可以
Dialogue: 0,0:22:16.20,0:22:18.27,Default2,,0,0,0,,來吧
Dialogue: 0,0:22:18.67,0:22:21.20,Default2,,0,0,0,,等等
Dialogue: 0,0:22:21.54,0:22:24.74,Default2,,0,0,0,,你在想什麼!
Dialogue: 0,0:22:24.74,0:22:27.47,Default2,,0,0,0,,不可以
Dialogue: 0,0:22:27.81,0:22:31.01,Default2,,0,0,0,,開吧
Dialogue: 0,0:22:33.01,0:22:35.08,Default2,,0,0,0,,不可以嗎?
Dialogue: 0,0:22:35.08,0:22:37.08,Default2,,0,0,0,,我有老公
Dialogue: 0,0:22:37.62,0:22:39.62,Default2,,0,0,0,,這才好
Dialogue: 0,0:22:41.76,0:22:46.03,Default2,,0,0,0,,才會更興奮
Dialogue: 0,0:22:46.29,0:22:49.96,Default2,,0,0,0,,不可以
Dialogue: 0,0:22:50.23,0:22:53.63,Default2,,0,0,0,,進去
Dialogue: 0,0:22:53.97,0:22:58.44,Default2,,0,0,0,,不可以
Dialogue: 0,0:23:00.97,0:23:04.44,Default2,,0,0,0,,不可以
Dialogue: 0,0:23:04.85,0:23:09.52,Default2,,0,0,0,,不可以
Dialogue: 0,0:23:19.66,0:23:23.86,Default2,,0,0,0,,不可以
Dialogue: 0,0:23:32.87,0:23:35.94,Default2,,0,0,0,,拔出來
Dialogue: 0,0:23:35.94,0:23:37.94,Default2,,0,0,0,,騙人
Dialogue: 0,0:23:45.69,0:23:48.42,Default2,,0,0,0,,好好品嘗啊
Dialogue: 0,0:23:55.63,0:24:00.17,Default2,,0,0,0,,慢慢的
Dialogue: 0,0:24:15.85,0:24:20.05,Default2,,0,0,0,,不可以
Dialogue: 0,0:24:43.61,0:24:47.88,Default2,,0,0,0,,不可以
Dialogue: 0,0:24:52.15,0:24:55.16,Default2,,0,0,0,,不可以
Dialogue: 0,0:25:16.64,0:25:20.18,Default2,,0,0,0,,不可以
Dialogue: 0,0:25:33.06,0:25:37.40,Default2,,0,0,0,,不可以
Dialogue: 0,0:25:37.66,0:25:41.20,Default2,,0,0,0,,不可以
Dialogue: 0,0:25:53.95,0:25:58.29,Default2,,0,0,0,,這麼大聲好嗎?
Dialogue: 0,0:26:25.45,0:26:28.78,Default2,,0,0,0,,爽吧
Dialogue: 0,0:26:29.18,0:26:33.59,Default2,,0,0,0,,不可以
Dialogue: 0,0:26:36.06,0:26:40.13,Default2,,0,0,0,,不可以
Dialogue: 0,0:26:57.81,0:27:02.08,Default2,,0,0,0,,不可以
Dialogue: 0,0:27:11.63,0:27:14.76,Default2,,0,0,0,,不可以
Dialogue: 0,0:27:14.96,0:27:17.90,Default2,,0,0,0,,不可以嗎?
Dialogue: 0,0:27:27.84,0:27:32.11,Default2,,0,0,0,,好好動
Dialogue: 0,0:27:39.59,0:27:43.86,Default2,,0,0,0,,爽吧
Dialogue: 0,0:28:04.61,0:28:09.15,Default2,,0,0,0,,好爽
Dialogue: 0,0:28:49.79,0:28:52.93,Default2,,0,0,0,,想舔吧
Dialogue: 0,0:28:53.33,0:28:56.73,Default2,,0,0,0,,想吧
Dialogue: 0,0:29:02.20,0:29:05.67,Default2,,0,0,0,,很爽吧
Dialogue: 0,0:29:15.88,0:29:20.09,Default2,,0,0,0,,高潮吧
Dialogue: 0,0:29:21.42,0:29:25.76,Default2,,0,0,0,,用我的肉棒
Dialogue: 0,0:30:00.93,0:30:06.13,Default2,,0,0,0,,再來
Dialogue: 0,0:30:06.47,0:30:09.47,Default2,,0,0,0,,那個
Dialogue: 0,0:30:09.87,0:30:13.01,Default2,,0,0,0,,怎麼啦?
Dialogue: 0,0:30:13.67,0:30:17.01,Default2,,0,0,0,,很爽吧
Dialogue: 0,0:30:21.15,0:30:25.22,Default2,,0,0,0,,交給我
Dialogue: 0,0:30:25.49,0:30:27.69,Default2,,0,0,0,,不可以
Dialogue: 0,0:30:27.69,0:30:29.69,Default2,,0,0,0,,去了
Dialogue: 0,0:32:04.78,0:32:06.52,Default2,,0,0,0,,我回來了
Dialogue: 0,0:32:06.99,0:32:09.12,Default2,,0,0,0,,幸好你醒著
Dialogue: 0,0:32:09.39,0:32:11.26,Default2,,0,0,0,,歡迎回家
Dialogue: 0,0:32:16.66,0:32:21.07,Default2,,0,0,0,,我有話想說
Dialogue: 0,0:32:21.27,0:32:22.47,Default2,,0,0,0,,啥?
Dialogue: 0,0:32:22.60,0:32:25.67,Default2,,0,0,0,,其實我也有
Dialogue: 0,0:32:26.21,0:32:28.07,Default2,,0,0,0,,怎了?
Dialogue: 0,0:32:28.88,0:32:31.54,Default2,,0,0,0,,今天部長跟我說
Dialogue: 0,0:32:31.81,0:32:34.15,Default2,,0,0,0,,我可能會當課長
Dialogue: 0,0:32:35.62,0:32:37.55,Default2,,0,0,0,,太棒了
Dialogue: 0,0:32:38.95,0:32:43.49,Default2,,0,0,0,,所以最近會一直加班
Dialogue: 0,0:32:44.22,0:32:46.16,Default2,,0,0,0,,加油
Dialogue: 0,0:32:47.09,0:32:49.10,Default2,,0,0,0,,我會為了你努力
Dialogue: 0,0:32:49.50,0:32:51.36,Default2,,0,0,0,,謝謝
Dialogue: 0,0:32:51.63,0:32:55.10,Default2,,0,0,0,,你要講啥?
Dialogue: 0,0:32:55.37,0:32:57.17,Default2,,0,0,0,,沒有啦
Dialogue: 0,0:32:57.64,0:33:00.64,Default2,,0,0,0,,好在意唷
Dialogue: 0,0:33:01.04,0:33:03.31,Default2,,0,0,0,,我去放洗澡水
Dialogue: 0,0:33:03.31,0:33:05.31,Default2,,0,0,0,,謝謝
Dialogue: 0,0:33:12.12,0:33:15.86,Default2,,0,0,0,,我昨天去書店看
Dialogue: 0,0:33:15.86,0:33:18.73,Default2,,0,0,0,,給女生看的色情小說好多
Dialogue: 0,0:33:20.39,0:33:22.13,Default2,,0,0,0,,好像是
Dialogue: 0,0:33:22.73,0:33:25.60,Default2,,0,0,0,,你看了?
Dialogue: 0,0:33:27.67,0:33:30.94,Default2,,0,0,0,,比想像中還色
Dialogue: 0,0:33:31.80,0:33:34.01,Default2,,0,0,0,,興奮了?
Dialogue: 0,0:33:35.88,0:33:37.41,Default2,,0,0,0,,對啊
Dialogue: 0,0:33:37.41,0:33:40.88,Default2,,0,0,0,,雖然在書店
Dialogue: 0,0:33:41.08,0:33:43.48,Default2,,0,0,0,,卻有點硬了
Dialogue: 0,0:33:43.62,0:33:45.95,Default2,,0,0,0,,真是糟糕
Dialogue: 0,0:33:48.22,0:33:49.76,Default2,,0,0,0,,抱歉
Dialogue: 0,0:33:50.29,0:33:52.69,Default2,,0,0,0,,我沒那意思
Dialogue: 0,0:33:52.69,0:33:56.10,Default2,,0,0,0,,別想太多
Dialogue: 0,0:33:56.30,0:33:58.43,Default2,,0,0,0,,因為稱在寫
Dialogue: 0,0:33:58.56,0:34:02.44,Default2,,0,0,0,,所以我很在意
Dialogue: 0,0:34:04.57,0:34:06.44,Default2,,0,0,0,,射謝
Dialogue: 0,0:34:07.11,0:34:09.71,Default2,,0,0,0,,不過我差不多
Dialogue: 0,0:34:09.71,0:34:11.71,Default2,,0,0,0,,要回絕了
Dialogue: 0,0:34:11.98,0:34:14.71,Default2,,0,0,0,,為啥
Dialogue: 0,0:34:15.11,0:34:16.85,Default2,,0,0,0,,沒有理由
Dialogue: 0,0:34:17.18,0:34:19.19,Default2,,0,0,0,,是嗎?
Dialogue: 0,0:34:20.79,0:34:24.26,Default2,,0,0,0,,這麼晚了 我去丟垃圾
Dialogue: 0,0:34:28.26,0:34:30.46,Default2,,0,0,0,,來了
Dialogue: 0,0:34:35.20,0:34:38.00,Default2,,0,0,0,,-我回來了 -歡迎回家
Dialogue: 0,0:34:38.20,0:34:41.14,Default2,,0,0,0,,請進
Dialogue: 0,0:34:41.67,0:34:42.88,Default2,,0,0,0,,晚安
Dialogue: 0,0:34:43.28,0:34:45.34,Default2,,0,0,0,,晚安
Dialogue: 0,0:34:45.55,0:34:49.82,Default2,,0,0,0,,他說你不寫 非常擔心就來了
Dialogue: 0,0:34:50.28,0:34:53.09,Default2,,0,0,0,,不好意思
Dialogue: 0,0:34:53.35,0:34:55.15,Default2,,0,0,0,,抱歉這麼晚
Dialogue: 0,0:34:55.56,0:34:58.22,Default2,,0,0,0,,沒關係啦 請進
Dialogue: 0,0:34:58.22,0:35:00.23,Default2,,0,0,0,,好的
Dialogue: 0,0:35:00.23,0:35:02.23,Default2,,0,0,0,,謝謝
Dialogue: 0,0:35:06.03,0:35:10.17,Default2,,0,0,0,,-請喝 -謝謝
Dialogue: 0,0:35:12.71,0:35:14.91,Default2,,0,0,0,,抱歉啊
Dialogue: 0,0:35:15.24,0:35:18.24,Default2,,0,0,0,,還請我吃飯
Dialogue: 0,0:35:19.65,0:35:23.05,Default2,,0,0,0,,幸好你來了
Dialogue: 0,0:35:23.05,0:35:26.12,Default2,,0,0,0,,她最近很沒精神
Dialogue: 0,0:35:26.12,0:35:28.12,Default2,,0,0,0,,這樣啊
Dialogue: 0,0:35:28.25,0:35:32.06,Default2,,0,0,0,,可能是我意見太多了
Dialogue: 0,0:35:32.46,0:35:34.73,Default2,,0,0,0,,其實
Dialogue: 0,0:35:34.86,0:35:39.00,Default2,,0,0,0,,今年有個小說獎
Dialogue: 0,0:35:39.33,0:35:41.60,Default2,,0,0,0,,我希望你得獎
Dialogue: 0,0:35:42.67,0:35:45.61,Default2,,0,0,0,,所以才一直逼你
Dialogue: 0,0:35:45.81,0:35:48.14,Default2,,0,0,0,,抱歉
Dialogue: 0,0:35:49.74,0:35:51.28,Default2,,0,0,0,,沒關條
Dialogue: 0,0:35:51.88,0:35:54.21,Default2,,0,0,0,,很厲害啊
Dialogue: 0,0:35:54.61,0:35:57.42,Default2,,0,0,0,,麻煩你了
Dialogue: 0,0:35:57.48,0:36:00.82,Default2,,0,0,0,,我才是
Dialogue: 0,0:36:01.22,0:36:03.42,Default2,,0,0,0,,太太一起加油吧
Dialogue: 0,0:36:06.43,0:36:07.56,Default2,,0,0,0,,對了
Dialogue: 0,0:36:07.83,0:36:12.03,Default2,,0,0,0,,你昨天有寫吧 我去印
Dialogue: 0,0:36:12.43,0:36:15.23,Default2,,0,0,0,,等等
Dialogue: 0,0:36:36.32,0:36:39.66,Default2,,0,0,0,,等等 很困擾的
Dialogue: 0,0:36:40.73,0:36:42.20,Default2,,0,0,0,,如何?
Dialogue: 0,0:36:42.20,0:36:44.20,Default2,,0,0,0,,很刺激吧
Dialogue: 0,0:36:44.20,0:36:46.20,Default2,,0,0,0,,住手
Dialogue: 0,0:36:47.20,0:36:50.14,Default2,,0,0,0,,這也是經驗
Dialogue: 0,0:36:50.14,0:36:52.14,Default2,,0,0,0,,很背德吧
Dialogue: 0,0:36:59.28,0:37:02.08,Default2,,0,0,0,,住手
Dialogue: 0,0:37:03.35,0:37:07.55,Default2,,0,0,0,,住手
Dialogue: 0,0:37:07.82,0:37:10.76,Default2,,0,0,0,,住手
Dialogue: 0,0:37:11.09,0:37:14.43,Default2,,0,0,0,,很刺激吧
Dialogue: 0,0:37:22.30,0:37:27.31,Default2,,0,0,0,,感覺很爽吧
Dialogue: 0,0:37:38.52,0:37:41.65,Default2,,0,0,0,,再來
Dialogue: 0,0:37:46.19,0:37:49.66,Default2,,0,0,0,,住手
Dialogue: 0,0:37:49.66,0:37:53.67,Default2,,0,0,0,,他發現怎麼辦?
Dialogue: 0,0:37:53.93,0:37:57.60,Default2,,0,0,0,,久等了
Dialogue: 0,0:37:57.60,0:38:00.94,Default2,,0,0,0,,請看
Dialogue: 0,0:38:00.94,0:38:02.94,Default2,,0,0,0,,她很努力
Dialogue: 0,0:38:06.48,0:38:09.55,Default2,,0,0,0,,不錯呢
Dialogue: 0,0:38:10.88,0:38:12.82,Default2,,0,0,0,,很好
Dialogue: 0,0:38:28.30,0:38:30.84,Default2,,0,0,0,,仁美
Dialogue: 0,0:38:32.31,0:38:35.24,Default2,,0,0,0,,去哪了?
Dialogue: 0,0:38:50.32,0:38:52.46,Default2,,0,0,0,,早安
Dialogue: 0,0:38:52.46,0:38:55.33,Default2,,0,0,0,,我馬上做菜
Dialogue: 0,0:38:55.59,0:38:56.60,Default2,,0,0,0,,你熬夜寫?
Dialogue: 0,0:38:59.60,0:39:00.87,Default2,,0,0,0,,我去泡咖啡
Dialogue: 0,0:39:00.87,0:39:04.40,Default2,,0,0,0,,沒關係啦 我來
Dialogue: 0,0:39:04.87,0:39:09.14,Default2,,0,0,0,,謝謝
Dialogue: 0,0:39:11.74,0:39:13.48,Default2,,0,0,0,,黑咖啡唷
Dialogue: 0,0:39:25.96,0:39:30.63,Default2,,0,0,0,,老公 你今天真早
Dialogue: 0,0:39:36.04,0:39:38.57,Default2,,0,0,0,,總編輯?
Dialogue: 0,0:39:45.31,0:39:48.71,Default2,,0,0,0,,住手
Dialogue: 0,0:39:48.71,0:39:50.72,Default2,,0,0,0,,很困擾的
Dialogue: 0,0:39:50.72,0:39:52.72,Default2,,0,0,0,,對吧
Dialogue: 0,0:39:52.72,0:39:54.72,Default2,,0,0,0,,不可以呢
Dialogue: 0,0:39:55.65,0:39:58.52,Default2,,0,0,0,,不可以但是忍不住
Dialogue: 0,0:39:59.06,0:40:03.13,Default2,,0,0,0,,身體不聽使喚
Dialogue: 0,0:40:04.80,0:40:07.73,Default2,,0,0,0,,這就是外遇
Dialogue: 0,0:40:09.60,0:40:13.21,Default2,,0,0,0,,放開我
Dialogue: 0,0:40:17.74,0:40:21.28,Default2,,0,0,0,,在這吧
Dialogue: 0,0:40:21.28,0:40:23.28,Default2,,0,0,0,,住手
Dialogue: 0,0:40:26.69,0:40:30.56,Default2,,0,0,0,,你跟老公在這睡?
Dialogue: 0,0:40:30.82,0:40:34.23,Default2,,0,0,0,,封
Dialogue: 0,0:40:34.76,0:40:38.30,Default2,,0,0,0,,有做嗎?
Dialogue: 0,0:40:38.96,0:40:43.24,Default2,,0,0,0,,最近沒有跟你無關
Dialogue: 0,0:40:45.77,0:40:48.44,Default2,,0,0,0,,是嗎?
Dialogue: 0,0:40:49.58,0:40:53.78,Default2,,0,0,0,,所以你才會
Dialogue: 0,0:40:54.11,0:40:58.12,Default2,,0,0,0,,那麼敏感
Dialogue: 0,0:41:03.32,0:41:07.79,Default2,,0,0,0,,這樣很不好呢
Dialogue: 0,0:41:18.27,0:41:22.21,Default2,,0,0,0,,總編輯
Dialogue: 0,0:41:22.21,0:41:24.21,Default2,,0,0,0,,知道不可以
Dialogue: 0,0:41:25.95,0:41:27.75,Default2,,0,0,0,,住手
Dialogue: 0,0:41:28.01,0:41:32.28,Default2,,0,0,0,,住手
Dialogue: 0,0:41:41.36,0:41:44.70,Default2,,0,0,0,,知道不可以
Dialogue: 0,0:41:45.03,0:41:47.03,Default2,,0,0,0,,好是
Dialogue: 0,0:41:49.70,0:41:51.90,Default2,,0,0,0,,忍不住
Dialogue: 0,0:41:55.91,0:41:58.24,Default2,,0,0,0,,為啥不看我?
Dialogue: 0,0:42:01.71,0:42:04.65,Default2,,0,0,0,,想要吧
Dialogue: 0,0:42:04.92,0:42:07.85,Default2,,0,0,0,,不是的
Dialogue: 0,0:42:07.85,0:42:09.86,Default2,,0,0,0,,那是怎樣?
Dialogue: 0,0:42:43.96,0:42:46.89,Default2,,0,0,0,,住手
Dialogue: 0,0:42:47.09,0:42:51.16,Default2,,0,0,0,,很期待吧
Dialogue: 0,0:42:51.16,0:42:53.17,Default2,,0,0,0,,對吧
Dialogue: 0,0:42:53.17,0:42:56.30,Default2,,0,0,0,,才沒有
Dialogue: 0,0:42:57.90,0:43:00.77,Default2,,0,0,0,,對吧
Dialogue: 0,0:43:13.39,0:43:16.46,Default2,,0,0,0,,你很想要吧
Dialogue: 0,0:43:52.42,0:43:56.23,Default2,,0,0,0,,很爽吧
Dialogue: 0,0:43:56.23,0:43:58.23,Default2,,0,0,0,,住壬
Dialogue: 0,0:44:07.64,0:44:12.18,Default2,,0,0,0,,聽話
Dialogue: 0,0:44:26.46,0:44:29.93,Default2,,0,0,0,,來吧
Dialogue: 0,0:44:30.26,0:44:34.80,Default2,,0,0,0,,住手
Dialogue: 0,0:44:50.82,0:44:53.22,Default2,,0,0,0,,害羞嗎?
Dialogue: 0,0:44:53.22,0:44:55.22,Default2,,0,0,0,,不可以
Dialogue: 0,0:44:55.49,0:44:57.89,Default2,,0,0,0,,天還亮著呢
Dialogue: 0,0:45:01.69,0:45:04.70,Default2,,0,0,0,,想要吧
Dialogue: 0,0:45:20.05,0:45:24.32,Default2,,0,0,0,,知道不可以
Dialogue: 0,0:45:27.12,0:45:29.19,Default2,,0,0,0,,不可以
Dialogue: 0,0:45:29.39,0:45:32.86,Default2,,0,0,0,,卻濕了
Dialogue: 0,0:45:35.26,0:45:40.73,Default2,,0,0,0,,不可以
Dialogue: 0,0:45:41.33,0:45:44.14,Default2,,0,0,0,,不可以
Dialogue: 0,0:45:44.54,0:45:47.27,Default2,,0,0,0,,啥不可以?
Dialogue: 0,0:45:57.95,0:46:00.75,Default2,,0,0,0,,不可以
Dialogue: 0,0:46:00.75,0:46:02.76,Default2,,0,0,0,,很爽吧
Dialogue: 0,0:46:02.96,0:46:05.89,Default2,,0,0,0,,不可以
Dialogue: 0,0:46:11.16,0:46:15.57,Default2,,0,0,0,,很有感覺吧
Dialogue: 0,0:46:46.13,0:46:49.94,Default2,,0,0,0,,你看
Dialogue: 0,0:47:34.51,0:47:37.32,Default2,,0,0,0,,不可以
Dialogue: 0,0:47:37.58,0:47:40.19,Default2,,0,0,0,,很髒的
Dialogue: 0,0:47:40.59,0:47:45.12,Default2,,0,0,0,,不會髒啊
Dialogue: 0,0:47:48.46,0:47:52.06,Default2,,0,0,0,,不會髒的
Dialogue: 0,0:47:57.47,0:48:01.21,Default2,,0,0,0,,我來證明吧
Dialogue: 0,0:48:02.47,0:48:06.95,Default2,,0,0,0,,不可以
Dialogue: 0,0:48:14.42,0:48:17.62,Default2,,0,0,0,,不髒的
Dialogue: 0,0:48:17.62,0:48:19.63,Default2,,0,0,0,,很爽吧
Dialogue: 0,0:48:19.76,0:48:23.56,Default2,,0,0,0,,不可以
