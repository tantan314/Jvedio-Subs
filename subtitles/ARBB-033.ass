Dialogue: 0,0:01:44.17,0:01:51.71,Default,,0,0,0,,新宿等神離家出走女高中生  朱里  03
Dialogue: 0,0:01:53.54,0:02:00.82,Default,,0,0,0,,﻿和等神的女高中生的奇妙生活…
Dialogue: 0,0:02:12.01,0:02:14.78,Default,,0,0,0,,﻿打擾了
Dialogue: 0,0:02:15.48,0:02:18.22,Default,,0,0,0,,可以進去哦\N﻿打擾了
Dialogue: 0,0:02:28.55,0:02:30.60,Default,,0,0,0,,﻿打擾了
Dialogue: 0,0:02:31.16,0:02:34.03,Default,,0,0,0,,﻿進去裡面\N是
Dialogue: 0,0:02:40.76,0:02:43.49,Default,,0,0,0,,﻿抱歉啊  很髒亂的
Dialogue: 0,0:02:48.46,0:02:51.47,Default,,0,0,0,,﻿坐啊
Dialogue: 0,0:02:56.74,0:02:59.47,Default,,0,0,0,,﻿坐啊
Dialogue: 0,0:03:05.75,0:03:07.61,Default,,0,0,0,,﻿好可愛
Dialogue: 0,0:03:09.75,0:03:11.40,Default,,0,0,0,,﻿真可愛啊
Dialogue: 0,0:03:12.60,0:03:15.61,Default,,0,0,0,,﻿為什麼離家出走啊?
Dialogue: 0,0:03:22.99,0:03:24.64,Default,,0,0,0,,﻿不能說啊?
Dialogue: 0,0:03:26.64,0:03:29.54,Default,,0,0,0,,﻿我想妳爸媽很擔心哦
Dialogue: 0,0:03:35.61,0:03:38.34,Default,,0,0,0,,﻿爸媽對不起的
Dialogue: 0,0:03:39.48,0:03:40.63,Default,,0,0,0,,﻿說啊
Dialogue: 0,0:03:46.75,0:03:49.77,Default,,0,0,0,,﻿爸媽對不起
Dialogue: 0,0:03:51.85,0:03:54.46,Default,,0,0,0,,﻿好乖啊
Dialogue: 0,0:03:58.47,0:04:02.03,Default,,0,0,0,,﻿譲你住家裡相對的做什麼都可以吧?
Dialogue: 0,0:04:04.71,0:04:07.91,Default,,0,0,0,,﻿那再譲我看看可愛的臉
Dialogue: 0,0:04:10.73,0:04:12.01,Default,,0,0,0,,﻿笑一個
Dialogue: 0,0:04:17.40,0:04:18.63,Default,,0,0,0,,﻿讓我看牙齒
Dialogue: 0,0:04:23.42,0:04:24.76,Default,,0,0,0,,﻿真可愛
Dialogue: 0,0:04:28.09,0:04:30.63,Default,,0,0,0,,﻿可以多看點別的地方嗎?
Dialogue: 0,0:04:32.23,0:04:33.98,Default,,0,0,0,,﻿那  站起來
Dialogue: 0,0:04:52.49,0:04:54.79,Default,,0,0,0,,﻿裙子好短啊
Dialogue: 0,0:04:56.76,0:04:58.49,Default,,0,0,0,,﻿會看到吧?
Dialogue: 0,0:05:00.51,0:05:02.99,Default,,0,0,0,,﻿讓我看一下啊
Dialogue: 0,0:05:07.99,0:05:09.32,Default,,0,0,0,,﻿再來
Dialogue: 0,0:05:17.88,0:05:20.48,Default,,0,0,0,,﻿這是你喜歡的內褲?
Dialogue: 0,0:05:22.75,0:05:24.47,Default,,0,0,0,,﻿真可愛
Dialogue: 0,0:05:25.49,0:05:29.48,Default,,0,0,0,,﻿那內褲…穿幾天了?
Dialogue: 0,0:05:31.49,0:05:34.14,Default,,0,0,0,,3天\N3天?
Dialogue: 0,0:05:35.46,0:05:38.41,Default,,0,0,0,,﻿一直穿著?
Dialogue: 0,0:05:41.69,0:05:43.87,Default,,0,0,0,,﻿轉到後面
Dialogue: 0,0:05:53.37,0:05:54.92,Default,,0,0,0,,sexy
Dialogue: 0,0:05:56.48,0:05:57.95,Default,,0,0,0,,﻿緊張嗎?
Dialogue: 0,0:06:10.10,0:06:12.44,Default,,0,0,0,,﻿後面是這樣的啊
Dialogue: 0,0:06:13.63,0:06:15.27,Default,,0,0,0,,﻿自己拿著
Dialogue: 0,0:06:21.48,0:06:23.25,Default,,0,0,0,,﻿翹起來
Dialogue: 0,0:06:34.42,0:06:35.96,Default,,0,0,0,,﻿扭一扭
Dialogue: 0,0:06:56.58,0:06:58.22,Default,,0,0,0,,﻿好滑
Dialogue: 0,0:07:11.48,0:07:13.70,Default,,0,0,0,,﻿有淫蕩的味道
Dialogue: 0,0:07:18.47,0:07:20.65,Default,,0,0,0,,﻿為什麼一抖一抖的?
Dialogue: 0,0:07:26.00,0:07:28.88,Default,,0,0,0,,也﻿給我看胸部
Dialogue: 0,0:07:44.82,0:07:46.81,Default,,0,0,0,,﻿給我看胸部
Dialogue: 0,0:08:00.09,0:08:02.49,Default,,0,0,0,,﻿邊說請看我胸部的
Dialogue: 0,0:08:07.91,0:08:10.65,Default,,0,0,0,,﻿請看我胸部
Dialogue: 0,0:08:15.49,0:08:19.34,Default,,0,0,0,,﻿什麼罩杯?\NB罩杯
Dialogue: 0,0:08:27.38,0:08:29.27,Default,,0,0,0,,﻿可以摸嗎?
Dialogue: 0,0:08:31.03,0:08:32.61,Default,,0,0,0,,﻿求我
Dialogue: 0,0:08:33.96,0:08:35.69,Default,,0,0,0,,﻿請摸
Dialogue: 0,0:09:04.39,0:09:06.35,Default,,0,0,0,,﻿好軟
Dialogue: 0,0:09:08.74,0:09:13.26,Default,,0,0,0,,﻿怎樣?  被摸胸部的\N好害羞
Dialogue: 0,0:09:31.47,0:09:33.17,Default,,0,0,0,,﻿這樣的呢?
Dialogue: 0,0:09:56.83,0:10:00.07,Default,,0,0,0,,﻿喜歡這樣的?\N喜歡
Dialogue: 0,0:10:22.45,0:10:24.80,Default,,0,0,0,,﻿也讓我看內濾
Dialogue: 0,0:10:44.44,0:10:46.12,Default,,0,0,0,,﻿害羞?
Dialogue: 0,0:10:56.14,0:10:58.04,Default,,0,0,0,,﻿給我看屁股
Dialogue: 0,0:11:26.20,0:11:28.12,Default,,0,0,0,,﻿屁股怎樣?  被摸著的
Dialogue: 0,0:11:33.21,0:11:35.34,Default,,0,0,0,,﻿好好掀起來
Dialogue: 0,0:12:03.63,0:12:05.09,Default,,0,0,0,,﻿你來舔啊
Dialogue: 0,0:12:10.46,0:12:12.41,Default,,0,0,0,,﻿什麼都會做吧?
Dialogue: 0,0:12:30.81,0:12:32.41,Default,,0,0,0,,﻿聞味道
Dialogue: 0,0:12:38.72,0:12:40.08,Default,,0,0,0,,﻿有什麼味道?
Dialogue: 0,0:12:46.07,0:12:48.12,Default,,0,0,0,,﻿有奇怪的味道
Dialogue: 0,0:12:53.47,0:12:54.63,Default,,0,0,0,,﻿舔啊
Dialogue: 0,0:13:03.05,0:13:04.68,Default,,0,0,0,,﻿手借我
Dialogue: 0,0:13:08.71,0:13:10.85,Default,,0,0,0,,﻿含著…
Dialogue: 0,0:13:27.64,0:13:29.92,Default,,0,0,0,,﻿再多含點
Dialogue: 0,0:13:36.44,0:13:38.56,Default,,0,0,0,,﻿再多含點
Dialogue: 0,0:14:04.97,0:14:06.95,Default,,0,0,0,,﻿伸出舌頭
Dialogue: 0,0:14:10.86,0:14:13.09,Default,,0,0,0,,﻿邊看這邊
Dialogue: 0,0:14:45.99,0:14:49.66,Default,,0,0,0,,﻿屁股翹起來  只用嘴做
Dialogue: 0,0:14:54.46,0:14:56.33,Default,,0,0,0,,﻿這樣?\N對
Dialogue: 0,0:15:43.67,0:15:46.56,Default,,0,0,0,,﻿這樣子  含深點
Dialogue: 0,0:16:06.71,0:16:08.88,Default,,0,0,0,,﻿不要躲開
Dialogue: 0,0:17:23.83,0:17:25.12,Default,,0,0,0,,﻿舔啊
Dialogue: 0,0:17:27.71,0:17:29.70,Default,,0,0,0,,﻿什麼都會做吧?
Dialogue: 0,0:17:47.17,0:17:48.61,Default,,0,0,0,,﻿再來
Dialogue: 0,0:17:57.03,0:17:59.44,Default,,0,0,0,,﻿不是那樣啊
Dialogue: 0,0:18:00.33,0:18:03.72,Default,,0,0,0,,﻿吸啊  吸到深處
Dialogue: 0,0:18:14.46,0:18:18.19,Default,,0,0,0,,﻿已經不行了\N全部
Dialogue: 0,0:18:19.31,0:18:21.24,Default,,0,0,0,,﻿不然你回去
Dialogue: 0,0:18:25.23,0:18:26.73,Default,,0,0,0,,﻿全部
Dialogue: 0,0:18:35.85,0:18:38.43,Default,,0,0,0,,﻿也自己摸胸部
Dialogue: 0,0:19:07.44,0:19:10.44,Default,,0,0,0,,﻿也摸小穴
Dialogue: 0,0:20:24.73,0:20:27.00,Default,,0,0,0,,﻿直爽
Dialogue: 0,0:20:32.21,0:20:34.79,Default,,0,0,0,,﻿再來舔這邊的
Dialogue: 0,0:20:59.48,0:21:01.03,Default,,0,0,0,,﻿再來
Dialogue: 0,0:21:25.45,0:21:27.64,Default,,0,0,0,,﻿也來舔屁股
Dialogue: 0,0:21:35.18,0:21:36.17,Default,,0,0,0,,﻿快點
Dialogue: 0,0:22:04.58,0:22:08.46,Default,,0,0,0,,﻿可以了嗎?\N不行
Dialogue: 0,0:22:09.75,0:22:10.75,Default,,0,0,0,,﻿再來
Dialogue: 0,0:22:27.18,0:22:29.84,Default,,0,0,0,,﻿邊套弄肉棒
Dialogue: 0,0:22:31.01,0:22:34.45,Default,,0,0,0,,﻿給我爽
Dialogue: 0,0:22:38.45,0:22:42.26,Default,,0,0,0,,﻿這様?\N對
Dialogue: 0,0:23:01.44,0:23:04.42,Default,,0,0,0,,﻿可以了嗎?\N再來
Dialogue: 0,0:23:57.81,0:24:00.87,Default,,0,0,0,,﻿過來這邊
Dialogue: 0,0:24:06.28,0:24:07.81,Default,,0,0,0,,﻿衣服脫掉
Dialogue: 0,0:24:15.04,0:24:16.83,Default,,0,0,0,,﻿自己脫
Dialogue: 0,0:24:27.11,0:24:28.76,Default,,0,0,0,,﻿邊看這邊
Dialogue: 0,0:25:37.43,0:25:40.04,Default,,0,0,0,,﻿我叫你脫掉啊
Dialogue: 0,0:25:41.90,0:25:43.46,Default,,0,0,0,,﻿這個也要
Dialogue: 0,0:26:05.92,0:26:07.43,Default,,0,0,0,,﻿譲我看
Dialogue: 0,0:26:40.23,0:26:42.98,Default,,0,0,0,,﻿為什麼變硬了?
Dialogue: 0,0:26:45.77,0:26:47.35,Default,,0,0,0,,﻿為什麼?
Dialogue: 0,0:27:26.28,0:27:28.22,Default,,0,0,0,,﻿興奮嗎?
Dialogue: 0,0:27:41.56,0:27:43.24,Default,,0,0,0,,﻿興奮嗎?
Dialogue: 0,0:27:46.95,0:27:51.14,Default,,0,0,0,,﻿用這張嘴啊  再來給我多爽點啊
Dialogue: 0,0:27:54.45,0:27:56.04,Default,,0,0,0,,﻿舔肉棒
Dialogue: 0,0:29:29.07,0:29:32.10,Default,,0,0,0,,﻿裙子也脫掉
Dialogue: 0,0:29:53.91,0:29:57.89,Default,,0,0,0,,﻿用胸部給我爽一下
Dialogue: 0,0:30:02.67,0:30:05.99,Default,,0,0,0,,﻿這樣子\N要怎做?
Dialogue: 0,0:30:07.99,0:30:11.42,Default,,0,0,0,,﻿夾著\N夾不了啊
Dialogue: 0,0:30:12.41,0:30:13.72,Default,,0,0,0,,﻿做啊
Dialogue: 0,0:30:23.00,0:30:25.31,Default,,0,0,0,,﻿這樣?\N對
Dialogue: 0,0:30:31.40,0:30:34.46,Default,,0,0,0,,﻿這樣?\N對
Dialogue: 0,0:30:41.27,0:30:42.57,Default,,0,0,0,,﻿夾不了
Dialogue: 0,0:31:48.77,0:31:50.76,Default,,0,0,0,,﻿吐些口水
Dialogue: 0,0:32:17.21,0:32:20.15,Default,,0,0,0,,﻿夠了  真爛
Dialogue: 0,0:32:21.44,0:32:23.69,Default,,0,0,0,,﻿完全一點也不爽
Dialogue: 0,0:32:24.17,0:32:26.10,Default,,0,0,0,,﻿對不起
Dialogue: 0,0:32:27.70,0:32:30.90,Default,,0,0,0,,﻿給我看小穴啊
Dialogue: 0,0:32:37.54,0:32:39.41,Default,,0,0,0,,﻿內褲也脫掉啊
Dialogue: 0,0:33:18.55,0:33:20.12,Default,,0,0,0,,﻿光溜溜啊
Dialogue: 0,0:33:43.20,0:33:45.80,Default,,0,0,0,,﻿這裡要插入肉棒哦
Dialogue: 0,0:33:47.87,0:33:50.02,Default,,0,0,0,,﻿插的進去嗎?
Dialogue: 0,0:33:53.48,0:33:55.19,Default,,0,0,0,,﻿小菊花也是
Dialogue: 0,0:34:01.44,0:34:03.67,Default,,0,0,0,,﻿扳的很開哦
Dialogue: 0,0:34:37.44,0:34:40.10,Default,,0,0,0,,﻿這個洞裡可以插入肉棒嗎?
Dialogue: 0,0:34:45.48,0:34:50.05,Default,,0,0,0,,﻿因為完全都不爽啊  口交也是乳交也是
Dialogue: 0,0:34:52.15,0:34:54.92,Default,,0,0,0,,﻿用小穴譲我爽啊
Dialogue: 0,0:34:58.79,0:35:00.13,Default,,0,0,0,,﻿可以吧?
Dialogue: 0,0:35:51.75,0:35:53.25,Default,,0,0,0,,﻿不行
Dialogue: 0,0:35:59.83,0:36:01.24,Default,,0,0,0,,﻿不行
Dialogue: 0,0:36:04.65,0:36:06.11,Default,,0,0,0,,﻿不行
Dialogue: 0,0:37:07.69,0:37:09.64,Default,,0,0,0,,…爽嗎?
Dialogue: 0,0:37:11.64,0:37:13.78,Default,,0,0,0,,﻿好爽
Dialogue: 0,0:38:25.43,0:38:28.39,Default,,0,0,0,,﻿爽嗎?\N好爽
Dialogue: 0,0:38:29.70,0:38:32.40,Default,,0,0,0,,﻿想要我再多插點?\N再來
Dialogue: 0,0:39:28.20,0:39:29.00,Default,,0,0,0,,﻿不行
Dialogue: 0,0:39:35.62,0:39:37.03,Default,,0,0,0,,﻿不行
Dialogue: 0,0:39:40.76,0:39:42.44,Default,,0,0,0,,﻿不行
Dialogue: 0,0:39:57.46,0:39:59.22,Default,,0,0,0,,﻿不行
Dialogue: 0,0:40:21.45,0:40:23.39,Default,,0,0,0,,﻿過來
Dialogue: 0,0:40:42.81,0:40:44.57,Default,,0,0,0,,﻿看這邊
Dialogue: 0,0:40:45.44,0:40:48.23,Default,,0,0,0,,﻿說請把肉棒插進來
Dialogue: 0,0:40:53.60,0:40:55.90,Default,,0,0,0,,﻿不說的話就不插
Dialogue: 0,0:40:59.45,0:41:03.82,Default,,0,0,0,,﻿請把肉棒  插進來
Dialogue: 0,0:41:06.46,0:41:07.32,Default,,0,0,0,,﻿好哦
Dialogue: 0,0:43:22.72,0:43:24.39,Default,,0,0,0,,﻿不行
Dialogue: 0,0:43:47.88,0:43:50.78,Default,,0,0,0,,﻿慢慢動
Dialogue: 0,0:46:55.59,0:46:57.74,Default,,0,0,0,,﻿膝蓋抬起來
Dialogue: 0,0:48:16.78,0:48:18.00,Default,,0,0,0,,﻿不行
Dialogue: 0,0:49:51.55,0:49:52.37,Default,,0,0,0,,﻿不行
Dialogue: 0,0:51:38.61,0:51:40.88,Default,,0,0,0,,﻿轉過去
Dialogue: 0,0:51:56.00,0:51:59.99,Default,,0,0,0,,﻿說請插進來的  求我啊
Dialogue: 0,0:52:01.17,0:52:04.48,Default,,0,0,0,,﻿請插進來
Dialogue: 0,0:52:49.78,0:52:52.41,Default,,0,0,0,,﻿被打會爽嗎?
Dialogue: 0,0:52:55.95,0:53:00.81,Default,,0,0,0,,﻿爽嗎?\N好爽
Dialogue: 0,0:53:00.85,0:53:02.15,Default,,0,0,0,,﻿再來
Dialogue: 0,0:54:39.88,0:54:42.36,Default,,0,0,0,,﻿到這邊來
Dialogue: 0,0:54:53.83,0:54:56.12,Default,,0,0,0,,﻿說請插進來
Dialogue: 0,0:54:56.50,0:55:02.69,Default,,0,0,0,,﻿求我啊  請插進來
Dialogue: 0,0:55:05.77,0:55:08.73,Default,,0,0,0,,﻿再說\N請插進來
Dialogue: 0,0:55:15.00,0:55:17.16,Default,,0,0,0,,﻿扳開屁股
Dialogue: 0,0:55:20.43,0:55:23.17,Default,,0,0,0,,﻿害羞?
Dialogue: 0,0:55:23.89,0:55:27.17,Default,,0,0,0,,—開一合的啊
Dialogue: 0,0:55:39.36,0:55:41.69,Default,,0,0,0,,﻿小穴也扳開來
Dialogue: 0,0:55:46.42,0:55:50.53,Default,,0,0,0,,﻿想要我插進去?\N請插進來
Dialogue: 0,0:56:39.80,0:56:43.57,Default,,0,0,0,,﻿爽嗎?\N好爽
Dialogue: 0,0:57:03.64,0:57:08.20,Default,,0,0,0,,﻿說請再多打點的\N請再多打點
Dialogue: 0,0:57:08.23,0:57:10.17,Default,,0,0,0,,﻿再來…
Dialogue: 0,0:57:28.36,0:57:31.16,Default,,0,0,0,,﻿不行
Dialogue: 0,0:58:01.03,0:58:04.23,Default,,0,0,0,,﻿不行  要去了
Dialogue: 0,0:59:33.15,0:59:36.15,Default,,0,0,0,,﻿不行
Dialogue: 0,0:59:40.43,0:59:43.16,Default,,0,0,0,,﻿快射了
Dialogue: 0,0:59:47.17,0:59:50.34,Default,,0,0,0,,﻿要射了\N不行
Dialogue: 0,1:00:25.46,1:00:28.17,Default,,0,0,0,,﻿射了很多
Dialogue: 0,1:00:34.03,1:00:38.15,Default,,0,0,0,,﻿聽好了  今天起就住在我家裡
Dialogue: 0,1:00:42.42,1:00:45.16,Default,,0,0,0,,…來弄乾淨啊
Dialogue: 0,1:01:10.28,1:01:12.05,Default,,0,0,0,,﻿怎麼了?
Dialogue: 0,1:01:14.35,1:01:18.45,Default,,0,0,0,,﻿肚子餓了\N肚子餓了?
Dialogue: 0,1:01:21.43,1:01:24.04,Default,,0,0,0,,﻿那要吃東西嗎?
Dialogue: 0,1:01:34.44,1:01:37.33,Default,,0,0,0,,﻿幾天沒吃東西了?\N3天
Dialogue: 0,1:01:37.83,1:01:38.81,Default,,0,0,0,,3天?
Dialogue: 0,1:01:41.15,1:01:43.46,Default,,0,0,0,,﻿想吃什麼?
Dialogue: 0,1:01:46.15,1:01:50.06,Default,,0,0,0,,﻿壽司\N壽司?  好哦
Dialogue: 0,1:01:50.46,1:01:55.45,Default,,0,0,0,,﻿哪一種的?\N最好的
Dialogue: 0,1:01:55.59,1:01:59.80,Default,,0,0,0,,欸?  最好的?
Dialogue: 0,1:02:01.17,1:02:03.80,Default,,0,0,0,,﻿像是特級的?
Dialogue: 0,1:02:04.60,1:02:07.38,Default,,0,0,0,,﻿那  有菜單啊
Dialogue: 0,1:02:10.71,1:02:15.26,Default,,0,0,0,,﻿好了\N最貴的?
