Dialogue: 0,0:00:40.01,0:00:43.01,Default,,0,0,0,,(客人聊天)
Dialogue: 0,0:02:57.01,0:03:00.01,Default,,0,0,0,,(客人聊天)
Dialogue: 0,0:03:05.02,0:03:08.02,Default,,0,0,0,,不好意思
Dialogue: 0,0:03:15.03,0:03:18.03,Default,,0,0,0,,好可爱哦\N你好可爱
Dialogue: 0,0:03:20.03,0:03:23.00,Default,,0,0,0,,酒臭味\N请别在公共场合说色情的东西
Dialogue: 0,0:04:09.01,0:04:12.02,Default,,0,0,0,,可以借用厕所吗\N在最里面 谢谢
Dialogue: 0,0:04:39.01,0:04:42.01,Default,,0,0,0,,你看不起我们哦?
Dialogue: 0,0:04:48.02,0:04:51.02,Default,,0,0,0,,我们是很没品\N你也高尚不到哪里去
Dialogue: 0,0:05:00.03,0:05:03.00,Default,,0,0,0,,想被我们玩是吗
Dialogue: 0,0:05:09.01,0:05:12.01,Default,,0,0,0,,别叫哦
Dialogue: 0,0:05:19.02,0:05:22.02,Default,,0,0,0,,你好可爱哦
Dialogue: 0,0:05:30.03,0:05:33.03,Default,,0,0,0,,屁股也不错
Dialogue: 0,0:05:53.02,0:05:56.02,Default,,0,0,0,,请住手
Dialogue: 0,0:11:44.00,0:11:47.01,Default,,0,0,0,,不行
Dialogue: 0,0:13:00.01,0:13:03.02,Default,,0,0,0,,换我舔
Dialogue: 0,0:15:47.01,0:15:50.02,Default,,0,0,0,,好淫荡哦
Dialogue: 0,0:17:09.03,0:17:12.03,Default,,0,0,0,,去哪
Dialogue: 0,0:20:44.34,0:20:47.28,Default,,0,0,0,,店员来了
Dialogue: 0,0:20:58.02,0:21:01.03,Default,,0,0,0,,我要打扫厕所 是哦\N我哥在上大号 是吗 是的
Dialogue: 0,0:21:13.01,0:21:16.01,Default,,0,0,0,,他经常便秘 所以要久一点\N那我先清理手台
Dialogue: 0,0:21:43.00,0:21:46.01,Default,,0,0,0,,辛苦了
Dialogue: 0,0:22:38.02,0:22:41.03,Default,,0,0,0,,我也要上\N上好通知我 好
Dialogue: 0,0:22:55.01,0:22:58.01,Default,,0,0,0,,店员走了
Dialogue: 0,0:23:49.03,0:23:52.03,Default,,0,0,0,,张开嘴
Dialogue: 0,0:26:27.02,0:26:30.02,Default,,0,0,0,,不要\N别叫
Dialogue: 0,0:28:16.03,0:28:19.03,Default,,0,0,0,,要射了
Dialogue: 0,0:28:21.03,0:28:24.00,Default,,0,0,0,,嘴张开
Dialogue: 0,0:29:02.01,0:29:05.01,Default,,0,0,0,,还没结束\N过来
Dialogue: 0,0:29:29.00,0:29:32.00,Default,,0,0,0,,要干嘛啊
Dialogue: 0,0:29:33.01,0:29:36.01,Default,,0,0,0,,被发现你就完蛋了哦
Dialogue: 0,0:41:47.01,0:41:50.01,Default,,0,0,0,,要高潮了
Dialogue: 0,0:42:40.03,0:42:43.03,Default,,0,0,0,,要高潮了
Dialogue: 0,0:44:37.01,0:44:40.01,Default,,0,0,0,,不行了
Dialogue: 0,0:48:15.03,0:48:18.03,Default,,0,0,0,,要射了
Dialogue: 0,0:48:28.01,0:48:31.01,Default,,0,0,0,,要射了
Dialogue: 0,0:49:48.02,0:49:51.02,Default,,0,0,0,,麻烦你扫厕所了
Dialogue: 0,0:50:16.02,0:50:19.02,Default,,0,0,0,,(客人聊天)
Dialogue: 0,0:50:29.03,0:50:32.03,Default,,0,0,0,,我真火大\N还有一个月
Dialogue: 0,0:50:51.02,0:50:54.02,Default,,0,0,0,,我妈都不理我了
Dialogue: 0,0:51:05.03,0:51:08.03,Default,,0,0,0,,没有\N你都30了
Dialogue: 0,0:51:27.02,0:51:30.02,Default,,0,0,0,,不好意思
Dialogue: 0,0:51:41.03,0:51:44.00,Default,,0,0,0,,久等了
Dialogue: 0,0:51:45.00,0:51:48.01,Default,,0,0,0,,一样的 是什么
Dialogue: 0,0:51:53.01,0:51:56.02,Default,,0,0,0,,最便宜的烧酒吗\N好的
Dialogue: 0,0:52:06.03,0:52:09.03,Default,,0,0,0,,请别这样 这里不是风俗店
Dialogue: 0,0:52:16.04,0:52:19.00,Default,,0,0,0,,最便宜的烧酒是把\N真是的
Dialogue: 0,0:52:24.01,0:52:27.01,Default,,0,0,0,,客人要最便宜的烧酒
Dialogue: 0,0:52:28.01,0:52:31.02,Default,,0,0,0,,好
Dialogue: 0,0:52:37.02,0:52:40.03,Default,,0,0,0,,让人火大
Dialogue: 0,0:53:01.01,0:53:04.02,Default,,0,0,0,,喜欢喝酒吗\N喜欢
Dialogue: 0,0:53:26.01,0:53:29.01,Default,,0,0,0,,我要最贵的\N好的
Dialogue: 0,0:53:34.01,0:53:37.02,Default,,0,0,0,,你去
Dialogue: 0,0:53:49.03,0:53:52.03,Default,,0,0,0,,久等了\N要贵的吗
Dialogue: 0,0:54:02.01,0:54:05.01,Default,,0,0,0,,看不起我们哦
Dialogue: 0,0:54:12.02,0:54:15.02,Default,,0,0,0,,别出声哦 被发现你就完了
Dialogue: 0,0:54:29.03,0:54:32.00,Default,,0,0,0,,别出声哦
Dialogue: 0,0:54:34.97,0:54:38.01,Default,,0,0,0,,看不起我们
Dialogue: 0,1:00:15.01,1:00:18.02,Default,,0,0,0,,住手
Dialogue: 0,1:04:38.01,1:04:41.01,Default,,0,0,0,,张嘴
Dialogue: 0,1:06:49.01,1:06:52.01,Default,,0,0,0,,换我
Dialogue: 0,1:08:26.01,1:08:29.01,Default,,0,0,0,,要射了
Dialogue: 0,1:08:32.01,1:08:35.01,Default,,0,0,0,,要射了
Dialogue: 0,1:16:04.03,1:16:07.03,Default,,0,0,0,,要射了
Dialogue: 0,1:17:13.03,1:17:16.04,Default,,0,0,0,,干嘛\N你注册一星期了把
Dialogue: 0,1:17:24.01,1:17:27.01,Default,,0,0,0,,我很忙的\N可是还有人后补
Dialogue: 0,1:17:37.02,1:17:40.03,Default,,0,0,0,,那就换人\N不行
Dialogue: 0,1:17:46.03,1:17:49.03,Default,,0,0,0,,我们可是付钱了的人\N给我想办法啊
Dialogue: 0,1:18:05.02,1:18:08.02,Default,,0,0,0,,别出声哦 会吓到别人的
Dialogue: 0,1:18:18.03,1:18:21.03,Default,,0,0,0,,请住手
Dialogue: 0,1:18:21.03,1:18:24.04,Default,,0,0,0,,别出声
Dialogue: 0,1:18:32.01,1:18:35.01,Default,,0,0,0,,请住手
Dialogue: 0,1:25:04.04,1:25:07.01,Default,,0,0,0,,嘴张开
Dialogue: 0,1:32:46.03,1:32:49.03,Default,,0,0,0,,主任找你们\N好的
Dialogue: 0,1:33:04.02,1:33:07.02,Default,,0,0,0,,明天这个时间你再过来拿包包
Dialogue: 0,1:33:08.02,1:33:11.02,Default,,0,0,0,,现在就去
Dialogue: 0,1:33:34.01,1:33:37.02,Default,,0,0,0,,请把包包换我\N什么?
Dialogue: 0,1:33:45.02,1:33:48.03,Default,,0,0,0,,你说还就还哦
Dialogue: 0,1:33:57.04,1:34:00.01,Default,,0,0,0,,让你消失很简单\N少来了
Dialogue: 0,1:34:38.01,1:34:41.01,Default,,0,0,0,,请住手\N别出声
Dialogue: 0,1:36:19.01,1:36:22.01,Default,,0,0,0,,别出声
Dialogue: 0,1:36:23.02,1:36:26.02,Default,,0,0,0,,舒服把
Dialogue: 0,1:37:16.04,1:37:19.04,Default,,0,0,0,,换我
Dialogue: 0,1:50:37.04,1:50:40.01,Default,,0,0,0,,要高潮了
Dialogue: 0,1:54:20.03,1:54:23.03,Default,,0,0,0,,别出声
Dialogue: 0,1:54:24.03,1:54:27.03,Default,,0,0,0,,别出声
Dialogue: 0,1:54:27.03,1:54:30.04,Default,,0,0,0,,要射了
Dialogue: 0,1:54:47.02,1:54:50.02,Default,,0,0,0,,舔干净
Dialogue: 0,1:55:29.03,1:55:32.03,Default,,0,0,0,,吹啊
Dialogue: 0,1:56:01.03,1:56:04.03,Default,,0,0,0,,射脸上
Dialogue: 0,1:56:23.02,1:56:26.02,Default,,0,0,0,,全部含进去
Dialogue: 0,1:56:52.01,1:56:55.01,Default,,0,0,0,,拿去把
