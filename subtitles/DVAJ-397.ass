Dialogue: 0,0:01:01.58,0:01:03.58,Default,,0,0,0,,
Dialogue: 0,0:01:03.58,0:01:04.80,Default,,0,0,0,,
Dialogue: 0,0:01:04.80,0:01:06.80,Default,,0,0,0,,哎呀   梓妹
Dialogue: 0,0:01:06.80,0:01:08.80,Default,,0,0,0,,怎麼突然來呢
Dialogue: 0,0:01:09.38,0:01:11.82,Default,,0,0,0,,連續放假六天
Dialogue: 0,0:01:13.02,0:01:13.06,Default,,0,0,0,,
Dialogue: 0,0:01:13.06,0:01:15.50,Default,,0,0,0,,所以就過來看看姐你
Dialogue: 0,0:01:15.50,0:01:17.50,Default,,0,0,0,,
Dialogue: 0,0:01:17.50,0:01:19.48,Default,,0,0,0,,這麼突然
Dialogue: 0,0:01:19.48,0:01:21.88,Default,,0,0,0,,也不先打個電話過來
Dialogue: 0,0:01:21.88,0:01:23.88,Default,,0,0,0,,得讓我打掃房間
Dialogue: 0,0:01:23.88,0:01:26.50,Default,,0,0,0,,臨時的
Dialogue: 0,0:01:26.50,0:01:28.50,Default,,0,0,0,,
Dialogue: 0,0:01:28.50,0:01:31.44,Default,,0,0,0,,想到了就過來
Dialogue: 0,0:01:31.44,0:01:33.92,Default,,0,0,0,,所以沒有說
Dialogue: 0,0:01:33.92,0:01:35.92,Default,,0,0,0,,真是的
Dialogue: 0,0:01:35.92,0:01:37.92,Default,,0,0,0,,
Dialogue: 0,0:01:37.92,0:01:39.92,Default,,0,0,0,,
Dialogue: 0,0:01:39.92,0:01:41.92,Default,,0,0,0,,
Dialogue: 0,0:01:41.92,0:01:43.92,Default,,0,0,0,,
Dialogue: 0,0:01:43.92,0:01:45.92,Default,,0,0,0,,
Dialogue: 0,0:01:45.92,0:01:48.94,Default,,0,0,0,,唉   我回來了
Dialogue: 0,0:01:48.94,0:01:50.94,Default,,0,0,0,,
Dialogue: 0,0:01:50.94,0:01:52.94,Default,,0,0,0,,咳
Dialogue: 0,0:01:52.94,0:01:54.94,Default,,0,0,0,,嗄
Dialogue: 0,0:01:54.94,0:01:56.94,Default,,0,0,0,,
Dialogue: 0,0:01:56.94,0:01:58.94,Default,,0,0,0,,
Dialogue: 0,0:01:58.94,0:02:00.94,Default,,0,0,0,,
Dialogue: 0,0:02:00.94,0:02:02.94,Default,,0,0,0,,
Dialogue: 0,0:02:02.94,0:02:04.94,Default,,0,0,0,,
Dialogue: 0,0:02:04.94,0:02:07.40,Default,,0,0,0,,送蔬菜到市場
Dialogue: 0,0:02:07.40,0:02:09.86,Default,,0,0,0,,搞到現在這麼晚
Dialogue: 0,0:02:09.86,0:02:11.86,Default,,0,0,0,,
Dialogue: 0,0:02:11.86,0:02:13.86,Default,,0,0,0,,姐夫啊
Dialogue: 0,0:02:13.86,0:02:15.86,Default,,0,0,0,,嗄
Dialogue: 0,0:02:15.86,0:02:17.96,Default,,0,0,0,,小姨子
Dialogue: 0,0:02:17.96,0:02:20.14,Default,,0,0,0,,梓   什麼時候來的
Dialogue: 0,0:02:20.14,0:02:22.38,Default,,0,0,0,,中午過來的
Dialogue: 0,0:02:22.38,0:02:24.78,Default,,0,0,0,,好久沒見了  姐夫
Dialogue: 0,0:02:24.78,0:02:26.78,Default,,0,0,0,,
Dialogue: 0,0:02:26.78,0:02:28.78,Default,,0,0,0,,是很久了
Dialogue: 0,0:02:28.78,0:02:30.78,Default,,0,0,0,,
Dialogue: 0,0:02:30.78,0:02:32.78,Default,,0,0,0,,沒想到四年不見都長大了
Dialogue: 0,0:02:32.78,0:02:35.72,Default,,0,0,0,,變成了波濤洶湧的
Dialogue: 0,0:02:35.72,0:02:39.02,Default,,0,0,0,,這麼性感的真女人
Dialogue: 0,0:02:39.02,0:02:41.94,Default,,0,0,0,,姐夫也變帥了
Dialogue: 0,0:02:41.94,0:02:43.94,Default,,0,0,0,,
Dialogue: 0,0:02:43.94,0:02:45.94,Default,,0,0,0,,四年了
Dialogue: 0,0:02:45.94,0:02:47.94,Default,,0,0,0,,姐夫還好吧
Dialogue: 0,0:02:47.94,0:02:49.94,Default,,0,0,0,,哦~還好
Dialogue: 0,0:02:49.94,0:02:51.94,Default,,0,0,0,,
Dialogue: 0,0:02:51.94,0:02:53.94,Default,,0,0,0,,
Dialogue: 0,0:02:53.94,0:02:55.94,Default,,0,0,0,,
Dialogue: 0,0:02:55.94,0:02:57.94,Default,,0,0,0,,
Dialogue: 0,0:02:57.94,0:02:59.94,Default,,0,0,0,,誰啊
Dialogue: 0,0:02:59.98,0:03:01.94,Default,,0,0,0,,哦 我啦
Dialogue: 0,0:03:01.94,0:03:03.94,Default,,0,0,0,,老婆美月
Dialogue: 0,0:03:03.94,0:03:05.94,Default,,0,0,0,,小妹過來啦
Dialogue: 0,0:03:05.94,0:03:09.76,Default,,0,0,0,,竟然一個電話都沒有先打過來
Dialogue: 0,0:03:09.76,0:03:11.76,Default,,0,0,0,,氣死
Dialogue: 0,0:03:11.76,0:03:14.92,Default,,0,0,0,,小姨子  啊梓
Dialogue: 0,0:03:14.92,0:03:16.92,Default,,0,0,0,,都變成真女人了
Dialogue: 0,0:03:16.92,0:03:20.08,Default,,0,0,0,,她讓我  對此感到驚訝
Dialogue: 0,0:03:20.08,0:03:22.08,Default,,0,0,0,,
Dialogue: 0,0:03:22.08,0:03:24.08,Default,,0,0,0,,
Dialogue: 0,0:03:24.08,0:03:26.08,Default,,0,0,0,,（和連日回老家的小姨子）
Dialogue: 0,0:03:26.08,0:03:28.08,Default,,0,0,0,,（不小心發生了肉體關係）
Dialogue: 0,0:03:28.08,0:03:30.08,Default,,0,0,0,,（明明妻子在極近距離）
Dialogue: 0,0:03:30.08,0:03:32.08,Default,,0,0,0,,（乃被在耳邊咬耳朵誘惑）
Dialogue: 0,0:03:32.08,0:03:34.04,Default,,0,0,0,,梓妹啊
Dialogue: 0,0:03:34.08,0:03:34.58,Default,,0,0,0,,嗯
Dialogue: 0,0:03:34.58,0:03:36.58,Default,,0,0,0,,妳在東京工作怎麼樣
Dialogue: 0,0:03:36.58,0:03:38.58,Default,,0,0,0,,做事認真嗎
Dialogue: 0,0:03:38.58,0:03:40.58,Default,,0,0,0,,當然有啦
Dialogue: 0,0:03:40.58,0:03:44.02,Default,,0,0,0,,你完全沒有聯絡  就連信息也不回
Dialogue: 0,0:03:44.02,0:03:46.02,Default,,0,0,0,,可是卻突然回來
Dialogue: 0,0:03:46.02,0:03:48.02,Default,,0,0,0,,我可是很忙
Dialogue: 0,0:03:48.02,0:03:50.02,Default,,0,0,0,,很多事情要做
Dialogue: 0,0:03:50.02,0:03:52.02,Default,,0,0,0,,
Dialogue: 0,0:03:52.02,0:03:54.02,Default,,0,0,0,,嘟嘟
Dialogue: 0,0:03:54.02,0:03:56.02,Default,,0,0,0,,
Dialogue: 0,0:03:56.02,0:03:58.02,Default,,0,0,0,,
Dialogue: 0,0:03:58.02,0:04:00.02,Default,,0,0,0,,嘟嘟
Dialogue: 0,0:04:00.02,0:04:02.02,Default,,0,0,0,,
Dialogue: 0,0:04:02.02,0:04:04.02,Default,,0,0,0,,
Dialogue: 0,0:04:04.02,0:04:06.02,Default,,0,0,0,,
Dialogue: 0,0:04:06.02,0:04:08.02,Default,,0,0,0,,梓妹啊
Dialogue: 0,0:04:08.82,0:04:11.44,Default,,0,0,0,,吃飯還一直看手機
Dialogue: 0,0:04:11.44,0:04:13.44,Default,,0,0,0,,還有啊
Dialogue: 0,0:04:13.44,0:04:15.96,Default,,0,0,0,,別穿成這樣子出門啊
Dialogue: 0,0:04:15.96,0:04:19.38,Default,,0,0,0,,還有在家也一樣遮一下
Dialogue: 0,0:04:20.84,0:04:22.42,Default,,0,0,0,,我又不是這樣子出門
Dialogue: 0,0:04:22.42,0:04:24.00,Default,,0,0,0,,
Dialogue: 0,0:04:24.00,0:04:26.00,Default,,0,0,0,,穿這樣子比較輕鬆
Dialogue: 0,0:04:26.00,0:04:27.42,Default,,0,0,0,,
Dialogue: 0,0:04:27.42,0:04:30.60,Default,,0,0,0,,你真的從以前一樣嘮叨
Dialogue: 0,0:04:30.60,0:04:32.60,Default,,0,0,0,,
Dialogue: 0,0:04:32.60,0:04:34.60,Default,,0,0,0,,還不是因為妳
Dialogue: 0,0:04:34.60,0:04:37.24,Default,,0,0,0,,以前就是個  怪咖呢
Dialogue: 0,0:04:38.04,0:04:40.26,Default,,0,0,0,,你就別管我了
Dialogue: 0,0:04:40.26,0:04:41.94,Default,,0,0,0,,
Dialogue: 0,0:04:41.94,0:04:43.94,Default,,0,0,0,,如果你是個大人
Dialogue: 0,0:04:43.94,0:04:45.94,Default,,0,0,0,,就不會這麼久  都不聯繫
Dialogue: 0,0:04:45.94,0:04:47.94,Default,,0,0,0,,知道了啊
Dialogue: 0,0:04:47.94,0:04:49.94,Default,,0,0,0,,
Dialogue: 0,0:04:49.94,0:04:51.94,Default,,0,0,0,,美月~
Dialogue: 0,0:04:52.14,0:04:53.84,Default,,0,0,0,,別唸這些啦
Dialogue: 0,0:04:53.84,0:04:55.84,Default,,0,0,0,,怎麼        梓 回來不容易
Dialogue: 0,0:04:55.84,0:04:57.84,Default,,0,0,0,,梓  難得回來一次
Dialogue: 0,0:04:57.84,0:04:59.84,Default,,0,0,0,,
Dialogue: 0,0:04:59.84,0:05:01.84,Default,,0,0,0,,
Dialogue: 0,0:05:01.84,0:05:03.84,Default,,0,0,0,,嗬~~
Dialogue: 0,0:05:03.84,0:05:05.84,Default,,0,0,0,,
Dialogue: 0,0:05:05.84,0:05:07.84,Default,,0,0,0,,
Dialogue: 0,0:05:07.84,0:05:09.84,Default,,0,0,0,,姐啊
Dialogue: 0,0:05:09.84,0:05:11.84,Default,,0,0,0,,你們為什麼不生小孩呢
Dialogue: 0,0:05:11.84,0:05:13.84,Default,,0,0,0,,堼
Dialogue: 0,0:05:13.84,0:05:15.84,Default,,0,0,0,,唉啊
Dialogue: 0,0:05:15.84,0:05:17.84,Default,,0,0,0,,
Dialogue: 0,0:05:17.84,0:05:20.36,Default,,0,0,0,,你  怎麼突然問  這些問題
Dialogue: 0,0:05:20.36,0:05:24.02,Default,,0,0,0,,咳  夫妻之間很多事情的
Dialogue: 0,0:05:24.02,0:05:26.02,Default,,0,0,0,,
Dialogue: 0,0:05:26.18,0:05:29.02,Default,,0,0,0,,嗯   這樣啊
Dialogue: 0,0:05:29.02,0:05:31.02,Default,,0,0,0,,
Dialogue: 0,0:05:31.02,0:05:33.50,Default,,0,0,0,,雖然 美月
Dialogue: 0,0:05:33.50,0:05:36.10,Default,,0,0,0,,看待 梓的時候
Dialogue: 0,0:05:36.10,0:05:38.46,Default,,0,0,0,,乃像以前一樣把她當小孩了
Dialogue: 0,0:05:38.46,0:05:40.46,Default,,0,0,0,,然而我
Dialogue: 0,0:05:40.46,0:05:43.52,Default,,0,0,0,,對於 梓的成熟
Dialogue: 0,0:05:43.52,0:05:45.52,Default,,0,0,0,,卻產生了困惑
Dialogue: 0,0:05:45.52,0:05:47.52,Default,,0,0,0,,
Dialogue: 0,0:05:47.52,0:05:49.52,Default,,0,0,0,,
Dialogue: 0,0:05:49.52,0:05:51.52,Default,,0,0,0,,
Dialogue: 0,0:05:51.52,0:05:53.52,Default,,0,0,0,,
Dialogue: 0,0:05:53.52,0:05:55.52,Default,,0,0,0,,
Dialogue: 0,0:05:56.42,0:05:58.12,Default,,0,0,0,,一想到 梓  就睡在隔壁
Dialogue: 0,0:05:58.12,0:06:01.12,Default,,0,0,0,,我就會過於意識到她
Dialogue: 0,0:06:02.92,0:06:04.22,Default,,0,0,0,,因而無法入睡
Dialogue: 0,0:06:05.28,0:06:07.92,Default,,0,0,0,,腦海里就是梓的影子
Dialogue: 0,0:06:07.92,0:06:09.92,Default,,0,0,0,,
Dialogue: 0,0:06:09.92,0:06:11.92,Default,,0,0,0,,
Dialogue: 0,0:06:11.92,0:06:13.92,Default,,0,0,0,,
Dialogue: 0,0:06:13.92,0:06:15.92,Default,,0,0,0,,
Dialogue: 0,0:06:15.92,0:06:17.92,Default,,0,0,0,,咳  老公
Dialogue: 0,0:06:17.92,0:06:21.76,Default,,0,0,0,,已經是起床的時間啦
Dialogue: 0,0:06:21.76,0:06:23.76,Default,,0,0,0,,老公   起來啦
Dialogue: 0,0:06:23.76,0:06:25.76,Default,,0,0,0,,你還在睡懶覺
Dialogue: 0,0:06:25.76,0:06:27.76,Default,,0,0,0,,起來啦 起來吃早餐
Dialogue: 0,0:06:27.76,0:06:29.36,Default,,0,0,0,,
Dialogue: 0,0:06:29.36,0:06:31.36,Default,,0,0,0,,啊梓
Dialogue: 0,0:06:31.36,0:06:33.36,Default,,0,0,0,,
Dialogue: 0,0:06:33.36,0:06:35.36,Default,,0,0,0,,
Dialogue: 0,0:06:35.36,0:06:37.36,Default,,0,0,0,,
Dialogue: 0,0:06:37.36,0:06:39.58,Default,,0,0,0,,睡成這樣子
Dialogue: 0,0:06:39.58,0:06:41.58,Default,,0,0,0,,
Dialogue: 0,0:06:41.58,0:06:43.58,Default,,0,0,0,,
Dialogue: 0,0:06:43.58,0:06:45.58,Default,,0,0,0,,梓~   該起床啦
Dialogue: 0,0:06:45.58,0:06:47.58,Default,,0,0,0,,起來吃早餐
Dialogue: 0,0:06:47.58,0:06:49.58,Default,,0,0,0,,不要睡 起來
Dialogue: 0,0:06:49.58,0:06:51.58,Default,,0,0,0,,不要睡啦 起來吃早餐
Dialogue: 0,0:06:51.58,0:06:53.58,Default,,0,0,0,,
Dialogue: 0,0:06:53.58,0:06:55.58,Default,,0,0,0,,哦  知道啦
Dialogue: 0,0:06:55.58,0:06:57.58,Default,,0,0,0,, 就算是放假
Dialogue: 0,0:06:58.18,0:07:01.48,Default,,0,0,0,,在家也別這樣懶散哦
Dialogue: 0,0:07:01.48,0:07:03.48,Default,,0,0,0,,嗄~
Dialogue: 0,0:07:03.48,0:07:06.12,Default,,0,0,0,,真是的
Dialogue: 0,0:07:06.12,0:07:08.12,Default,,0,0,0,,你們快起來啊
Dialogue: 0,0:07:08.12,0:07:10.12,Default,,0,0,0,,老公你也快換衣服啦
Dialogue: 0,0:07:10.12,0:07:12.12,Default,,0,0,0,,好
Dialogue: 0,0:07:12.12,0:07:14.12,Default,,0,0,0,,
