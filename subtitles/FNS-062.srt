01:23:56,909 --> 01:23:58,310
6

549
01:24:00,949 --> 01:24:02,210
5

550
01:24:06,460 --> 01:24:07,159
8

551
01:24:09,220 --> 01:24:10,619
7

552
01:24:12,560 --> 01:24:13,380
6

553
01:24:15,380 --> 01:24:16,079
5

554
01:24:18,359 --> 01:24:19,760
4

555
01:24:31,380 --> 01:24:32,779
3

556
01:24:32,779 --> 01:24:34,500
5

557
01:24:36,279 --> 01:24:37,680
6

558
01:24:37,680 --> 01:24:37,979
7

559
01:24:39,739 --> 01:24:41,140
8

