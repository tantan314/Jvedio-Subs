Dialogue: 0,0:00:26.09,0:00:30.22,ASS,,0,0,0,,（高濑智香 AV出道）
Dialogue: 0,0:00:33.23,0:00:41.64,ASS,,0,0,0,,（前地方电视台 女主播）\N（高濑智香 AV出道）
Dialogue: 0,0:00:46.51,0:00:48.57,ASS,,0,0,0,,早安\N早
Dialogue: 0,0:00:49.64,0:00:50.98,ASS,,0,0,0,,请坐
Dialogue: 0,0:00:51.45,0:00:52.31,ASS,,0,0,0,,好
Dialogue: 0,0:00:57.65,0:00:59.71,ASS,,0,0,0,,谢谢您今天光临
Dialogue: 0,0:01:00.25,0:01:01.38,ASS,,0,0,0,,谢谢
Dialogue: 0,0:01:01.59,0:01:02.92,ASS,,0,0,0,,请多指教
Dialogue: 0,0:01:03.12,0:01:04.25,ASS,,0,0,0,,多指教
Dialogue: 0,0:01:04.46,0:01:05.86,ASS,,0,0,0,,很高雅喔
Dialogue: 0,0:01:07.20,0:01:08.18,ASS,,0,0,0,,是喔
Dialogue: 0,0:01:08.33,0:01:09.46,ASS,,0,0,0,,常被这样说吗
Dialogue: 0,0:01:10.06,0:01:11.86,ASS,,0,0,0,,我很开心 谢谢
Dialogue: 0,0:01:13.40,0:01:15.53,ASS,,0,0,0,,我的真心话
Dialogue: 0,0:01:18.07,0:01:21.41,ASS,,0,0,0,,昨晚睡得好吗
Dialogue: 0,0:01:22.34,0:01:25.47,ASS,,0,0,0,,睡不着
Dialogue: 0,0:01:26.68,0:01:28.01,ASS,,0,0,0,,为什么啊
Dialogue: 0,0:01:28.55,0:01:32.28,ASS,,0,0,0,,很紧张
Dialogue: 0,0:01:33.82,0:01:36.09,ASS,,0,0,0,,就醒了\N是吧
Dialogue: 0,0:01:36.96,0:01:38.43,ASS,,0,0,0,,身体还好吗
Dialogue: 0,0:01:38.63,0:01:41.42,ASS,,0,0,0,,身体没事
Dialogue: 0,0:01:43.63,0:01:47.36,ASS,,0,0,0,,那就首先
Dialogue: 0,0:01:48.37,0:01:53.97,ASS,,0,0,0,,先请教一些问题 可以吗
Dialogue: 0,0:01:54.38,0:01:55.31,ASS,,0,0,0,,好
Dialogue: 0,0:01:56.11,0:01:59.57,ASS,,0,0,0,,现在几岁
Dialogue: 0,0:02:00.98,0:02:02.85,ASS,,0,0,0,,43岁
Dialogue: 0,0:02:03.25,0:02:04.91,ASS,,0,0,0,,43啊\N是
Dialogue: 0,0:02:06.25,0:02:09.05,ASS,,0,0,0,,看起来比较年轻耶
Dialogue: 0,0:02:09.86,0:02:11.72,ASS,,0,0,0,,是喔
Dialogue: 0,0:02:11.93,0:02:14.66,ASS,,0,0,0,,常被说比较年轻
Dialogue: 0,0:02:16.66,0:02:18.13,ASS,,0,0,0,,很高雅
Dialogue: 0,0:02:18.87,0:02:20.06,ASS,,0,0,0,,谢谢
Dialogue: 0,0:02:22.67,0:02:26.80,ASS,,0,0,0,,结婚多久了
Dialogue: 0,0:02:27.74,0:02:29.40,ASS,,0,0,0,,第六年
Dialogue: 0,0:02:29.61,0:02:30.47,ASS,,0,0,0,,是喔
Dialogue: 0,0:02:31.35,0:02:35.87,ASS,,0,0,0,,该怎么说
Dialogue: 0,0:02:36.15,0:02:38.35,ASS,,0,0,0,,结婚比较晚
Dialogue: 0,0:02:38.62,0:02:41.35,ASS,,0,0,0,,35左右结婚的
Dialogue: 0,0:02:42.56,0:02:45.15,ASS,,0,0,0,,太太现在是干嘛的
Dialogue: 0,0:02:46.49,0:02:49.29,ASS,,0,0,0,,家庭主妇
Dialogue: 0,0:02:50.50,0:02:51.97,ASS,,0,0,0,,结婚之前呢
Dialogue: 0,0:02:53.03,0:02:57.70,ASS,,0,0,0,,结婚前是某电台女主播
Dialogue: 0,0:02:58.91,0:03:00.77,ASS,,0,0,0,,主播啊
Dialogue: 0,0:03:01.38,0:03:02.17,ASS,,0,0,0,,是
Dialogue: 0,0:03:02.51,0:03:03.91,ASS,,0,0,0,,所以很高雅
Dialogue: 0,0:03:07.11,0:03:08.10,ASS,,0,0,0,,谢谢
Dialogue: 0,0:03:08.98,0:03:10.51,ASS,,0,0,0,,主播
Dialogue: 0,0:03:10.85,0:03:12.05,ASS,,0,0,0,,都是干嘛的
Dialogue: 0,0:03:16.66,0:03:19.32,ASS,,0,0,0,,就是
Dialogue: 0,0:03:19.46,0:03:24.06,ASS,,0,0,0,,这样说有点害羞
Dialogue: 0,0:03:24.93,0:03:28.13,ASS,,0,0,0,,当时是电台的红人
Dialogue: 0,0:03:29.07,0:03:30.94,ASS,,0,0,0,,工作着
Dialogue: 0,0:03:32.54,0:03:34.60,ASS,,0,0,0,,过了30岁
Dialogue: 0,0:03:34.94,0:03:41.14,ASS,,0,0,0,,就开始教育年轻的主播
Dialogue: 0,0:03:42.75,0:03:43.88,ASS,,0,0,0,,是喔
Dialogue: 0,0:03:46.75,0:03:48.88,ASS,,0,0,0,,谢谢今天前来
Dialogue: 0,0:03:49.49,0:03:51.22,ASS,,0,0,0,,我才要道谢
Dialogue: 0,0:03:52.56,0:03:54.82,ASS,,0,0,0,,还有想问的 可以吗
Dialogue: 0,0:03:55.63,0:03:56.56,ASS,,0,0,0,,好
Dialogue: 0,0:03:58.10,0:04:02.76,ASS,,0,0,0,,为什么想要演出
Dialogue: 0,0:04:05.64,0:04:09.37,ASS,,0,0,0,,其实 我老公
Dialogue: 0,0:04:09.51,0:04:11.57,ASS,,0,0,0,,是电台的导播
Dialogue: 0,0:04:12.91,0:04:16.44,ASS,,0,0,0,,很忙 都没时间陪我
Dialogue: 0,0:04:18.72,0:04:20.85,ASS,,0,0,0,,有点
Dialogue: 0,0:04:24.13,0:04:26.06,ASS,,0,0,0,,没做爱吧
Dialogue: 0,0:04:27.19,0:04:29.59,ASS,,0,0,0,,都没做爱了
Dialogue: 0,0:04:31.40,0:04:34.06,ASS,,0,0,0,,也就是自己自慰吗
Dialogue: 0,0:04:37.54,0:04:39.13,ASS,,0,0,0,,是啊 一点点
Dialogue: 0,0:04:39.41,0:04:41.07,ASS,,0,0,0,,一点点吗
Dialogue: 0,0:04:41.88,0:04:43.81,ASS,,0,0,0,,可能不是一点点
Dialogue: 0,0:04:44.15,0:04:45.27,ASS,,0,0,0,,是喔
Dialogue: 0,0:04:47.62,0:04:48.95,ASS,,0,0,0,,也就是
Dialogue: 0,0:04:50.42,0:04:55.15,ASS,,0,0,0,,可能之前是女主播\N是
Dialogue: 0,0:04:55.76,0:05:00.69,ASS,,0,0,0,,但是现在 只是淫荡女
Dialogue: 0,0:05:01.36,0:05:02.95,ASS,,0,0,0,,我的认知
Dialogue: 0,0:05:03.76,0:05:06.36,ASS,,0,0,0,,可能吧
Dialogue: 0,0:05:09.84,0:05:14.57,ASS,,0,0,0,,你应该是对于淫荡的字眼\N就会笑出来的人
Dialogue: 0,0:05:16.04,0:05:17.84,ASS,,0,0,0,,我对字眼很敏感
Dialogue: 0,0:05:19.11,0:05:20.10,ASS,,0,0,0,,真的啊
Dialogue: 0,0:05:20.51,0:05:21.98,ASS,,0,0,0,,性爱
Dialogue: 0,0:05:24.32,0:05:25.18,ASS,,0,0,0,,口交
Dialogue: 0,0:05:26.59,0:05:28.11,ASS,,0,0,0,,口交不会笑啊
Dialogue: 0,0:05:29.39,0:05:30.45,ASS,,0,0,0,,舔小穴
Dialogue: 0,0:05:32.73,0:05:33.66,ASS,,0,0,0,,知道了
Dialogue: 0,0:05:34.20,0:05:36.72,ASS,,0,0,0,,多指教\N多指教
Dialogue: 0,0:05:36.80,0:05:38.46,ASS,,0,0,0,,性感带是哪边
Dialogue: 0,0:05:39.67,0:05:41.79,ASS,,0,0,0,,耳朵 脖子
Dialogue: 0,0:05:45.34,0:05:46.33,ASS,,0,0,0,,是喔
Dialogue: 0,0:05:46.87,0:05:47.81,ASS,,0,0,0,,知道了
Dialogue: 0,0:05:48.21,0:05:50.34,ASS,,0,0,0,,今天请多指教
Dialogue: 0,0:05:50.75,0:05:52.21,ASS,,0,0,0,,请多指教
Dialogue: 0,0:05:55.82,0:06:00.08,ASS,,0,0,0,,要开始做爱了
Dialogue: 0,0:06:01.89,0:06:03.41,ASS,,0,0,0,,心情怎样呢
Dialogue: 0,0:06:04.56,0:06:06.03,ASS,,0,0,0,,很紧张
Dialogue: 0,0:06:08.10,0:06:09.62,ASS,,0,0,0,,可以叫男优了吗
Dialogue: 0,0:06:10.10,0:06:10.96,ASS,,0,0,0,,好
Dialogue: 0,0:06:11.57,0:06:14.63,ASS,,0,0,0,,拜托了\N请多指教
Dialogue: 0,0:06:19.31,0:06:21.04,ASS,,0,0,0,,是美人耶
Dialogue: 0,0:06:22.31,0:06:23.44,ASS,,0,0,0,,谢谢
Dialogue: 0,0:06:23.64,0:06:25.58,ASS,,0,0,0,,知道我在想什么吗
Dialogue: 0,0:06:26.31,0:06:27.44,ASS,,0,0,0,,不知道
Dialogue: 0,0:06:33.85,0:06:36.45,ASS,,0,0,0,,想摸这边啊
Dialogue: 0,0:06:36.66,0:06:38.85,ASS,,0,0,0,,有被这样搓揉过吗\N没有
Dialogue: 0,0:07:03.02,0:07:04.61,ASS,,0,0,0,,是主播啊
Dialogue: 0,0:07:05.89,0:07:06.88,ASS,,0,0,0,,是啊
Dialogue: 0,0:07:08.76,0:07:11.16,ASS,,0,0,0,,来了喔
Dialogue: 0,0:07:12.56,0:07:13.82,ASS,,0,0,0,,我当过主播
Dialogue: 0,0:07:17.16,0:07:18.89,ASS,,0,0,0,,想这样做吧
Dialogue: 0,0:07:56.87,0:07:58.20,ASS,,0,0,0,,不要动喔
Dialogue: 0,0:07:59.94,0:08:01.27,ASS,,0,0,0,,很漂亮
Dialogue: 0,0:08:10.48,0:08:13.42,ASS,,0,0,0,,主播的腋下是这种味道喔
Dialogue: 0,0:08:33.44,0:08:34.84,ASS,,0,0,0,,好好吃
Dialogue: 0,0:09:01.47,0:09:03.87,ASS,,0,0,0,,很久没做了
Dialogue: 0,0:09:04.87,0:09:07.40,ASS,,0,0,0,,这样很爽吧
Dialogue: 0,0:09:09.54,0:09:11.53,ASS,,0,0,0,,这样不够啊
Dialogue: 0,0:09:28.16,0:09:29.63,ASS,,0,0,0,,让我看屁股
Dialogue: 0,0:09:58.33,0:09:59.52,ASS,,0,0,0,,让我看表情
Dialogue: 0,0:10:05.80,0:10:06.86,ASS,,0,0,0,,表情很棒喔
Dialogue: 0,0:10:14.68,0:10:16.40,ASS,,0,0,0,,摸哪边呢
Dialogue: 0,0:10:20.61,0:10:21.67,ASS,,0,0,0,,小穴
Dialogue: 0,0:10:23.08,0:10:24.41,ASS,,0,0,0,,再说
Dialogue: 0,0:10:26.69,0:10:27.62,ASS,,0,0,0,,小穴
Dialogue: 0,0:10:52.98,0:10:54.24,ASS,,0,0,0,,超漂亮
Dialogue: 0,0:11:15.07,0:11:17.00,ASS,,0,0,0,,湿了喔
Dialogue: 0,0:11:17.94,0:11:20.20,ASS,,0,0,0,,这是淫汁吗
Dialogue: 0,0:11:22.34,0:11:23.21,ASS,,0,0,0,,好害羞
Dialogue: 0,0:11:29.68,0:11:32.08,ASS,,0,0,0,,这边湿了
Dialogue: 0,0:11:49.70,0:11:50.90,ASS,,0,0,0,,好期待啊
Dialogue: 0,0:11:55.51,0:11:56.64,ASS,,0,0,0,,几岁了
Dialogue: 0,0:11:58.05,0:11:59.44,ASS,,0,0,0,,43
Dialogue: 0,0:12:01.52,0:12:03.18,ASS,,0,0,0,,这身材真棒
Dialogue: 0,0:12:06.85,0:12:08.79,ASS,,0,0,0,,穿着衣服很浪费喔
Dialogue: 0,0:12:11.26,0:12:12.38,ASS,,0,0,0,,脱掉吧
Dialogue: 0,0:12:18.93,0:12:20.19,ASS,,0,0,0,,可以吧
Dialogue: 0,0:13:08.65,0:13:09.71,ASS,,0,0,0,,心情是
Dialogue: 0,0:13:11.85,0:13:13.18,ASS,,0,0,0,,好害羞
Dialogue: 0,0:13:15.66,0:13:17.52,ASS,,0,0,0,,裸体好漂亮
Dialogue: 0,0:13:18.39,0:13:19.45,ASS,,0,0,0,,白色的
Dialogue: 0,0:13:25.27,0:13:26.73,ASS,,0,0,0,,要脱了啊
Dialogue: 0,0:13:30.20,0:13:31.40,ASS,,0,0,0,,太快了
Dialogue: 0,0:14:06.31,0:14:07.64,ASS,,0,0,0,,好软喔
Dialogue: 0,0:14:22.32,0:14:25.12,ASS,,0,0,0,,这个很碍事
Dialogue: 0,0:14:30.53,0:14:31.52,ASS,,0,0,0,,脱掉吧
Dialogue: 0,0:14:46.75,0:14:48.48,ASS,,0,0,0,,太漂亮喔
Dialogue: 0,0:15:04.83,0:15:07.30,ASS,,0,0,0,,觉得乳头颜色怎样呢
Dialogue: 0,0:15:11.51,0:15:13.10,ASS,,0,0,0,,比较淡
Dialogue: 0,0:15:14.37,0:15:16.43,ASS,,0,0,0,,很自傲吗
Dialogue: 0,0:15:16.64,0:15:17.97,ASS,,0,0,0,,不是啊
Dialogue: 0,0:15:20.85,0:15:21.97,ASS,,0,0,0,,很满足吧
Dialogue: 0,0:15:23.45,0:15:26.32,ASS,,0,0,0,,也没有\N很有自信吧
Dialogue: 0,0:15:30.06,0:15:31.39,ASS,,0,0,0,,脱掉裤袜
Dialogue: 0,0:15:35.26,0:15:36.66,ASS,,0,0,0,,鞋子也脱吧
Dialogue: 0,0:15:59.69,0:16:00.74,ASS,,0,0,0,,内裤也脱
Dialogue: 0,0:16:09.63,0:16:12.36,ASS,,0,0,0,,等等 屁股好棒\N让我看看
Dialogue: 0,0:16:25.38,0:16:27.37,ASS,,0,0,0,,为什么今天穿这个
Dialogue: 0,0:16:29.78,0:16:31.25,ASS,,0,0,0,,不知道
Dialogue: 0,0:16:31.99,0:16:33.58,ASS,,0,0,0,,很棒吗
Dialogue: 0,0:16:34.52,0:16:36.25,ASS,,0,0,0,,很可爱
Dialogue: 0,0:16:37.59,0:16:40.39,ASS,,0,0,0,,这形状很棒喔
Dialogue: 0,0:16:48.80,0:16:50.79,ASS,,0,0,0,,有被这样玩弄过吗
Dialogue: 0,0:16:51.20,0:16:52.33,ASS,,0,0,0,,没有
Dialogue: 0,0:16:55.34,0:16:57.28,ASS,,0,0,0,,还没喔
Dialogue: 0,0:17:08.56,0:17:09.61,ASS,,0,0,0,,脱掉吧
Dialogue: 0,0:17:24.17,0:17:25.83,ASS,,0,0,0,,内裤
Dialogue: 0,0:17:26.64,0:17:28.37,ASS,,0,0,0,,让我看看
Dialogue: 0,0:17:31.04,0:17:31.84,ASS,,0,0,0,,看这边
Dialogue: 0,0:17:33.98,0:17:35.04,ASS,,0,0,0,,湿了
Dialogue: 0,0:17:38.39,0:17:39.51,ASS,,0,0,0,,为什么呢
Dialogue: 0,0:17:41.86,0:17:43.32,ASS,,0,0,0,,兴奋了
Dialogue: 0,0:17:43.72,0:17:45.71,ASS,,0,0,0,,哪时候啊\N刚刚
Dialogue: 0,0:17:56.27,0:17:58.60,ASS,,0,0,0,,超厉害喔
Dialogue: 0,0:18:07.81,0:18:08.80,ASS,,0,0,0,,毛很少喔
Dialogue: 0,0:18:11.08,0:18:12.14,ASS,,0,0,0,,为什么啊
Dialogue: 0,0:18:12.55,0:18:13.95,ASS,,0,0,0,,修理过了
Dialogue: 0,0:18:14.42,0:18:15.41,ASS,,0,0,0,,是喔
Dialogue: 0,0:18:45.12,0:18:46.78,ASS,,0,0,0,,好软喔
Dialogue: 0,0:18:51.99,0:18:53.72,ASS,,0,0,0,,很粉嫩喔
Dialogue: 0,0:18:54.39,0:18:55.19,ASS,,0,0,0,,看见了
Dialogue: 0,0:18:55.73,0:18:57.39,ASS,,0,0,0,,为什么这么粉嫩
Dialogue: 0,0:19:01.33,0:19:02.86,ASS,,0,0,0,,很一般吧
Dialogue: 0,0:19:03.14,0:19:04.13,ASS,,0,0,0,,不是啊
Dialogue: 0,0:19:05.81,0:19:07.33,ASS,,0,0,0,,好像很爽
Dialogue: 0,0:19:08.94,0:19:10.60,ASS,,0,0,0,,看见了吧 很软
Dialogue: 0,0:19:17.42,0:19:19.28,ASS,,0,0,0,,放松喔
Dialogue: 0,0:19:23.89,0:19:24.88,ASS,,0,0,0,,怎么了
Dialogue: 0,0:19:25.69,0:19:26.68,ASS,,0,0,0,,好害羞
Dialogue: 0,0:19:32.43,0:19:33.96,ASS,,0,0,0,,好小喔
Dialogue: 0,0:19:44.44,0:19:45.38,ASS,,0,0,0,,自己掰开
Dialogue: 0,0:20:19.75,0:20:20.61,ASS,,0,0,0,,那边
Dialogue: 0,0:21:13.20,0:21:14.72,ASS,,0,0,0,,喜欢吗
Dialogue: 0,0:21:18.07,0:21:19.66,ASS,,0,0,0,,喜欢用吸的
Dialogue: 0,0:22:11.59,0:22:13.32,ASS,,0,0,0,,超棒喔
Dialogue: 0,0:22:32.01,0:22:33.48,ASS,,0,0,0,,舔了喔
Dialogue: 0,0:22:56.30,0:22:58.63,ASS,,0,0,0,,这边都流汗了
Dialogue: 0,0:24:05.04,0:24:06.84,ASS,,0,0,0,,爽吗\N超爽
Dialogue: 0,0:24:14.78,0:24:18.11,ASS,,0,0,0,,现在被怎样玩弄了啊
Dialogue: 0,0:24:19.85,0:24:21.18,ASS,,0,0,0,,阴核
Dialogue: 0,0:24:22.39,0:24:24.25,ASS,,0,0,0,,被舔着 超爽
Dialogue: 0,0:24:36.34,0:24:37.39,ASS,,0,0,0,,过来啊
Dialogue: 0,0:24:42.94,0:24:44.34,ASS,,0,0,0,,会自慰吗
Dialogue: 0,0:24:45.14,0:24:45.94,ASS,,0,0,0,,会
Dialogue: 0,0:24:47.61,0:24:48.81,ASS,,0,0,0,,几次啊
Dialogue: 0,0:24:49.22,0:24:50.34,ASS,,0,0,0,,一周三次
Dialogue: 0,0:25:10.24,0:25:11.64,ASS,,0,0,0,,好紧啊
Dialogue: 0,0:25:26.32,0:25:28.38,ASS,,0,0,0,,还没动喔\N那边
