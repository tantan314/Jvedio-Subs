Dialogue: 0,0:00:01.00,0:00:04.06,Default,,0,0,0,,
Dialogue: 0,0:00:31.03,0:00:34.02,Default,,0,0,0,,抱歉 久等了
Dialogue: 0,0:00:36.03,0:00:39.02,Default,,0,0,0,,抱歉
Dialogue: 0,0:00:39.03,0:00:42.03,Default,,0,0,0,,你好 請多指教
Dialogue: 0,0:00:44.04,0:00:47.03,Default,,0,0,0,,抱歉 還讓你站著
Dialogue: 0,0:00:48.04,0:00:51.03,Default,,0,0,0,,我們一邊走一邊聊吧
Dialogue: 0,0:00:53.05,0:00:56.04,Default,,0,0,0,,有點暗
Dialogue: 0,0:00:57.05,0:01:00.04,Default,,0,0,0,,我這是在拍攝
Dialogue: 0,0:01:01.06,0:01:04.05,Default,,0,0,0,,去找亮一點的地方
Dialogue: 0,0:01:06.06,0:01:09.05,Default,,0,0,0,,打光哦
Dialogue: 0,0:01:12.07,0:01:14.06,Default,,0,0,0,,抱歉
Dialogue: 0,0:01:14.07,0:01:17.06,Default,,0,0,0,,都濕了
Dialogue: 0,0:01:17.07,0:01:20.01,Default,,0,0,0,,真美啊
Dialogue: 0,0:01:20.01,0:01:23.00,Default,,0,0,0,,套裝嗎？對
Dialogue: 0,0:01:25.01,0:01:28.00,Default,,0,0,0,,所以...
Dialogue: 0,0:01:29.02,0:01:32.01,Default,,0,0,0,,今天剛下班 對
Dialogue: 0,0:01:34.02,0:01:37.01,Default,,0,0,0,,下班就出來了
Dialogue: 0,0:01:39.03,0:01:41.02,Default,,0,0,0,,想問一下
Dialogue: 0,0:01:41.03,0:01:44.02,Default,,0,0,0,,工作是怎樣的
Dialogue: 0,0:01:45.03,0:01:48.02,Default,,0,0,0,,證券公司
Dialogue: 0,0:01:49.04,0:01:52.03,Default,,0,0,0,,那你呢？
Dialogue: 0,0:01:53.04,0:01:56.03,Default,,0,0,0,,秘書
Dialogue: 0,0:01:57.04,0:02:00.04,Default,,0,0,0,,感覺好高級唷
Dialogue: 0,0:02:03.05,0:02:06.04,Default,,0,0,0,,社長秘書啊
Dialogue: 0,0:02:09.06,0:02:11.05,Default,,0,0,0,,沒想到
Dialogue: 0,0:02:11.06,0:02:14.05,Default,,0,0,0,,真―的看到
Dialogue: 0,0:02:14.06,0:02:17.05,Default,,0,0,0,,這種工作
Dialogue: 0,0:02:18.07,0:02:21.06,Default,,0,0,0,,好厲害 真美啊
Dialogue: 0,0:02:23.07,0:02:25.00,Default,,0,0,0,,好美唷
Dialogue: 0,0:02:25.01,0:02:27.00,Default,,0,0,0,,這樣啊
Dialogue: 0,0:02:27.01,0:02:30.00,Default,,0,0,0,,我們上去吧
Dialogue: 0,0:02:33.01,0:02:36.01,Default,,0,0,0,,等等
Dialogue: 0,0:02:36.02,0:02:39.01,Default,,0,0,0,,屁股我看看
Dialogue: 0,0:02:41.02,0:02:44.01,Default,,0,0,0,,屁股
Dialogue: 0,0:02:44.02,0:02:47.02,Default,,0,0,0,,剛下班
Dialogue: 0,0:02:50.03,0:02:53.02,Default,,0,0,0,,雨變大了
Dialogue: 0,0:02:56.04,0:02:59.03,Default,,0,0,0,,今天會過來
Dialogue: 0,0:02:59.04,0:03:02.03,Default,,0,0,0,,知道要幹痳吧
Dialogue: 0,0:03:05.05,0:03:08.04,Default,,0,0,0,,今天來幹痳
Dialogue: 0,0:03:08.05,0:03:11.04,Default,,0,0,0,,要講啊
Dialogue: 0,0:03:11.05,0:03:14.04,Default,,0,0,0,,現在剛好
Dialogue: 0,0:03:18.06,0:03:21.05,Default,,0,0,0,,做愛
Dialogue: 0,0:03:21.06,0:03:24.05,Default,,0,0,0,,是啊
Dialogue: 0,0:03:24.06,0:03:26.06,Default,,0,0,0,,穿這樣
Dialogue: 0,0:03:26.07,0:03:29.06,Default,,0,0,0,,具體說一下
Dialogue: 0,0:03:33.01,0:03:35.00,Default,,0,0,0,,害羞
Dialogue: 0,0:03:35.01,0:03:38.00,Default,,0,0,0,,可以講一下
Dialogue: 0,0:03:39.01,0:03:42.00,Default,,0,0,0,,具體...
Dialogue: 0,0:03:44.02,0:03:47.01,Default,,0,0,0,,怎麼樣
Dialogue: 0,0:03:48.02,0:03:51.01,Default,,0,0,0,,做愛....
Dialogue: 0,0:03:53.03,0:03:56.02,Default,,0,0,0,,很好哦
Dialogue: 0,0:03:57.03,0:03:59.02,Default,,0,0,0,,講了
Dialogue: 0,0:03:59.03,0:04:02.02,Default,,0,0,0,,今天不用加班
Dialogue: 0,0:04:05.04,0:04:08.03,Default,,0,0,0,,真的好美
Dialogue: 0,0:04:09.04,0:04:12.03,Default,,0,0,0,,慢慢走
Dialogue: 0,0:04:14.05,0:04:17.04,Default,,0,0,0,,來的理由呢？
Dialogue: 0,0:04:19.05,0:04:22.04,Default,,0,0,0,,我原本就很鑾態
Dialogue: 0,0:04:26.06,0:04:29.05,Default,,0,0,0,,突然講出來
Dialogue: 0,0:04:31.06,0:04:34.06,Default,,0,0,0,,變態的關係
Dialogue: 0,0:04:34.07,0:04:37.06,Default,,0,0,0,,這樣啊
Dialogue: 0,0:04:37.07,0:04:40.01,Default,,0,0,0,,再說什麼
Dialogue: 0,0:04:41.01,0:04:44.00,Default,,0,0,0,,我會想說
Dialogue: 0,0:04:46.01,0:04:49.01,Default,,0,0,0,,可以多一點
Dialogue: 0,0:04:49.02,0:04:52.01,Default,,0,0,0,,等等 電車....
Dialogue: 0,0:04:54.02,0:04:57.01,Default,,0,0,0,,希望可以....
Dialogue: 0,0:04:58.03,0:05:01.02,Default,,0,0,0,,這太誇張了
Dialogue: 0,0:05:04.03,0:05:07.02,Default,,0,0,0,,再一次
Dialogue: 0,0:05:07.03,0:05:10.03,Default,,0,0,0,,希望可以滿足 謝謝
Dialogue: 0,0:05:11.04,0:05:14.03,Default,,0,0,0,,太好了
Dialogue: 0,0:05:16.04,0:05:19.04,Default,,0,0,0,,這裡由
Dialogue: 0,0:05:19.05,0:05:22.04,Default,,0,0,0,,所以....
Dialogue: 0,0:05:24.05,0:05:27.04,Default,,0,0,0,,會想要拍攝
Dialogue: 0,0:05:28.06,0:05:31.05,Default,,0,0,0,,這什麼意思
Dialogue: 0,0:05:34.06,0:05:37.05,Default,,0,0,0,,怎麼樣的拍攝
Dialogue: 0,0:05:39.07,0:05:42.06,Default,,0,0,0,,我上班
Dialogue: 0,0:05:44.07,0:05:47.01,Default,,0,0,0,,也會想到那個事
Dialogue: 0,0:05:49.01,0:05:52.00,Default,,0,0,0,,這樣認真的臉
Dialogue: 0,0:05:54.01,0:05:57.01,Default,,0,0,0,,工作啊
Dialogue: 0,0:05:57.02,0:05:59.01,Default,,0,0,0,,往這邊吧
Dialogue: 0,0:05:59.02,0:06:02.01,Default,,0,0,0,,太大聲
Dialogue: 0,0:06:03.02,0:06:05.01,Default,,0,0,0,,然後呢？
Dialogue: 0,0:06:05.03,0:06:08.02,Default,,0,0,0,,都濕了
Dialogue: 0,0:06:09.03,0:06:12.02,Default,,0,0,0,,好美唷
Dialogue: 0,0:06:13.03,0:06:16.03,Default,,0,0,0,,這夜景
Dialogue: 0,0:06:16.04,0:06:19.03,Default,,0,0,0,,好美
Dialogue: 0,0:06:19.04,0:06:22.03,Default,,0,0,0,,只能看你
Dialogue: 0,0:06:24.04,0:06:27.04,Default,,0,0,0,,會一直想
Dialogue: 0,0:06:29.05,0:06:32.04,Default,,0,0,0,,一直想
Dialogue: 0,0:06:34.05,0:06:37.05,Default,,0,0,0,,想什麼
Dialogue: 0,0:06:39.06,0:06:42.05,Default,,0,0,0,,那件事情
Dialogue: 0,0:06:44.06,0:06:47.06,Default,,0,0,0,,這樣啊
Dialogue: 0,0:06:47.07,0:06:50.06,Default,,0,0,0,,怎麼講呢？
Dialogue: 0,0:06:51.07,0:06:54.01,Default,,0,0,0,,自己啊
Dialogue: 0,0:06:54.01,0:06:57.00,Default,,0,0,0,,工作時候
Dialogue: 0,0:06:57.01,0:07:00.00,Default,,0,0,0,,情色的事情
Dialogue: 0,0:07:01.01,0:07:04.01,Default,,0,0,0,,會想著啊
Dialogue: 0,0:07:07.02,0:07:10.01,Default,,0,0,0,,我以為只有漫畫會有
Dialogue: 0,0:07:13.03,0:07:16.02,Default,,0,0,0,,真的
Dialogue: 0,0:07:17.03,0:07:20.02,Default,,0,0,0,,會想到
Dialogue: 0,0:07:21.03,0:07:24.03,Default,,0,0,0,,不過很開心啦
Dialogue: 0,0:07:26.04,0:07:29.03,Default,,0,0,0,,這樣同事
Dialogue: 0,0:07:29.04,0:07:32.03,Default,,0,0,0,,很色好鑾態
Dialogue: 0,0:07:34.05,0:07:37.04,Default,,0,0,0,,真讓人心動
Dialogue: 0,0:07:38.05,0:07:41.04,Default,,0,0,0,,那麼....
Dialogue: 0,0:07:41.05,0:07:44.05,Default,,0,0,0,,自己鑾態
Dialogue: 0,0:07:44.06,0:07:47.05,Default,,0,0,0,,所以要來拍攝
Dialogue: 0,0:07:50.06,0:07:53.06,Default,,0,0,0,,不過戚覺真的
Dialogue: 0,0:07:54.07,0:07:57.06,Default,,0,0,0,,很高級
Dialogue: 0,0:07:59.01,0:08:02.00,Default,,0,0,0,,沒有啦
Dialogue: 0,0:08:04.01,0:08:07.00,Default,,0,0,0,,認真的臉
Dialogue: 0,0:08:08.01,0:08:11.01,Default,,0,0,0,,穿這麼好看
Dialogue: 0,0:08:12.02,0:08:15.01,Default,,0,0,0,,卻是這樣的
Dialogue: 0,0:08:19.03,0:08:22.02,Default,,0,0,0,,沒有啦
Dialogue: 0,0:08:24.03,0:08:27.02,Default,,0,0,0,,不行這樣想
Dialogue: 0,0:08:29.04,0:08:32.03,Default,,0,0,0,,知道可是....
Dialogue: 0,0:08:33.04,0:08:36.03,Default,,0,0,0,,我自己也沒辦法
Dialogue: 0,0:08:40.05,0:08:43.04,Default,,0,0,0,,往這遑走吧
Dialogue: 0,0:08:44.05,0:08:47.04,Default,,0,0,0,,快到了
Dialogue: 0,0:08:47.05,0:08:50.05,Default,,0,0,0,,車上
Dialogue: 0,0:08:51.06,0:08:54.05,Default,,0,0,0,,真的
Dialogue: 0,0:08:54.06,0:08:57.05,Default,,0,0,0,,要到了
Dialogue: 0,0:08:59.07,0:09:02.06,Default,,0,0,0,,雨太大了
Dialogue: 0,0:09:09.01,0:09:12.00,Default,,0,0,0,,往這唷
Dialogue: 0,0:09:14.01,0:09:17.01,Default,,0,0,0,,請吧
Dialogue: 0,0:09:21.02,0:09:24.01,Default,,0,0,0,,小心點
Dialogue: 0,0:09:25.03,0:09:27.02,Default,,0,0,0,,關上了
Dialogue: 0,0:09:27.03,0:09:30.02,Default,,0,0,0,,這好了可以
Dialogue: 0,0:09:30.03,0:09:33.02,Default,,0,0,0,,包包的話....
Dialogue: 0,0:09:34.03,0:09:37.03,Default,,0,0,0,,可以放下去
Dialogue: 0,0:09:40.04,0:09:43.03,Default,,0,0,0,,真美啊
Dialogue: 0,0:09:44.04,0:09:47.04,Default,,0,0,0,,很好唷 是
Dialogue: 0,0:09:49.05,0:09:52.04,Default,,0,0,0,,好厲害
Dialogue: 0,0:09:54.05,0:09:57.05,Default,,0,0,0,,狀態很好啊
Dialogue: 0,0:09:59.06,0:10:02.05,Default,,0,0,0,,沒有啦
Dialogue: 0,0:10:02.06,0:10:05.05,Default,,0,0,0,,真的好厲害
Dialogue: 0,0:10:05.07,0:10:08.06,Default,,0,0,0,,工作下班
Dialogue: 0,0:10:11.07,0:10:14.01,Default,,0,0,0,,剛說過了
Dialogue: 0,0:10:16.01,0:10:19.00,Default,,0,0,0,,現在
Dialogue: 0,0:10:21.01,0:10:23.01,Default,,0,0,0,,要去做愛的地方
Dialogue: 0,0:10:23.02,0:10:26.01,Default,,0,0,0,,希望什麼呢？
Dialogue: 0,0:10:27.02,0:10:30.01,Default,,0,0,0,,基本上
Dialogue: 0,0:10:31.02,0:10:34.02,Default,,0,0,0,,變態一點
Dialogue: 0,0:10:34.03,0:10:37.02,Default,,0,0,0,,你一直這樣講
Dialogue: 0,0:10:37.03,0:10:40.02,Default,,0,0,0,,就是
Dialogue: 0,0:10:41.03,0:10:44.03,Default,,0,0,0,,越不行做的事情
Dialogue: 0,0:10:49.04,0:10:52.03,Default,,0,0,0,,我會想去做
Dialogue: 0,0:10:53.05,0:10:56.04,Default,,0,0,0,,對啊
Dialogue: 0,0:10:56.05,0:10:59.04,Default,,0,0,0,,做點不可以做的事情
Dialogue: 0,0:11:01.05,0:11:04.05,Default,,0,0,0,,會更想要....
Dialogue: 0,0:11:06.06,0:11:09.05,Default,,0,0,0,,地點之類的
Dialogue: 0,0:11:10.06,0:11:13.06,Default,,0,0,0,,基本來說
Dialogue: 0,0:11:13.07,0:11:16.06,Default,,0,0,0,,這種會好點對
Dialogue: 0,0:11:18.07,0:11:21.01,Default,,0,0,0,,沒有錯吧
Dialogue: 0,0:11:23.01,0:11:26.00,Default,,0,0,0,,這樣講
Dialogue: 0,0:11:27.01,0:11:30.01,Default,,0,0,0,,就跟對方一起
Dialogue: 0,0:11:31.02,0:11:34.01,Default,,0,0,0,,說什麼東西啊
Dialogue: 0,0:11:36.02,0:11:39.01,Default,,0,0,0,,真的好色的秘書
Dialogue: 0,0:11:39.03,0:11:42.02,Default,,0,0,0,,是是什麼啦
Dialogue: 0,0:11:44.03,0:11:47.02,Default,,0,0,0,,工作這樣想太過份了
Dialogue: 0,0:11:49.04,0:11:51.03,Default,,0,0,0,,只是一下下
Dialogue: 0,0:11:51.04,0:11:54.03,Default,,0,0,0,,我很開心
Dialogue: 0,0:11:55.04,0:11:58.03,Default,,0,0,0,,可以遇到這樣的人
Dialogue: 0,0:11:59.05,0:12:02.04,Default,,0,0,0,,會幻想唷
Dialogue: 0,0:12:05.05,0:12:08.04,Default,,0,0,0,,秘書這種事
Dialogue: 0,0:12:09.06,0:12:12.05,Default,,0,0,0,,是嗎？真的
Dialogue: 0,0:12:13.06,0:12:16.05,Default,,0,0,0,,嚇到了
Dialogue: 0,0:12:16.06,0:12:19.05,Default,,0,0,0,,很色的秘書很好啊
Dialogue: 0,0:12:20.07,0:12:23.06,Default,,0,0,0,,是嗎？
Dialogue: 0,0:12:23.07,0:12:26.00,Default,,0,0,0,,工作遇不到很可惜
Dialogue: 0,0:12:29.01,0:12:32.00,Default,,0,0,0,,幾歲呢？23
Dialogue: 0,0:12:33.01,0:12:36.00,Default,,0,0,0,,工作顺利嗎？
Dialogue: 0,0:12:37.02,0:12:40.01,Default,,0,0,0,,還可以
Dialogue: 0,0:12:41.02,0:12:44.01,Default,,0,0,0,,怎麼的公司呢？
Dialogue: 0,0:12:47.03,0:12:50.02,Default,,0,0,0,,一般公司
Dialogue: 0,0:12:51.03,0:12:54.02,Default,,0,0,0,,很不錯吧
Dialogue: 0,0:12:54.03,0:12:57.03,Default,,0,0,0,,可以買很多東西
Dialogue: 0,0:12:59.04,0:13:02.03,Default,,0,0,0,,是啊
Dialogue: 0,0:13:03.04,0:13:06.03,Default,,0,0,0,,這種看樣子很厲害
Dialogue: 0,0:13:07.05,0:13:10.04,Default,,0,0,0,,厲害嗎？
Dialogue: 0,0:13:11.05,0:13:14.04,Default,,0,0,0,,是講真的啦
Dialogue: 0,0:13:15.05,0:13:18.05,Default,,0,0,0,,看著鏡頭
Dialogue: 0,0:13:19.06,0:13:22.05,Default,,0,0,0,,蠻多人會看到的
Dialogue: 0,0:13:24.06,0:13:27.06,Default,,0,0,0,,這麼美麗
Dialogue: 0,0:13:27.07,0:13:30.06,Default,,0,0,0,,這樣跟你講話
Dialogue: 0,0:13:34.01,0:13:37.00,Default,,0,0,0,,好像也有不一樣的事吧
Dialogue: 0,0:13:40.01,0:13:43.01,Default,,0,0,0,,不一樣啊
Dialogue: 0,0:13:44.02,0:13:47.01,Default,,0,0,0,,像什麼呢？
Dialogue: 0,0:13:49.02,0:13:52.01,Default,,0,0,0,,你是社長秘書
Dialogue: 0,0:13:54.03,0:13:56.02,Default,,0,0,0,,社長他
Dialogue: 0,0:13:56.03,0:13:59.02,Default,,0,0,0,,有怎麼樣嗎？
Dialogue: 0,0:13:59.03,0:14:02.02,Default,,0,0,0,,也是有
Dialogue: 0,0:14:05.04,0:14:08.03,Default,,0,0,0,,多久一次騷擾呢？
Dialogue: 0,0:14:13.05,0:14:16.04,Default,,0,0,0,,都會講吧
Dialogue: 0,0:14:17.05,0:14:20.04,Default,,0,0,0,,很多種嗎？
Dialogue: 0,0:14:20.05,0:14:23.05,Default,,0,0,0,,要你做愛
Dialogue: 0,0:14:24.06,0:14:27.05,Default,,0,0,0,,這直接說了吧
Dialogue: 0,0:14:28.06,0:14:34.06,Default,,0,0,0,,有做嗎？
Dialogue: 0,0:14:37.07,0:14:40.01,Default,,0,0,0,,對方說的嗎？對
Dialogue: 0,0:14:42.01,0:14:45.00,Default,,0,0,0,,一開始是
Dialogue: 0,0:14:47.01,0:14:50.01,Default,,0,0,0,,多久一次
Dialogue: 0,0:14:50.02,0:14:53.01,Default,,0,0,0,,....因為一起工作很久
Dialogue: 0,0:14:54.02,0:14:57.01,Default,,0,0,0,,很久
Dialogue: 0,0:14:58.02,0:15:01.02,Default,,0,0,0,,怎麼會呢？
Dialogue: 0,0:15:04.03,0:15:07.02,Default,,0,0,0,,不會先摸你
Dialogue: 0,0:15:09.04,0:15:12.03,Default,,0,0,0,,或是親你呢？
Dialogue: 0,0:15:14.04,0:15:17.03,Default,,0,0,0,,有 有啊
Dialogue: 0,0:15:17.04,0:15:20.04,Default,,0,0,0,,就是一邊工作
Dialogue: 0,0:15:21.05,0:15:24.04,Default,,0,0,0,,然後偷偷摸
Dialogue: 0,0:15:24.05,0:15:27.04,Default,,0,0,0,,沒人在時候
